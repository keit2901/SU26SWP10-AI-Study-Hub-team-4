@namespace AI_Study_Hub_v2.Components.Admin
@page "/admin"
@page "/admin/dashboard"
@layout AdminLayout
@using Microsoft.AspNetCore.Components
@using MudBlazor
@using AI_Study_Hub_v2.Components.Admin.Shared
@inject NavigationManager Navigation
@inject IDocumentModerationService ModerationService
@inject AuthSessionState Session
@inject AdminDashboardApiClient DashboardApi

<div class="dashboard-page page-enter">
    <!-- Page Header -->
    <div class="d-flex flex-column gap-1 mb-md px-1">
        <h2 class="text-headline-lg font-headline-lg text-on-surface">Overview</h2>
        <p class="text-body-md text-on-surface-variant max-w-2xl">Monitor adoption, document processing health, moderation risk, and token consumption from one command center.</p>
    </div>

    @if (_isLoading)
    {
        <MudGrid>
            @for (var index = 0; index < 5; index++)
            {
                <MudItem xs="12" sm="6" lg="3" xl="2">
                    <MudSkeleton Height="156px" Animation="Animation.Wave" />
                </MudItem>
            }
            <MudItem xs="12" lg="8">
                <MudSkeleton Height="360px" Animation="Animation.Wave" />
            </MudItem>
            <MudItem xs="12" lg="4">
                <MudSkeleton Height="360px" Animation="Animation.Wave" />
            </MudItem>
        </MudGrid>
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled">@_errorMessage</MudAlert>
    }
    else
    {
        <!-- KPI Cards grid -->
        <div class="kpi-grid-container mb-6">
            @foreach (var metric in KpiCards)
            {
                <div class="kpi-card-custom">
                    <div class="kpi-card-header">
                        <div class="kpi-icon-wrapper @metric.AccentClass">
                            <MudIcon Icon="@metric.Icon" Size="Size.Medium" />
                        </div>
                        <span class="kpi-badge @metric.AccentClass">@metric.SupportingText</span>
                    </div>
                    <div class="kpi-card-body">
                        <div class="kpi-value">@metric.Value</div>
                        <div class="kpi-label">@metric.Label</div>
                    </div>
                </div>
            }
        </div>

        <MudGrid Class="mb-6">
            <!-- Activity trends (Line chart) -->
            <MudItem xs="12" lg="8">
                <MudPaper Elevation="0" Class="dashboard-card">
                    <div class="d-flex justify-space-between align-center mb-6 flex-wrap" style="gap: 1rem;">
                        <div>
                            <h3 class="text-headline-sm font-headline-sm text-on-surface mb-1">Activity trends</h3>
                            <span class="text-label-md font-label-md text-on-surface-variant uppercase">Uploads, sessions, and token usage</span>
                        </div>
                        <select class="bg-surface-container border-none text-label-md font-label-md rounded-lg py-2 px-3" style="background: #eceef0; border-radius: 0.5rem; outline: none; font-weight: 600; font-size: 12px; color: #191c1e;">
                            <option>Last 7 days</option>
                            <option>Last 30 days</option>
                        </select>
                    </div>
                    <MudChart T="double" ChartType="ChartType.Bar" ChartSeries="@_activitySeries" ChartLabels="@_activityLabels" ChartOptions="@_activityChartOptions" Width="100%" Height="305px" />
                </MudPaper>
            </MudItem>

            <!-- Document Status Breakdown (Donut chart) -->
            <MudItem xs="12" lg="4">
                <MudPaper Elevation="0" Class="dashboard-card">
                    <h3 class="text-headline-sm font-headline-sm text-on-surface mb-1">Document status breakdown</h3>
                    <span class="text-label-md font-label-md text-on-surface-variant uppercase mb-6 d-block">Pipeline state for indexed knowledge</span>
                    
                    <div style="position: relative; display: flex; align-items: center; justify-content: center; height: 200px;">
                        <MudChart T="double" ChartType="ChartType.Donut" ChartSeries="@StatusSeries" ChartLabels="@_statusLabels" ChartOptions="@_statusChartOptions" Width="100%" Height="200px" />
                        <div class="donut-center-overlay" style="position: absolute; display: flex; flex-direction: column; align-items: center; justify-content: center; pointer-events: none; text-align: center;">
                            <span class="donut-center-val" style="font-size: 26px; font-weight: 800; line-height: 1; font-family: 'Hanken Grotesk', sans-serif;">155</span>
                            <span class="donut-center-lbl" style="font-size: 10px; font-weight: 700; color: #767586; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 2px;">Total</span>
                        </div>
                    </div>
                    
                    <div class="space-y-2 mt-4">
                        @foreach (var status in _documentStatuses)
                        {
                            <div class="status-row">
                                <div class="d-flex align-center" style="gap: 0.75rem;">
                                    <span class="status-dot @status.CssClass"></span>
                                    <span class="text-body-md" style="font-size: 14px; font-weight: 500;">@status.Label</span>
                                </div>
                                <span class="text-body-md font-bold" style="font-size: 14px;">@status.Count</span>
                            </div>
                        }
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <!-- Attention Documents Row (12 columns, full width) -->
        <MudGrid Class="mb-6">
            <MudItem xs="12">
                <MudPaper Elevation="0" Class="dashboard-card overflow-hidden" Style="padding: 0;">
                    <div class="p-4 d-flex justify-space-between align-center border-b" style="border-bottom: 1px solid #e0e3e5; gap: 1rem; flex-wrap: wrap;">
                        <div>
                            <h3 class="text-headline-sm font-headline-sm text-on-surface mb-1">Documents needing attention</h3>
                            <span class="text-label-md font-label-md text-on-surface-variant uppercase">Pending review, reported, or failed items</span>
                        </div>
                        <MudButton Variant="Variant.Outlined" Class="attention-queue-btn px-4 py-2 text-label-md font-bold" StartIcon="@Icons.Material.Filled.OpenInNew" OnClick="OpenModerationQueue">
                            OPEN QUEUE
                        </MudButton>
                    </div>
                    
                    <div class="overflow-x-auto">
                        <MudTable Items="@_attentionDocuments" Dense="true" Hover="true" Elevation="0" Class="attention-table">
                            <HeaderContent>
                                <MudTh>Document</MudTh>
                                <MudTh>Owner</MudTh>
                                <MudTh Class="text-center">Status</MudTh>
                                <MudTh Class="text-center">Risk</MudTh>
                                <MudTh Class="text-right">Age</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Document">
                                    <div class="font-bold text-body-md" style="color: #191c1e;">@context.Title</div>
                                    <div class="text-[10px] text-on-surface-variant uppercase font-bold">@context.SubjectCode</div>
                                </MudTd>
                                <MudTd DataLabel="Owner">
                                    <div class="text-body-md" style="color: #191c1e;">@context.OwnerName</div>
                                    <div class="text-[11px] text-on-surface-variant">@context.OwnerEmail</div>
                                </MudTd>
                                <MudTd DataLabel="Status" Class="text-center">
                                    <span class="attention-status-badge @GetStatusClass(context.Status)">@context.Status</span>
                                </MudTd>
                                <MudTd DataLabel="Risk" Class="text-center">
                                    <span class="attention-risk-badge @GetSeverityClass(context.Severity)">@context.Severity</span>
                                </MudTd>
                                <MudTd DataLabel="Age" Class="text-right text-body-md">@context.AgeLabel</MudTd>
                            </RowTemplate>
                        </MudTable>
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <!-- Bottom row: Critical Events (4), Token Usage (4), Checklist (4) -->
        <MudGrid Class="pb-10">
            <!-- Critical Events -->
            <MudItem xs="12" lg="4">
                <MudPaper Elevation="0" Class="dashboard-card">
                    <div class="d-flex justify-space-between align-center mb-6">
                        <h3 class="text-headline-sm font-headline-sm text-on-surface">Critical events</h3>
                        <MudButton Variant="Variant.Text" Color="Color.Primary" Class="font-bold text-label-md" OnClick="OpenAuditLogs" Style="padding: 0; min-width: auto;">VIEW LOGS</MudButton>
                    </div>
                    <div class="space-y-6 timeline-custom pl-2">
                        @foreach (var item in _recentActivities)
                        {
                            <div class="timeline-item">
                                <div class="timeline-dot @item.Color.ToString().ToLower()"></div>
                                <div class="timeline-content">
                                    <div class="text-body-md font-bold text-on-surface">@item.Title</div>
                                    <div class="text-[11px] font-bold timeline-desc mt-0.5 mb-1">@item.Description</div>
                                    <div class="text-[10px] text-on-surface-variant">@FormatDateTime(item.CreatedAt)</div>
                                </div>
                            </div>
                        }
                    </div>
                </MudPaper>
            </MudItem>

            <!-- Daily Token Usage -->
            <MudItem xs="12" lg="4">
                <MudPaper Elevation="0" Class="dashboard-card">
                    <h3 class="text-headline-sm font-headline-sm text-on-surface mb-1">Daily token usage</h3>
                    <span class="text-label-md font-label-md text-on-surface-variant uppercase mb-8 d-block">Current consumption against daily platform quota</span>
                    
                    <div class="mb-2 d-flex justify-space-between align-end">
                        <span class="text-headline-md font-headline-md">@_metrics.DailyTokensUsed.ToString("N0") <span class="text-label-md font-normal" style="font-size: 14px; font-weight: normal; color: #464554;">used</span></span>
                        <span class="text-label-md text-on-surface-variant" style="font-size: 12px; font-weight: 600;">@_metrics.DailyTokenQuota.ToString("N0") quota</span>
                    </div>
                    
                    <div class="w-full h-3 bg-surface-container rounded-full overflow-hidden mb-8" style="background-color: #eceef0; height: 12px; border-radius: 9999px;">
                        <div class="h-full bg-gradient-to-r" style="height: 100%; border-radius: 9999px; background: linear-gradient(90deg, #4648d4, #6b38d4); width: @($"{_metrics.TokenUsagePercent:0}%");"></div>
                    </div>
                    
                    <div class="p-sm bg-error-container/20 border border-error/10 rounded-lg d-flex gap-3 align-start" style="background-color: #ffdad6; border: 1px solid rgba(186, 26, 26, 0.1); border-radius: 0.5rem; padding: 12px;">
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Class="text-error mt-0.5" Style="color: #ba1a1a;" />
                        <p class="text-body-md text-on-error-container mb-0" style="color: #93000a; font-size: 13px; line-height: 1.4;">12 users are above 85% of their assigned quotas. Review UC16 controls in Users &amp; Permissions.</p>
                    </div>
                </MudPaper>
            </MudItem>

            <!-- Administrator Checklist -->
            <MudItem xs="12" lg="4">
                <MudPaper Elevation="0" Class="dashboard-card d-flex flex-column justify-space-between">
                    <div>
                        <h3 class="text-headline-sm font-headline-sm text-on-surface mb-1">Administrator checklist</h3>
                        <span class="text-label-md font-label-md text-on-surface-variant uppercase mb-6 d-block">Recommended actions based on use-case guardrails</span>
                        
                        <div class="space-y-4">
                            <label class="flex items-center gap-3 cursor-pointer group d-flex align-center">
                                <div class="w-5 h-5 rounded flex items-center justify-center" style="width: 20px; height: 20px; background-color: #4648d4; border-radius: 4px;">
                                    <MudIcon Icon="@Icons.Material.Filled.Check" Style="color: #ffffff; font-size: 14px;" />
                                </div>
                                <span class="text-body-md text-on-surface pl-2" style="font-size: 13px; font-weight: 500;">Resolve pending and reported documents before indexing.</span>
                            </label>
                            <label class="flex items-center gap-3 cursor-pointer group d-flex align-center">
                                <div class="w-5 h-5 rounded border-2 border-outline flex items-center justify-center" style="width: 20px; height: 20px; border: 2px solid #767586; border-radius: 0.25rem;"></div>
                                <span class="text-body-md text-on-surface pl-2" style="font-size: 13px; font-weight: 500;">Confirm no administrator is deactivating own account.</span>
                            </label>
                            <label class="flex items-center gap-3 cursor-pointer group d-flex align-center">
                                <div class="w-5 h-5 rounded border-2 border-outline flex items-center justify-center" style="width: 20px; height: 20px; border: 2px solid #767586; border-radius: 0.25rem;"></div>
                                <span class="text-body-md text-on-surface pl-2" style="font-size: 13px; font-weight: 500;">Adjust daily token quotas for high-usage courses.</span>
                            </label>
                            <label class="flex items-center gap-3 cursor-pointer group d-flex align-center">
                                <div class="w-5 h-5 rounded border-2 border-outline flex items-center justify-center" style="width: 20px; height: 20px; border: 2px solid #767586; border-radius: 0.25rem;"></div>
                                <span class="text-body-md text-on-surface pl-2" style="font-size: 13px; font-weight: 500;">Review critical AI configuration changes and verify audit logs.</span>
                            </label>
                        </div>
                    </div>
                    
                    <div class="mt-8 pt-6 border-t d-flex align-center justify-space-between" style="border-top: 1px solid #e0e3e5;">
                        <div class="d-flex flex-column">
                            <span class="text-label-md text-on-surface-variant uppercase" style="font-size: 11px; font-weight: 700;">Retrieval readiness</span>
                            <div class="d-flex align-center" style="gap: 0.5rem; margin-top: 2px;">
                                <span class="text-headline-sm font-bold text-primary" style="font-size: 18px; font-weight: 700; color: #4648d4;">@($"{_metrics.TotalDocuments > 0 ? Math.Min(100, (_metrics.TotalDocuments - _metrics.FailedJobs) * 100 / Math.Max(1, _metrics.TotalDocuments)) : 0}%")</span>
                                <div class="w-16 h-1.5 bg-surface-container rounded-full overflow-hidden" style="width: 64px; height: 6px; background-color: #eceef0; border-radius: 9999px;">
                                    <div class="h-full bg-primary" style="height: 100%; background-color: #4648d4; width: @($"{(_metrics.TotalDocuments > 0 ? (_metrics.TotalDocuments - _metrics.FailedJobs) * 100 / _metrics.TotalDocuments : 0)}%");"></div>
                                </div>
                            </div>
                        </div>
                        <div class="text-right">
                            <div class="text-[10px] text-on-surface-variant uppercase leading-none font-bold" style="font-size: 10px; color: #464554;">Status summary</div>
                            <div class="text-[10px] font-bold text-on-surface mt-1" style="font-size: 10px; font-weight: 700; color: #191c1e;">@($"{_metrics.TotalDocuments - _metrics.FailedJobs} INDEXED, {_metrics.FailedJobs} FAILED")</div>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</div>

@code {
    private bool _isLoading = true;
    private string? _errorMessage;
    private DashboardMetrics _metrics = new();
    private readonly List<ActivityFeedItem> _recentActivities = new();
    private readonly List<AttentionDocument> _attentionDocuments = new();
    private readonly List<DocumentStatusMetric> _documentStatuses = new();

    private readonly ChartOptions _activityChartOptions = new()
    {
        ChartPalette = new[] { "#4648d4", "#6b38d4", "#575e72" }
    };

    private readonly ChartOptions _statusChartOptions = new()
    {
        ChartPalette = new[] { "#fbc02d", "#6b38d4", "#4648d4", "#ba1a1a" }
    };

    private IEnumerable<KpiCard> KpiCards => new[]
    {
        new KpiCard("Total Users", _metrics.TotalUsers.ToString("N0"), $"+{_metrics.NewUsersThisWeek} this week", Icons.Material.Outlined.People, "green"),
        new KpiCard("Total Documents", _metrics.TotalDocuments.ToString("N0"), $"{_metrics.ProcessingDocuments} processing now", Icons.Material.Outlined.Description, "purple"),
        new KpiCard("Active Sessions", _metrics.ActiveSessions.ToString("N0"), "Live sessions", Icons.Material.Outlined.Monitor, "blue"),
        new KpiCard("Daily Tokens", _metrics.DailyTokensUsed.ToString("N0"), $"{_metrics.TokenUsagePercent:0}% of quota", Icons.Material.Outlined.GeneratingTokens, "grey")
    };

    private readonly List<ChartSeries<double>> _activitySeries = new()
    {
        new ChartSeries<double> { Name = "Uploads", Data = new double[] { 12, 18, 10, 22, 27, 19, 34 } },
        new ChartSeries<double> { Name = "Chat sessions", Data = new double[] { 44, 51, 49, 63, 70, 58, 86 } },
        new ChartSeries<double> { Name = "Tokens", Data = new double[] { 18, 21, 17, 26, 31, 29, 36 } }
    };

    private readonly string[] _activityLabels = { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" };
    private readonly string[] _statusLabels = { "Pending", "Processing", "Indexed", "Failed" };
    private List<ChartSeries<double>> StatusSeries =>
        _documentStatuses.Any()
            ? new List<ChartSeries<double>> { new() { Name = "Documents", Data = _documentStatuses.Select(s => (double)s.Count).ToArray() } }
            : new List<ChartSeries<double>> { new() { Name = "Documents", Data = new double[] { 0, 0, 0, 0 } } };

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        try
        {
            var statsTask = Session.IsAuthenticated && !string.IsNullOrWhiteSpace(Session.AccessToken)
                ? DashboardApi.GetAdminStatsAsync(Session.AccessToken)
                : Task.FromResult<AdminDashboardStatsDto?>(null);
            var queueTask = ModerationService.GetQueueAsync();

            await Task.WhenAll(statsTask, queueTask);

            var stats = statsTask.Result;
            var queue = queueTask.Result;

            if (stats is not null)
            {
                _metrics = new DashboardMetrics
                {
                    TotalUsers = stats.TotalUsers,
                    TotalDocuments = stats.TotalDocuments,
                    ActiveSessions = stats.TotalActiveSessions,
                    FailedJobs = stats.TotalFailedJobs,
                    DailyTokensUsed = 0,
                    DailyTokenQuota = 500_000,
                    NewUsersThisWeek = 0,
                    ProcessingDocuments = 0
                };
            }

            _attentionDocuments.Clear();
            foreach (var doc in queue.Take(5))
            {
                _attentionDocuments.Add(new AttentionDocument(
                    doc.Title, doc.SubjectCode, doc.OwnerName, doc.OwnerEmail,
                    doc.ProcessingStatus, doc.Severity, doc.UploadedAt.ToString("d")));
            }

            _documentStatuses.Clear();
            if (queue.Any())
            {
                _documentStatuses.Add(new DocumentStatusMetric("Indexed", queue.Count(d => d.ProcessingStatus == "Ready" || d.ProcessingStatus == "Indexed"), "indexed"));
                _documentStatuses.Add(new DocumentStatusMetric("Processing", queue.Count(d => d.ProcessingStatus == "Processing"), "processing"));
                _documentStatuses.Add(new DocumentStatusMetric("Pending", queue.Count(d => d.ProcessingStatus == "Pending"), "pending"));
                _documentStatuses.Add(new DocumentStatusMetric("Failed", queue.Count(d => d.ProcessingStatus == "Failed"), "failed"));
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to load dashboard: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OpenModerationQueue() => Navigation.NavigateTo("/admin/documents/moderation");

    private void OpenAuditLogs() => Navigation.NavigateTo("/admin/audit-logs");

    private static string FormatDateTime(DateTime value) => value.ToString("MMM dd, yyyy HH:mm", System.Globalization.CultureInfo.InvariantCulture);

    private static string GetStatusClass(string status)
    {
        return status switch
        {
            "Pending Review" or "Pending" => "pending-review",
            "Reported" => "reported",
            "Failed" => "failed",
            _ => "pending-review"
        };
    }

    private static string GetSeverityClass(string severity)
    {
        return severity switch
        {
            "High" => "risk-high",
            "Medium" => "risk-medium",
            _ => "risk-low"
        };
    }

    private static Color GetDocumentStatusColor(string status)
    {
        return status switch
        {
            "Pending Review" => Color.Warning,
            "Reported" => Color.Error,
            "Failed" => Color.Error,
            "Rejected" => Color.Default,
            _ => Color.Primary
        };
    }

    private static Color GetSeverityColor(string severity)
    {
        return severity switch
        {
            "High" => Color.Error,
            "Medium" => Color.Warning,
            _ => Color.Info
        };
    }

    private static Color GetTokenProgressColor(double usagePercent)
    {
        return usagePercent >= 90 ? Color.Error : usagePercent >= 75 ? Color.Warning : Color.Success;
    }

    private sealed class DashboardMetrics
    {
        public int TotalUsers { get; set; }
        public int NewUsersThisWeek { get; set; }
        public int TotalDocuments { get; set; }
        public int ProcessingDocuments { get; set; }
        public int ActiveSessions { get; set; }
        public int FailedJobs { get; set; }
        public int DailyTokensUsed { get; set; }
        public int DailyTokenQuota { get; set; } = 1;
        public double TokenUsagePercent => DailyTokenQuota == 0 ? 0 : DailyTokensUsed * 100d / DailyTokenQuota;
    }

    private sealed record KpiCard(string Label, string Value, string SupportingText, string Icon, string AccentClass);
    private sealed record DocumentStatusMetric(string Label, int Count, string CssClass);
    private sealed record AttentionDocument(string Title, string SubjectCode, string OwnerName, string OwnerEmail, string Status, string Severity, string AgeLabel);
    private sealed record ActivityFeedItem(string Title, string Description, DateTime CreatedAt, string Icon, Color Color);
}

<style>
    .page-enter {
        animation: pageRise .42s ease both;
    }

    /* ── Cards ── */
    .dashboard-card {
        border-radius: 0.75rem;
        background: #ffffff;
        border: 1px solid rgba(199, 196, 215, 0.3);
        padding: 1.5rem;
        height: 100%;
        box-shadow: 0px 4px 20px rgba(0, 0, 0, 0.05);
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .dashboard-card:hover {
        box-shadow: 0px 10px 30px rgba(99, 102, 241, 0.06);
    }

    /* ── KPI Grid ── */
    .kpi-grid-container {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.25rem;
    }

    @@media (max-width: 1200px) {
        .kpi-grid-container {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .kpi-grid-container {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 480px) {
        .kpi-grid-container {
            grid-template-columns: 1fr;
        }
    }

    .kpi-card-custom {
        background: #ffffff;
        border-radius: 0.75rem;
        border: 1px solid rgba(199, 196, 215, 0.3);
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        transition: all 0.2s ease;
        box-shadow: 0px 4px 20px rgba(0, 0, 0, 0.05);
        min-height: 140px;
    }

    .dark-theme .kpi-card-custom {
        background: #1e2124;
        border: 1px solid rgba(199, 196, 215, 0.1);
        box-shadow: none;
    }

    .kpi-card-custom:hover {
        transform: translateY(-2px);
        box-shadow: 0px 10px 30px rgba(99, 102, 241, 0.08);
        border-color: rgba(70, 72, 212, 0.2);
    }

    .kpi-card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1rem;
    }

    .kpi-icon-wrapper {
        padding: 0.5rem;
        border-radius: 0.5rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    /* KPI Colors mapping */
    .kpi-icon-wrapper.green {
        background-color: #e8f5e9;
        color: #2e7d32;
    }

    .kpi-icon-wrapper.purple {
        background-color: #f3e5f5;
        color: #7b1fa2;
    }

    .kpi-icon-wrapper.blue {
        background-color: #e3f2fd;
        color: #1565c0;
    }

    .kpi-icon-wrapper.grey {
        background-color: #f5f5f5;
        color: #616161;
    }

    .dark-theme .kpi-icon-wrapper.green {
        background-color: rgba(46, 125, 50, 0.15);
        color: #81c784;
    }

    .dark-theme .kpi-icon-wrapper.purple {
        background-color: rgba(123, 31, 162, 0.15);
        color: #ba68c8;
    }

    .dark-theme .kpi-icon-wrapper.blue {
        background-color: rgba(21, 101, 192, 0.15);
