@namespace AI_Study_Hub_v2.Components.Admin.Subjects
@using Microsoft.AspNetCore.Components
@using MudBlazor
@using AI_Study_Hub_v2.Components.Admin.Shared

<EntitySheet Open="@Open"
             OpenChanged="@OpenChanged"
             Title="@SheetTitle"
             Subtitle="Maintain subjects(code, name, semester, description)."
             Width="520px">
    <ChildContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudStack Spacing="3">
                <MudTextField @bind-Value="_model.Code"
                              Label="Subject code"
                              Variant="Variant.Outlined"
                              Required="true"
                              RequiredError="Subject code is required"
                              Placeholder="SWP391" />
                <MudTextField @bind-Value="_model.Name"
                              Label="Subject name"
                              Variant="Variant.Outlined"
                              Required="true"
                              RequiredError="Subject name is required" />
                <MudSelect T="string" @bind-Value="_model.Semester" Label="Semester" Variant="Variant.Outlined" Required="true">
                    <MudSelectItem T="string" Value="@("Spring 2026")">Spring 2026</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Summer 2026")">Summer 2026</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Fall 2026")">Fall 2026</MudSelectItem>
                </MudSelect>
                <MudTextField @bind-Value="_model.Description"
                              Label="Description"
                              Variant="Variant.Outlined"
                              Lines="4" />
            </MudStack>
        </MudForm>
    </ChildContent>
    <FooterContent>
        <MudButton Variant="Variant.Text" OnClick="CancelAsync">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Save" Disabled="@(!_isValid)" OnClick="SaveAsync">
            Save subject
        </MudButton>
    </FooterContent>
</EntitySheet>

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }
    [Parameter] public SubjectFormModel? Model { get; set; }
    [Parameter] public EventCallback<SubjectFormModel> Saved { get; set; }

    private MudForm? _form;
    private bool _isValid;
    private SubjectFormModel _model = SubjectFormModel.New();

    private string SheetTitle => _model.Id == Guid.Empty ? "Create subject" : "Edit subject";

    protected override void OnParametersSet()
    {
        if (Model is null && !Open)
        {
            _model = SubjectFormModel.New();
            return;
        }

        if (Model is not null)
        {
            _model = Model.Clone();
        }
    }

    private async Task SaveAsync()
    {
        if (_form is null)
        {
            return;
        }

        await _form.ValidateAsync();
        if (!_form.IsValid)
        {
            return;
        }

        await Saved.InvokeAsync(_model.Clone());
        await OpenChanged.InvokeAsync(false);
    }

    private async Task CancelAsync()
    {
        await OpenChanged.InvokeAsync(false);
    }

    public sealed class SubjectFormModel
    {
        public Guid Id { get; set; }
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string Semester { get; set; } = "Summer 2026";
        public string Description { get; set; } = string.Empty;
        public DateTime CreatedAt { get; set; } = DateTime.UtcNow;

        public static SubjectFormModel New()
        {
            return new SubjectFormModel
            {
                Id = Guid.Empty,
                Semester = "Summer 2026",
                CreatedAt = DateTime.UtcNow
            };
        }

        public SubjectFormModel Clone()
        {
            return new SubjectFormModel
            {
                Id = Id,
                Code = Code,
                Name = Name,
                Semester = Semester,
                Description = Description,
                CreatedAt = CreatedAt
            };
        }
    }
}
