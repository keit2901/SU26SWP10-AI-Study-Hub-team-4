        overflow: hidden;
        transition: all 0.2s ease;
    }
    .subject-group-header {
        padding: 1rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        cursor: pointer;
        background: #ffffff;
        transition: background 0.2s;
        user-select: none;
    }
    .subject-group-header:hover {
        background: #f8fafc;
    }
    .subject-header-left {
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    .calendar-icon-wrapper {
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #eaecef;
        border-radius: 8px;
        color: #575e72;
