        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
    }
    .search-input-wrapper {
        position: relative;
        flex: 1;
        min-width: 280px;
    }
    .search-input {
        width: 100%;
        padding: 0.625rem 1rem 0.625rem 2.5rem;
        border: 1px solid rgba(199, 196, 215, 0.3);
        border-radius: 8px;
        background: #ffffff;
        font-size: 14px;
        outline: none;
        color: #191c1e;
        transition: border-color 0.2s;
    }
    .search-input:focus {
        border-color: #4648d4;
    }
    .search-icon {
        position: absolute;
        left: 0.75rem;
        top: 50%;
        transform: translateY(-50%);
        color: #767586;
        pointer-events: none;
    }
    .filter-select {
        padding: 0.625rem 2.25rem 0.625rem 1rem;
        border: 1px solid rgba(199, 196, 215, 0.3);
        border-radius: 8px;
        background: #ffffff;
        font-size: 14px;
        outline: none;
        color: #191c1e;
        cursor: pointer;
        transition: border-color 0.2s;
        min-width: 180px;
    }
    .filter-select:focus {
        border-color: #4648d4;
    }

