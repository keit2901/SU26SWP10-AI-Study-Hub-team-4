        padding: 0.375rem;
        border-radius: 6px;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }
    .action-btn:hover {
        background: #f1f5f9;
        color: #1e293b;
    }
