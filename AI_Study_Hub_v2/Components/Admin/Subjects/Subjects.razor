@namespace AI_Study_Hub_v2.Components.Admin.Subjects
@page "/admin/subjects"
@layout AdminLayout
@using MudBlazor
@using AI_Study_Hub_v2.Components.Admin.Shared
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<div class="subjects-page page-enter">
    <!-- Breadcrumbs & Header -->
    <div class="header-breadcrumb-row">
        <span class="crumb-link">Governance</span>
        <span class="crumb-separator">&gt;</span>
        <span class="crumb-active">Subjects</span>
    </div>

    <div class="page-title-row">
        <div>
            <h1 class="page-title-text">Subject Management</h1>
            <p class="page-subtitle-text">
                Organize subjects by semester and maintain searchable course metadata for RAG indexing.
            </p>
        </div>
        <button class="create-subject-btn" @onclick="CreateSubject">
            <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" Style="margin-right: 0.5rem;" />
            Create Subject
        </button>
    </div>

    <!-- KPI Grid -->
    <div class="kpi-grid-container">
        <div class="kpi-card-custom">
            <div class="kpi-card-top">
                <span class="kpi-label">TOTAL SUBJECTS</span>
            </div>
            <div class="kpi-value kpi-blue">124</div>
        </div>
        <div class="kpi-card-custom">
            <div class="kpi-card-top">
                <span class="kpi-label">ACTIVE SEMESTERS</span>
            </div>
            <div class="kpi-value kpi-purple">3</div>
        </div>
        <div class="kpi-card-custom">
            <div class="kpi-card-top">
                <span class="kpi-label">METADATA COMPLETION</span>
            </div>
            <div class="kpi-value kpi-green">98%</div>
        </div>
        <div class="kpi-card-custom">
            <div class="kpi-card-top">
                <span class="kpi-label">RAG INDEX NODES</span>
            </div>
            <div class="kpi-value kpi-dark">2.4k</div>
        </div>
    </div>

    <!-- Filters Row -->
    <div class="filter-row-custom">
        <div class="search-input-wrapper">
            <input type="text" class="search-input" placeholder="Search code, name, or description"
                   value="@_searchText" @oninput="OnSearchInput" />
            <MudIcon Icon="@Icons.Material.Filled.Search" Class="search-icon" Size="Size.Small" />
        </div>
        <select class="filter-select" value="@_selectedSemester" @onchange="OnSemesterSelect">
            <option value="">All Semesters</option>
            @foreach (var sem in _subjects.Select(s => s.Semester).Distinct().OrderBy(s => s))
            {
                <option value="@sem">@sem</option>
            }
        </select>
    </div>

    <!-- List of semesters and subjects -->
    @if (_isLoading)
    {
        <div style="margin-top: 1.5rem;">
            <MudStack Spacing="2">
                <MudSkeleton Height="84px" Animation="Animation.Wave" />
                <MudSkeleton Height="160px" Animation="Animation.Wave" />
                <MudSkeleton Height="160px" Animation="Animation.Wave" />
            </MudStack>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div style="margin-top: 1.5rem;">
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled">@_errorMessage</MudAlert>
        </div>
    }
    else if (!FilteredSubjects.Any())
    {
        <div class="empty-state-card">
            <MudIcon Icon="@Icons.Material.Filled.AutoStories" Size="Size.Large" Color="Color.Secondary" Style="margin-bottom: 1rem;" />
            <h3 class="empty-state-title">No subjects found</h3>
            <p class="empty-state-subtitle">Clear search terms or select another semester.</p>
        </div>
    }
    else
    {
        <div class="subject-groups">
            @foreach (var group in GroupedSubjects)
            {
                var semester = group.Key;
                var isExpanded = IsSemesterExpanded(semester);
                var subjectCount = group.Count();
                var countText = subjectCount == 1 ? "1 SUBJECT" : $"{subjectCount} SUBJECTS";

                <div class="subject-group-card">
                    <!-- Header -->
                    <div class="subject-group-header" @onclick="() => ToggleSemester(semester)">
                        <div class="subject-header-left">
                            <div class="calendar-icon-wrapper">
                                <MudIcon Icon="@Icons.Material.Outlined.CalendarToday" Size="Size.Small" />
                            </div>
                            <span class="semester-title">@semester</span>
                            <span class="subject-count-badge">@countText</span>
                        </div>
                        <div class="subject-header-right">
                            <MudIcon Icon="@(isExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Class="chevron-icon" />
                        </div>
                    </div>

                    <!-- Child Table Content -->
                    @if (isExpanded)
                    {
                        <div class="subject-group-body">
                            <table class="subjects-table">
                                <thead>
                                    <tr>
                                        <th style="width: 120px;">CODE</th>
                                        <th style="width: 220px;">NAME</th>
                                        <th>DESCRIPTION</th>
                                        <th style="width: 140px;">CREATED</th>
                                        <th style="width: 100px; text-align: right;">ACTIONS</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var subject in group)
                                    {
                                        <tr>
                                            <td>
                                                <span class="code-badge">@subject.Code</span>
                                            </td>
                                            <td>
                                                <span class="subject-name">@subject.Name</span>
                                            </td>
                                            <td>
                                                <span class="subject-description">@subject.Description</span>
                                            </td>
                                            <td>
                                                <span class="subject-date">@FormatDate(subject.CreatedAt)</span>
                                            </td>
                                            <td style="text-align: right;">
                                                <div class="actions-wrapper">
                                                    <button class="action-btn edit-btn" @onclick="() => EditSubject(subject)" @onclick:stopPropagation="true" title="Edit">
                                                        <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                                                    </button>
                                                    <button class="action-btn delete-btn" @onclick="() => DeleteSubjectAsync(subject)" @onclick:stopPropagation="true" title="Delete">
                                                        <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

<SubjectForm Open="@_subjectSheetOpen"
             OpenChanged="@(value => _subjectSheetOpen = value)"
             Model="@_editingSubject"
             Saved="SaveSubjectAsync" />

@code {
    private readonly List<SubjectForm.SubjectFormModel> _subjects = new();
    private SubjectForm.SubjectFormModel? _editingSubject;
    private bool _isLoading = true;
    private bool _subjectSheetOpen;
    private string? _searchText;
    private string? _selectedSemester;
    private string? _errorMessage;

    private readonly HashSet<string> _collapsedSemesters = new();

    private IEnumerable<SubjectForm.SubjectFormModel> FilteredSubjects => _subjects
        .Where(MatchesSemester)
        .Where(MatchesSearch)
        .OrderBy(subject => subject.Code);

    private IEnumerable<IGrouping<string, SubjectForm.SubjectFormModel>> GroupedSubjects => FilteredSubjects
        .GroupBy(subject => subject.Semester)
        .OrderBy(group => group.Key);

    protected override void OnInitialized()
    {
        try
        {
            _subjects.AddRange(BuildSeedSubjects());
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to load subjects: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private Task OnSearchInput(ChangeEventArgs e)
    {
        _searchText = e.Value?.ToString();
        return Task.CompletedTask;
    }

    private Task OnSemesterSelect(ChangeEventArgs e)
    {
        _selectedSemester = e.Value?.ToString();
        return Task.CompletedTask;
    }

    private bool MatchesSemester(SubjectForm.SubjectFormModel subject)
    {
        return string.IsNullOrWhiteSpace(_selectedSemester)
            || subject.Semester.Equals(_selectedSemester, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesSearch(SubjectForm.SubjectFormModel subject)
    {
        if (string.IsNullOrWhiteSpace(_searchText))
        {
            return true;
        }

        var text = _searchText.Trim();
        return subject.Code.Contains(text, StringComparison.OrdinalIgnoreCase)
            || subject.Name.Contains(text, StringComparison.OrdinalIgnoreCase)
            || subject.Description.Contains(text, StringComparison.OrdinalIgnoreCase);
    }

    private void ToggleSemester(string semester)
    {
        if (_collapsedSemesters.Contains(semester))
        {
            _collapsedSemesters.Remove(semester);
        }
        else
        {
            _collapsedSemesters.Add(semester);
        }
    }

    private bool IsSemesterExpanded(string semester) => !_collapsedSemesters.Contains(semester);

    private void CreateSubject()
    {
        _editingSubject = SubjectForm.SubjectFormModel.New();
        _subjectSheetOpen = true;
    }

    private void EditSubject(SubjectForm.SubjectFormModel subject)
    {
        _editingSubject = subject.Clone();
        _subjectSheetOpen = true;
    }

    private Task SaveSubjectAsync(SubjectForm.SubjectFormModel subject)
    {
        if (subject.Id == Guid.Empty)
        {
            subject.Id = Guid.NewGuid();
            subject.CreatedAt = DateTime.UtcNow;
            _subjects.Add(subject.Clone());
            Snackbar.Add($"Subject {subject.Code} created.", Severity.Success);
        }
        else
        {
            var existing = _subjects.FirstOrDefault(item => item.Id == subject.Id);
            if (existing is not null)
            {
                existing.Code = subject.Code;
                existing.Name = subject.Name;
                existing.Semester = subject.Semester;
                existing.Description = subject.Description;
                Snackbar.Add($"Subject {subject.Code} updated.", Severity.Success);
            }
        }

        _editingSubject = null;
        return Task.CompletedTask;
    }

    private async Task DeleteSubjectAsync(SubjectForm.SubjectFormModel subject)
    {
        var parameters = new DialogParameters
        {
            ["Title"] = "Delete subject",
            ["Message"] = $"Delete {subject.Code} - {subject.Name}? This should only be allowed when no documents depend on it.",
            ["ConfirmText"] = "Delete",
            ["ConfirmationText"] = subject.Code,
            ["ConfirmColor"] = Color.Error
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Delete subject", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            _subjects.Remove(subject);
            Snackbar.Add($"Subject {subject.Code} deleted.", Severity.Warning);
        }
    }

    private static string FormatDate(DateTime value) => value.ToString("MMM dd, yyyy");

    private static IEnumerable<SubjectForm.SubjectFormModel> BuildSeedSubjects()
    {
        return new[]
        {
            new SubjectForm.SubjectFormModel { Id = Guid.NewGuid(), Code = "SWP391", Name = "Software Development Project", Semester = "Summer 2026", Description = "Capstone-style team project focusing on full software development lif...", CreatedAt = DateTime.Parse("2026-06-02T00:00:00Z") },
            new SubjectForm.SubjectFormModel { Id = Guid.NewGuid(), Code = "PRN212", Name = ".NET Cross-Platform Programming", Semester = "Summer 2026", Description = "C# application development and service integration across Windows, ...", CreatedAt = DateTime.Parse("2026-06-05T00:00:00Z") },
            new SubjectForm.SubjectFormModel { Id = Guid.NewGuid(), Code = "DBI202", Name = "Database Systems", Semester = "Spring 2026", Description = "Relational modeling, SQL, and normalization techniques for large-scal...", CreatedAt = DateTime.Parse("2026-04-26T00:00:00Z") },
            new SubjectForm.SubjectFormModel { Id = Guid.NewGuid(), Code = "SWT301", Name = "Software Testing", Semester = "Fall 2026", Description = "Testing strategy, automation, and quality control methodologies for en...", CreatedAt = DateTime.Parse("2026-06-26T00:00:00Z") }
        };
    }
}

<style>
    .page-enter {
        animation: pageRise .42s ease both;
    }

    .subjects-page {
        font-family: 'Hanken Grotesk', 'Segoe UI', system-ui, -apple-system, sans-serif;
        color: #1e293b;
    }

    /* Breadcrumbs */
    .header-breadcrumb-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.5rem;
    }
    .crumb-link {
        font-size: 11px;
        font-weight: 700;
        color: #767586;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .crumb-separator {
        font-size: 11px;
        color: #bfc6dd;
    }
    .crumb-active {
        font-size: 11px;
        font-weight: 700;
        color: #575e72;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    /* Header Title Row */
    .page-title-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }
    .page-title-text {
        font-size: 28px;
        font-weight: 800;
        color: #191c1e;
        letter-spacing: -0.02em;
        margin: 0;
    }
    .page-subtitle-text {
        font-size: 14px;
        color: #575e72;
        margin: 0.25rem 0 0 0;
    }
    .create-subject-btn {
        background: #4648d4;
        color: #ffffff;
        font-weight: 700;
        font-size: 14px;
        padding: 0.625rem 1.25rem;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        box-shadow: 0 4px 12px rgba(70, 72, 212, 0.24);
        transition: all 0.2s;
    }
    .create-subject-btn:hover {
        background: #3b3cbd;
        box-shadow: 0 6px 16px rgba(70, 72, 212, 0.32);
        transform: translateY(-1px);
    }

    /* KPI Cards Grid */
    .kpi-grid-container {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
        margin-bottom: 1.5rem;
    }
    @@media (max-width: 1200px) {
        .kpi-grid-container {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    @@media (max-width: 600px) {
        .kpi-grid-container {
            grid-template-columns: 1fr;
        }
    }
    .kpi-card-custom {
        background: #ffffff;
        border: 1px solid rgba(199, 196, 215, 0.3);
        border-radius: 12px;
        padding: 1.25rem;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        min-height: 110px;
    }
    .kpi-card-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .kpi-label {
        font-size: 10px;
        font-weight: 700;
        color: #767586;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .kpi-value {
        font-size: 28px;
        font-weight: 800;
        line-height: 1.2;
        margin-top: 0.5rem;
    }
    .kpi-value.kpi-blue {
        color: #4648d4;
    }
    .kpi-value.kpi-purple {
        color: #8b5cf6;
    }
    .kpi-value.kpi-green {
        color: #10b981;
    }
    .kpi-value.kpi-dark {
        color: #1e293b;
    }

