        font-weight: 700;
        color: #1e293b;
        margin: 0 0 0.5rem 0;
    }
    .empty-state-subtitle {
        font-size: 14px;
        color: #64748b;
        margin: 0;
    }

    /* Semester Groups list */
    .subject-groups {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }
