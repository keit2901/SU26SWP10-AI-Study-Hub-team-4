@namespace AI_Study_Hub_v2.Components.Admin.Users
@page "/admin/users"
@layout AdminLayout
@using Microsoft.AspNetCore.Components
@using MudBlazor
@using AI_Study_Hub_v2.Components.Admin.Shared
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IRoleCatalogService Roles

<div class="admin-users-page page-enter">
    <!-- Breadcrumbs & Header -->
    <div class="d-flex justify-space-between align-center mb-6 flex-wrap" style="gap: 1rem;">
        <div>
            <div class="d-flex align-center mb-1" style="gap: 0.5rem; font-size: 12px; font-weight: 500; font-family: 'Hanken Grotesk', sans-serif;">
                <span style="color: #767586;">Governance</span>
                <span style="color: #c7c6d5;">&gt;</span>
                <span style="color: #5A32EA;">Users &amp; Permissions</span>
            </div>
            <h2 class="text-[32px] font-extrabold text-on-background" style="font-size: 28px; font-weight: 800; color: #191c1e; font-family: 'Hanken Grotesk', sans-serif; line-height: 1.2;">Users &amp; Permissions</h2>
            <p class="text-body-md text-on-surface-variant mt-1" style="font-size: 14px; color: #575e72; font-family: 'Hanken Grotesk', sans-serif;">Manage team access levels, moderate student accounts, and configure RBAC policies.</p>
        </div>
        <div class="d-flex align-center" style="gap: 0.75rem;">
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Outlined.Download" Class="export-report-btn" Style="border-radius: 8px; font-weight: 700; text-transform: none; color: #575e72; border-color: #c7c6d5; background-color: #ffffff; font-size: 13px;">
                Export Report
            </MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.PersonAddAlt" OnClick="OpenInviteSheet" Class="add-new-user-btn" Style="background-color: #5A32EA; color: #ffffff; border-radius: 8px; font-weight: 700; text-transform: none; font-size: 13px;">
                Add New User
            </MudButton>
        </div>
    </div>

    <!-- KPI Grid -->
    <div class="kpi-grid-container mb-6">
        <!-- Card 1: Total Users -->
        <div class="kpi-card-custom">
            <div class="d-flex justify-space-between align-start" style="width: 100%;">
                <div>
                    <span class="kpi-label">TOTAL USERS</span>
                    <div class="kpi-value">1,284</div>
                    <div class="d-flex align-center mt-2" style="gap: 4px; color: #5A32EA; font-size: 11px; font-weight: 700;">
                        <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small" Style="font-size: 14px;" />
                        <span>+12% this month</span>
                    </div>
                </div>
                <div class="kpi-icon-circle blue">
                    <MudIcon Icon="@Icons.Material.Outlined.People" />
                </div>
            </div>
        </div>

        <!-- Card 2: Active Admins -->
        <div class="kpi-card-custom">
            <div class="d-flex justify-space-between align-start" style="width: 100%;">
                <div>
                    <span class="kpi-label">ACTIVE ADMINS</span>
                    <div class="kpi-value">24</div>
                    <span class="kpi-subtext mt-2">Privileged accounts</span>
                </div>
                <div class="kpi-icon-circle purple">
                    <MudIcon Icon="@Icons.Material.Outlined.Shield" />
                </div>
            </div>
        </div>

        <!-- Card 3: Pending Invites -->
        <div class="kpi-card-custom">
            <div class="d-flex justify-space-between align-start" style="width: 100%;">
                <div>
                    <span class="kpi-label">PENDING INVITES</span>
                    <div class="kpi-value">18</div>
                    <span class="kpi-subtext mt-2">Awaiting verification</span>
                </div>
                <div class="kpi-icon-circle slate">
                    <MudIcon Icon="@Icons.Material.Outlined.Mail" />
                </div>
            </div>
        </div>

        <!-- Card 4: Revoked Access -->
        <div class="kpi-card-custom">
            <div class="d-flex justify-space-between align-start" style="width: 100%;">
                <div>
                    <span class="kpi-label">REVOKED ACCESS</span>
                    <div class="kpi-value">7</div>
                    <div class="d-flex align-center mt-2" style="gap: 4px; color: #ba1a1a; font-size: 11px; font-weight: 700;">
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Style="font-size: 14px;" />
                        <span>Critical alerts</span>
                    </div>
                </div>
                <div class="kpi-icon-circle red">
                    <MudIcon Icon="@Icons.Material.Outlined.Block" />
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content Layout (Table & Widgets) -->
    <MudGrid>
        <!-- Table Column -->
        <MudItem xs="12" lg="8">
            <!-- Search & Filters -->
            <div class="filter-row-custom mb-6">
                <div class="search-input-wrapper">
                    <MudIcon Icon="@Icons.Material.Filled.Search" Class="search-icon" />
                    <input type="text" placeholder="Search by name, email, or user" value="@_searchText" @oninput="OnSearchInputChanged" class="search-input" />
                </div>
                
                <select class="filter-select" value="@_selectedRole" @onchange="OnRoleSelectChanged">
                    <option value="">All Roles</option>
                    @foreach (var role in AvailableRoleNames)
                    {
                        <option value="@role">@role</option>
                    }
                </select>

                <select class="filter-select" value="@_selectedStatus" @onchange="OnStatusSelectChanged">
                    <option value="">Status</option>
                    <option value="@ActiveStatus">Active</option>
                    <option value="@InactiveStatus">Inactive</option>
                </select>

                <button class="filter-btn">
                    <MudIcon Icon="@Icons.Material.Filled.Tune" Style="font-size: 18px; color: #575e72;" />
                </button>
            </div>

            <!-- Custom Table -->
            <div class="users-table-container mb-6">
                @if (_isLoading)
                {
                    <div class="pa-6">
                        <MudSkeleton Height="44px" Animation="Animation.Wave" />
                        <MudSkeleton Height="44px" Animation="Animation.Wave" />
                        <MudSkeleton Height="44px" Animation="Animation.Wave" />
                    </div>
                }
                else if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="ma-4">
                        @_errorMessage
                    </MudAlert>
                }
                else if (!FilteredUsers.Any())
                {
                    <div class="d-flex flex-column align-center justify-center py-10" style="text-align: center; gap: 0.5rem;">
                        <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Secondary" />
                        <div class="font-bold text-lg" style="color: #191c1e;">No users found</div>
                        <div class="text-sm" style="color: #767586;">Try changing filters or invite a new user.</div>
                    </div>
                }
                else
                {
                    <table class="users-table">
                        <thead>
                            <tr>
                                <th>USER</th>
                                <th>ROLE</th>
                                <th>PERMISSIONS</th>
                                <th>LAST ACTIVE</th>
                                <th style="width: 50px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in FilteredUsers)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-center" style="gap: 0.75rem;">
                                            @if (!string.IsNullOrEmpty(user.AvatarUrl))
                                            {
                                                <img src="@user.AvatarUrl" class="user-avatar-img" />
                                            }
                                            else
                                            {
                                                <span class="user-avatar-initials @(user.Role.ToLower())">@user.Initials</span>
                                            }
                                            <div>
                                                <div class="user-name">
                                                    @user.FullName
                                                    @if (IsCurrentAdmin(user))
                                                    {
                                                        <span class="user-badge-you">You</span>
                                                    }
                                                </div>
                                                <div class="user-email">@user.Email</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="role-badge @(user.Role.ToLower())">@user.Role.ToUpper()</span>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-1 flex-wrap">
                                            @foreach (var perm in GetPermissionsList(user.Role))
                                            {
                                                <span class="perm-badge">@perm</span>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <span class="last-active-text">@FormatLastActive(user.LastActiveAt)</span>
                                    </td>
                                    <td>
                                        <MudMenu Dense="true" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                                            <ActivatorContent>
                                                <MudIconButton Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Style="color: #767586; padding: 4px;" />
                                            </ActivatorContent>
                                            <ChildContent>
                                                <MudMenuItem Icon="@Icons.Material.Filled.Visibility" OnClick="@(() => OpenDetails(user))">View details</MudMenuItem>
                                                <MudMenuItem Icon="@Icons.Material.Filled.DataUsage" OnClick="@(() => OpenQuotaSheet(user))">Edit quota</MudMenuItem>
                                                @foreach (var role in AvailableRoleNames.Where(role => !role.Equals(user.Role, StringComparison.OrdinalIgnoreCase)))
                                                {
                                                    <MudMenuItem Icon="@GetRoleIcon(role)" Disabled="@IsRoleChangeDisabled(user, role)" OnClick="@(() => ChangeRoleAsync(user, role))">Change role to @role</MudMenuItem>
                                                }
                                                @if (user.IsActive)
                                                {
                                                    <MudMenuItem Icon="@Icons.Material.Filled.Block" Disabled="@IsCurrentAdmin(user)" OnClick="@(() => ToggleActiveAsync(user))">Deactivate</MudMenuItem>
                                                }
                                                else
                                                {
                                                    <MudMenuItem Icon="@Icons.Material.Filled.CheckCircle" OnClick="@(() => ToggleActiveAsync(user))">Activate</MudMenuItem>
                                                }
                                            </ChildContent>
                                        </MudMenu>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <div class="users-table-footer">
                        <span class="footer-count">Showing @FilteredUsers.Count() of @TotalUsersCount users</span>
                        <div class="footer-pagination">
                            <button class="pag-btn" disabled>&lt;</button>
                            <button class="pag-btn active">1</button>
                            <button class="pag-btn">2</button>
                            <button class="pag-btn">&gt;</button>
                        </div>
                    </div>
                }
            </div>

            <!-- Guardrail alert banner -->
            <div class="p-4 rounded-lg d-flex gap-3 align-start mb-6" style="background-color: #ffdad6; border: 1px solid rgba(186, 26, 26, 0.1); border-radius: 0.5rem; padding: 16px;">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Class="text-error mt-0.5" Style="color: #ba1a1a;" />
                <p class="text-body-md text-on-error-container mb-0" style="color: #93000a; font-size: 13px; line-height: 1.4; margin: 0;">
                    <strong>Security Guardrail:</strong> Administrators cannot deactivate or demote their own account. All role, status, and daily token quota updates write audit log entries to the database.
                </p>
            </div>
        </MudItem>

        <!-- Widgets Column -->
        <MudItem xs="12" lg="4">
            <div class="d-flex flex-column" style="gap: 1.5rem;">
                <!-- Widget 1: Permission Matrix -->
                <div class="widget-card">
                    <div class="d-flex align-center justify-space-between mb-4">
                        <div class="d-flex align-center" style="gap: 8px;">
                            <MudIcon Icon="@Icons.Material.Outlined.Shield" Style="color: #5A32EA; font-size: 20px;" />
                            <span style="font-size: 16px; font-weight: 700; color: #191c1e;">Permission Matrix</span>
                        </div>
                    </div>
                    <span style="font-size: 12px; font-weight: 700; color: #575e72; text-transform: uppercase; letter-spacing: 0.05em; display: block; margin-bottom: 12px;">
                        Current RBAC Policy Status: <span style="color: #191c1e;">Standard V2.4</span>
                    </span>
                    <div class="d-flex flex-column mb-6" style="gap: 12px;">
                        <div class="d-flex align-center justify-space-between" style="font-size: 13px; font-weight: 500; color: #575e72;">
                            <span>Inheritance Rules</span>
                            <span class="widget-badge success">Active</span>
                        </div>
                        <div class="d-flex align-center justify-space-between" style="font-size: 13px; font-weight: 500; color: #575e72;">
                            <span>Sync Interval</span>
                            <span class="widget-badge info">5m</span>
                        </div>
                        <div class="d-flex align-center justify-space-between" style="font-size: 13px; font-weight: 500; color: #575e72;">
                            <span>Conflicts Detected</span>
                            <span class="widget-badge error">0</span>
                        </div>
                    </div>
                    <MudButton Variant="Variant.Outlined" FullWidth="true" Style="border-color: #c7c6d5; color: #5A32EA; font-weight: 700; text-transform: none; border-radius: 8px; font-size: 13px; height: 38px;">
                        Configure RBAC Rules
                    </MudButton>
                </div>

                <!-- Widget 2: Automated Security Scans (Dark) -->
                <div class="widget-card dark">
                    <div class="d-flex align-center" style="gap: 8px; margin-bottom: 16px;">
                        <MudIcon Icon="@Icons.Material.Outlined.VerifiedUser" Style="color: #10b981; font-size: 20px;" />
                        <span style="font-size: 16px; font-weight: 700; color: #ffffff;">Automated Security Scans</span>
                    </div>
                    <div class="security-metric-grid">
                        <div>
                            <div class="security-metric-label">Next Scheduled Scan</div>
                            <div class="security-metric-val">Today, 22:00 UTC</div>
                        </div>
                        <div>
                            <div class="security-metric-label">Integrity</div>
                            <div class="security-metric-val" style="color: #10b981;">99.9%</div>
                        </div>
                    </div>
                    <div class="security-progress-bar">
                        <div class="security-progress-fill" style="width: 99.9%;"></div>
                    </div>
                    <div class="security-inner-box">
                        <div class="d-flex align-center" style="gap: 6px; margin-bottom: 6px;">
                            <MudIcon Icon="@Icons.Material.Outlined.History" Style="font-size: 14px; color: #9ca3af;" />
                            <span style="font-size: 10px; font-weight: 700; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em;">Recent Log Analysis</span>
                        </div>
                        <p style="font-size: 12px; font-style: italic; color: #d1d5db; line-height: 1.4; margin: 0;">
                            "All 128 administrative actions validated against signed session tokens."
                        </p>
                    </div>
                </div>

                <!-- Widget 3: AI Permission Audit (Indigo) -->
                <div class="widget-card blue">
                    <div class="d-flex align-center" style="gap: 8px; margin-bottom: 12px;">
                        <MudIcon Icon="@Icons.Material.Filled.FlashOn" Style="color: #ffffff; font-size: 20px;" />
                        <span style="font-size: 16px; font-weight: 700; color: #ffffff;">AI Permission Audit</span>
                    </div>
                    <p style="font-size: 13px; line-height: 1.5; color: #e0e7ff; margin-bottom: 20px; font-weight: 500;">
                        I noticed 2 users haven't accessed their high-privilege seats in over 30 days. Would you like to review their access?
                    </p>
                    <div class="d-flex align-center" style="gap: 1.25rem;">
                        <button class="audit-link-btn underline">Run Audit</button>
                        <button class="audit-link-btn">Dismiss</button>
                    </div>
                </div>
            </div>
        </MudItem>
    </MudGrid>
</div>

<InviteUserSheet Open="@_inviteSheetOpen"
                 OpenChanged="@(value => _inviteSheetOpen = value)"
                 InviteSubmitted="InviteUserAsync"
                 AvailableRoles="@AvailableRoleNames"
                 IsSubmitting="@_isInviting" />

<EntitySheet Open="@_quotaSheetOpen"
             OpenChanged="@(value => _quotaSheetOpen = value)"
             Title="Daily token quota"
             Subtitle="Configure UC16 per-user daily token limits and warning state."
             Width="520px">
    <ChildContent>
        <MudStack Spacing="3">
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                Quota updates should be persisted to user_quota_overrides or an equivalent Supabase table and written to audit_logs.
            </MudAlert>
            <MudTextField Value="@_quotaEdit.UserName" Label="User" Variant="Variant.Outlined" ReadOnly="true" />
            <MudNumericField T="int" Value="@_quotaEdit.DailyTokenQuota" ValueChanged="OnQuotaValueChanged" Label="Daily token quota" Variant="Variant.Outlined" Min="1000" Step="1000" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Current usage: @_quotaEdit.TokensUsedToday.ToString("N0") tokens today</MudText>
            <MudProgressLinear Value="@_quotaEdit.UsagePercent" Color="@GetQuotaProgressColor(_quotaEdit.UsagePercent)" Rounded="true" Size="Size.Large" />
            <MudStack Row="true" Spacing="1" Style="flex-wrap: wrap;">
                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="@(() => SetQuotaPreset(25000))">Student preset</MudButton>
                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="@(() => SetQuotaPreset(75000))">Admin preset</MudButton>
                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="@(() => SetQuotaPreset(150000))">Temporary boost</MudButton>
            </MudStack>
            @if (_quotaEdit.UsagePercent >= 100)
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled">This user has exceeded the proposed quota and should be throttled or boosted.</MudAlert>
            }
            else if (_quotaEdit.UsagePercent >= 85)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">This user is approaching the proposed quota.</MudAlert>
            }
        </MudStack>
    </ChildContent>
    <FooterContent>
        <MudButton Variant="Variant.Text" OnClick="CloseQuotaSheetAsync">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveQuotaAsync">
            Save quota
        </MudButton>
    </FooterContent>
</EntitySheet>

@code {
    private const string StudentRole = "Student";
    private const string AdminRole = "Admin";
    private const string ModeratorRole = "Moderator";
    private const string ActiveStatus = "Active";
    private const string InactiveStatus = "Inactive";
    private const string QuotaNormal = "Normal";
    private const string QuotaWarning = "Warning";
    private const string QuotaExceeded = "Exceeded";
    private static readonly Guid CurrentAdminId = Guid.Parse("a8b3e2f7-1b99-401c-b558-1ba1ea5568e8");

    private readonly List<UserRow> _users = new();
    private readonly List<RoleOption> _roles = new();
    private bool _isLoading = true;
    private bool _inviteSheetOpen;
    private bool _quotaSheetOpen;
    private bool _isInviting;
    private string? _searchText;
    private string? _selectedRole;
    private string? _selectedStatus;
    private string? _selectedQuotaRisk;
    private string? _errorMessage;
    private QuotaEditModel _quotaEdit = new();

    private IEnumerable<UserRow> FilteredUsers => _users
        .Where(MatchesRole)
        .Where(MatchesStatus)
        .Where(MatchesQuotaRisk)
        .Where(MatchesSearch)
        .OrderByDescending(user => IsCurrentAdmin(user))
        .ThenByDescending(user => user.TokenUsagePercent)
        .ThenBy(user => user.FullName);

    private IReadOnlyList<string> AvailableRoleNames => _roles
        .Select(role => role.RoleName)
        .Where(role => !string.IsNullOrWhiteSpace(role))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(role => role.Equals(AdminRole, StringComparison.OrdinalIgnoreCase) ? 0 : 1)
        .ThenBy(role => role)
        .ToList();

    private IEnumerable<string> ActiveFilters
    {
        get
        {
            if (!string.IsNullOrWhiteSpace(_selectedRole))
            {
                yield return $"Role: {_selectedRole}";
            }

            if (!string.IsNullOrWhiteSpace(_selectedStatus))
            {
                yield return $"Status: {_selectedStatus}";
            }

            if (!string.IsNullOrWhiteSpace(_selectedQuotaRisk))
            {
                yield return $"Quota: {_selectedQuotaRisk}";
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadRolesAsync();
            _users.AddRange(BuildSeedUsers());
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to load users or roles: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadRolesAsync()
    {
        var roles = await Roles.ListAsync();
        _roles.Clear();
        _roles.AddRange(roles.Select(role => new RoleOption(role.RoleName, role.Description)));

        if (_roles.Count == 0)
        {
            _roles.AddRange(BuildFallbackRoles());
        }
    }

    private Task OnSearchChanged(string? value)
    {
        _searchText = value;
        return Task.CompletedTask;
    }

    private Task OnRoleChanged(string? value)
    {
        _selectedRole = value;
        return Task.CompletedTask;
    }

    private Task OnStatusChanged(string? value)
    {
        _selectedStatus = value;
        return Task.CompletedTask;
    }

    private Task OnQuotaRiskChanged(string? value)
    {
        _selectedQuotaRisk = value;
        return Task.CompletedTask;
    }

    private Task RemoveFilterAsync(string filter)
    {
        if (filter.StartsWith("Role:", StringComparison.OrdinalIgnoreCase))
        {
            _selectedRole = null;
        }
        else if (filter.StartsWith("Status:", StringComparison.OrdinalIgnoreCase))
        {
            _selectedStatus = null;
        }
        else if (filter.StartsWith("Quota:", StringComparison.OrdinalIgnoreCase))
        {
            _selectedQuotaRisk = null;
        }

        return Task.CompletedTask;
    }

    private Task ClearFiltersAsync()
    {
        _selectedRole = null;
        _selectedStatus = null;
        _selectedQuotaRisk = null;
        return Task.CompletedTask;
    }

    private void ApplyQuotaRiskFilter()
    {
        _selectedQuotaRisk = QuotaWarning;
    }

    private bool MatchesRole(UserRow user)
    {
        return string.IsNullOrWhiteSpace(_selectedRole)
            || user.Role.Equals(_selectedRole, StringComparison.OrdinalIgnoreCase);
    }

    private bool IsRoleChangeDisabled(UserRow user, string targetRole)
    {
        return user.Role.Equals(targetRole, StringComparison.OrdinalIgnoreCase)
            || (IsCurrentAdmin(user) && !targetRole.Equals(AdminRole, StringComparison.OrdinalIgnoreCase));
    }

    private static string GetRoleIcon(string role)
    {
        return role.Equals(AdminRole, StringComparison.OrdinalIgnoreCase)
            ? Icons.Material.Filled.AdminPanelSettings
            : Icons.Material.Filled.Badge;
    }

    private bool MatchesStatus(UserRow user)
    {
        return _selectedStatus switch
        {
            ActiveStatus => user.IsActive,
            InactiveStatus => !user.IsActive,
            _ => true
        };
    }

    private bool MatchesQuotaRisk(UserRow user)
    {
        return _selectedQuotaRisk switch
        {
            QuotaNormal => user.TokenUsagePercent < 85,
            QuotaWarning => user.TokenUsagePercent >= 85 && user.TokenUsagePercent < 100,
            QuotaExceeded => user.TokenUsagePercent >= 100,
            _ => true
        };
    }

    private bool MatchesSearch(UserRow user)
    {
        if (string.IsNullOrWhiteSpace(_searchText))
        {
            return true;
        }

        var text = _searchText.Trim();
        return user.FullName.Contains(text, StringComparison.OrdinalIgnoreCase)
            || user.Email.Contains(text, StringComparison.OrdinalIgnoreCase)
            || user.StudentCode.Contains(text, StringComparison.OrdinalIgnoreCase);
    }

    private void OpenInviteSheet() => _inviteSheetOpen = true;

    private async Task InviteUserAsync(InviteUserSheet.InviteUserRequest request)
    {
        _isInviting = true;
        await Task.Delay(500);

        _users.Insert(0, new UserRow
        {
            Id = Guid.NewGuid(),
            FullName = request.FullName,
            Email = request.Email,
            StudentCode = request.StudentCode,
            Role = request.Role,
            AvatarUrl = string.Empty,
            CreatedAt = DateTime.UtcNow,
            LastActiveAt = DateTime.UtcNow,
            IsActive = true,
            DailyTokenQuota = request.DailyTokenQuota,
            TokensUsedToday = 0,
            DocumentCount = 0
        });

        _isInviting = false;
        Snackbar.Add($"Invitation prepared for {request.Email} and audit log queued.", Severity.Success);
    }

    private void OpenDetails(UserRow user)
    {
        Navigation.NavigateTo($"/admin/users/{user.Id}");
    }

    private async Task ChangeRoleAsync(UserRow user, string targetRole)
    {
        if (!AvailableRoleNames.Contains(targetRole, StringComparer.OrdinalIgnoreCase))
        {
            Snackbar.Add($"Role '{targetRole}' is not present in the database roles list.", Severity.Error);
            return;
        }

        if (IsCurrentAdmin(user) && !targetRole.Equals(AdminRole, StringComparison.OrdinalIgnoreCase))
        {
            Snackbar.Add("You cannot demote your own administrator account.", Severity.Error);
            return;
        }

        if (user.Role.Equals(targetRole, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        var parameters = new DialogParameters
        {
            ["Title"] = "Change user role",
            ["Message"] = $"Change {user.FullName} from {user.Role} to {targetRole}? This affects authorization claims and should be audited.",
            ["ConfirmText"] = "Change role",
            ["ConfirmColor"] = Color.Warning,
            ["IconColor"] = Color.Warning,
            ["Icon"] = Icons.Material.Filled.AdminPanelSettings
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Change user role", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            var previousRole = user.Role;
            user.Role = targetRole;
            if (targetRole.Equals(AdminRole, StringComparison.OrdinalIgnoreCase) && user.DailyTokenQuota < 75_000)
            {
                user.DailyTokenQuota = 75_000;
            }

            Snackbar.Add($"{user.FullName} changed from {previousRole} to {targetRole}. Audit log entry queued.", Severity.Success);
        }
    }

    private async Task ToggleActiveAsync(UserRow user)
    {
        if (IsCurrentAdmin(user) && user.IsActive)
        {
            Snackbar.Add("You cannot deactivate your own administrator account.", Severity.Error);
            return;
        }

        if (!user.IsActive)
        {
            user.IsActive = true;
            Snackbar.Add($"{user.FullName} has been activated.", Severity.Success);
            return;
        }

        var parameters = new DialogParameters
        {
            ["Title"] = "Deactivate user",
            ["Message"] = $"Deactivate {user.FullName}? They will lose access until an administrator restores the account.",
            ["ConfirmText"] = "Deactivate",
            ["ConfirmationText"] = user.Email,
            ["ConfirmColor"] = Color.Error
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Deactivate user", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            user.IsActive = false;
            Snackbar.Add($"{user.FullName} has been deactivated and audit log entry queued.", Severity.Warning);
        }
    }

    private void OpenQuotaSheet(UserRow user)
    {
        _quotaEdit = QuotaEditModel.FromUser(user);
        _quotaSheetOpen = true;
    }

    private Task CloseQuotaSheetAsync()
    {
        _quotaSheetOpen = false;
        _quotaEdit = new QuotaEditModel();
        return Task.CompletedTask;
    }

    private void OnQuotaValueChanged(int value)
    {
        _quotaEdit.DailyTokenQuota = value;
    }

    private void SetQuotaPreset(int value)
    {
        _quotaEdit.DailyTokenQuota = value;
    }

    private async Task SaveQuotaAsync()
    {
        if (_quotaEdit.DailyTokenQuota <= 0)
        {
            Snackbar.Add("Daily token quota must be greater than zero.", Severity.Error);
            return;
        }

        var user = _users.FirstOrDefault(item => item.Id == _quotaEdit.UserId);
        if (user is null)
        {
            Snackbar.Add("User no longer exists in the current result set.", Severity.Error);
            return;
        }

        if (_quotaEdit.DailyTokenQuota < user.TokensUsedToday)
        {
            var parameters = new DialogParameters
            {
                ["Title"] = "Quota below current usage",
                ["Message"] = $"The proposed quota is below today's usage for {user.FullName}. The user may be throttled immediately.",
                ["ConfirmText"] = "Save quota",
                ["ConfirmColor"] = Color.Warning,
                ["IconColor"] = Color.Warning,
                ["Icon"] = Icons.Material.Filled.DataUsage
            };

            var dialog = await DialogService.ShowAsync<ConfirmDialog>("Confirm quota change", parameters);
            var result = await dialog.Result;
            if (result is not { Canceled: false })
            {
                return;
            }
        }

        user.DailyTokenQuota = _quotaEdit.DailyTokenQuota;
        _quotaSheetOpen = false;
        Snackbar.Add($"Daily token quota updated for {user.FullName}. Audit log entry queued.", Severity.Success);
    }

    private static bool IsCurrentAdmin(UserRow user) => user.Id == CurrentAdminId;

    private static string GetQuotaLabel(UserRow user)
    {
        return user.TokenUsagePercent >= 100 ? QuotaExceeded : user.TokenUsagePercent >= 85 ? QuotaWarning : QuotaNormal;
    }

    private static Color GetRoleColor(string role)
    {
        return role.Equals(AdminRole, StringComparison.OrdinalIgnoreCase)
            ? Color.Error
            : Color.Primary;
    }

    private static Color GetQuotaChipColor(double usagePercent)
    {
        return usagePercent >= 100 ? Color.Error : usagePercent >= 85 ? Color.Warning : Color.Success;
    }

    private static Color GetQuotaProgressColor(double usagePercent)
    {
        return usagePercent >= 100 ? Color.Error : usagePercent >= 85 ? Color.Warning : Color.Success;
    }

