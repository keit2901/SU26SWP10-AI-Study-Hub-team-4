@namespace AI_Study_Hub_v2.Components.Admin.Users
@page "/admin/users"
@layout AdminLayout
@using Microsoft.AspNetCore.Components
@using MudBlazor
@using AI_Study_Hub_v2.Components.Admin.Shared
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IRoleCatalogService Roles
@inject AuthSessionState Session
@inject AdminApiClient AdminApi

<div class="admin-users-page page-enter">
    <!-- Breadcrumbs & Header -->
    <div class="d-flex justify-space-between align-center mb-6 flex-wrap" style="gap: 1rem;">
        <div>
            <div class="d-flex align-center mb-1" style="gap: 0.5rem; font-size: 12px; font-weight: 500; font-family: 'Hanken Grotesk', sans-serif;">
                <span style="color: #767586;">Operations</span>
                <span style="color: #c7c6d5;">&gt;</span>
                <span style="color: #4648d4;">Users &amp; Permissions</span>
            </div>
            <h2 class="text-[32px] font-extrabold text-on-background" style="font-size: 28px; font-weight: 800; color: #191c1e; font-family: 'Hanken Grotesk', sans-serif; line-height: 1.2;">Users &amp; Permissions</h2>
            <p class="text-body-md text-on-surface-variant mt-1" style="font-size: 14px; color: #575e72; font-family: 'Hanken Grotesk', sans-serif;">Manage team access levels, moderate student accounts, and configure RBAC policies.</p>
        </div>
        <div class="d-flex align-center" style="gap: 0.75rem;">
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Outlined.Download" Disabled="true" Class="export-report-btn" Style="border-radius: 8px; font-weight: 700; text-transform: none; color: #c7c6d5; border-color: #c7c6d5; background-color: #f7f9fb; font-size: 13px;">
                Export not available
            </MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.PersonAddAlt" OnClick="OpenInviteSheet" Class="add-new-user-btn" Style="background-color: #4648d4; color: #ffffff; border-radius: 8px; font-weight: 700; text-transform: none; font-size: 13px;">
                Add New User
            </MudButton>
        </div>
    </div>

    <!-- Tab Switcher -->
    <div class="d-flex mb-6" style="gap: 0; border-bottom: 2px solid #e0e3e5;">
        <button class="tab-btn @(!_showHighUsageTab ? "tab-active" : "")" @onclick="() => _showHighUsageTab = false"
                style="padding: 10px 20px; border: none; background: none; font-size: 14px; font-weight: 600; cursor: pointer; border-bottom: @(!_showHighUsageTab ? "2px solid #4648d4" : "2px solid transparent"); color: @(!_showHighUsageTab ? "#4648d4" : "#767586"); margin-bottom: -2px;">
            All Users
        </button>
        <button class="tab-btn @(_showHighUsageTab ? "tab-active" : "")" @onclick="() => _showHighUsageTab = true"
                style="padding: 10px 20px; border: none; background: none; font-size: 14px; font-weight: 600; cursor: pointer; border-bottom: @(_showHighUsageTab ? "2px solid #4648d4" : "2px solid transparent"); color: @(_showHighUsageTab ? "#4648d4" : "#767586"); margin-bottom: -2px;">
            High-usage Users
        </button>
    </div>

    @if (_showHighUsageTab)
    {
        @* High-usage Users view *@
        @if (!_users.Any(u => u.TokenUsagePercent >= 85))
        {
            <div class="d-flex flex-column align-center justify-center py-10" style="text-align: center; gap: 0.75rem;">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Style="font-size: 32px; color: #16a34a;" />
                <div class="font-bold text-lg" style="color: #191c1e;">No high-usage users yet.</div>
                <div class="text-sm" style="color: #767586; max-width: 360px;">Users will appear here when they reach 85% of their daily token quota.</div>
            </div>
        }
        else
        {
            <MudAlert Severity="Severity.Warning" Class="mb-4" Variant="Variant.Outlined">
                Users at or above 85% of daily token quota. Review and adjust quotas as needed.
            </MudAlert>

            <div class="document-table-container">
                <table class="document-table">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Role</th>
                            <th>Used Today</th>
                            <th>Quota</th>
                            <th>Usage %</th>
                            <th>Remaining</th>
                            <th>Status</th>
                            <th style="width: 80px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in _users.Where(u => u.TokenUsagePercent >= 85).OrderByDescending(u => u.TokenUsagePercent))
                        {
                            <tr>
                                <td>
                                    <div class="doc-name-cell">
                                        <div class="doc-avatar pdf" style="width: 32px; height: 32px; font-size: 12px;">
                                            @user.FullName[0]
                                        </div>
                                        <div>
                                            <div class="doc-title-text" style="font-size: 13px;">@user.FullName</div>
                                            <div class="doc-meta-text">@user.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="subject-pill">@user.Role</span></td>
                                <td>@user.TokensUsedToday.ToString("N0")</td>
                                <td>@user.DailyTokenQuota.ToString("N0")</td>
                                <td>
                                    <div class="d-flex align-center" style="gap: 6px;">
                                        <span style="font-weight: 700; font-size: 13px;">@($"{user.TokenUsagePercent:0}%")</span>
                                        <div style="flex: 1; height: 6px; background: #eceef0; border-radius: 3px; min-width: 60px;">
                                            <div style="height: 100%; border-radius: 3px; background: @(user.TokenUsagePercent >= 95 ? "#ba1a1a" : "#d97706"); width: @($"{user.TokenUsagePercent}%");"></div>
                                        </div>
                                    </div>
                                </td>
                                <td>@((user.DailyTokenQuota - user.TokensUsedToday).ToString("N0"))</td>
                                <td>
                                    <span class="moderation-badge @(user.TokenUsagePercent >= 95 ? "rejected" : "pending")" style="background-color: @(user.TokenUsagePercent >= 95 ? "rgba(186,26,26,0.08)" : "rgba(217,119,6,0.08)"); color: @(user.TokenUsagePercent >= 95 ? "#ba1a1a" : "#d97706");">
                                        @(user.TokenUsagePercent >= 95 ? "Critical" : "Warning")
                                    </span>
                                </td>
                                <td>
                                    <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="@(() => OpenQuotaSheet(user))" Style="text-transform:none;font-size:11px;">
                                        Adjust quota
                                    </MudButton>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
    else
    {
    <!-- KPI Grid -->
    <div class="kpi-grid-container mb-6">
        <!-- Card 1: Users Loaded -->
        @{
            var activeAdminCount = _users.Count(u => u.Role.Equals(AdminRole, StringComparison.OrdinalIgnoreCase) && u.IsActive);
            var inactiveCount = _users.Count(u => !u.IsActive);
        }
        <div class="kpi-card-custom">
            <div class="d-flex justify-space-between align-start" style="width: 100%;">
                <div>
                    <span class="kpi-label">USERS SHOWN</span>
                    <div class="kpi-value">@_users.Count.ToString("N0")</div>
                    @if (_users.Count == 0)
                    {
            <span class="kpi-subtext mt-2">No users loaded yet.</span>
                    }
                </div>
                <div class="kpi-icon-circle blue">
                    <MudIcon Icon="@Icons.Material.Outlined.People" />
                </div>
            </div>
        </div>

        <!-- Card 2: Active Admins -->
        <div class="kpi-card-custom">
            <div class="d-flex justify-space-between align-start" style="width: 100%;">
                <div>
                    <span class="kpi-label">ACTIVE ADMINS</span>
                    <div class="kpi-value">@activeAdminCount.ToString("N0")</div>
                    <span class="kpi-subtext mt-2">@(activeAdminCount == 0 ? "No active admins yet." : "Privileged accounts")</span>
                </div>
                <div class="kpi-icon-circle purple">
                    <MudIcon Icon="@Icons.Material.Outlined.Shield" />
                </div>
            </div>
        </div>

        <!-- Card 3: Pending Invites -->
        <div class="kpi-card-custom muted">
            <div class="d-flex justify-space-between align-start" style="width: 100%;">
                <div>
                    <span class="kpi-label" style="color: #9ca3af;">PENDING INVITES</span>
                    <div class="kpi-value" style="font-size: 20px; color: #9ca3af;">&mdash;</div>
                    <span class="kpi-subtext mt-2" style="color: #9ca3af;">Invite data is not available.</span>
                </div>
                <div class="kpi-icon-circle slate" style="opacity: 0.4;">
                    <MudIcon Icon="@Icons.Material.Outlined.Mail" />
                </div>
            </div>
        </div>

        <!-- Card 4: Inactive Users -->
        <div class="kpi-card-custom">
            <div class="d-flex justify-space-between align-start" style="width: 100%;">
                <div>
                    <span class="kpi-label">INACTIVE USERS</span>
                    <div class="kpi-value">@inactiveCount.ToString("N0")</div>
                    <span class="kpi-subtext mt-2">@(inactiveCount == 0 ? "No inactive users yet." : "Deactivated accounts")</span>
                </div>
                <div class="kpi-icon-circle red">
                    <MudIcon Icon="@Icons.Material.Outlined.Block" />
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content Layout (Table & Widgets) -->
    <MudGrid>
        <!-- Table Column -->
        <MudItem xs="12" lg="8">
            <!-- Search & Filters -->
            <div class="filter-row-custom mb-6">
                <div class="search-input-wrapper">
                    <MudIcon Icon="@Icons.Material.Filled.Search" Class="search-icon" />
                    <input type="text" placeholder="Search by name, email, or user" value="@_searchText" @oninput="OnSearchInputChanged" class="search-input" />
                </div>
                
                <select class="filter-select" value="@_selectedRole" @onchange="OnRoleSelectChanged">
                    <option value="">All Roles</option>
                    @foreach (var role in AvailableRoleNames)
                    {
                        <option value="@role">@role</option>
                    }
                </select>

                <select class="filter-select" value="@_selectedStatus" @onchange="OnStatusSelectChanged">
                    <option value="">Status</option>
                    <option value="@ActiveStatus">Active</option>
                    <option value="@InactiveStatus">Inactive</option>
                </select>

                @{
                    var hasActiveFilters = !string.IsNullOrWhiteSpace(_searchText)
                        || !string.IsNullOrWhiteSpace(_selectedRole)
                        || !string.IsNullOrWhiteSpace(_selectedStatus)
                        || !string.IsNullOrWhiteSpace(_selectedQuotaRisk);
                    var filterIconColor = hasActiveFilters ? "#575e72" : "#c7c6d5";
                    var filterIconStyle = $"font-size: 18px; color: {filterIconColor};";
                }
                <button class="filter-btn @(hasActiveFilters ? "" : "muted")" @onclick="ClearFiltersAsync" disabled="@(!hasActiveFilters)" title="@(hasActiveFilters ? "Clear all filters" : "No filters active")">
                    <MudIcon Icon="@Icons.Material.Outlined.FilterAltOff" Style="@filterIconStyle" />
                </button>
            </div>

            <!-- Custom Table -->
            <div class="users-table-container mb-6">
                @if (_isLoading)
                {
                    <div class="pa-6">
                        <MudSkeleton Height="44px" Animation="Animation.Wave" />
                        <MudSkeleton Height="44px" Animation="Animation.Wave" />
                        <MudSkeleton Height="44px" Animation="Animation.Wave" />
                    </div>
                }
                else if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="ma-4">
                        @_errorMessage
                    </MudAlert>
                }
                else if (!FilteredUsers.Any())
                {
                    <div class="d-flex flex-column align-center justify-center py-10" style="text-align: center; gap: 0.5rem;">
                        <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Secondary" />
                        <div class="font-bold text-lg" style="color: #191c1e;">No users found</div>
                        <div class="text-sm" style="color: #767586;">Try changing filters or invite a new user.</div>
                        <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary" OnClick="ClearFiltersAsync" Style="text-transform: none; font-size: 12px; margin-top: 0.5rem;">Clear filters</MudButton>
                    </div>
                }
                else
                {
                    <table class="users-table">
                        <thead>
                            <tr>
                                <th>USER</th>
                                <th>ROLE</th>
                                <th>PERMISSIONS</th>
                                <th>LAST ACTIVE</th>
                                <th style="width: 50px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in FilteredUsers)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-center" style="gap: 0.75rem;">
                                            @if (!string.IsNullOrEmpty(user.AvatarUrl))
                                            {
                                                <img src="@user.AvatarUrl" class="user-avatar-img" />
                                            }
                                            else
                                            {
                                                <span class="user-avatar-initials @(user.Role.ToLower())">@user.Initials</span>
                                            }
                                            <div>
                                                <div class="user-name">
                                                    @user.FullName
                                                    @if (IsCurrentAdmin(user))
                                                    {
                                                        <MudTooltip Text="Current user">
                                                            <span class="user-badge-you">You</span>
                                                        </MudTooltip>
                                                    }
                                                </div>
                                                <div class="user-email">@user.Email</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="role-badge @(user.Role.ToLower())">@user.Role.ToUpper()</span>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-1 flex-wrap">
                                            @foreach (var perm in GetPermissionsList(user.Role))
                                            {
                                                <span class="perm-badge">@perm</span>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <span class="last-active-text">@FormatLastActive(user.LastActiveAt)</span>
                                    </td>
                                    <td>
                                        <MudMenu Dense="true" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                                            <ActivatorContent>
                                                <MudIconButton Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Style="color: #767586; padding: 4px;" />
                                            </ActivatorContent>
                                            <ChildContent>
                                                <MudMenuItem Icon="@Icons.Material.Filled.Visibility" OnClick="@(() => OpenDetails(user))">View details</MudMenuItem>
                                                <MudMenuItem Icon="@Icons.Material.Filled.DataUsage" OnClick="@(() => OpenQuotaSheet(user))">Edit quota</MudMenuItem>
                                                @foreach (var role in AvailableRoleNames.Where(role => !role.Equals(user.Role, StringComparison.OrdinalIgnoreCase)))
                                                {
                                                    <MudMenuItem Icon="@GetRoleIcon(role)" Disabled="@IsRoleChangeDisabled(user, role)" OnClick="@(() => ChangeRoleAsync(user, role))">Change role to @role</MudMenuItem>
                                                }
                                                @if (user.IsActive)
                                                {
                                                    <MudMenuItem Icon="@Icons.Material.Filled.Block" Disabled="@IsCurrentAdmin(user)" OnClick="@(() => ToggleActiveAsync(user))">Deactivate</MudMenuItem>
                                                }
                                                else
                                                {
                                                    <MudMenuItem Icon="@Icons.Material.Filled.CheckCircle" OnClick="@(() => ToggleActiveAsync(user))">Activate</MudMenuItem>
                                                }
                                            </ChildContent>
                                        </MudMenu>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <div class="users-table-footer">
                        <span class="footer-count">Showing @FilteredUsers.Count() of @TotalUsersCount users</span>
                    </div>
                }
            </div>

            <!-- Guardrail alert banner -->
            <div class="p-3 rounded-lg d-flex gap-2 align-center mb-6" style="background-color: #fffdf5; border: 1px solid rgba(245, 158, 11, 0.15); border-radius: 0.5rem;">
                <MudIcon Icon="@Icons.Material.Filled.Info" Style="color: #d97706; font-size: 18px; flex-shrink: 0;" />
                <span style="color: #92400e; font-size: 12px; line-height: 1.4;">
                    <strong>Guardrail:</strong> Admins cannot deactivate or demote themselves. All role, status and quota changes are audited.
                </span>
                <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Warning" Style="flex-shrink: 0; text-transform: none; font-size: 11px; margin-left: auto;" OnClick="NavigateToAuditLogs">
                    View audit logs
                </MudButton>
            </div>
        </MudItem>

        <!-- Widgets Column -->
        <MudItem xs="12" lg="4">
            <div class="d-flex flex-column" style="gap: 1.5rem;">
                <!-- Widget 1: Permission Matrix -->
                <div class="widget-card">
                    <div class="d-flex align-center justify-space-between mb-4">
                        <div class="d-flex align-center" style="gap: 8px;">
                            <MudIcon Icon="@Icons.Material.Outlined.Shield" Style="color: #4648d4; font-size: 20px;" />
                            <span style="font-size: 16px; font-weight: 700; color: #191c1e;">Permission Matrix</span>
                        </div>
                    </div>
                    <div class="d-flex flex-column align-center justify-center py-6" style="text-align: center; gap: 0.5rem;">
                        <span style="font-size: 14px; color: #767586;">&mdash;</span>
                        <span style="font-size: 12px; color: #9ca3af;">RBAC data is not available.</span>
                    </div>
                </div>

                <!-- Widget 2: Automated Security Scans -->
                <div class="widget-card dark">
                    <div class="d-flex align-center" style="gap: 8px; margin-bottom: 16px;">
                        <MudIcon Icon="@Icons.Material.Outlined.VerifiedUser" Style="color: #10b981; font-size: 20px;" />
                        <span style="font-size: 16px; font-weight: 700; color: #ffffff;">Automated Security Scans</span>
                    </div>
                    <div class="d-flex flex-column align-center justify-center py-6" style="text-align: center; gap: 0.5rem;">
                        <span style="font-size: 14px; color: #6b7280;">&mdash;</span>
                        <span style="font-size: 12px; color: #6b7280;">Scan data is not available.</span>
                    </div>
                </div>

                <!-- Widget 3: AI Permission Audit -->
                <div class="widget-card blue">
                    <div class="d-flex align-center" style="gap: 8px; margin-bottom: 12px;">
                        <MudIcon Icon="@Icons.Material.Filled.FlashOn" Style="color: #ffffff; font-size: 20px;" />
                        <span style="font-size: 16px; font-weight: 700; color: #ffffff;">AI Permission Audit</span>
                    </div>
                    <div class="d-flex flex-column align-center justify-center py-4" style="text-align: center; gap: 0.5rem;">
                        <span style="font-size: 14px; color: #c7d2fe;">&mdash;</span>
                        <span style="font-size: 12px; color: #a5b4fc;">Audit data is not available.</span>
                    </div>
                </div>
            </div>
        </MudItem>
    </MudGrid>
    }
</div>

<InviteUserSheet Open="@_inviteSheetOpen"
                 OpenChanged="@(value => _inviteSheetOpen = value)"
                 InviteSubmitted="InviteUserAsync"
                 AvailableRoles="@AvailableRoleNames"
                 IsSubmitting="@_isInviting" />

<EntitySheet Open="@_quotaSheetOpen"
             OpenChanged="@(value => _quotaSheetOpen = value)"
             Title="Daily token quota"
             Subtitle="Configure UC16 per-user daily token limits and warning state."
             Width="520px">
    <ChildContent>
        <MudStack Spacing="3">
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                Quota updates should be persisted to user_quota_overrides or an equivalent Supabase table and written to audit_logs.
            </MudAlert>
            <MudTextField Value="@_quotaEdit.UserName" Label="User" Variant="Variant.Outlined" ReadOnly="true" />
            <MudNumericField T="int" Value="@_quotaEdit.DailyTokenQuota" ValueChanged="OnQuotaValueChanged" Label="Daily token quota" Variant="Variant.Outlined" Min="1000" Step="1000" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Current usage: @_quotaEdit.TokensUsedToday.ToString("N0") tokens today</MudText>
            <MudProgressLinear Value="@_quotaEdit.UsagePercent" Color="@GetQuotaProgressColor(_quotaEdit.UsagePercent)" Rounded="true" Size="Size.Large" />
            <MudStack Row="true" Spacing="1" Style="flex-wrap: wrap;">
                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="@(() => SetQuotaPreset(25000))">Student preset</MudButton>
                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="@(() => SetQuotaPreset(75000))">Admin preset</MudButton>
                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="@(() => SetQuotaPreset(150000))">Temporary boost</MudButton>
            </MudStack>
            @if (_quotaEdit.UsagePercent >= 100)
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled">This user has exceeded the proposed quota and should be throttled or boosted.</MudAlert>
            }
            else if (_quotaEdit.UsagePercent >= 85)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">This user is approaching the proposed quota.</MudAlert>
            }
        </MudStack>
    </ChildContent>
    <FooterContent>
        <MudButton Variant="Variant.Text" OnClick="CloseQuotaSheetAsync">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveQuotaAsync">
            Save quota
        </MudButton>
    </FooterContent>
</EntitySheet>

@code {
    private const string StudentRole = "Student";
    private const string AdminRole = "Admin";
    private const string ModeratorRole = "Moderator";
    private const string ActiveStatus = "Active";
    private const string InactiveStatus = "Inactive";
    private const string QuotaNormal = "Normal";
    private const string QuotaWarning = "Warning";
    private const string QuotaExceeded = "Exceeded";
    private readonly List<UserRow> _users = new();
    private readonly List<RoleOption> _roles = new();
    private bool _showHighUsageTab;
    private bool _isLoading = true;
    private bool _inviteSheetOpen;
    private bool _quotaSheetOpen;
    private bool _isInviting;
    private string? _searchText;
    private string? _selectedRole;
    private string? _selectedStatus;
    private string? _selectedQuotaRisk;
    private string? _errorMessage;
    private Guid? _processingUserId;
    private QuotaEditModel _quotaEdit = new();

    private IEnumerable<UserRow> FilteredUsers => _users
        .Where(MatchesRole)
        .Where(MatchesStatus)
        .Where(MatchesQuotaRisk)
        .Where(MatchesSearch)
        .OrderByDescending(user => IsCurrentAdmin(user))
        .ThenByDescending(user => user.TokenUsagePercent)
        .ThenBy(user => user.FullName);

    private IReadOnlyList<string> AvailableRoleNames => _roles
        .Select(role => role.RoleName)
        .Where(role => !string.IsNullOrWhiteSpace(role))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(role => role.Equals(AdminRole, StringComparison.OrdinalIgnoreCase) ? 0 : 1)
        .ThenBy(role => role)
        .ToList();

    private IEnumerable<string> ActiveFilters
    {
        get
        {
            if (!string.IsNullOrWhiteSpace(_selectedRole))
            {
                yield return $"Role: {_selectedRole}";
            }

            if (!string.IsNullOrWhiteSpace(_selectedStatus))
            {
                yield return $"Status: {_selectedStatus}";
            }

            if (!string.IsNullOrWhiteSpace(_selectedQuotaRisk))
            {
                yield return $"Quota: {_selectedQuotaRisk}";
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadRolesAsync();
            await LoadUsersAsync();

            var uri = new Uri(Navigation.Uri);
            var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
            if (query["quota"] == "warning")
            {
                _showHighUsageTab = true;
                _selectedQuotaRisk = QuotaWarning;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to load users or roles: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadUsersAsync()
    {
        if (!Session.IsAuthenticated || string.IsNullOrWhiteSpace(Session.AccessToken)) return;

        var users = await AdminApi.ListUsersAsync(Session.AccessToken);
        _users.Clear();
        foreach (var dto in users)
        {
            _users.Add(new UserRow
            {
                Id = dto.Id,
                FullName = dto.FullName,
                Email = dto.Username,
                Role = dto.Role,
                IsActive = dto.IsActive,
                DailyTokenQuota = (int)dto.DailyTokenQuota,
                TokensUsedToday = (int)dto.TokensUsedToday,
                DocumentCount = dto.DocumentCount,
                CreatedAt = dto.CreatedAt.UtcDateTime,
                LastActiveAt = dto.CreatedAt.UtcDateTime
            });
        }
    }

    private async Task LoadRolesAsync()
    {
