@namespace AI_Study_Hub_v2.Components.Admin.Users
@page "/admin/users/{Id:guid}"
@layout AdminLayout
@using Microsoft.AspNetCore.Components
@using MudBlazor
@using AI_Study_Hub_v2.Components.Admin.Shared
@using AI_Study_Hub_v2.Dtos
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject AdminApiClient AdminApi
@inject AuthSessionState Session

@if (_isLoading)
{
    <MudStack Spacing="3" Class="page-enter">
        <MudSkeleton Height="120px" Animation="Animation.Wave" />
        <MudSkeleton Height="360px" Animation="Animation.Wave" />
    </MudStack>
}
else if (!string.IsNullOrWhiteSpace(_errorMessage) || _user is null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
        @_errorMessage
    </MudAlert>
}
else
{
    <MudStack Spacing="4" Class="user-detail-page page-enter">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="flex-wrap: wrap; gap: 1rem;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudAvatar Size="Size.Large" Color="Color.Primary">@_user.Initials</MudAvatar>
                <div>
                    <MudText Typo="Typo.overline" Color="Color.Secondary">Profile detail</MudText>
                    <MudText Typo="Typo.h4">@_user.FullName</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@_user.Email</MudText>
                </div>
            </MudStack>
            <MudStack Row="true" Spacing="1" Style="flex-wrap: wrap;">
                <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="BackToUsers">Back</MudButton>
                <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Edit" OnClick="EditUser">Edit</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Warning" StartIcon="@Icons.Material.Filled.LockReset" OnClick="ResetPasswordAsync">Reset password</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.Block" Disabled="@(!_user.IsActive)" OnClick="DeactivateAsync">Deactivate</MudButton>
            </MudStack>
        </MudStack>

        <MudGrid>
            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="detail-card">
                    <MudText Typo="Typo.caption">Role</MudText>
                    <MudText Typo="Typo.h5">@_user.Role</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="detail-card">
                    <MudText Typo="Typo.caption">Student code</MudText>
                    <MudText Typo="Typo.h5">@DisplayValue(_user.StudentCode)</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="detail-card">
                    <MudText Typo="Typo.caption">Status</MudText>
                    <MudText Typo="Typo.h5">@(_user.IsActive ? "Active" : "Inactive")</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudPaper Elevation="0" Class="detail-tabs-card">
            <MudTabs Rounded="true" Elevation="0" TabPanelsClass="pa-4">
                <MudTabPanel Text="Overview" Icon="@Icons.Material.Filled.AccountCircle">
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <MudList T="string" Dense="true">
                                <MudListSubheader>Profile fields</MudListSubheader>
                                <MudListItem Text="ID" SecondaryText="@_user.Id.ToString()" />
                                <MudListItem Text="Full name" SecondaryText="@_user.FullName" />
                                <MudListItem Text="Email" SecondaryText="@_user.Email" />
                                <MudListItem Text="Created at" SecondaryText="@FormatDateTime(_user.CreatedAt)" />
                            </MudList>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudPaper Elevation="0" Class="pa-3" Style="border:1px solid rgba(199,196,215,0.3); border-radius:8px;">
                                <MudAlert Severity="@(_user.IsActive ? Severity.Success : Severity.Error)" Variant="Variant.Outlined">
                                    Status: @(_user.IsActive ? "Active" : "Inactive")
                                </MudAlert>
                                <MudText Typo="Typo.caption" Class="mt-3">Role</MudText>
                                <MudText Typo="Typo.body2" Style="font-weight:600;">@_user.Role</MudText>
                                <MudText Typo="Typo.caption" Class="mt-2">Student Code</MudText>
                                <MudText Typo="Typo.body2" Style="color:#767586;">@(_user.StudentCode ?? "Not assigned")</MudText>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

                <MudTabPanel Text="Documents" Icon="@Icons.Material.Filled.Description">
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">Document details are not yet available for individual users.</MudAlert>
                </MudTabPanel>

                <MudTabPanel Text="Activity" Icon="@Icons.Material.Filled.History">
                    @if (_isActivityLoading)
                    {
                        <MudSkeleton Height="40px" Animation="Animation.Wave" />
                        <MudSkeleton Height="40px" Animation="Animation.Wave" />
                        <MudSkeleton Height="40px" Animation="Animation.Wave" />
                    }
                    else if (!_activities.Any())
                    {
                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">No activity recorded for this user.</MudAlert>
                    }
                    else
                    {
                        <MudTimeline Class="activity-timeline">
                            @foreach (var activity in _activities)
                            {
                                <MudTimelineItem Color="@GetActivityColor(activity)" Icon="@GetActivityIcon(activity)">
                                    <MudText Typo="Typo.subtitle2">@activity.Action</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@activity.EntityType @activity.EntityId</MudText>
                                    <MudText Typo="Typo.caption">@FormatDateTime(activity.CreatedAt.UtcDateTime)</MudText>
                                </MudTimelineItem>
                            }
                        </MudTimeline>
                    }
                </MudTabPanel>
            </MudTabs>
        </MudPaper>
    </MudStack>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private UserDetailRow? _user;
    private bool _isLoading = true;
    private string? _errorMessage;
    private List<AuditLogDto> _activities = new();
    private bool _isActivityLoading;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (!Session.IsAuthenticated || string.IsNullOrWhiteSpace(Session.AccessToken))
            {
                _errorMessage = "Authentication required.";
                return;
            }

            var users = await AdminApi.ListUsersAsync(Session.AccessToken);
            var dto = users.FirstOrDefault(u => u.Id == Id);
            if (dto is null)
            {
                _errorMessage = "User not found.";
                return;
            }

            _user = new UserDetailRow
            {
                Id = dto.Id,
                FullName = dto.FullName,
                Email = dto.Username,
                StudentCode = string.Empty,
                Role = dto.Role,
                CreatedAt = dto.CreatedAt.UtcDateTime,
                IsActive = dto.IsActive
            };

            await LoadActivityAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to load user detail: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void BackToUsers() => Navigation.NavigateTo("/admin/users");

    private void EditUser()
    {
        Snackbar.Add("Edit profile is not yet implemented.", Severity.Info);
    }

    private async Task ResetPasswordAsync()
    {
        if (_user is null) return;

        var parameters = new DialogParameters
        {
            ["Title"] = "Reset password",
            ["Message"] = $"Send a password reset link to {_user.Email}?",
            ["ConfirmText"] = "Send link",
            ["ConfirmColor"] = Color.Warning,
            ["IconColor"] = Color.Warning,
            ["Icon"] = Icons.Material.Filled.LockReset
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Reset password", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            Snackbar.Add($"Password reset is not yet implemented.", Severity.Info);
        }
    }

    private async Task DeactivateAsync()
    {
        if (_user is null || _user.Id == (Session.CurrentUser?.Id ?? Guid.Empty))
        {
            Snackbar.Add("You cannot deactivate your own account.", Severity.Error);
            return;
        }

        var parameters = new DialogParameters
        {
            ["Title"] = "Deactivate user",
            ["Message"] = $"Deactivate {_user.FullName}? This prevents future access until restored.",
            ["ConfirmText"] = "Deactivate",
            ["ConfirmationText"] = _user.Email,
            ["ConfirmColor"] = Color.Error
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Deactivate user", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            try
            {
                var token = Session.AccessToken;
                if (string.IsNullOrWhiteSpace(token))
                {
                    Snackbar.Add("Authentication required.", Severity.Error);
                    return;
                }

                await AdminApi.ToggleActiveAsync(token, _user.Id, false);
                _user.IsActive = false;
                Snackbar.Add($"{_user.FullName} has been deactivated.", Severity.Warning);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Failed to deactivate: {ex.Message}", Severity.Error);
            }
        }
    }

    private static string DisplayValue(string value) => string.IsNullOrWhiteSpace(value) ? "Not assigned" : value;

    private static string FormatDate(DateTime value) => value.ToString("MMM dd, yyyy");

    private static string FormatDateTime(DateTime value) => value.ToLocalTime().ToString("MMM dd, yyyy HH:mm");

    private async Task LoadActivityAsync()
    {
        _isActivityLoading = true;
        try
        {
            if (Session.IsAuthenticated && !string.IsNullOrWhiteSpace(Session.AccessToken))
            {
                var logs = await AdminApi.ListAuditLogsAsync(Session.AccessToken, actorUserId: Id, limit: 50);
                _activities = logs.ToList();
            }
        }
        catch { }
        finally { _isActivityLoading = false; }
    }

    private static Color GetActivityColor(AuditLogDto log) => log.Severity == "High" ? Color.Error : log.Severity == "Medium" ? Color.Warning : Color.Info;

    private static string GetActivityIcon(AuditLogDto log) => log.Action switch
    {
        "USER_REGISTERED" => Icons.Material.Filled.PersonAdd,
        "USER_LOCK" or "USER_UNLOCK" => Icons.Material.Filled.Lock,
        "ROLE_CHANGE" => Icons.Material.Filled.AdminPanelSettings,
        "QUOTA_UPDATE" => Icons.Material.Filled.DataUsage,
        "DOCUMENT_UPLOADED" => Icons.Material.Filled.UploadFile,
        _ => Icons.Material.Filled.History
    };

    private static Color GetDocumentColor(string status)
    {
        return status switch
        {
            "Indexed" => Color.Success,
            "Processing" => Color.Warning,
            "Rejected" => Color.Error,
            _ => Color.Default
        };
    }

    private sealed class UserDetailRow
    {
        public Guid Id { get; set; }
        public string FullName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string StudentCode { get; set; } = string.Empty;
        public string Role { get; set; } = string.Empty;
        public DateTime CreatedAt { get; set; }
        public bool IsActive { get; set; }

        public string Initials => string.Join(string.Empty, FullName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .Select(part => part[0]))
            .ToUpperInvariant();
    }
}

<style>
    .page-enter {
        animation: pageRise .42s ease both;
    }

    .detail-card,
    .detail-tabs-card {
        border-radius: 24px;
        border: 1px solid rgba(15, 118, 110, .12);
        background: rgba(255, 252, 246, .88);
    }

    .detail-card {
        padding: 1.25rem;
    }

    .activity-timeline {
        max-width: 760px;
    }

    @@keyframes pageRise {
        from {
            opacity: 0;
            transform: translateY(14px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
