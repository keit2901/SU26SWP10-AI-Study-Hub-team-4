@namespace AI_Study_Hub_v2.Components.Admin.Community
@using Microsoft.AspNetCore.Components

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudAvatar Color="@DecisionColor" Variant="Variant.Filled" Size="Size.Large">
                <MudIcon Icon="@DecisionIcon" />
            </MudAvatar>
            <div>
                <MudText Typo="Typo.h5">@Decision report</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">@FolderName</MudText>
            </div>
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                Reporter reason: @ReporterReason
            </MudAlert>
            <MudTextField T="string"
                          @bind-Value="_resolution"
                          Label="Resolution note"
                          Placeholder="Explain the review outcome"
                          Lines="4"
                          Immediate="true"
                          Counter="2000"
                          MaxLength="2000"
                          Required="true"
                          Variant="Variant.Outlined" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="@DecisionColor"
                   Variant="Variant.Filled"
                   Disabled="@string.IsNullOrWhiteSpace(_resolution)"
                   OnClick="Confirm">
            @Decision
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string FolderName { get; set; } = string.Empty;
    [Parameter] public string ReporterReason { get; set; } = string.Empty;
    [Parameter] public string Decision { get; set; } = "Resolved";

    private string _resolution = string.Empty;

    private Color DecisionColor => Decision == "Resolved" ? Color.Success : Color.Warning;

    private string DecisionIcon => Decision == "Resolved"
        ? Icons.Material.Filled.CheckCircle
        : Icons.Material.Filled.Cancel;

    private void Confirm() => MudDialog.Close(DialogResult.Ok(_resolution.Trim()));

    private void Cancel() => MudDialog.Cancel();
}
