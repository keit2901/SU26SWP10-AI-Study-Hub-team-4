@namespace AI_Study_Hub_v2.Components.Admin.Documents
@page "/admin/documents"
@layout AdminLayout
@using Microsoft.AspNetCore.Components
@using MudBlazor
@using AI_Study_Hub_v2.Components.Admin.Shared
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<div class="documents-page page-enter">
    <!-- Breadcrumbs & Header -->
    <div class="d-flex justify-space-between align-center mb-6 flex-wrap" style="gap: 1rem;">
        <div>
            <div class="breadcrumb-custom mb-1">
                <span class="crumb-parent">Console</span>
                <span class="crumb-separator">/</span>
                <span class="crumb-active">Document Library</span>
            </div>
            <h2 class="text-headline-lg font-headline-lg text-on-surface" style="font-size: 28px; font-weight: 800; color: #191c1e; font-family: 'Hanken Grotesk', sans-serif; line-height: 1.2;">Document Library</h2>
            <p class="text-body-md text-on-surface-variant mt-1" style="font-size: 14px; color: #575e72; font-family: 'Hanken Grotesk', sans-serif;">Manage and monitor the health of your RAG knowledge base. Ensure all academic materials are correctly indexed for the AI tutor system.</p>
        </div>
        <div class="d-flex align-center" style="gap: 0.75rem;">
            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Tune" OnClick="OpenModerationQueue" Class="moderation-queue-btn" Style="border-radius: 8px; font-weight: 700; text-transform: none; color: #575e72; background-color: #eceef0; font-size: 13px; box-shadow: none;">
                Moderation Queue
            </MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.UploadFile" OnClick="OpenRegisterSheet" Class="register-doc-btn" Style="background-color: #4648d4; color: #ffffff; border-radius: 8px; font-weight: 700; text-transform: none; font-size: 13px;">
                Register Document
            </MudButton>
        </div>
    </div>

    <!-- KPI Grid -->
    <div class="kpi-grid-container mb-6">
        <!-- Total Documents -->
        <div class="kpi-card-custom">
            <div class="kpi-card-top">
                <div class="kpi-icon-circle violet">
                    <MudIcon Icon="@Icons.Material.Filled.Folder" Size="Size.Small" />
                </div>
                <span class="kpi-trend violet">+12%</span>
            </div>
            <div class="kpi-card-bottom">
                <span class="kpi-label">TOTAL DOCUMENTS</span>
                <div class="kpi-value">@TotalDocumentsCount.ToString("N0")</div>
                <div class="kpi-progress-bar">
                    <div class="kpi-progress-fill violet" style="width: 85%"></div>
                </div>
            </div>
        </div>

        <!-- Indexed -->
        <div class="kpi-card-custom">
            <div class="kpi-card-top">
                <div class="kpi-icon-circle violet">
                    <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" />
                </div>
                <span class="kpi-trend violet">93.8%</span>
            </div>
            <div class="kpi-card-bottom">
                <span class="kpi-label">INDEXED</span>
                <div class="kpi-value">@IndexedCount.ToString("N0")</div>
                <div class="kpi-progress-bar">
                    <div class="kpi-progress-fill violet" style="width: 93.8%"></div>
                </div>
            </div>
        </div>

        <!-- Needs Attention -->
        <div class="kpi-card-custom">
            <div class="kpi-card-top">
                <div class="kpi-icon-circle red">
                    <MudIcon Icon="@Icons.Material.Filled.PriorityHigh" Size="Size.Small" />
                </div>
                <span class="kpi-trend red">Action Req.</span>
            </div>
            <div class="kpi-card-bottom">
                <span class="kpi-label">NEEDS ATTENTION</span>
                <div class="kpi-value">@NeedsAttentionCount.ToString("N0")</div>
                <div class="kpi-progress-bar">
                    <div class="kpi-progress-fill red" style="width: 20%"></div>
                </div>
            </div>
        </div>

        <!-- Failed Jobs -->
        <div class="kpi-card-custom">
            <div class="kpi-card-top">
                <div class="kpi-icon-circle grey">
                    <MudIcon Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" />
                </div>
                <span class="kpi-trend grey">Critical</span>
            </div>
            <div class="kpi-card-bottom">
                <span class="kpi-label">FAILED JOBS</span>
                <div class="kpi-value">@FailedCount.ToString("N0")</div>
                <div class="kpi-progress-bar">
                    <div class="kpi-progress-fill grey" style="width: 10%"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Search & Filters -->
    <div class="filter-row-custom mb-6">
        <div class="search-input-wrapper">
            <MudIcon Icon="@Icons.Material.Filled.Search" Class="search-icon" />
            <input type="text" placeholder="Search title, owner, or subject..." value="@_searchText" @oninput="OnSearchInputChanged" class="search-input" />
        </div>
        
        <select class="filter-select" value="@_selectedProcessingStatus" @onchange="OnProcessingStatusSelectChanged">
            <option value="">Processing Status</option>
            @foreach (var status in _documents.Select(d => d.ProcessingStatus).Distinct().OrderBy(s => s))
            {
                <option value="@status">@GetProcessingText(status)</option>
            }
        </select>

        <select class="filter-select" value="@_selectedModerationStatus" @onchange="OnModerationStatusSelectChanged">
            <option value="">Moderation</option>
            @foreach (var status in _documents.Select(d => d.ModerationStatus).Distinct().OrderBy(s => s))
            {
                <option value="@status">@GetModerationText(status)</option>
            }
        </select>

        <select class="filter-select" value="@_selectedSubject" @onchange="OnSubjectSelectChanged">
            <option value="">Subject</option>
            @foreach (var subject in _documents.Select(d => d.SubjectCode).Distinct().OrderBy(s => s))
            {
                <option value="@subject">@subject</option>
            }
        </select>

        <button class="filter-btn" @onclick="ClearFiltersAsync">
            <MudIcon Icon="@Icons.Material.Filled.Tune" Style="font-size: 18px; color: #575e72;" />
        </button>
    </div>

    <!-- Custom Data Grid -->
    <div class="document-table-container mb-6">
        @if (_isLoading)
        {
            <div class="pa-6">
                <MudSkeleton Height="44px" Animation="Animation.Wave" />
                <MudSkeleton Height="44px" Animation="Animation.Wave" />
                <MudSkeleton Height="44px" Animation="Animation.Wave" />
            </div>
        }
        else if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="ma-4">
                @_errorMessage
            </MudAlert>
        }
        else if (!FilteredDocuments.Any())
        {
            <div class="d-flex flex-column align-center justify-center py-10" style="text-align: center; gap: 0.5rem;">
                <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Large" Color="Color.Secondary" />
                <div class="font-bold text-lg" style="color: #191c1e;">No documents match the current filters</div>
                <div class="text-sm" style="color: #767586;">Clear filters or register a document.</div>
            </div>
        }
        else
        {
            <table class="document-table">
                <thead>
                    <tr>
                        <th>DOCUMENT NAME</th>
                        <th>SUBJECT</th>
                        <th>OWNER</th>
                        <th>PROCESSING</th>
                        <th>MODERATION</th>
                        <th style="width: 80px;">ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var doc in PagedDocuments)
                    {
                        <tr>
                            <td>
                                <div class="doc-name-cell">
                                    <div class="doc-avatar @GetFileAvatarClass(doc.FileType)">
                                        <MudIcon Icon="@GetFileIcon(doc.FileType)" />
                                    </div>
                                    <div>
                                        <div class="doc-title-text">@doc.Title</div>
                                        <div class="doc-meta-text">@doc.FileSizeMb.ToString("N1") MB · Uploaded @GetAgeLabel(doc.CreatedAt)</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="subject-pill">@doc.SubjectCode</span>
                            </td>
                            <td>
                                <div class="owner-name">@doc.OwnerName</div>
                                <div class="owner-email">@doc.OwnerEmail</div>
                            </td>
                            <td>
                                <div class="processing-status @GetProcessingClass(doc.ProcessingStatus)">
                                    @if (doc.ProcessingStatus == ProcessingProcessing)
                                    {
                                        <span class="status-dot-blue"></span>
                                    }
                                    else if (doc.ProcessingStatus == IndexedProcessing)
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.CheckCircleOutline" Style="font-size: 16px;" />
                                    }
                                    else if (doc.ProcessingStatus == FailedProcessing)
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.HighlightOff" Style="font-size: 16px;" />
                                    }
                                    <span>@GetProcessingText(doc.ProcessingStatus)</span>
                                </div>
                            </td>
                            <td>
                                <span class="moderation-badge @GetModerationClass(doc.ModerationStatus)">
                                    @GetModerationText(doc.ModerationStatus)
                                </span>
                            </td>
                            <td>
                                <MudMenu Dense="true" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                                    <ActivatorContent>
                                        <button class="filter-btn" style="border: none; background: transparent; width: 32px; height: 32px; margin: 0 auto;">
                                            <MudIcon Icon="@Icons.Material.Filled.MoreVert" Style="font-size: 20px; color: #575e72;" />
                                        </button>
                                    </ActivatorContent>
                                    <ChildContent>
                                        <MudMenuItem Icon="@Icons.Material.Filled.Visibility" OnClick="@(() => OpenDetails(doc))">View details</MudMenuItem>
                                        <MudMenuItem Icon="@Icons.Material.Filled.Gavel" Disabled="@(!CanModerate(doc))" OnClick="OpenModerationQueue">Open moderation</MudMenuItem>
                                        <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="@(() => EditDocument(doc))">Edit metadata</MudMenuItem>
                                        <MudMenuItem Icon="@Icons.Material.Filled.Sync" Disabled="@(doc.ModerationStatus != ApprovedModeration)" OnClick="@(() => ReindexDocumentAsync(doc))">Re-index</MudMenuItem>
                                        <MudMenuItem Icon="@Icons.Material.Filled.Delete" OnClick="@(() => RemoveDocumentAsync(doc))">Remove record</MudMenuItem>
                                    </ChildContent>
                                </MudMenu>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- Pagination Row -->
            <div class="pagination-bar-custom">
                <div class="pagination-info">
                    @GetPaginationText()
                </div>
                <div class="pagination-buttons">
                    <button class="pagination-btn" disabled="@(_currentPage <= 1)" @onclick="(() => GoToPage(_currentPage - 1))">Previous</button>
                    @for (int i = 1; i <= _totalPages; i++)
                    {
                        var pageNum = i;
                        <button class="pagination-btn @(pageNum == _currentPage ? "active" : "")" @onclick="(() => GoToPage(pageNum))">@pageNum</button>
                    }
                    <button class="pagination-btn" disabled="@(_currentPage >= _totalPages)" @onclick="(() => GoToPage(_currentPage + 1))">Next</button>
                </div>
            </div>
        }
    </div>

    <!-- Bottom Status Footer -->
    <div class="bottom-status-footer mb-6">
        <div class="indexing-progress-wrapper">
            <span class="indexing-label">Background Indexing in Progress</span>
            <div class="indexing-progress-bar">
                <div class="indexing-progress-fill" style="width: 65%"></div>
            </div>
            <span class="indexing-percentage">65%</span>
        </div>
        <div class="db-status-badge">
            <span class="db-status-dot"></span>
            <span class="db-status-text">DATABASE STATUS OPERATIONAL</span>
        </div>
        <div class="last-updated-text">
            Last Updated: 14:32:01
        </div>
    </div>
</div>

<EntitySheet Open="@_documentSheetOpen"
             OpenChanged="@(value => _documentSheetOpen = value)"
             Title="@DocumentSheetTitle"
             Subtitle="Edit document metadata used by search, moderation, and retrieval pipelines."
             Width="540px">
    <ChildContent>
        <MudForm @ref="_form" @bind-IsValid="_isFormValid">
            <MudStack Spacing="3">
                <MudTextField @bind-Value="_editingDocument.Title" Label="Title" Variant="Variant.Outlined" Required="true" RequiredError="Title is required" />
                <MudSelect T="string" @bind-Value="_editingDocument.SubjectCode" Label="Subject" Variant="Variant.Outlined" Required="true">
                    <MudSelectItem T="string" Value="@("SWP391")">SWP391</MudSelectItem>
                    <MudSelectItem T="string" Value="@("PRN212")">PRN212</MudSelectItem>
                    <MudSelectItem T="string" Value="@("DBI202")">DBI202</MudSelectItem>
                    <MudSelectItem T="string" Value="@("SWT301")">SWT301</MudSelectItem>
                    <MudSelectItem T="string" Value="@("CS402")">CS402</MudSelectItem>
                    <MudSelectItem T="string" Value="@("MATH101")">MATH101</MudSelectItem>
                    <MudSelectItem T="string" Value="@("PHYS205")">PHYS205</MudSelectItem>
                </MudSelect>
                <MudTextField @bind-Value="_editingDocument.OwnerName" Label="Owner name" Variant="Variant.Outlined" Required="true" />
                <MudTextField @bind-Value="_editingDocument.OwnerEmail" Label="Owner email" Variant="Variant.Outlined" InputType="InputType.Email" Required="true" />
                <MudSelect T="string" @bind-Value="_editingDocument.ProcessingStatus" Label="Processing status" Variant="Variant.Outlined" Required="true">
                    <MudSelectItem T="string" Value="@PendingProcessing">Pending</MudSelectItem>
                    <MudSelectItem T="string" Value="@ProcessingProcessing">Processing</MudSelectItem>
                    <MudSelectItem T="string" Value="@IndexedProcessing">Indexed</MudSelectItem>
                    <MudSelectItem T="string" Value="@FailedProcessing">Failed</MudSelectItem>
                </MudSelect>
                <MudSelect T="string" @bind-Value="_editingDocument.ModerationStatus" Label="Moderation status" Variant="Variant.Outlined" Required="true">
                    <MudSelectItem T="string" Value="@PendingModeration">Pending Review</MudSelectItem>
                    <MudSelectItem T="string" Value="@ApprovedModeration">Approved</MudSelectItem>
                    <MudSelectItem T="string" Value="@ReportedModeration">Reported</MudSelectItem>
                    <MudSelectItem T="string" Value="@RejectedModeration">Rejected</MudSelectItem>
                    <MudSelectItem T="string" Value="@RemovedModeration">Removed</MudSelectItem>
                </MudSelect>
                <MudTextField @bind-Value="_editingDocument.StoragePath" Label="Storage path" Variant="Variant.Outlined" Required="true" />
                <MudTextField @bind-Value="_editingDocument.TagsCsv" Label="Tags" Variant="Variant.Outlined" Placeholder="rag, supabase, project" />
                <HumanCheck @ref="_humanCheck" Action="admin-document-edit" ValidChanged="OnHumanCheckChanged" />
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                    Use Document Moderation for approve/reject/remove decisions that require owner notification and audit log details.
                </MudAlert>
            </MudStack>
        </MudForm>
    </ChildContent>
    <FooterContent>
        <MudButton Variant="Variant.Text" OnClick="CloseSheetAsync">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Save" Disabled="@(!_isFormValid || !_humanCheckValid)" OnClick="SaveDocumentAsync">
            Save document
        </MudButton>
    </FooterContent>
</EntitySheet>

@code {
    private const string PendingProcessing = "Pending";
    private const string ProcessingProcessing = "Processing";
    private const string IndexedProcessing = "Indexed";
    private const string FailedProcessing = "Failed";
    private const string PendingModeration = "Pending Review";
    private const string ApprovedModeration = "Approved";
    private const string ReportedModeration = "Reported";
    private const string RejectedModeration = "Rejected";
    private const string RemovedModeration = "Removed";

    private readonly List<DocumentRow> _documents = new();
    private bool _isLoading = true;
    private bool _documentSheetOpen;
    private bool _isFormValid;
    private string? _searchText;
    private string? _selectedProcessingStatus;
    private string? _selectedModerationStatus;
    private string? _selectedSubject;
    private string? _errorMessage;
    private MudForm? _form;
    private HumanCheck? _humanCheck;
    private bool _humanCheckValid;
    private DocumentEditModel _editingDocument = DocumentEditModel.New();

    private string DocumentSheetTitle => _editingDocument.Id == Guid.Empty ? "Register document" : "Edit document";

    private IEnumerable<DocumentRow> FilteredDocuments => _documents
        .Where(MatchesProcessingStatus)
        .Where(MatchesModerationStatus)
        .Where(MatchesSubject)
        .Where(MatchesSearch)
        .OrderByDescending(document => document.ModerationStatus is PendingModeration or ReportedModeration)
        .ThenByDescending(document => document.CreatedAt);

    private IEnumerable<DocumentRow> PagedDocuments => FilteredDocuments
        .Skip((_currentPage - 1) * _pageSize)
        .Take(_pageSize);

    private int _currentPage = 1;
    private int _pageSize = 10;

    private int _totalPages => Math.Max(1, (int)Math.Ceiling((double)FilteredDocuments.Count() / _pageSize));

    // Dynamic counts with mockup fallback
    private int TotalDocumentsCount => string.IsNullOrEmpty(_searchText) && string.IsNullOrEmpty(_selectedProcessingStatus) && string.IsNullOrEmpty(_selectedModerationStatus) && string.IsNullOrEmpty(_selectedSubject)
        ? 1482
        : FilteredDocuments.Count();

    private int IndexedCount => string.IsNullOrEmpty(_searchText) && string.IsNullOrEmpty(_selectedProcessingStatus) && string.IsNullOrEmpty(_selectedModerationStatus) && string.IsNullOrEmpty(_selectedSubject)
        ? 1390
        : FilteredDocuments.Count(d => d.ProcessingStatus == IndexedProcessing);

    private int NeedsAttentionCount => string.IsNullOrEmpty(_searchText) && string.IsNullOrEmpty(_selectedProcessingStatus) && string.IsNullOrEmpty(_selectedModerationStatus) && string.IsNullOrEmpty(_selectedSubject)
        ? 18
        : FilteredDocuments.Count(d => d.ModerationStatus is PendingModeration or ReportedModeration);

    private int FailedCount => string.IsNullOrEmpty(_searchText) && string.IsNullOrEmpty(_selectedProcessingStatus) && string.IsNullOrEmpty(_selectedModerationStatus) && string.IsNullOrEmpty(_selectedSubject)
        ? 4
        : FilteredDocuments.Count(d => d.ProcessingStatus == FailedProcessing);

    private string GetPaginationText()
    {
        var total = string.IsNullOrEmpty(_searchText) && string.IsNullOrEmpty(_selectedProcessingStatus) && string.IsNullOrEmpty(_selectedModerationStatus) && string.IsNullOrEmpty(_selectedSubject)
            ? 1482
            : FilteredDocuments.Count();
        
        var start = (_currentPage - 1) * _pageSize + 1;
        var end = Math.Min(_currentPage * _pageSize, total);
        if (total == 0) return "Showing 0-0 of 0 results";
        return $"Showing {start}-{end} of {total:N0} results";
    }

    private void GoToPage(int page)
    {
        _currentPage = Math.Clamp(page, 1, _totalPages);
    }

    protected override void OnInitialized()
    {
        try
        {
            _documents.AddRange(BuildSeedDocuments());
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to load documents: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private Task OnSearchInputChanged(ChangeEventArgs e)
    {
        _searchText = e.Value?.ToString();
        _currentPage = 1;
        return Task.CompletedTask;
    }

    private Task OnProcessingStatusSelectChanged(ChangeEventArgs e)
    {
        _selectedProcessingStatus = e.Value?.ToString();
        _currentPage = 1;
        return Task.CompletedTask;
    }

    private Task OnModerationStatusSelectChanged(ChangeEventArgs e)
    {
        _selectedModerationStatus = e.Value?.ToString();
        _currentPage = 1;
        return Task.CompletedTask;
    }

    private Task OnSubjectSelectChanged(ChangeEventArgs e)
    {
        _selectedSubject = e.Value?.ToString();
        _currentPage = 1;
        return Task.CompletedTask;
    }

    private Task ClearFiltersAsync()
    {
        _searchText = null;
        _selectedProcessingStatus = null;
        _selectedModerationStatus = null;
        _selectedSubject = null;
        _currentPage = 1;
        return Task.CompletedTask;
    }

    private bool MatchesProcessingStatus(DocumentRow document)
    {
        return string.IsNullOrWhiteSpace(_selectedProcessingStatus)
            || document.ProcessingStatus.Equals(_selectedProcessingStatus, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesModerationStatus(DocumentRow document)
    {
        return string.IsNullOrWhiteSpace(_selectedModerationStatus)
            || document.ModerationStatus.Equals(_selectedModerationStatus, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesSubject(DocumentRow document)
    {
        return string.IsNullOrWhiteSpace(_selectedSubject)
            || document.SubjectCode.Equals(_selectedSubject, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesSearch(DocumentRow document)
    {
        if (string.IsNullOrWhiteSpace(_searchText))
        {
            return true;
        }

        var text = _searchText.Trim();
        return document.Title.Contains(text, StringComparison.OrdinalIgnoreCase)
            || document.OwnerName.Contains(text, StringComparison.OrdinalIgnoreCase)
            || document.OwnerEmail.Contains(text, StringComparison.OrdinalIgnoreCase)
            || document.SubjectCode.Contains(text, StringComparison.OrdinalIgnoreCase)
            || document.StoragePath.Contains(text, StringComparison.OrdinalIgnoreCase)
            || document.Tags.Any(tag => tag.Contains(text, StringComparison.OrdinalIgnoreCase));
    }

    private void OpenRegisterSheet()
    {
        _editingDocument = DocumentEditModel.New();
        _documentSheetOpen = true;
    }

    private void OpenModerationQueue()
    {
        Navigation.NavigateTo("/admin/documents/moderation");
    }

    private void OpenDetails(DocumentRow document)
    {
        Navigation.NavigateTo($"/admin/documents/{document.Id}");
    }

    private void EditDocument(DocumentRow document)
    {
        _editingDocument = DocumentEditModel.FromRow(document);
        _documentSheetOpen = true;
    }

    private async Task CloseSheetAsync()
    {
        _documentSheetOpen = false;
        _editingDocument = DocumentEditModel.New();
        if (_humanCheck is not null)
        {
            await _humanCheck.ResetAsync();
        }
    }

    private Task OnHumanCheckChanged(bool valid)
    {
        _humanCheckValid = valid;
        return Task.CompletedTask;
    }

    private async Task SaveDocumentAsync()
    {
        if (_form is null)
        {
            return;
        }

        await _form.ValidateAsync();
        var humanOk = _humanCheck is not null && await _humanCheck.ValidateAsync();
        if (!_form.IsValid || !humanOk)
        {
            return;
        }

        if (_editingDocument.Id == Guid.Empty)
        {
            _documents.Insert(0, _editingDocument.ToDocumentRow(DateTime.UtcNow));
            Snackbar.Add("Document registered and audit log entry queued.", Severity.Success);
        }
        else
        {
            var document = _documents.FirstOrDefault(item => item.Id == _editingDocument.Id);
            if (document is not null)
            {
                document.Title = _editingDocument.Title;
                document.SubjectCode = _editingDocument.SubjectCode;
                document.OwnerName = _editingDocument.OwnerName;
                document.OwnerEmail = _editingDocument.OwnerEmail;
                document.ProcessingStatus = _editingDocument.ProcessingStatus;
                document.ModerationStatus = _editingDocument.ModerationStatus;
                document.StoragePath = _editingDocument.StoragePath;
                document.Tags = ParseTags(_editingDocument.TagsCsv);
                Snackbar.Add("Document metadata saved and audit log entry queued.", Severity.Success);
            }
        }

        await CloseSheetAsync();
    }

    private async Task ReindexDocumentAsync(DocumentRow document)
    {
        var parameters = new DialogParameters
        {
            ["Title"] = "Re-index document",
            ["Message"] = $"Queue {document.Title} for chunking and embedding again? Existing vector rows may be replaced.",
            ["ConfirmText"] = "Queue re-index",
            ["ConfirmColor"] = Color.Warning,
            ["IconColor"] = Color.Warning,
            ["Icon"] = Icons.Material.Filled.Sync
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Re-index document", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            document.ProcessingStatus = ProcessingProcessing;
            Snackbar.Add($"{document.Title} queued for re-indexing.", Severity.Info);
        }
    }

    private async Task RemoveDocumentAsync(DocumentRow document)
    {
        var parameters = new DialogParameters
        {
            ["Title"] = "Remove document record",
            ["Message"] = $"Remove {document.Title} from the library view? Use moderation removal when owner notification and reason capture are required.",
            ["ConfirmText"] = "Remove",
            ["ConfirmationText"] = document.Title,
            ["ConfirmColor"] = Color.Error
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Remove document", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            _documents.Remove(document);
            Snackbar.Add($"{document.Title} removed from the library view.", Severity.Warning);
        }
    }

    private static bool CanModerate(DocumentRow document)
    {
        return document.ModerationStatus is PendingModeration or ReportedModeration or RejectedModeration;
    }

    private static string GetProcessingText(string status)
    {
        return status switch
        {
            IndexedProcessing => "Ready",
            ProcessingProcessing => "Indexing...",
            FailedProcessing => "Failed",
            PendingProcessing => "Pending",
            _ => status
        };
    }

    private static string GetProcessingClass(string status)
    {
        return status switch
        {
