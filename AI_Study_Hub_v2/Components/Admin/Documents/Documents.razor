        };
    }

    private static string GetAgeLabel(DateTime createdAt)
    {
        var diff = DateTime.UtcNow - createdAt;
        if (diff.TotalDays >= 2)
        {
            return $"{Math.Floor(diff.TotalDays)} days ago";
        }
        if (diff.TotalDays >= 1)
        {
            return "Yesterday";
        }
        if (diff.TotalHours >= 1)
        {
            return $"{Math.Floor(diff.TotalHours)}h ago";
        }
        if (diff.TotalMinutes >= 1)
        {
            return $"{Math.Floor(diff.TotalMinutes)}m ago";
        }
        return "Just now";
    }

