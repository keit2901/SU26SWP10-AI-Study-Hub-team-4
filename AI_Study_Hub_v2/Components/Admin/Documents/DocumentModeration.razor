@namespace AI_Study_Hub_v2.Components.Admin.Documents
@page "/admin/documents/moderation"
@layout AdminLayout
@using AI_Study_Hub_v2.Components.Admin.Shared
@using AI_Study_Hub_v2.Dtos
@using AI_Study_Hub_v2.Services
@using Microsoft.AspNetCore.Components
@using MudBlazor
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IDocumentModerationService ModerationService

<div class="admin-moderation-page page-enter">
    <!-- Breadcrumbs & Header -->
    <div class="d-flex justify-space-between align-center mb-6 flex-wrap" style="gap: 1rem;">
        <div>
            <h2 class="text-[32px] font-extrabold text-on-background" style="font-size: 28px; font-weight: 800; color: #191c1e; font-family: 'Hanken Grotesk', sans-serif; line-height: 1.2;">Document Moderation</h2>
            <p class="text-body-md text-on-surface-variant mt-1" style="font-size: 14px; color: #575e72; font-family: 'Hanken Grotesk', sans-serif;">Review pending and reported documents, inspect metadata, and approve safe uploads for indexing.</p>
        </div>
        <div class="d-flex align-center" style="gap: 0.75rem;">
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Outlined.Folder" OnClick="OpenDocumentLibrary" Class="document-library-btn" Style="border-radius: 8px; font-weight: 700; text-transform: none; color: #575e72; border-color: #c7c6d5; background-color: #ffffff; font-size: 13px;">
                Document Library
            </MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Refresh" OnClick="ReloadAsync" Class="refresh-queue-btn" Style="background-color: #4648d4; color: #ffffff; border-radius: 8px; font-weight: 700; text-transform: none; font-size: 13px;">
                Refresh Queue
            </MudButton>
        </div>
    </div>

    <!-- KPI Grid -->
    <div class="kpi-grid-container mb-6">
        <!-- Card 1: Pending Review -->
        <div class="kpi-card-custom">
            <div class="d-flex justify-space-between align-start" style="width: 100%;">
                <div>
                    <span class="kpi-label">Pending Review</span>
                    <div class="kpi-value">@GetCount(PendingStatus, 12)</div>
                    <span class="kpi-subtext mt-2">Awaiting admin decision</span>
                </div>
                <div class="kpi-icon-circle blue">
                    <MudIcon Icon="@Icons.Material.Outlined.AssignmentLate" />
                </div>
            </div>
        </div>

        <!-- Card 2: Reported -->
        <div class="kpi-card-custom">
            <div class="d-flex justify-space-between align-start" style="width: 100%;">
                <div>
                    <span class="kpi-label">Reported</span>
                    <div class="kpi-value">@GetCount(ReportedStatus, 5)</div>
                    <span class="kpi-subtext mt-2">User or policy flags</span>
                </div>
                <div class="kpi-icon-circle red">
                    <MudIcon Icon="@Icons.Material.Outlined.ReportProblem" />
                </div>
            </div>
        </div>

        <!-- Card 3: Rejected -->
        <div class="kpi-card-custom">
            <div class="d-flex justify-space-between align-start" style="width: 100%;">
                <div>
                    <span class="kpi-label">Rejected</span>
                    <div class="kpi-value">@GetCount(RejectedStatus, 48)</div>
                    <span class="kpi-subtext mt-2">Reason retained in logs</span>
                </div>
                <div class="kpi-icon-circle slate">
                    <MudIcon Icon="@Icons.Material.Outlined.Cancel" />
                </div>
            </div>
        </div>

        <!-- Card 4: Total Indexed -->
        <div class="kpi-card-custom">
            <div class="d-flex justify-space-between align-start" style="width: 100%;">
                <div>
                    <span class="kpi-label">Total Indexed</span>
                    <div class="kpi-value">1,248</div>
                    <span class="kpi-subtext mt-2">RAG ready documents</span>
                </div>
                <div class="kpi-icon-circle purple">
                    <MudIcon Icon="@Icons.Material.Outlined.Storage" />
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content Layout (Table & Inspection Panel) -->
    <MudGrid>
        <!-- Table Column -->
        <MudItem xs="12" lg="8">
            <!-- Search & Filters -->
            <div class="filter-row-custom mb-6">
                <div class="search-input-wrapper">
                    <MudIcon Icon="@Icons.Material.Filled.Search" Class="search-icon" />
                    <input type="text" placeholder="Search title, owner, or subject..." value="@_searchText" @oninput="OnSearchInputChanged" class="search-input" />
                </div>
                
                <select class="filter-select" value="@_selectedStatus" @onchange="OnStatusSelectChanged">
                    <option value="">All Queue</option>
                    <option value="@PendingStatus">@PendingStatus</option>
                    <option value="@ReportedStatus">@ReportedStatus</option>
                    <option value="@RejectedStatus">@RejectedStatus</option>
                </select>

                <select class="filter-select" value="@_selectedSeverity" @onchange="OnSeveritySelectChanged">
                    <option value="">Severity</option>
                    <option value="@HighSeverity">High</option>
                    <option value="@MediumSeverity">Medium</option>
                    <option value="@LowSeverity">Low</option>
                </select>

                <button class="filter-btn">
                    <MudIcon Icon="@Icons.Material.Filled.Tune" Style="font-size: 18px; color: #575e72;" />
                </button>
            </div>

            <!-- Custom Table -->
            <div class="moderation-table-container mb-6">
                @if (_isLoading)
                {
                    <div class="pa-6">
                        <MudSkeleton Height="44px" Animation="Animation.Wave" />
                        <MudSkeleton Height="44px" Animation="Animation.Wave" />
                        <MudSkeleton Height="44px" Animation="Animation.Wave" />
                    </div>
                }
                else if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="ma-4">
                        @_errorMessage
                    </MudAlert>
                }
                else if (!FilteredDocuments.Any())
                {
                    <div class="d-flex flex-column align-center justify-center py-10" style="text-align: center; gap: 0.5rem;">
                        <MudIcon Icon="@Icons.Material.Filled.Gavel" Size="Size.Large" Color="Color.Secondary" />
                        <div class="font-bold text-lg" style="color: #191c1e;">No documents need moderation</div>
                        <div class="text-sm" style="color: #767586;">Clear filters or upload a test document.</div>
                    </div>
                }
                else
                {
                    <table class="moderation-table">
                        <thead>
                            <tr>
                                <th>DOCUMENT</th>
                                <th>SUBJECT</th>
                                <th>OWNER</th>
                                <th>STATUS</th>
                                <th>RISK LEVEL</th>
                                <th style="width: 50px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var doc in FilteredDocuments)
                            {
                                <tr class="@(_selectedDocument?.Id == doc.Id ? "selected" : "")" @onclick="@(() => SelectDocumentAsync(doc))" style="cursor: pointer;">
                                    <td>
                                        <div class="d-flex align-center" style="gap: 0.75rem;">
                                            <div class="doc-icon-container @(doc.FileType.ToLower())">
                                                <MudIcon Icon="@GetFileIcon(doc.FileType)" Style="font-size: 18px;" />
                                            </div>
                                            <div style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 250px;">
                                                <div class="doc-title">@doc.Title</div>
                                                <div class="doc-path">@doc.StoragePath</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="subject-badge">@doc.SubjectCode</span>
                                    </td>
                                    <td>
                                        <div>
                                            <div class="owner-name">@doc.OwnerName</div>
                                            <div class="owner-email">@doc.OwnerEmail</div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="status-badge @(GetModerationClass(doc.ModerationStatus))">
                                            @GetModerationDisplay(doc.ModerationStatus)
                                        </span>
                                    </td>
                                    <td>
                                        <span class="risk-badge @(doc.Severity.ToLower())">@doc.Severity.ToUpper()</span>
                                    </td>
                                    <td @onclick:stopPropagation="true">
                                        <MudMenu Dense="true" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                                            <ActivatorContent>
                                                <MudIconButton Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Style="color: #767586; padding: 4px;" />
                                            </ActivatorContent>
                                            <ChildContent>
                                                <MudMenuItem Icon="@Icons.Material.Filled.Visibility" OnClick="@(() => SelectDocumentAsync(doc))">Preview</MudMenuItem>
                                                <MudMenuItem Icon="@Icons.Material.Filled.CheckCircle" Disabled="@(!CanApprove(doc))" OnClick="@(() => ModerateAsync(doc, ApprovedStatus))">Approve</MudMenuItem>
                                                <MudMenuItem Icon="@Icons.Material.Filled.Cancel" Disabled="@(doc.ModerationStatus == RemovedStatus)" OnClick="@(() => ModerateAsync(doc, RejectedStatus))">Reject with reason</MudMenuItem>
                                                <MudMenuItem Icon="@Icons.Material.Filled.DeleteForever" Disabled="@(doc.ModerationStatus == RemovedStatus)" OnClick="@(() => ModerateAsync(doc, RemovedStatus))">Remove with reason</MudMenuItem>
                                            </ChildContent>
                                        </MudMenu>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <div class="moderation-table-footer">
                        <span class="footer-count">Showing @FilteredDocuments.Count() of @TotalDocumentsCount moderation tasks</span>
                        <div class="footer-pagination">
                            <button class="pag-btn" disabled>&lt;</button>
                            <span class="pag-text">Page 1 of 3</span>
                            <button class="pag-btn">&gt;</button>
                        </div>
                    </div>
                }
            </div>
        </MudItem>

        <!-- Inspection Panel Column -->
        <MudItem xs="12" lg="4">
            <div class="inspection-panel-container">
                @if (_selectedDocument is null)
                {
                    <div class="d-flex flex-column align-center justify-center py-10" style="text-align: center; gap: 0.5rem; min-height: 480px; background: #ffffff; border: 1px solid rgba(199, 196, 215, 0.3); border-radius: 12px;">
                        <MudIcon Icon="@Icons.Material.Filled.Article" Size="Size.Large" Color="Color.Secondary" />
                        <div class="font-bold text-lg" style="color: #191c1e;">Select a document</div>
                        <div class="text-sm px-6" style="color: #767586;">Use Preview to inspect metadata, extracted text, report context, and moderation decisions.</div>
                    </div>
                }
                else
                {
                    <div class="inspection-card">
                        <!-- Panel Header -->
                        <div class="d-flex align-center justify-space-between mb-4">
                            <span class="inspection-header-label">INSPECTION PANEL</span>
                            <span class="inspection-status-badge @(GetModerationClass(_selectedDocument.ModerationStatus))">
                                @GetModerationDisplay(_selectedDocument.ModerationStatus)
                            </span>
                        </div>

                        <!-- Document Details -->
                        <div class="mb-4">
                            <h3 class="inspection-title">@_selectedDocument.Title</h3>
                            <div class="inspection-id">documentID: #@_selectedDocument.Id.ToString().Substring(0, 18)...</div>
                        </div>

                        <!-- Restricted Preview Box -->
                        <div class="restricted-preview-box mb-6">
                            <div class="lock-icon-circle mb-2">
                                <MudIcon Icon="@Icons.Material.Filled.Lock" Style="font-size: 24px; color: #191c1e;" />
                            </div>
                            <span class="restricted-text">RESTRICTED PREVIEW</span>
                        </div>

                        <!-- Metadata Fields -->
                        <div class="d-flex flex-column mb-6" style="gap: 16px; border-top: 1px solid #e0e3e5; padding-top: 16px;">
                            <div>
                                <span class="meta-label">OWNER</span>
                                <div class="meta-value">@_selectedDocument.OwnerName</div>
                            </div>
                            <div>
                                <span class="meta-label">FORMAT/SIZE</span>
                                <div class="meta-value">@(_selectedDocument.FileType.ToUpperInvariant()) / @_selectedDocument.FileSizeMb.ToString("N1") MB</div>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-flex flex-column" style="gap: 0.75rem;">
                            <button class="approve-btn" @onclick="@(() => ModerateAsync(_selectedDocument, ApprovedStatus))">
                                <MudIcon Icon="@Icons.Material.Outlined.VerifiedUser" Class="me-1" Style="font-size: 18px;" />
                                Approve &amp; Index
                            </button>
                            <div class="d-flex" style="gap: 0.75rem;">
                                <button class="action-outline-btn flex-1" @onclick="@(() => ModerateAsync(_selectedDocument, RejectedStatus))">
                                    <MudIcon Icon="@Icons.Material.Outlined.Cancel" Class="me-1" Style="font-size: 16px;" />
                                    Reject
                                </button>
                                <button class="action-outline-btn flex-1 remove" @onclick="@(() => ModerateAsync(_selectedDocument, RemovedStatus))">
                                    <MudIcon Icon="@Icons.Material.Outlined.Delete" Class="me-1" Style="font-size: 16px;" />
                                    Remove
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </MudItem>
    </MudGrid>
</div>

@code {
    private const string PendingStatus = "Pending Review";
    private const string ReportedStatus = "Reported";
    private const string ApprovedStatus = "Approved";
    private const string RejectedStatus = "Rejected";
    private const string RemovedStatus = "Removed";
    private const string NotificationQueued = "Queued";
    private const string FailedProcessing = "Failed";
    private const string HighSeverity = "High";
    private const string MediumSeverity = "Medium";
    private const string LowSeverity = "Low";

    private readonly List<ReviewDocumentRow> _documents = new();
    private bool _isLoading = true;
    private string? _searchText;
    private string? _selectedStatus;
    private string? _selectedSubject;
    private string? _selectedSeverity;
    private string? _errorMessage;
    private ReviewDocumentRow? _selectedDocument;

    private int GetCount(string status, int fallback)
    {
        return _documents.Count(document => document.ModerationStatus == status);
    }

    private int TotalDocumentsCount => _documents.Count;

    private string GetModerationClass(string status)
    {
        return status switch
        {
            PendingStatus => "pending",
            ReportedStatus => "reported",
            ApprovedStatus => "approved",
            RejectedStatus => "rejected",
            RemovedStatus => "removed",
            _ => "pending"
        };
    }

    private string GetModerationDisplay(string status)
    {
        if (status == PendingStatus) return "PENDING REVIEW";
        if (status == ReportedStatus) return "REPORTED";
        if (status == RejectedStatus) return "REJECTED";
        if (status == ApprovedStatus) return "APPROVED";
        if (status == RemovedStatus) return "REMOVED";
        return status.ToUpper();
    }

    private async Task OnSearchInputChanged(ChangeEventArgs e)
    {
        _searchText = e.Value?.ToString();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnStatusSelectChanged(ChangeEventArgs e)
    {
        _selectedStatus = e.Value?.ToString();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnSeveritySelectChanged(ChangeEventArgs e)
    {
        _selectedSeverity = e.Value?.ToString();
        await InvokeAsync(StateHasChanged);
    }

    private IEnumerable<ReviewDocumentRow> FilteredDocuments => _documents
        .Where(MatchesStatus)
        .Where(MatchesSubject)
        .Where(MatchesSeverity)
        .Where(MatchesSearch)
        .OrderByDescending(document => document.Severity == HighSeverity)
        .ThenByDescending(document => document.UploadedAt);

    private IEnumerable<string> ActiveFilters
    {
        get
        {
            if (!string.IsNullOrWhiteSpace(_selectedStatus))
            {
                yield return $"Queue: {_selectedStatus}";
            }

            if (!string.IsNullOrWhiteSpace(_selectedSeverity))
            {
                yield return $"Severity: {_selectedSeverity}";
            }

            if (!string.IsNullOrWhiteSpace(_selectedSubject))
            {
                yield return $"Subject: {_selectedSubject}";
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var selectedId = _selectedDocument?.Id;
            var rows = await ModerationService.GetQueueAsync();

            _documents.Clear();
            _documents.AddRange(rows.Select(MapRow));

            _selectedDocument = selectedId.HasValue
                ? _documents.FirstOrDefault(document => document.Id == selectedId.Value)
                : _documents.FirstOrDefault();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to load moderation queue: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OpenDocumentLibrary() => Navigation.NavigateTo("/admin/documents");

    private Task OnSearchChanged(string? value)
    {
        _searchText = value;
        return Task.CompletedTask;
    }

    private Task OnStatusChanged(string? value)
    {
        _selectedStatus = value;
        return Task.CompletedTask;
    }

    private Task OnSubjectChanged(string? value)
    {
        _selectedSubject = value;
        return Task.CompletedTask;
    }

    private Task OnSeverityChanged(string? value)
    {
        _selectedSeverity = value;
        return Task.CompletedTask;
    }

    private Task RemoveFilterAsync(string filter)
    {
        if (filter.StartsWith("Queue:", StringComparison.OrdinalIgnoreCase))
        {
            _selectedStatus = null;
        }
        else if (filter.StartsWith("Severity:", StringComparison.OrdinalIgnoreCase))
        {
            _selectedSeverity = null;
        }
        else if (filter.StartsWith("Subject:", StringComparison.OrdinalIgnoreCase))
        {
            _selectedSubject = null;
        }

        return Task.CompletedTask;
    }

    private Task ClearFiltersAsync()
    {
        _selectedStatus = null;
        _selectedSeverity = null;
        _selectedSubject = null;
        return Task.CompletedTask;
    }

    private bool MatchesStatus(ReviewDocumentRow document)
    {
        return string.IsNullOrWhiteSpace(_selectedStatus)
            || document.ModerationStatus.Equals(_selectedStatus, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesSubject(ReviewDocumentRow document)
    {
        return string.IsNullOrWhiteSpace(_selectedSubject)
            || document.SubjectCode.Equals(_selectedSubject, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesSeverity(ReviewDocumentRow document)
    {
        return string.IsNullOrWhiteSpace(_selectedSeverity)
            || document.Severity.Equals(_selectedSeverity, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesSearch(ReviewDocumentRow document)
    {
        if (string.IsNullOrWhiteSpace(_searchText))
        {
            return true;
        }

        var text = _searchText.Trim();
        return document.Title.Contains(text, StringComparison.OrdinalIgnoreCase)
            || document.OwnerName.Contains(text, StringComparison.OrdinalIgnoreCase)
            || document.OwnerEmail.Contains(text, StringComparison.OrdinalIgnoreCase)
            || document.SubjectCode.Contains(text, StringComparison.OrdinalIgnoreCase)
            || document.ReportReason.Contains(text, StringComparison.OrdinalIgnoreCase);
    }

    private Task SelectDocumentAsync(ReviewDocumentRow document)
    {
        _selectedDocument = document;
        return Task.CompletedTask;
    }

    private static bool CanApprove(ReviewDocumentRow document)
    {
        return document.ModerationStatus is PendingStatus or RejectedStatus;
    }

    private async Task ModerateAsync(ReviewDocumentRow document, string decision)
    {
        var requiresReason = decision is RejectedStatus or RemovedStatus;
        var parameters = new DialogParameters
        {
            ["DocumentTitle"] = document.Title,
            ["Decision"] = decision,
            ["RequiresReason"] = requiresReason,
            ["ExistingReason"] = document.ModerationReason
        };

        var dialog = await DialogService.ShowAsync<ModerationDecisionDialog>($"{decision} document", parameters);
        var result = await dialog.Result;
        if (result is not { Canceled: false })
        {
            return;
        }

        var reason = result.Data as string ?? string.Empty;
        var success = decision switch
        {
            ApprovedStatus => await ModerationService.ApproveAsync(document.Id),
            RejectedStatus => await ModerationService.RejectAsync(document.Id, reason),
            RemovedStatus => await ModerationService.DeleteAsync(document.Id),
            _ => false
        };

        if (!success)
        {
            Snackbar.Add($"Unable to {decision.ToLowerInvariant()} {document.Title}.", Severity.Error);
            return;
        }

        if (decision == RemovedStatus)
        {
            _documents.Remove(document);
            if (_selectedDocument?.Id == document.Id)
            {
                _selectedDocument = _documents.FirstOrDefault();
            }

            Snackbar.Add($"{document.Title} removed from storage and moderation queue.", Severity.Warning);
            return;
        }

        if (decision == ApprovedStatus)
        {
            _documents.Remove(document);
            if (_selectedDocument?.Id == document.Id)
            {
                _selectedDocument = _documents.FirstOrDefault();
            }

            Snackbar.Add($"{document.Title} approved and removed from the moderation queue.", Severity.Success);
            return;
        }

        document.ModerationStatus = decision;
        document.ModerationReason = string.IsNullOrWhiteSpace(reason) ? "Rejected by moderator." : reason.Trim();
        document.ReportReason = document.ModerationReason;
        document.ReviewedAt = DateTime.UtcNow;
        document.ReviewedBy = "Admin moderation";
        document.NotificationStatus = NotificationQueued;
        document.ProcessingStatus = FailedProcessing;
        document.Severity = HighSeverity;

        _selectedDocument = document;
        Snackbar.Add($"{document.Title} rejected and kept in the queue for follow-up.", Severity.Warning);
    }

    private static string FormatDateTime(DateTime value) => value.ToLocalTime().ToString("MMM dd, yyyy HH:mm");

    private static Color GetModerationColor(string status)
    {
        return status switch
        {
            PendingStatus => Color.Warning,
            ReportedStatus => Color.Error,
            ApprovedStatus => Color.Success,
            RejectedStatus => Color.Default,
            RemovedStatus => Color.Error,
            _ => Color.Primary
        };
    }

    private static Color GetSeverityColor(string severity)
    {
        return severity switch
        {
            HighSeverity => Color.Error,
            MediumSeverity => Color.Warning,
            _ => Color.Info
        };
    }

    private static Color GetFileColor(string fileType)
    {
        return fileType.ToLowerInvariant() switch
        {
            "pdf" => Color.Error,
            "docx" => Color.Info,
            "pptx" => Color.Warning,
            _ => Color.Primary
        };
    }

    private static string GetFileIcon(string fileType)
    {
        return fileType.ToLowerInvariant() switch
        {
            "pdf" => Icons.Material.Filled.PictureAsPdf,
            "docx" => Icons.Material.Filled.Article,
            "pptx" => Icons.Material.Filled.Slideshow,
            _ => Icons.Material.Filled.Description
        };
    }

    private static ReviewDocumentRow MapRow(ModerationQueueDocumentDto document)
    {
        return new ReviewDocumentRow
        {
            Id = document.Id,
            Title = document.Title,
            SubjectCode = document.SubjectCode,
            OwnerName = document.OwnerName,
            OwnerEmail = document.OwnerEmail,
            FileType = document.FileType,
            FileSizeMb = Math.Round(document.FileSizeBytes / 1024d / 1024d, 1),
            StoragePath = document.StoragePath,
            ModerationStatus = document.ModerationStatus,
            ProcessingStatus = document.ProcessingStatus,
            Severity = document.Severity,
            ReportReason = document.ReportReason,
            PreviewText = document.PreviewText,
            Tags = BuildTags(document),
            ModerationReason = document.ModerationReason,
            NotificationStatus = string.Empty,
            UploadedAt = document.UploadedAt.LocalDateTime,
            ReviewedAt = document.ModerationStatus == RejectedStatus ? document.UpdatedAt.LocalDateTime : null,
            ReviewedBy = document.ModerationStatus == RejectedStatus ? "Admin moderation" : string.Empty
        };
    }

    private static List<string> BuildTags(ModerationQueueDocumentDto document)
    {
        var tags = new List<string>
        {
            document.SubjectCode.ToLowerInvariant(),
            document.Semester.ToLowerInvariant()
        };

        if (document.ProcessingStatus == FailedProcessing)
        {
            tags.Add("failed-processing");
        }

        if (document.ModerationStatus == RejectedStatus)
        {
            tags.Add("rejected");
        }

        return tags.Distinct(StringComparer.OrdinalIgnoreCase).ToList();
    }

    private sealed class ReviewDocumentRow
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public string SubjectCode { get; set; } = string.Empty;
        public string OwnerName { get; set; } = string.Empty;
        public string OwnerEmail { get; set; } = string.Empty;
        public string FileType { get; set; } = string.Empty;
        public double FileSizeMb { get; set; }
        public string StoragePath { get; set; } = string.Empty;
        public string ModerationStatus { get; set; } = PendingStatus;
        public string ProcessingStatus { get; set; } = "Pending";
        public string Severity { get; set; } = MediumSeverity;
        public string ReportReason { get; set; } = string.Empty;
        public string PreviewText { get; set; } = string.Empty;
        public List<string> Tags { get; set; } = new();
        public string ModerationReason { get; set; } = string.Empty;
        public string NotificationStatus { get; set; } = "Not sent";
        public DateTime UploadedAt { get; set; }
