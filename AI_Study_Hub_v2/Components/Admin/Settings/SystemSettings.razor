@code {
    private const string CriticalRisk = "Critical";
    private const string StandardRisk = "Standard";
    private const string UnsavedRisk = "Unsaved changes";

    private readonly List<ConfigRow> _configs = new();
    private readonly List<ConfigChangePreview> _recentChanges = new();
    private readonly List<string> _terminalLogs = new();
    private System.Threading.Timer? _logTimer;
    private bool _isLoading = true;
    private string? _searchText;
    private string? _selectedCategory;
    private string? _selectedRisk;
    private string? _errorMessage;

    private IEnumerable<ConfigRow> FilteredConfigs => _configs
        .Where(MatchesCategory)
        .Where(MatchesRisk)
        .Where(MatchesSearch)
        .OrderByDescending(config => config.IsCritical)
        .ThenBy(config => config.Category)
        .ThenBy(config => config.Key);

    private IEnumerable<string> ActiveFilters
    {
        get
        {
            if (!string.IsNullOrWhiteSpace(_selectedCategory))
            {
                yield return $"Category: {_selectedCategory}";
            }

            if (!string.IsNullOrWhiteSpace(_selectedRisk))
            {
                yield return $"Risk: {_selectedRisk}";
            }
        }
    }

    protected override async void OnInitialized()
    {
        await ReloadAsync();
        InitializeTerminalLogs();
        _logTimer = new System.Threading.Timer(OnLogTimerTick, null, 8000, 8000);
    }

    private async Task ReloadAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            if (!Session.IsAuthenticated || string.IsNullOrWhiteSpace(Session.AccessToken))
            {
                _errorMessage = "You must be logged in as an administrator to view system settings.";
                return;
            }

            var configs = await SettingsApi.GetAllAsync(Session.AccessToken);
            _configs.Clear();
            foreach (var dto in configs)
            {
                _configs.Add(ConfigRow.FromDto(dto));
            }
            _terminalLogs.Add($"[{DateTime.Now:HH:mm:ss}] info: Successfully fetched {_configs.Count} parameters from API.");
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to load system settings: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void Reload()
    {
        _ = ReloadAsync();
    }

    private void InitializeTerminalLogs()
    {
        var now = DateTime.Now;
        _terminalLogs.Add($"[{now.AddMinutes(-5).ToString("HH:mm:ss")}] info: Polling Supabase for configuration updates...");
        _terminalLogs.Add($"[{now.AddMinutes(-4).ToString("HH:mm:ss")}] info: Successfully fetched 14 parameters.");
        _terminalLogs.Add($"[{now.AddMinutes(-3).ToString("HH:mm:ss")}] event: User 'admin@aistudyhub.edu' accessed ai.chat_model via Admin Console.");
        _terminalLogs.Add($"[{now.AddMinutes(-1).ToString("HH:mm:ss")}] warn: generation.temperature local value (0.2) differs from production (0.2).");
        _terminalLogs.Add($"[{now.ToString("HH:mm:ss")}] info: RAG pipeline health check: 200 OK. Latency: 1.2s.");
    }

    private void OnLogTimerTick(object? state)
    {
        var random = new Random();
        var now = DateTime.Now.ToString("HH:mm:ss");
        string log;
        int choice = random.Next(3);
        if (choice == 0)
        {
            log = $"[{now}] info: RAG pipeline health check: 200 OK. Latency: {random.NextDouble() * 0.5 + 0.8:F1}s.";
        }
        else if (choice == 1)
        {
            log = $"[{now}] info: Polling Supabase for configuration updates...";
        }
        else
        {
            log = $"[{now}] info: Successfully synced {_configs.Count} parameters with secondary replica.";
        }

        InvokeAsync(() =>
        {
            _terminalLogs.Add(log);
            if (_terminalLogs.Count > 50)
            {
                _terminalLogs.RemoveAt(0);
            }
            StateHasChanged();
        });
    }

    private void ClearTerminalLogs()
    {
        _terminalLogs.Clear();
    }

    private void ShowAuditHint()
    {
        Snackbar.Add("Open /admin/audit-logs to review persisted CONFIG_CHANGE entries with before/after JSON.", Severity.Info);
    }

    private void OnCategoryChanged(ChangeEventArgs args)
    {
        _selectedCategory = args.Value?.ToString();
        if (_selectedCategory == "") _selectedCategory = null;
    }

    private void OnRiskChanged(ChangeEventArgs args)
    {
        _selectedRisk = args.Value?.ToString();
        if (_selectedRisk == "") _selectedRisk = null;
    }

    private Task RemoveFilterAsync(string filter)
    {
        if (filter.StartsWith("Category:", StringComparison.OrdinalIgnoreCase))
        {
            _selectedCategory = null;
        }
        else if (filter.StartsWith("Risk:", StringComparison.OrdinalIgnoreCase))
        {
            _selectedRisk = null;
        }

        return Task.CompletedTask;
    }

    private async Task ClearFiltersAsync()
    {
        _selectedCategory = null;
        _selectedRisk = null;
        _searchText = null;
        await InvokeAsync(StateHasChanged);
    }

    private bool MatchesCategory(ConfigRow config)
    {
        return string.IsNullOrWhiteSpace(_selectedCategory)
            || config.Category.Equals(_selectedCategory, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesRisk(ConfigRow config)
    {
        return _selectedRisk switch
        {
            CriticalRisk => config.IsCritical,
            StandardRisk => !config.IsCritical,
            UnsavedRisk => config.HasChanges,
            _ => true
        };
    }

    private bool MatchesSearch(ConfigRow config)
    {
        if (string.IsNullOrWhiteSpace(_searchText))
        {
            return true;
        }

        var text = _searchText.Trim();
        return config.Key.Contains(text, StringComparison.OrdinalIgnoreCase)
            || config.DisplayName.Contains(text, StringComparison.OrdinalIgnoreCase)
            || config.Description.Contains(text, StringComparison.OrdinalIgnoreCase)
            || config.Category.Contains(text, StringComparison.OrdinalIgnoreCase);
    }

    private async Task SaveConfigAsync(ConfigRow config)
    {
        if (config.Type == ConfigInputType.Json && !IsValidJson(config.Value))
        {
            Snackbar.Add($"{config.Key} does not contain valid JSON.", Severity.Error);
            return;
        }

        if (config.IsCritical)
        {
            var parameters = new DialogParameters
            {
                ["Title"] = "Confirm critical change",
                ["Message"] = $"Saving {config.Key} can affect retrieval quality, model behavior, quota enforcement, or access control.",
                ["ConfirmText"] = "Save setting",
                ["ConfirmationText"] = config.Key,
                ["ConfirmColor"] = Color.Warning,
                ["IconColor"] = Color.Warning,
                ["Icon"] = Icons.Material.Filled.Tune
            };

            var dialog = await DialogService.ShowAsync<ConfirmDialog>("Confirm critical setting", parameters);
            var result = await dialog.Result;
            if (result is not { Canceled: false })
            {
                return;
            }
        }

        if (!Session.IsAuthenticated || string.IsNullOrWhiteSpace(Session.AccessToken))
        {
            Snackbar.Add("Session expired. Please log in again.", Severity.Error);
            return;
        }

        try
        {
            var previous = config.OriginalValue;
            var updated = await SettingsApi.UpdateValueAsync(Session.AccessToken, config.Key, config.Value);
            config.OriginalValue = config.Value;
            config.UpdatedAt = updated.UpdatedAt?.UtcDateTime ?? DateTime.UtcNow;
            config.UpdatedBy = updated.UpdatedBy ?? "admin";

            _recentChanges.Insert(0, new ConfigChangePreview(config.Key, config.UpdatedBy, config.UpdatedAt, ToBeforeAfterJson(previous, config.Value)));

            _terminalLogs.Add($"[{DateTime.Now:HH:mm:ss}] event: Config '{config.Key}' saved via API to value '{config.Value}'.");

            Snackbar.Add($"{config.Key} saved to server.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save {config.Key}: {ex.Message}", Severity.Error);
        }
    }

    private void ResetConfig(ConfigRow config)
    {
        var prev = config.Value;
        config.Value = config.OriginalValue;
        
        _terminalLogs.Add($"[{DateTime.Now.ToString("HH:mm:ss")}] event: User 'admin@aistudyhub.edu' reset {config.Key} from '{prev}' to '{config.OriginalValue}'.");
        
        Snackbar.Add($"{config.Key} reset to the last saved value.", Severity.Info);
    }

    private static bool GetBooleanValue(ConfigRow config)
    {
        return bool.TryParse(config.Value, out var value) && value;
    }

    private static void SetBooleanValue(ConfigRow config, bool value)
    {
        config.Value = value.ToString().ToLowerInvariant();
    }

    private static decimal GetDecimalValue(ConfigRow config)
    {
        return decimal.TryParse(config.Value, NumberStyles.Number, CultureInfo.InvariantCulture, out var value) ? value : 0;
    }

    private static void SetDecimalValue(ConfigRow config, decimal value)
    {
        config.Value = value.ToString(CultureInfo.InvariantCulture);
    }

    private static string GetSuffixUnit(string key)
    {
        return key switch
        {
            "rag.chunk_size" => "TOKENS",
            "rag.chunk_overlap" => "TOKENS",
            "rag.max_chunks" => "CHUNKS",
            "quota.default_student_daily_tokens" => "TOKENS",
            "quota.default_admin_daily_tokens" => "TOKENS",
            "audit.retention_days" => "DAYS",
            _ => "UNITS"
        };
    }

    private static string GetWarningText(string key)
    {
        return key switch
        {
            "generation.temperature" => "Directly impacts hallucination rates and output diversity.",
            "generation.top_p" => "Controls context diversity and randomness threshold.",
            "ai.chat_model" => "Directly impacts generation costs, context window limits, and answer latency.",
            "ai.embedding_model" => "Modifying the embedding model invalidates all existing index vectors.",
            "auth.allow_self_registration" => "Exposes student sign-ups to open public domains without whitelist checks.",
            "rag.chunk_size" => "RAG indexing parameters modify token consumption and LLM context window loading.",
            "rag.chunk_overlap" => "RAG indexing parameters modify token consumption and LLM context window loading.",
            _ => "Saving this setting requires typed confirmation and writes before/after values to audit_logs."
        };
    }

    private static bool IsValidJson(string value)
    {
        try
        {
            using var _ = JsonDocument.Parse(value);
            return true;
        }
        catch (JsonException)
        {
            return false;
        }
    }

    private static string ToBeforeAfterJson(string previous, string current)
    {
        return $"{{\"before\":\"{EscapeJson(previous)}\",\"after\":\"{EscapeJson(current)}\"}}";
    }

    private static string EscapeJson(string value)
    {
        return value.Replace("\\", "\\\\", StringComparison.Ordinal).Replace("\"", "\\\"", StringComparison.Ordinal).Replace("\r", "", StringComparison.Ordinal).Replace("\n", "\\n", StringComparison.Ordinal);
    }

    private static string FormatDateTime(DateTime value)
    {
        return value.ToLocalTime().ToString("MMM dd, HH:mm");
    }

    public void Dispose()
    {
        _logTimer?.Dispose();
    }

    private sealed class ConfigRow
    {
        private ConfigRow(string key, string displayName, string description, string category, ConfigInputType type, string value, string defaultValue, bool isCritical, int lines, DateTime updatedAt, string updatedBy)
        {
            Key = key;
            DisplayName = displayName;
            Description = description;
            Category = category;
            Type = type;
            Value = value;
            OriginalValue = value;
            DefaultValue = defaultValue;
            IsCritical = isCritical;
            Lines = lines;
            UpdatedAt = updatedAt;
            UpdatedBy = updatedBy;
        }

        public static ConfigRow FromDto(SystemConfigDto dto)
        {
            var type = dto.ConfigType switch
            {
                "Number" => ConfigInputType.Number,
                "Boolean" => ConfigInputType.Boolean,
                "Json" => ConfigInputType.Json,
                _ => ConfigInputType.Text
            };
            var lines = dto.ConfigType is "Json" ? 4 : (dto.ConfigType is "Text" && dto.Key == "generation.system_prompt" ? 5 : 1);
            return new ConfigRow(
                dto.Key,
                dto.DisplayName,
                dto.Description ?? "",
                dto.Category,
                type,
                dto.Value,
                dto.DefaultValue,
                dto.IsCritical,
                lines,
                dto.UpdatedAt?.UtcDateTime ?? DateTime.UtcNow,
                dto.UpdatedBy ?? "admin");
        }

        public string Key { get; }
        public string DisplayName { get; }
        public string Description { get; }
        public string Category { get; }
        public ConfigInputType Type { get; }
        public string Value { get; set; }
        public string OriginalValue { get; set; }
        public string DefaultValue { get; }
        public bool IsCritical { get; }
        public int Lines { get; }
        public DateTime UpdatedAt { get; set; }
        public string UpdatedBy { get; set; }
        public bool HasChanges => !string.Equals(Value, OriginalValue, StringComparison.Ordinal);
    }

    private sealed record ConfigChangePreview(string Key, string Actor, DateTime CreatedAt, string BeforeAfterJson);

    private enum ConfigInputType
    {
        Text,
        Number,
        Boolean,
        Json
    }
}
