@namespace AI_Study_Hub_v2.Components.Admin.Settings
@page "/admin/settings"
@layout AdminLayout
@using System.Globalization
@using System.Text.Json
@using MudBlazor
@using AI_Study_Hub_v2.Components.Admin.Shared
@using AI_Study_Hub_v2.Services
@using AI_Study_Hub_v2.Dtos
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject AuthSessionState Session
@inject SystemSettingsApiClient SettingsApi
@implements IDisposable

<div class="settings-page">
    <div class="breadcrumbs-container">
        UC13 • UC16 • AI SYSTEM PARAMETERS
    </div>

    <div class="page-header-row">
        <div>
            <h1 class="page-title">AI System Settings</h1>
            <p class="page-desc">Configure RAG model parameters, chunking rules, and system behavior.</p>
        </div>
        <div class="header-actions">
            <button class="header-outline-btn" @onclick="ShowAuditHint">
                <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" />
                <span>AUDIT TRAIL</span>
            </button>
            <button class="header-filled-btn" @onclick="Reload">
                <MudIcon Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" />
                <span>RELOAD CONFIGS</span>
            </button>
        </div>
    </div>

    <!-- KPI Grid -->
    <div class="kpi-grid-container mb-6">
        <div class="kpi-card-custom">
            <div class="kpi-card-bottom">
                <span class="kpi-label">SYSTEM CONFIGS</span>
                <div class="kpi-value">@_configs.Count</div>
                <span class="kpi-subtext">Active system parameters</span>
            </div>
        </div>
        <div class="kpi-card-custom">
            <div class="kpi-card-bottom">
                <span class="kpi-label">ACTION REQUIRED</span>
                <div class="kpi-value warning-color">@_configs.Count(c => c.IsCritical)</div>
                <span class="kpi-subtext">Requires confirmation</span>
            </div>
        </div>
        <div class="kpi-card-custom">
            <div class="kpi-card-bottom">
                <span class="kpi-label">LAST SYNC</span>
                <div class="kpi-value">@DateTime.Now.ToString("HH:mm")</div>
                <span class="kpi-subtext">Refreshed just now</span>
            </div>
        </div>
        <div class="kpi-card-custom">
            <div class="kpi-card-bottom">
                <span class="kpi-label">MODEL HEALTH</span>
                <div class="kpi-value success-color">99.8%</div>
                <span class="kpi-subtext">Optimal performance</span>
            </div>
        </div>
    </div>

    <!-- Search & Filters -->
    <div class="filter-row-custom mb-6">
        <div class="search-input-wrapper">
            <input type="text" class="search-input" placeholder="Search configs, logs, or sessions..."
                   @bind-value="_searchText" @bind-value:event="oninput" />
            <MudIcon Icon="@Icons.Material.Filled.Search" Class="search-icon" Size="Size.Small" />
        </div>
        <select class="filter-select" value="@_selectedCategory" @onchange="OnCategoryChanged">
            <option value="">Category</option>
            @foreach (var category in _configs.Select(c => c.Category).Distinct().OrderBy(c => c))
            {
                <option value="@category">@category</option>
            }
        </select>
        <select class="filter-select" value="@_selectedRisk" @onchange="OnRiskChanged">
            <option value="">Risk</option>
            <option value="@CriticalRisk">Critical</option>
            <option value="@StandardRisk">Standard</option>
            <option value="@UnsavedRisk">Unsaved changes</option>
        </select>
        @{
            var hasActiveFilters = !string.IsNullOrWhiteSpace(_searchText)
                || !string.IsNullOrWhiteSpace(_selectedCategory)
                || !string.IsNullOrWhiteSpace(_selectedRisk);
            var filterIconColor = hasActiveFilters ? "#575e72" : "#c7c6d5";
            var filterIconStyle = $"font-size: 18px; color: {filterIconColor};";
        }
        <button class="filter-btn @(hasActiveFilters ? "" : "muted")" @onclick="ClearFiltersAsync" disabled="@(!hasActiveFilters)" title="@(hasActiveFilters ? "Clear all filters" : "No filters active")">
            <MudIcon Icon="@Icons.Material.Outlined.FilterAltOff" Style="@filterIconStyle" />
        </button>
    </div>

    <!-- Active Filters -->
    @if (ActiveFilters.Any())
    {
        <div class="active-filters-container">
            @foreach (var filter in ActiveFilters)
            {
                <span class="filter-pill">
                    @filter
                    <button class="filter-pill-close" @onclick="@(() => RemoveFilterAsync(filter))">×</button>
                </span>
            }
            <button class="clear-all-btn" @onclick="ClearFiltersAsync">Clear all filters</button>
        </div>
    }

    <!-- Config Grid -->
    @if (_isLoading)
    {
        <div class="config-grid mb-6">
            @for (var index = 0; index < 4; index++)
            {
                <MudSkeleton Height="260px" Animation="Animation.Wave" Style="border-radius: 12px;" />
            }
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-6">@_errorMessage</MudAlert>
    }
    else if (!FilteredConfigs.Any())
    {
        <div class="empty-state mb-6" style="background: #ffffff; border: 1px solid rgba(199, 196, 215, 0.3); border-radius: 12px; padding: 3rem; text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 280px;">
            <MudIcon Icon="@Icons.Material.Filled.Tune" Size="Size.Large" Color="Color.Secondary" Style="font-size: 48px; color: #767586;" />
            <h3 style="font-size: 18px; font-weight: 800; margin-top: 1rem; color: #191c1e;">No configuration found</h3>
            <p style="font-size: 14px; color: #575e72; margin-top: 0.5rem;">Change the search or filters to inspect a wider set of parameters.</p>
        </div>
    }
    else
    {
        <div class="config-grid mb-6">
            @foreach (var config in FilteredConfigs)
            {
                <div class="config-card">
                    <div>
                        <div class="config-header-row">
                            <div>
                                <h3 class="config-title">@config.DisplayName</h3>
                                <span class="config-key">@config.Key</span>
                            </div>
                            <div class="badge-group">
                                <span class="custom-badge category-badge">@config.Category</span>
                                @if (config.IsCritical)
                                {
                                    <span class="custom-badge critical-badge">Critical</span>
                                }
                                @if (config.HasChanges)
                                {
                                    <span class="custom-badge unsaved-badge">Unsaved</span>
                                }
                            </div>
                        </div>

                        <span class="config-desc-label mt-4">@config.Description.ToUpperInvariant()</span>

                        @if (config.Key == "generation.temperature" || config.Key == "generation.top_p")
                        {
                            <!-- Slider UI -->
                            <div class="custom-slider-container">
                                <input type="range" class="custom-slider" min="0" max="1" step="0.05"
                                       value="@GetDecimalValue(config)"
                                       @oninput="@(e => SetDecimalValue(config, decimal.TryParse(e.Value?.ToString(), out var v) ? v : 0))" />
                                <div class="slider-labels">
                                    <span>CONSISTENT (0)</span>
                                    <span>BALANCED (0.5)</span>
                                    <span>CREATIVE (1.0)</span>
                                </div>
                                <div class="slider-value-box">
                                    <span class="value-box-label">Value</span>
                                    <span class="value-box-val">@config.Value</span>
                                </div>
                            </div>
                        }
                        else if (config.Type == ConfigInputType.Boolean)
                        {
                            <!-- Switch UI -->
                            <div class="switch-field-group">
                                <label class="custom-switch-container">
                                    <input type="checkbox" checked="@GetBooleanValue(config)"
                                           @onchange="@(e => SetBooleanValue(config, (bool)(e.Value ?? false)))" />
                                    <span class="custom-switch-slider"></span>
                                </label>
                                <span class="switch-field-label">@(GetBooleanValue(config) ? "Active" : "Disabled")</span>
                            </div>
                        }
                        else if (config.Key == "ai.chat_model" || config.Key == "ai.embedding_model")
                        {
                            <!-- Select Dropdown UI -->
                            <div class="custom-select-wrapper">
                                <select class="custom-select" value="@config.Value" @onchange="@(e => config.Value = e.Value?.ToString() ?? "")">
                                    @if (config.Key == "ai.chat_model")
                                    {
                                        <option value="gpt-4o-mini">gpt-4o-mini (Current)</option>
                                        <option value="gpt-4">gpt-4</option>
                                        <option value="gpt-4o">gpt-4o</option>
                                        <option value="claude-3-5-sonnet">claude-3-5-sonnet</option>
                                    }
                                    else
                                    {
                                        <option value="text-embedding-3-small">text-embedding-3-small (Current)</option>
                                        <option value="text-embedding-3-large">text-embedding-3-large</option>
                                        <option value="text-embedding-ada-002">text-embedding-ada-002</option>
                                    }
                                </select>
                            </div>
                        }
                        else if (config.Type == ConfigInputType.Number)
                        {
                            <!-- Suffix input UI -->
                            <div class="custom-input-group">
                                <input type="number" class="custom-input"
                                       value="@GetDecimalValue(config)"
                                       @oninput="@(e => SetDecimalValue(config, decimal.TryParse(e.Value?.ToString(), out var v) ? v : 0))" />
                                <span class="custom-input-suffix">@GetSuffixUnit(config.Key)</span>
                            </div>
                        }
                        else if (config.Type == ConfigInputType.Json || config.Lines > 1)
                        {
                            <!-- Custom Textarea UI -->
                            <textarea class="custom-textarea" rows="@(config.Lines > 1 ? config.Lines : 4)"
                                      value="@config.Value" @oninput="@(e => config.Value = e.Value?.ToString() ?? "")"></textarea>
                        }
                        else
                        {
                            <!-- Standard Text input UI -->
                            <div class="custom-input-group">
                                <input type="text" class="custom-input" value="@config.Value" @oninput="@(e => config.Value = e.Value?.ToString() ?? "")" />
                            </div>
                        }

                        @if (config.IsCritical || config.Key == "generation.temperature")
                        {
                            <div class="custom-warning-box">
                                <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Class="warning-box-icon" />
                                <span class="warning-box-text">@GetWarningText(config.Key)</span>
                            </div>
                        }
                    </div>

                    <div>
                        <div class="card-meta-row">
                            <span>Default: @config.DefaultValue</span>
                            <span>Last updated: @FormatDateTime(config.UpdatedAt) by admin</span>
                        </div>

                        <div class="card-actions">
                            <button class="reset-btn" disabled="@(!config.HasChanges)" @onclick="@(() => ResetConfig(config))">RESET</button>
                            <button class="save-btn" disabled="@(!config.HasChanges)" @onclick="@(() => SaveConfigAsync(config))">SAVE</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Live configuration stream console -->
    <div class="live-stream-panel mb-6">
        <div class="stream-header">
            <div class="stream-title-group">
                <span class="stream-dot"></span>
                <span class="stream-title">LIVE CONFIGURATION STREAM</span>
            </div>
            <div class="stream-actions">
                <button class="stream-action-btn" title="Pause Stream">
                    <MudIcon Icon="@Icons.Material.Filled.Pause" Size="Size.Small" />
                </button>
                <button class="stream-action-btn" title="Clear Logs" @onclick="ClearTerminalLogs">
                    <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                </button>
            </div>
        </div>
        <div class="terminal-console">
            @foreach (var log in _terminalLogs)
            {
                var lowerLog = log.ToLowerInvariant();
                var logClass = "info";
                if (lowerLog.Contains("event:")) logClass = "event";
                else if (lowerLog.Contains("warn:")) logClass = "warn";
                else if (lowerLog.Contains("error:")) logClass = "error";

                <p class="terminal-line @logClass">@log</p>
            }
            <p class="terminal-line"><span class="terminal-cursor"></span></p>
        </div>
    </div>

    <!-- Configuration Audit Preview -->
    <div class="audit-preview-card mb-6">
        <div class="audit-preview-header">
            <div>
                <h3 class="audit-preview-title">Configuration audit preview</h3>
                <p class="audit-preview-desc">Recent local changes that should map to audit_logs entries.</p>
            </div>
            <button class="open-audit-btn" @onclick="ShowAuditHint">
                <span>Open Audit Logs</span>
                <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" />
            </button>
        </div>

        @if (!_recentChanges.Any())
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">No configuration changes in this session.</MudAlert>
        }
        else
        {
            <div class="audit-table-container">
                <table class="audit-table">
                    <thead>
                        <tr>
                            <th>Key</th>
                            <th>Actor</th>
                            <th>Changed</th>
                            <th>Before / After</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var context in _recentChanges)
                        {
                            <tr>
                                <td>@context.Key</td>
                                <td>@context.Actor</td>
                                <td>@FormatDateTime(context.CreatedAt)</td>
                                <td><code class="audit-code-value">@context.BeforeAfterJson</code></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap');

    .settings-page {
        font-family: 'Hanken Grotesk', sans-serif;
        color: #191c1e;
        animation: pageRise 0.4s ease-out;
    }

    /* Breadcrumbs */
    .breadcrumbs-container {
        font-size: 11px;
        font-weight: 700;
        color: #4648d4;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin-bottom: 0.5rem;
    }

    /* Page Header */
    .page-header-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .page-title {
        font-size: 28px;
        font-weight: 800;
        color: #191c1e;
        margin: 0;
        line-height: 1.2;
    }

    .page-desc {
        font-size: 14px;
        color: #575e72;
        margin: 4px 0 0 0;
    }

    .header-actions {
        display: flex;
        gap: 0.75rem;
        align-items: center;
    }

    .header-outline-btn {
        background: #ffffff;
        border: 1px solid #c7c6d5;
        border-radius: 8px;
        height: 38px;
        font-weight: 700;
        font-size: 12px;
        color: #575e72;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 16px;
        gap: 8px;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .header-outline-btn:hover {
        background-color: #f8fafc;
        border-color: #767586;
    }

    .header-filled-btn {
        background: #191c1e;
        border: none;
        border-radius: 8px;
        height: 38px;
        font-weight: 700;
        font-size: 12px;
        color: #ffffff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 16px;
        gap: 8px;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .header-filled-btn:hover {
        background-color: #2d3135;
    }

    /* KPI Grid */
    .kpi-grid-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1.25rem;
        margin-bottom: 1.5rem;
    }

    .kpi-card-custom {
        background: #ffffff;
        border: 1px solid rgba(199, 196, 215, 0.3);
        border-radius: 12px;
        padding: 1.25rem;
        box-shadow: 0px 4px 20px rgba(0, 0, 0, 0.03);
    }

    .kpi-label {
        font-size: 11px;
        font-weight: 700;
        color: #767586;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        display: block;
    }

    .kpi-value {
        font-size: 28px;
        font-weight: 800;
        color: #191c1e;
        margin-top: 4px;
        line-height: 1.1;
    }

    .kpi-value.warning-color {
        color: #d97706;
    }

    .kpi-value.success-color {
        color: #10b981;
    }

    .kpi-subtext {
        font-size: 12px;
        color: #767586;
        font-weight: 500;
        display: block;
        margin-top: 2px;
    }

    /* Filter Row */
    .filter-row-custom {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
    }

    .search-input-wrapper {
        position: relative;
        flex: 1;
        min-width: 260px;
    }

    .search-icon {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #767586;
        pointer-events: none;
    }

    .search-input {
        width: 100%;
        height: 40px;
        padding: 0 12px 0 40px;
        border: 1px solid #c7c6d5;
        border-radius: 8px;
        background: #ffffff;
        color: #191c1e;
        font-size: 14px;
        font-weight: 500;
        outline: none;
        transition: border-color 0.2s;
    }

    .search-input:focus {
        border-color: #4648d4;
    }

    .filter-select {
        height: 40px;
        padding: 0 24px 0 12px;
        border: 1px solid #c7c6d5;
        border-radius: 8px;
        background: #ffffff;
        color: #191c1e;
        font-size: 14px;
        font-weight: 600;
        outline: none;
        cursor: pointer;
        min-width: 150px;
        background-image: url("data:image/svg+xml;charset=utf-8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%23575e72'%3E%3Cpath d='M7 10l5 5 5-5z'/%3E%3C/svg%3E");
        background-repeat: no-repeat;
        background-position: right 8px center;
        background-size: 20px;
        -webkit-appearance: none;
        appearance: none;
    }

    .filter-btn {
        width: 40px;
        height: 40px;
        border: 1px solid #c7c6d5;
        border-radius: 8px;
        background: #ffffff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background-color 0.2s;
    }

    .filter-btn:hover {
        background-color: #f8fafc;
    }

    /* Active filter pills */
    .active-filters-container {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-bottom: 1.25rem;
    }

    .filter-pill {
        background-color: #f1f3f5;
        color: #575e72;
        font-size: 12px;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 9999px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .filter-pill-close {
        border: none;
        background: transparent;
        cursor: pointer;
        font-size: 12px;
        font-weight: bold;
        color: #767586;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .clear-all-btn {
        border: none;
        background: transparent;
        color: #4648d4;
        font-size: 12px;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
    }

    /* Grid */
    .config-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    @@media (max-width: 960px) {
        .config-grid {
            grid-template-columns: 1fr;
        }
    }

    /* Config Card */
    .config-card {
        background: #ffffff;
        border: 1px solid rgba(199, 196, 215, 0.3);
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: 0px 4px 20px rgba(0, 0, 0, 0.02);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 1.25rem;
    }

    .config-header-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
    }

    .config-title {
        font-size: 18px;
        font-weight: 800;
        color: #191c1e;
        margin: 0;
    }

    .config-key {
        font-size: 12px;
        color: #767586;
        font-weight: 500;
        margin-top: 2px;
        display: block;
    }

    .badge-group {
        display: flex;
        gap: 4px;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .custom-badge {
        font-size: 10px;
        font-weight: 700;
        padding: 3px 8px;
        border-radius: 4px;
        letter-spacing: 0.02em;
        text-transform: uppercase;
        display: inline-block;
    }

    .custom-badge.category-badge {
        background: #f1f3f5;
        border: 1px solid #e2e8f0;
        color: #575e72;
    }

    .custom-badge.critical-badge {
        background: #fef2f2;
        border: 1px solid #fca5a5;
        color: #b91c1c;
    }

    .custom-badge.unsaved-badge {
        background: rgba(70, 72, 212, 0.05);
        border: 1px solid rgba(70, 72, 212, 0.2);
        color: #4648d4;
    }

    .config-desc-label {
        font-size: 11px;
        font-weight: 700;
        color: #767586;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin-bottom: 0.5rem;
        display: block;
    }

    /* Sliders */
    .custom-slider-container {
        margin: 0.5rem 0;
    }

    .custom-slider {
        width: 100%;
        height: 6px;
        background: #e2e8f0;
        border-radius: 999px;
        outline: none;
        -webkit-appearance: none;
        appearance: none;
        cursor: pointer;
    }

    .custom-slider::-webkit-slider-thumb {
        -webkit-appearance: none;
        appearance: none;
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: #4648d4;
        cursor: pointer;
        box-shadow: 0 2px 6px rgba(70, 72, 212, 0.4);
        transition: transform 0.1s ease;
    }

    .custom-slider::-webkit-slider-thumb:hover {
        transform: scale(1.15);
    }

    .slider-labels {
        display: flex;
        justify-content: space-between;
        font-size: 10px;
        font-weight: 700;
        color: #94a3b8;
        margin-top: 6px;
    }

    .slider-value-box {
        display: flex;
        justify-content: space-between;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 10px 14px;
        margin-top: 12px;
    }

    .value-box-label {
        font-size: 13px;
        font-weight: 700;
        color: #575e72;
    }

    .value-box-val {
        font-size: 14px;
        font-weight: 800;
        color: #4648d4;
    }

    /* Custom Switch */
    .switch-field-group {
        display: flex;
        align-items: center;
        gap: 12px;
        margin: 0.5rem 0;
    }

    .custom-switch-container {
        position: relative;
        display: inline-block;
        width: 48px;
        height: 24px;
