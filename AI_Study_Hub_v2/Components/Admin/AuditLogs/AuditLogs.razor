@namespace AI_Study_Hub_v2.Components.Admin.AuditLogs
@page "/admin/audit-logs"
@layout AdminLayout
@implements IDisposable
@using MudBlazor
@using AI_Study_Hub_v2.Components.Admin.Shared
@inject ISnackbar Snackbar
@inject AuthSessionState Session
@inject AdminApiClient AdminApi

<div class="audit-page">
    <div class="breadcrumbs-container">
        GOVERNANCE > AUDIT LOGS
    </div>

    <div class="page-header-row">
        <div>
            <h1 class="page-title">Audit Logs</h1>
            <p class="page-desc">Review administrator actions, user security events, moderation decisions, configuration changes, and before/after JSON payloads.</p>
        </div>
        <div class="header-actions">
            <button class="header-outline-btn" @onclick="Reload">
                <MudIcon Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" />
                <span>REFRESH</span>
            </button>
            <button class="header-filled-btn" disabled title="Export not available">
                <MudIcon Icon="@Icons.Material.Filled.Download" Size="Size.Small" />
                <span>EXPORT NOT AVAILABLE</span>
            </button>
        </div>
    </div>

    <!-- Search & Filters -->
    <div class="filter-row-custom mb-6">
        <div class="search-input-wrapper">
            <input type="text" class="search-input" placeholder="Search action, actor, entity, IP, or JSON..."
                   value="@_searchText" @oninput="OnSearchInput" />
            <MudIcon Icon="@Icons.Material.Filled.Search" Class="search-icon" Size="Size.Small" />
        </div>
        <select class="filter-select" value="@_selectedAction" @onchange="OnActionChanged">
            <option value="">Action</option>
            @foreach (var action in _logs.Select(log => log.Action).Distinct().OrderBy(action => action))
            {
                <option value="@action">@action</option>
            }
        </select>
        <select class="filter-select" value="@_selectedActor" @onchange="OnActorChanged">
            <option value="">Actor</option>
            @foreach (var actor in _logs.Select(log => log.ActorEmail).Distinct().OrderBy(actor => actor))
            {
                <option value="@actor">@actor</option>
            }
        </select>
        <select class="filter-select" value="@_selectedSeverity" @onchange="OnSeverityChanged">
            <option value="">Severity</option>
            <option value="@HighSeverity">High</option>
            <option value="@MediumSeverity">Medium</option>
            <option value="@LowSeverity">Low</option>
        </select>
        <select class="filter-select" value="@_selectedEntityType" @onchange="OnEntityTypeChanged">
            <option value="">Entity Type</option>
            <option value="User">User</option>
            <option value="Document">Document</option>
            <option value="Folder">Folder</option>
            <option value="Chat">Chat</option>
            <option value="Config">Config</option>
            <option value="Escalation">Escalation</option>
            <option value="Payment">Payment</option>
        </select>
        <div class="date-range-wrapper">
            <div class="date-presets">
                <button class="preset-btn @(_selectedDateFrom is null ? "preset-active" : "")" @onclick="() => SetDatePreset(null, null)">All time</button>
                <button class="preset-btn @(IsPresetActive(7) ? "preset-active" : "")" @onclick="() => SetDatePreset(DateTime.UtcNow.AddDays(-7), null)">Last 7 days</button>
                <button class="preset-btn @(IsPresetActive(30) ? "preset-active" : "")" @onclick="() => SetDatePreset(DateTime.UtcNow.AddDays(-30), null)">Last 30 days</button>
            </div>
            <div class="date-inputs">
                <input type="date" class="custom-date-picker" value="@(_selectedDateFrom?.ToString("yyyy-MM-dd"))" @onchange="OnDateFromChanged" placeholder="From" />
                <span class="date-separator">→</span>
                <input type="date" class="custom-date-picker" value="@(_selectedDateTo?.ToString("yyyy-MM-dd"))" @onchange="OnDateToChanged" placeholder="To" />
            </div>
        </div>
        @{
            var hasActiveFilters = !string.IsNullOrWhiteSpace(_searchText)
                || !string.IsNullOrWhiteSpace(_selectedAction)
                || !string.IsNullOrWhiteSpace(_selectedActor)
                || !string.IsNullOrWhiteSpace(_selectedSeverity) || !string.IsNullOrWhiteSpace(_selectedEntityType) || _selectedDateFrom is not null || _selectedDateTo is not null;
            var filterIconColor = hasActiveFilters ? "#575e72" : "#c7c6d5";
            var filterIconStyle = $"font-size: 18px; color: {filterIconColor};";
        }
        <button class="filter-btn @(hasActiveFilters ? "" : "muted")" @onclick="ClearFiltersAsync" disabled="@(!hasActiveFilters)" title="@(hasActiveFilters ? "Clear all filters" : "No filters active")">
            <MudIcon Icon="@Icons.Material.Outlined.FilterAltOff" Style="@filterIconStyle" />
        </button>
    </div>

    <!-- Active Filters -->
    @if (ActiveFilters.Any())
    {
        <div class="active-filters-container">
            @foreach (var filter in ActiveFilters)
            {
                <span class="filter-pill">
                    @filter
                    <button class="filter-pill-close" @onclick="@(() => RemoveFilterAsync(filter))">×</button>
                </span>
            }
            <button class="clear-all-btn" @onclick="ClearFiltersAsync">Clear all filters</button>
        </div>
    }

    <div class="total-events-badge mb-6">
        <span class="total-label">@(_selectedCategory == "All" ? "TOTAL EVENTS" : _categories.First(c => c.Key == _selectedCategory).Label.ToUpper())</span>
        <span class="total-value">@_logs.Count</span>
    </div>

    <div class="category-tab-bar mb-6">
        @foreach (var cat in _categories)
        {
            <button class="category-tab @(cat.Key == _selectedCategory ? "cat-active" : "")" @onclick="() => { _selectedCategory = cat.Key; }">
                <span class="cat-icon">@cat.Icon</span>
                <span class="cat-label">@cat.Label</span>
                <span class="cat-count">@cat.Count</span>
            </button>
        }
    </div>

    @{
        var actorGroups = _logs
            .GroupBy(log => log.ActorEmail)
            .Select(g => new { Actor = g.Key, Count = g.Count(), HighCount = g.Count(l => l.Severity == HighSeverity), LastAt = g.Max(l => l.CreatedAt) })
            .OrderByDescending(g => g.Count)
            .Take(6)
            .ToList();
    }
    @if (actorGroups.Any())
    {
        <div class="actor-summary-section mb-6" style="background: #ffffff; border: 1px solid rgba(199, 196, 215, 0.3); border-radius: 12px; padding: 1.25rem;">
            <div class="d-flex align-center justify-space-between mb-4">
                <span style="font-size: 14px; font-weight: 700; color: #191c1e;">Actor Activity</span>
                <span style="font-size: 11px; color: #767586;">Top @actorGroups.Count actors</span>
            </div>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 0.75rem;">
                @foreach (var group in actorGroups)
                {
                    <div class="actor-card @(_selectedActor == group.Actor ? "actor-active" : "")" @onclick="@(() => { _selectedActor = group.Actor; })" style="cursor: pointer; padding: 0.75rem; border: 1px solid rgba(199, 196, 215, 0.2); border-radius: 8px; transition: all 0.2s; background: @(_selectedActor == group.Actor ? "rgba(70, 72, 212, 0.04)" : "#fafbfc");">
                        <div style="font-size: 13px; font-weight: 600; color: #191c1e; margin-bottom: 4px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@group.Actor</div>
                        <div style="font-size: 20px; font-weight: 800; color: #191c1e; line-height: 1;">@group.Count</div>
                        <div style="font-size: 10px; color: #767586; margin-top: 2px;">actions</div>
                        @if (group.HighCount > 0)
                        {
                            <div style="font-size: 10px; color: #ba1a1a; font-weight: 600; margin-top: 4px;">⚠ @group.HighCount HIGH</div>
                        }
                        <div style="font-size: 10px; color: #9ca3af; margin-top: 2px;">Last: @group.LastAt.ToString("HH:mm")</div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- KPI Grid -->
    <div class="kpi-grid-container mb-6">
        <div class="kpi-card-custom">
            <div class="kpi-card-bottom">
                <span class="kpi-label">VISIBLE EVENTS</span>
                <div class="kpi-value">@FilteredLogs.Count()</div>
                <span class="kpi-subtext">After filters</span>
            </div>
        </div>
        <div class="kpi-card-custom card-high-severity">
            <div class="kpi-card-bottom">
                <span class="kpi-label">HIGH SEVERITY</span>
                <div class="kpi-value danger-color">@FilteredLogs.Count(log => log.Severity == HighSeverity)</div>
                <span class="kpi-subtext">Immediate review</span>
            </div>
        </div>
        <div class="kpi-card-custom">
            <div class="kpi-card-bottom">
                <span class="kpi-label">CONFIG CHANGES</span>
                <div class="kpi-value">@FilteredLogs.Count(log => log.Action == ConfigChangeAction)</div>
                <div class="kpi-subtext">
                    <span class="stat-badge">UC13 trace</span>
                </div>
            </div>
        </div>
        <div class="kpi-card-custom">
            <div class="kpi-card-bottom">
                <span class="kpi-label">MODERATION</span>
                <div class="kpi-value">@FilteredLogs.Count(log => log.Action.StartsWith("DOCUMENT_", StringComparison.OrdinalIgnoreCase))</div>
                <div class="kpi-subtext">
                    <span class="stat-badge">UC10 decisions</span>
                </div>
            </div>
        </div>
    </div>

    <!-- List Items -->
    @if (_isLoading)
    {
        <div style="display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1.5rem;">
            @for (var index = 0; index < 3; index++)
            {
                <MudSkeleton Height="92px" Animation="Animation.Wave" Style="border-radius: 8px;" />
            }
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-6">@_errorMessage</MudAlert>
    }
    else if (!FilteredLogs.Any())
    {
        <div class="empty-state mb-6" style="background: #ffffff; border: 1px solid rgba(199, 196, 215, 0.3); border-radius: 12px; padding: 3rem; text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 280px;">
            <MudIcon Icon="@Icons.Material.Filled.ManageSearch" Size="Size.Large" Color="Color.Secondary" Style="font-size: 48px; color: #767586;" />
            <h3 style="font-size: 18px; font-weight: 800; margin-top: 1rem; color: #191c1e;">No @(_selectedCategory == "All" ? "audit events" : _categories.First(c => c.Key == _selectedCategory).Label.ToLower()) events found</h3>
            <p style="font-size: 14px; color: #575e72; margin-top: 0.5rem;">Adjust filters to inspect a wider time range.</p>
        </div>
    }
    else
    {
        <div class="audit-list-card mb-6">
            <div class="audit-rows-container">
                @foreach (var log in FilteredLogs)
                {
                    <div class="audit-row-custom">
                        <div class="audit-row-summary" @onclick="@(() => ToggleExpand(log.Id))">
                            <!-- Col 1: Action Badge & Date -->
                            <div>
                                <span class="action-badge-custom @GetActionClass(log.Action)">@log.Action</span>
                                <div class="col-subtitle">@FormatDateTime(log.CreatedAt)</div>
                            </div>
                            
                            <!-- Col 2: Actor & IP -->
                            <div>
                                <div class="col-title">@log.ActorEmail</div>
                                <div class="col-subtitle">@log.IpAddress</div>
                            </div>

                            <!-- Col 3: Target Entity & ID -->
                            <div>
                                <div class="col-title">@log.EntityName</div>
                                <div class="col-subtitle">@log.EntityId</div>
                            </div>

                            <!-- Col 4: Severity Badge -->
                            <div>
                                <span class="col-meta-label">SEVERITY</span>
                                <span class="severity-badge-custom severity-@log.Severity.ToLowerInvariant()">@log.Severity</span>
                            </div>

                            <!-- Col 5: Request ID & Expand -->
                            <div class="req-wrapper">
                                <span class="col-meta-label">REQUEST</span>
                                <span class="req-value">@log.RequestId</span>
                                <MudIcon Icon="@(IsExpanded(log.Id) ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Size="Size.Small" Style="color: #767586; margin-left: auto;" />
                            </div>
                        </div>

                        @if (IsExpanded(log.Id))
                        {
                            <div class="audit-row-details">
                                <div class="details-grid">
                                    <div>
                                        <span class="details-section-title">Before</span>
                                        <pre class="audit-json-box">@log.BeforeJson</pre>
                                    </div>
                                    <div>
                                        <span class="details-section-title">After</span>
                                        <pre class="audit-json-box">@log.AfterJson</pre>
                                    </div>
                                    <div>
                                        <span class="details-section-title">Context</span>
                                        <pre class="audit-json-box">@log.ContextJson</pre>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Pagination Footer -->
            <div class="pagination-row-custom">
                <span class="pagination-info">Showing @FilteredLogs.Count() events</span>
            </div>
        </div>
    }
</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap');

    .audit-page {
        font-family: 'Hanken Grotesk', sans-serif;
        color: #191c1e;
        animation: pageRise 0.4s ease-out;
    }

    /* Breadcrumbs */
    .breadcrumbs-container {
        font-size: 11px;
        font-weight: 700;
        color: #4648d4;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin-bottom: 0.5rem;
    }

    /* Page Header */
    .page-header-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .page-title {
        font-size: 28px;
        font-weight: 800;
        color: #191c1e;
        margin: 0;
        line-height: 1.2;
    }

    .page-desc {
        font-size: 14px;
        color: #575e72;
        margin: 4px 0 0 0;
    }

    .header-actions {
        display: flex;
        gap: 0.75rem;
        align-items: center;
    }

    .header-outline-btn {
        background: #ffffff;
        border: 1px solid #c7c6d5;
        border-radius: 8px;
        height: 38px;
        font-weight: 700;
        font-size: 12px;
        color: #575e72;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 16px;
        gap: 8px;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .header-outline-btn:hover {
        background-color: #f8fafc;
        border-color: #767586;
    }

    .header-filled-btn {
        background: #4648d4;
        border: none;
        border-radius: 8px;
        height: 38px;
        font-weight: 700;
        font-size: 12px;
        color: #ffffff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 16px;
        gap: 8px;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .header-filled-btn:hover {
        background-color: #3b3dbb;
    }

    /* Category Tab Bar */
    .category-tab-bar {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        overflow-x: auto;
    }

    .category-tab {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        border: 1px solid #e0e3e5;
        border-radius: 8px;
        background: #ffffff;
        cursor: pointer;
        font-family: 'Hanken Grotesk', sans-serif;
        font-size: 12px;
        color: #575e72;
        white-space: nowrap;
        transition: all 0.2s;
    }

    .category-tab:hover {
        background: #f8fafc;
        border-color: rgba(70, 72, 212, 0.3);
    }

    .cat-active {
        background: rgba(70, 72, 212, 0.08);
        color: #4648d4;
        border-color: rgba(70, 72, 212, 0.4);
        font-weight: 700;
    }

    .cat-icon {
        font-size: 14px;
    }

    .cat-label {
        font-weight: 600;
    }

    .cat-count {
        font-size: 11px;
        font-weight: 700;
        padding: 1px 6px;
        border-radius: 9999px;
        background: #f1f5f9;
        color: #767586;
        min-width: 20px;
        text-align: center;
    }

    .cat-active .cat-count {
        background: rgba(70, 72, 212, 0.15);
        color: #4648d4;
    }

    .dark-theme .category-tab {
        background: #1e2124;
        border-color: rgba(255, 255, 255, 0.08);
        color: #94a3b8;
    }

    .dark-theme .cat-active {
        background: rgba(129, 140, 248, 0.12);
        color: #818cf8;
        border-color: rgba(129, 140, 248, 0.25);
    }

    .dark-theme .cat-count {
        background: #25282c;
        color: #94a3b8;
    }

    .dark-theme .cat-active .cat-count {
        background: rgba(129, 140, 248, 0.2);
        color: #818cf8;
    }

    /* KPI Grid */
    /* Total Events Badge */
    .total-events-badge {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: #ffffff;
        border: 1px solid rgba(70, 72, 212, 0.2);
        border-radius: 10px;
        padding: 0.75rem 1.25rem;
        margin-bottom: 1.5rem;
        box-shadow: 0px 4px 20px rgba(0, 0, 0, 0.03);
    }

    .total-label {
        font-size: 11px;
        font-weight: 700;
        color: #767586;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    .total-value {
        font-size: 22px;
        font-weight: 800;
        color: #4648d4;
    }

    .dark-theme .total-events-badge {
        background-color: #1e2124 !important;
        border-color: rgba(255, 255, 255, 0.08) !important;
    }

    .dark-theme .total-label {
        color: #94a3b8 !important;
    }

    .dark-theme .total-value {
        color: #818cf8 !important;
    }

    .kpi-grid-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.25rem;
        margin-bottom: 1.5rem;
    }

    .kpi-card-custom {
        background: #ffffff;
        border: 1px solid rgba(199, 196, 215, 0.3);
        border-radius: 12px;
        padding: 1.25rem;
        box-shadow: 0px 4px 20px rgba(0, 0, 0, 0.03);
    }

    .kpi-card-custom.card-high-severity {
        border-color: #fca5a5;
    }

    .kpi-label {
        font-size: 11px;
        font-weight: 700;
        color: #767586;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        display: block;
    }

    .kpi-value {
        font-size: 28px;
        font-weight: 800;
        color: #191c1e;
        margin-top: 4px;
        line-height: 1.1;
    }

    .kpi-value.danger-color {
        color: #b91c1c;
    }

    .kpi-subtext {
        font-size: 12px;
        color: #767586;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 6px;
        margin-top: 4px;
    }

    .stat-badge {
        background: #f1f3f5;
        color: #767586;
        font-size: 10px;
        font-weight: 700;
        padding: 2px 6px;
        border-radius: 4px;
        text-transform: uppercase;
    }

    /* Filter Row */
    .filter-row-custom {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
    }

    .search-input-wrapper {
        position: relative;
        flex: 1;
        min-width: 260px;
    }

    .search-icon {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #767586;
        pointer-events: none;
    }

    .search-input {
        width: 100%;
        height: 40px;
        padding: 0 12px 0 40px;
        border: 1px solid #c7c6d5;
        border-radius: 8px;
        background: #ffffff;
        color: #191c1e;
        font-size: 14px;
        font-weight: 500;
        outline: none;
        transition: border-color 0.2s;
    }

    .search-input:focus {
        border-color: #4648d4;
    }

    .filter-select {
        height: 40px;
        padding: 0 24px 0 12px;
        border: 1px solid #c7c6d5;
        border-radius: 8px;
        background: #ffffff;
        color: #191c1e;
        font-size: 14px;
        font-weight: 600;
        outline: none;
        cursor: pointer;
        min-width: 130px;
        background-image: url("data:image/svg+xml;charset=utf-8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%23575e72'%3E%3Cpath d='M7 10l5 5 5-5z'/%3E%3C/svg%3E");
        background-repeat: no-repeat;
        background-position: right 8px center;
        background-size: 20px;
        -webkit-appearance: none;
        appearance: none;
    }

    .custom-date-picker {
        height: 40px;
        padding: 0 12px;
        border: 1px solid #c7c6d5;
        border-radius: 8px;
        background: #ffffff;
        color: #191c1e;
        font-size: 14px;
        font-weight: 600;
        outline: none;
        cursor: pointer;
        min-width: 160px;
    }

    .filter-btn {
        width: 40px;
        height: 40px;
        border: 1px solid #c7c6d5;
        border-radius: 8px;
        background: #ffffff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background-color 0.2s;
    }

    .filter-btn:hover {
        background-color: #f8fafc;
    }

    /* Active filter pills */
    .active-filters-container {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-bottom: 1.25rem;
    }

    .filter-pill {
        background-color: #f1f3f5;
        color: #575e72;
        font-size: 12px;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 9999px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .filter-pill-close {
        border: none;
        background: transparent;
        cursor: pointer;
        font-size: 12px;
        font-weight: bold;
        color: #767586;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .clear-all-btn {
        border: none;
        background: transparent;
        color: #4648d4;
        font-size: 12px;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
    }

    /* Audit List Card */
    .audit-list-card {
        background: #ffffff;
        border: 1px solid rgba(199, 196, 215, 0.3);
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: 0px 4px 20px rgba(0, 0, 0, 0.02);
    }

    .audit-rows-container {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    /* Custom Audit Row Card */
    .audit-row-custom {
