@namespace AI_Study_Hub_v2.Components.Admin.Shared
@inherits LayoutComponentBase
@implements IDisposable
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Routing
@using MudBlazor
@inject NavigationManager Navigation
@inject AuthSessionState Session
@inject AuthPersistenceService AuthPersistence
@inject AuthApiClient AuthApi

@if (_checkingAccess)
{
    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height: 100vh;">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        <MudText Typo="Typo.body2">Verifying administrator access…</MudText>
    </MudStack>
}
else if (_authorized)
{

<MudThemeProvider Theme="@_theme" IsDarkMode="@_isDarkMode" />

<MudLayout Class="admin-layout-shell">
    <MudDrawer @bind-Open="_drawerOpen"
               Variant="DrawerVariant.Responsive"
               Breakpoint="Breakpoint.Md"
               ClipMode="DrawerClipMode.Never"
               Elevation="0"
               Class="admin-sidebar">
        <div class="sidebar-brand">
            <h1 class="sidebar-title">AI Study Hub</h1>
            <p class="sidebar-subtitle">RAG ADMIN CONSOLE</p>
        </div>
        <nav class="sidebar-nav">
            <div class="sidebar-nav-item active" @onclick="@(() => Navigation.NavigateTo("/admin/dashboard"))">
                <MudIcon Icon="@Icons.Material.Filled.GridView" Size="Size.Small" /> Dashboard
            </div>
            <div class="sidebar-nav-item" @onclick="@(() => Navigation.NavigateTo("/admin/users"))">
                <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Small" /> Users & Permissions
            </div>
            <div class="sidebar-nav-item" @onclick="@(() => Navigation.NavigateTo("/admin/documents/moderation"))">
                <MudIcon Icon="@Icons.Material.Filled.FactCheck" Size="Size.Small" /> Document Moderation
            </div>
            <div class="sidebar-nav-item" @onclick="@(() => Navigation.NavigateTo("/admin/community-reports"))">
                <MudIcon Icon="@Icons.Material.Filled.ReportProblem" Size="Size.Small" /> Community Reports
            </div>
            <div class="sidebar-nav-item" @onclick="@(() => Navigation.NavigateTo("/admin/documents"))">
                <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Small" /> Document Library
            </div>
            <div class="sidebar-nav-item" @onclick="@(() => Navigation.NavigateTo("/admin/subjects"))">
                <MudIcon Icon="@Icons.Material.Filled.MenuBook" Size="Size.Small" /> Subjects
            </div>
            <div class="sidebar-nav-item" @onclick="@(() => Navigation.NavigateTo("/admin/settings"))">
                <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Small" /> AI System Settings
            </div>
            <div class="sidebar-nav-item" @onclick="@(() => Navigation.NavigateTo("/admin/audit-logs"))">
                <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" /> Audit Logs
            </div>
        </nav>
        <div class="sidebar-footer">
            <button class="sidebar-queue-btn" @onclick="@(() => Navigation.NavigateTo("/admin/documents/moderation"))">Open Queue</button>
            <div class="sidebar-nav-item"><MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Small" /> Settings</div>
            <div class="sidebar-nav-item"><MudIcon Icon="@Icons.Material.Filled.HelpOutline" Size="Size.Small" /> Support</div>
        </div>
    </MudDrawer>

    <MudMainContent Class="admin-main-content">
        <MudAppBar Elevation="0" Dense="true" Class="admin-topbar">
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
            <MudBreadcrumbs Items="@_breadcrumbs" Separator="/" Class="admin-breadcrumbs" />
            <MudSpacer />
            <MudIconButton Icon="@ThemeIcon" Color="Color.Inherit" OnClick="ToggleTheme" />
            <MudButton Variant="Variant.Text" Color="Color.Inherit" Size="Size.Small" OnClick="SignOutAsync" StartIcon="@Icons.Material.Filled.Logout">Logout</MudButton>
        </MudAppBar>
        <MudContainer MaxWidth="MaxWidth.False" Class="admin-page-frame">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>
}

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode;
    private bool _checkingAccess = true;
    private bool _authorized;
    private List<BreadcrumbItem> _breadcrumbs = new();

    private string ThemeIcon => _isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#5A32EA",
            PrimaryDarken = "#4C28D4",
            Secondary = "#10B981",
            Background = "#F8FAFC",
            Surface = "#FFFFFF",
            AppbarBackground = "#FFFFFF",
            AppbarText = "#1E293B",
            DrawerBackground = "#FFFFFF",
            DrawerText = "#64748B",
            DrawerIcon = "#5A32EA",
            TextPrimary = "#1E293B",
            TextSecondary = "#64748B",
            LinesDefault = "#E2E8F0",
            Info = "#3B82F6",
            Success = "#10B981",
            Warning = "#F59E0B",
            Error = "#EF4444"
        }
    };

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
        BuildBreadcrumbs();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await VerifyAccessAsync();
    }

    private async Task VerifyAccessAsync()
    {
        try
        {
            if (!Session.IsAuthenticated)
            {
                var restored = await AuthPersistence.TryRestoreAsync();
                if (restored is not null && restored.ExpiresAt > DateTimeOffset.UtcNow)
                    Session.Set(restored);
            }
            if (!Session.IsAuthenticated || string.IsNullOrWhiteSpace(Session.AccessToken))
            {
                await RedirectToLoginAsync();
                return;
            }
            var verifiedUser = await AuthApi.GetMeAsync(Session.AccessToken);
            if (Session.Session is not null)
            {
                Session.Session.User = verifiedUser;
                Session.Set(Session.Session);
                await AuthPersistence.SaveAsync(Session.Session);
            }
            if (!AdminAccessPolicy.IsAdmin(verifiedUser.Role))
            {
                _checkingAccess = false;
                Navigation.NavigateTo("/documents", replace: true);
                return;
            }
            _authorized = true;
            _checkingAccess = false;
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            Session.Clear();
            await AuthPersistence.ClearAsync();
            await RedirectToLoginAsync();
        }
    }

    private async Task RedirectToLoginAsync()
    {
        _authorized = false;
        _checkingAccess = false;
        await InvokeAsync(StateHasChanged);
        Navigation.NavigateTo("/login", replace: true);
    }

    private async Task SignOutAsync()
    {
        Session.Clear();
        await AuthPersistence.ClearAsync();
        Navigation.NavigateTo("/login", replace: true);
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void ToggleTheme() => _isDarkMode = !_isDarkMode;

    private void OnLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        BuildBreadcrumbs();
        _ = InvokeAsync(StateHasChanged);
    }

    private void BuildBreadcrumbs()
    {
        var relative = Navigation.ToBaseRelativePath(Navigation.Uri).Trim('/');
        var segments = string.IsNullOrWhiteSpace(relative) ? new[] { "admin", "dashboard" } : relative.Split('/', StringSplitOptions.RemoveEmptyEntries);
        _breadcrumbs = new List<BreadcrumbItem> { new("Admin", "/admin/dashboard") };
        var path = string.Empty;
        foreach (var segment in segments.Where(s => !s.Equals("admin", StringComparison.OrdinalIgnoreCase)))
        {
            path += $"/{segment}";
            _breadcrumbs.Add(new BreadcrumbItem(ToTitle(segment), $"/admin{path}"));
        }
    }

    private static string ToTitle(string value) =>
        string.Join(' ', value.Split('-', StringSplitOptions.RemoveEmptyEntries).Select(p => char.ToUpperInvariant(p[0]) + p[1..]));

    public void Dispose() => Navigation.LocationChanged -= OnLocationChanged;
}

<style>
    .admin-layout-shell { min-height: 100vh; background: #F8FAFC; }
    .admin-topbar { background: #FFFFFF !important; border-bottom: 1px solid #E2E8F0; color: #1E293B; }
    .admin-main-content { background: #F8FAFC; min-height: 100vh; }
    .admin-page-frame { padding: 5rem 3rem 3rem; max-width: 100%; }
    .admin-sidebar { background: #FFFFFF !important; display: flex; flex-direction: column; width: 260px; border-right: 1px solid #E2E8F0; }
    .sidebar-brand { padding: 2rem 1.5rem 1.5rem; }
    .sidebar-title { color: #5A32EA; font-size: 1.25rem; font-weight: 700; margin: 0; line-height: 1.3; }
    .sidebar-subtitle { color: #64748B; font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; margin-top: 4px; }
    .sidebar-nav { flex: 1; padding: 0 12px; display: flex; flex-direction: column; gap: 3px; overflow-y: auto; }
    .sidebar-nav-item { display: flex; align-items: center; gap: 12px; padding: 10px 16px; border-radius: 8px; cursor: pointer; transition: all 0.15s; color: #64748B; font-size: 13px; font-weight: 600; }
    .sidebar-nav-item:hover { background: #F5F3FF; color: #5A32EA; }
    .sidebar-nav-item.active { background: #5A32EA; color: #FFFFFF !important; }
    .sidebar-nav-item.active .mud-icon-root { color: #FFFFFF !important; }
    .sidebar-footer { padding: 16px; border-top: 1px solid #E2E8F0; display: flex; flex-direction: column; gap: 4px; margin-top: auto; }
    .sidebar-queue-btn { width: 100%; background: #5A32EA; color: #FFFFFF; border: none; padding: 10px; border-radius: 10px; font-size: 13px; font-weight: 700; cursor: pointer; }
    .sidebar-queue-btn:hover { background: #4C28D4; }
    .admin-breadcrumbs .mud-breadcrumb-item, .admin-breadcrumbs .mud-breadcrumb-separator { color: #64748B !important; }
</style>
