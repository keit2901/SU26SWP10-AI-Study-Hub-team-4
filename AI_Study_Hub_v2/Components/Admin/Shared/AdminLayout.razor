@namespace AI_Study_Hub_v2.Components.Admin.Shared
@inherits LayoutComponentBase
@implements IDisposable
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Routing
@using MudBlazor
@inject NavigationManager Navigation
@inject AuthSessionState Session
@inject AuthPersistenceService AuthPersistence
@inject AuthApiClient AuthApi

@if (_checkingAccess)
{
    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height: 100vh;">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        <MudText Typo="Typo.body2">Verifying administrator access…</MudText>
    </MudStack>
}
else if (_authorized)
{

<MudThemeProvider Theme="@_theme" IsDarkMode="@_isDarkMode" />

<MudLayout Class="admin-layout-shell">
    <MudAppBar Elevation="0" Dense="true" Class="admin-topbar" Color="Color.Surface">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudBreadcrumbs Items="@_breadcrumbs" Separator="/" Class="admin-breadcrumbs" />
        <MudSpacer />
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudChip T="string" Color="Color.Success" Variant="Variant.Outlined" Size="Size.Small" Icon="@Icons.Material.Filled.VerifiedUser">
                Admin workspace
            </MudChip>
        </MudHidden>
        <MudTooltip Text="Toggle theme">
            <MudIconButton Icon="@ThemeIcon" Color="Color.Inherit" OnClick="ToggleTheme" />
        </MudTooltip>
        <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="true">
            <ActivatorContent>
                <MudBadge Content="5" Color="Color.Error" Overlap="true" Class="me-2">
                    <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit" />
                </MudBadge>
            </ActivatorContent>
            <ChildContent>
                <MudMenuItem Icon="@Icons.Material.Filled.Gavel" OnClick="@(() => Navigation.NavigateTo("/admin/documents/moderation"))">7 documents need moderation</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.ReportProblem" OnClick="@(() => Navigation.NavigateTo("/admin/dashboard"))">4 failed processing jobs</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.DataUsage" OnClick="@(() => Navigation.NavigateTo("/admin/users"))">12 users near token quota</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.Tune" OnClick="@(() => Navigation.NavigateTo("/admin/settings"))">2 critical config drafts</MudMenuItem>
            </ChildContent>
        </MudMenu>
        <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="SignOutAsync" StartIcon="@Icons.Material.Filled.Logout" Class="admin-logout-btn">
            <MudHidden Breakpoint="Breakpoint.SmAndDown">Logout</MudHidden>
        </MudButton>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Variant="DrawerVariant.Responsive"
               Breakpoint="Breakpoint.Md"
               ClipMode="DrawerClipMode.Never"
               Elevation="0"
               Class="admin-sidebar">
        <MudDrawerHeader Class="admin-sidebar-header">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Medium">
                    <MudIcon Icon="@Icons.Material.Filled.AutoStories" />
                </MudAvatar>
                <div>
                    <MudText Typo="Typo.h6" Class="admin-brand">AI Study Hub</MudText>
                    <MudText Typo="Typo.caption" Class="admin-brand-subtitle">RAG Admin Console</MudText>
                </div>
            </MudStack>
        </MudDrawerHeader>

        <MudNavMenu Dense="true" Class="px-3 admin-nav-menu">
            <MudNavLink Href="/admin/dashboard" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
            <MudNavGroup Title="Operations" Icon="@Icons.Material.Filled.Workspaces" Expanded="true">
                <MudNavLink Href="/admin/users" Icon="@Icons.Material.Filled.People">Users & Permissions</MudNavLink>
                <MudNavLink Href="/admin/documents/moderation" Icon="@Icons.Material.Filled.Gavel">Document Moderation</MudNavLink>
                <MudNavLink Href="/admin/community-reports" Icon="@Icons.Material.Filled.Flag">Community Reports</MudNavLink>
                <MudNavLink Href="/admin/documents" Icon="@Icons.Material.Filled.Description">Document Library</MudNavLink>
                <MudNavLink Href="/admin/subjects" Icon="@Icons.Material.Filled.AutoStories">Subjects</MudNavLink>
            </MudNavGroup>
            <MudNavGroup Title="Governance" Icon="@Icons.Material.Filled.Policy" Expanded="true">
                <MudNavLink Href="/admin/settings" Icon="@Icons.Material.Filled.Tune">AI System Settings</MudNavLink>
                <MudNavLink Href="/admin/audit-logs" Icon="@Icons.Material.Filled.ManageSearch">Audit Logs</MudNavLink>
            </MudNavGroup>
        </MudNavMenu>

        <MudSpacer />

        <div class="admin-sidebar-card">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.subtitle2">Retrieval readiness</MudText>
                    <MudText Typo="Typo.caption">82%</MudText>
                </MudStack>
                <MudProgressLinear Value="82" Color="Color.Success" Rounded="true" />
                <MudText Typo="Typo.caption">126 indexed documents, 7 awaiting review, 4 failed jobs.</MudText>
            </MudStack>
        </div>
    </MudDrawer>

    <MudMainContent Class="admin-main-content">
        <MudContainer MaxWidth="MaxWidth.False" Class="admin-page-frame">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>
}

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode;
    private bool _checkingAccess = true;
    private bool _authorized;
    private List<BreadcrumbItem> _breadcrumbs = new();

    private string ThemeIcon => _isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#4F46E5",
            PrimaryDarken = "#4338CA", // Slightly darker indigo for hover/active
            Secondary = "#0F766E",
            Tertiary = "#64748B", // TextSecondary
            Background = "#F8FAFC",
            Surface = "#FFFFFF",
            AppbarBackground = "#FFFFFF",
            AppbarText = "#0F172A",
            DrawerBackground = "#FFFFFF",
            DrawerText = "#0F172A",
            DrawerIcon = "#4F46E5",
            TextPrimary = "#0F172A",
            TextSecondary = "#64748B",
            LinesDefault = "#E2E8F0",
            Info = "#2563EB", // Keep existing info color or define a new one if needed
            Success = "#10B981",
            Warning = "#F59E0B",
            Error = "#E11D48"
        },
        PaletteDark = new PaletteDark // Adjust dark palette to be consistent with the new light palette
        {
            Primary = "#7C3AED", // A lighter purple for dark mode primary
            PrimaryDarken = "#6D28D9",
            Secondary = "#2DD4BF", // Lighter teal
            Tertiary = "#94A3B8",
            Background = "#1E293B", // Darker background
            Surface = "#334155", // Darker surface
            AppbarBackground = "#1E293B",
            AppbarText = "#F8FAFC",
            DrawerBackground = "#1E293B",
            DrawerText = "#F8FAFC",
            DrawerIcon = "#7C3AED",
            TextPrimary = "#F8FAFC",
            TextSecondary = "#94A3B8",
            LinesDefault = "#475569",
            Info = "#60A5FA",
            Success = "#4ADE80",
            Warning = "#F59E0B",
            Error = "#F87171"
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = new[] { "Plus Jakarta Sans", "Inter", "Segoe UI", "sans-serif" },
                FontSize = ".95rem"
            },
            H4 = new H4Typography
            {
                FontFamily = new[] { "Plus Jakarta Sans", "Inter", "sans-serif" },
                FontWeight = "700",
                LetterSpacing = "-.035em"
            },
            H5 = new H5Typography
            {
                FontFamily = new[] { "Plus Jakarta Sans", "Inter", "sans-serif" },
                FontWeight = "700",
                LetterSpacing = "-.025em"
            }
        }
    };

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
        BuildBreadcrumbs();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await VerifyAccessAsync();
    }

    private async Task VerifyAccessAsync()
    {
        try
        {
            if (!Session.IsAuthenticated)
            {
                var restored = await AuthPersistence.TryRestoreAsync();
                if (restored is not null && restored.ExpiresAt > DateTimeOffset.UtcNow)
                {
                    Session.Set(restored);
                }
            }

            if (!Session.IsAuthenticated || string.IsNullOrWhiteSpace(Session.AccessToken))
            {
                await RedirectToLoginAsync();
                return;
            }

            var verifiedUser = await AuthApi.GetMeAsync(Session.AccessToken);
            if (Session.Session is not null)
            {
                Session.Session.User = verifiedUser;
                Session.Set(Session.Session);
                await AuthPersistence.SaveAsync(Session.Session);
            }

            if (!AdminAccessPolicy.IsAdmin(verifiedUser.Role))
            {
                _checkingAccess = false;
                Navigation.NavigateTo("/documents", replace: true);
                return;
            }

            _authorized = true;
            _checkingAccess = false;
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            Session.Clear();
            await AuthPersistence.ClearAsync();
            await RedirectToLoginAsync();
        }
    }

    private async Task RedirectToLoginAsync()
    {
        _authorized = false;
        _checkingAccess = false;
        await InvokeAsync(StateHasChanged);
        Navigation.NavigateTo("/login", replace: true);
    }

    private async Task SignOutAsync()
    {
        Session.Clear();
        await AuthPersistence.ClearAsync();
        Navigation.NavigateTo("/login", replace: true);
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private void ToggleTheme() => _isDarkMode = !_isDarkMode;

    private void OnLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        BuildBreadcrumbs();
        _ = InvokeAsync(StateHasChanged);
    }

    private void BuildBreadcrumbs()
    {
        var relative = Navigation.ToBaseRelativePath(Navigation.Uri).Trim('/');
        var segments = string.IsNullOrWhiteSpace(relative)
            ? new[] { "admin", "dashboard" }
            : relative.Split('/', StringSplitOptions.RemoveEmptyEntries);

        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Admin", "/admin/dashboard")
        };

        var path = string.Empty;
        foreach (var segment in segments.Where(segment => !segment.Equals("admin", StringComparison.OrdinalIgnoreCase)))
        {
            path += $"/{segment}";
            _breadcrumbs.Add(new BreadcrumbItem(ToTitle(segment), $"/admin{path}"));
        }
    }

    private static string ToTitle(string value)
    {
        return string.Join(' ', value
            .Split('-', StringSplitOptions.RemoveEmptyEntries)
            .Select(part => char.ToUpperInvariant(part[0]) + part[1..]));
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}

<style>
    .admin-layout-shell {
        min-height: 100vh;
        background: var(--mud-palette-background);
    }

    .admin-topbar {
        border-bottom: 1px solid var(--mud-palette-lines-default);
        backdrop-filter: blur(16px);
    }

    .admin-sidebar {
        border-right: 1px solid var(--mud-palette-lines-default);
    }

    .admin-sidebar-header {
        min-height: 92px;
        align-items: center;
    }

    .admin-brand {
        color: var(--mud-palette-drawer-text);
        font-family: 'Plus Jakarta Sans', sans-serif;
        letter-spacing: -.03em;
    }

    .admin-brand-subtitle {
        color: var(--mud-palette-text-secondary);
        text-transform: uppercase;
        letter-spacing: .14em;
        font-size: 0.7rem; /* Make it a bit smaller */
    }

    .admin-sidebar-card {
        margin: 1rem;
        padding: 1rem;
        border-radius: 18px;
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-lines-default);
        box-shadow: 0 1px 3px rgba(15,23,42,0.06), 0 8px 24px rgba(15,23,42,0.06);
    }

    .admin-sidebar-card .mud-typography-subtitle2 {
        color: var(--mud-palette-text-primary);
    }

    .admin-sidebar-card .mud-typography-caption {
        color: var(--mud-palette-text-secondary);
    }

    .admin-sidebar-card .mud-progress-linear-bar {
        background-color: var(--mud-palette-lines-default); /* Lighter bar for light card */
    }

    .admin-sidebar-card .mud-progress-linear-fill {
        background-color: var(--mud-palette-primary); /* Use primary color for fill */
    }

    /* Active NavLink styling */
    .admin-nav-menu .mud-navlink.mud-navlink-active {
        color: var(--mud-palette-primary) !important;
        background-color: rgba(var(--mud-palette-primary-rgb), 0.1); /* Subtle background for active */
        border-radius: 8px; /* Slightly rounded */
    }

    .admin-nav-menu .mud-navlink.mud-navlink-active .mud-nav-link-icon {
        color: var(--mud-palette-primary) !important;
    }

    .admin-breadcrumbs .mud-breadcrumb-item,
    .admin-breadcrumbs .mud-breadcrumb-separator {
        color: var(--mud-palette-text-secondary) !important; /* Use text secondary for breadcrumbs */
    }

    /* Remove dark mode component fixes as they will be handled by the general theme */
    .mud-theme-dark .mud-card {
        background-color: #0F2A27 !important;
        border: 1px solid #25514B !important;
    }

    .mud-theme-dark .mud-table-root {
        background-color: #0B2421;
    }

    .mud-theme-dark .mud-table-root .mud-table-head {
        background-color: #143A35;
    }

    .mud-theme-dark .mud-table-root td {
        color: #EAF7F4 !important;
    }

    .mud-theme-dark .mud-table-root th {
        color: #F3FFFC !important;
    }


    @@media (min-width: 960px) {
        .admin-page-frame {
            padding: 6rem 2.25rem 2.75rem;
        }
    }
</style>
