@namespace AI_Study_Hub_v2.Components.Admin.Shared
@using Microsoft.AspNetCore.Components
@using MudBlazor

<MudDrawer Open="@Open"
           OpenChanged="@OpenChanged"
           Anchor="Anchor.Right"
           Variant="DrawerVariant.Temporary"
           Elevation="8"
           Width="@Width"
           Class="entity-sheet-drawer">
    <div class="entity-sheet">
        <div class="entity-sheet-header">
            <div>
                <MudText Typo="Typo.h5">@Title</MudText>
                @if (!string.IsNullOrWhiteSpace(Subtitle))
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@Subtitle</MudText>
                }
            </div>
            <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="Close" />
        </div>

        <MudDivider />

        <div class="entity-sheet-body">
            @ChildContent
        </div>

        @if (FooterContent is not null)
        {
            <MudDivider />
            <div class="entity-sheet-footer">
                @FooterContent
            </div>
        }
    </div>
</MudDrawer>

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }
    [Parameter] public string Title { get; set; } = "Details";
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public string Width { get; set; } = "460px";
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? FooterContent { get; set; }

    private Task Close() => OpenChanged.InvokeAsync(false);
}

<style>
    .entity-sheet-drawer .mud-drawer-content {
        max-height: 100vh;
        overflow-y: auto;
    }

    .entity-sheet {
        background: #fafafb;
        min-height: 100%;
    }

    .entity-sheet-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.25rem;
    }

    .entity-sheet-footer {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 0.5rem;
        padding: 1.25rem;
    }

    .entity-sheet-body {
        flex: 1;
        padding: 1.25rem;
    }
</style>
