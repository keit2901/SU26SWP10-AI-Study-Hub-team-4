@namespace AI_Study_Hub_v2.Components.Admin.Shared
@using Microsoft.AspNetCore.Components
@using MudBlazor

<MudPaper Elevation="0" Class="filter-bar-shell">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="filter-bar-content" Style="flex-wrap: wrap;">
        <MudTextField T="string" Value="@SearchText"
                      ValueChanged="OnSearchTextChanged"
                      Placeholder="@SearchPlaceholder"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Immediate="true"
                      Clearable="true"
                      Class="filter-search" />

        @ChildContent

        @if (ActiveFilters.Any())
        {
            <MudDivider Vertical="true" FlexItem="true" Class="mx-1" />
            <MudChipSet T="string" Class="filter-chip-set">
                @foreach (var filter in ActiveFilters)
                {
                    <MudChip T="string" Value="@filter" Color="Color.Primary" Variant="Variant.Filled" OnClose="@(() => RemoveFilter.InvokeAsync(filter))">
                        @filter
                    </MudChip>
                }
            </MudChipSet>
            <MudButton Variant="Variant.Text" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.FilterAltOff" OnClick="ClearFilters">
                Clear
            </MudButton>
        }
    </MudStack>
</MudPaper>

@code {
    [Parameter] public string? SearchText { get; set; }
    [Parameter] public EventCallback<string?> SearchTextChanged { get; set; }
    [Parameter] public string SearchPlaceholder { get; set; } = "Search records";
    [Parameter] public IEnumerable<string> ActiveFilters { get; set; } = Enumerable.Empty<string>();
    [Parameter] public EventCallback<string> RemoveFilter { get; set; }
    [Parameter] public EventCallback ClearAllFilters { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private Task OnSearchTextChanged(string? value) => SearchTextChanged.InvokeAsync(value);

    private async Task ClearFilters()
    {
        await SearchTextChanged.InvokeAsync(null);
        await ClearAllFilters.InvokeAsync();
    }
}

<style>
    .filter-bar-shell {
        border-radius: 22px;
        padding: .9rem;
        border: 1px solid #E2E8F0;
        background: #FFFFFF;
        box-shadow: 0 1px 3px rgba(0,0,0,.06);
    }

    .dark-theme .filter-bar-shell {
        border: 1px solid rgba(199, 196, 215, 0.1);
        background: #1e2124;
        box-shadow: none;
    }

    .filter-bar-content {
        width: 100%;
    }

    .filter-search {
        min-width: min(100%, 320px);
        flex: 1 1 320px;
    }

    .filter-chip-set {
        max-width: 100%;
    }
</style>
