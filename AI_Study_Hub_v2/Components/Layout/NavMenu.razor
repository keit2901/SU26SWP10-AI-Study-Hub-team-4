@implements IDisposable
@inject AuthSessionState Session
@inject NavigationManager Nav

<header class="community-topbar">
    <div class="community-topbar-inner">
        <a class="brand-link" href="">
            <span class="brand-orb">AI</span>
            <span>
                <span class="brand-name">AI Study Hub</span>
                <span class="brand-subtitle">Secure RAG Forum</span>
            </span>
        </a>

        <input id="community-nav-toggle" type="checkbox" title="Navigation menu" class="navbar-toggler" />
        <label for="community-nav-toggle" class="navbar-toggler-label" aria-label="Toggle navigation"></label>

        <nav class="community-nav" onclick="document.getElementById('community-nav-toggle').checked = false">
            <NavLink class="nav-pill" href="" Match="NavLinkMatch.All">Forum</NavLink>
            @if (Session.IsAuthenticated)
            {
                <NavLink class="nav-pill" href="documents">Documents</NavLink>
                <NavLink class="nav-pill" href="ai/chat">AI Chat</NavLink>
                <NavLink class="nav-pill" href="documents/upload">Upload</NavLink>
                <NavLink class="nav-pill" href="profile">Profile</NavLink>
            }
            else
            {
                <NavLink class="nav-pill" href="login">Login</NavLink>
                <NavLink class="nav-pill" href="register">Register</NavLink>
            }
        </nav>

        <div class="community-actions">
            @if (Session.IsAuthenticated)
            {
                <span class="status-dot" title="Authenticated"></span>
                <a class="user-chip" href="profile">
                    <span class="user-avatar">@UserInitial</span>
                    <span>@Session.CurrentUser?.Username</span>
                </a>
                <button type="button" class="signout-button" @onclick="Logout">Sign out</button>
            }
            else
            {
                <a class="login-link" href="login">Login</a>
                <a class="join-button" href="register">Join beta</a>
            }
        </div>
    </div>
</header>

@code {
    private string UserInitial => string.IsNullOrWhiteSpace(Session.CurrentUser?.Username)
        ? "A"
        : Session.CurrentUser!.Username[0].ToString().ToUpperInvariant();

    protected override void OnInitialized()
    {
        Session.OnChange += OnSessionChanged;
    }

    private void OnSessionChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void Logout()
    {
        Session.Clear();
        Nav.NavigateTo("/login", replace: true);
    }

    public void Dispose()
    {
        Session.OnChange -= OnSessionChanged;
    }
}
