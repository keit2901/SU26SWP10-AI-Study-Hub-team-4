@implements IDisposable
@inject AuthSessionState Session
@inject AuthPersistenceService AuthPersistence
@inject IDialogService DialogService
@inject NavigationManager Nav
@inject PlanApiClient PlanApi

<header class="community-topbar teammate-topbar">
    <div class="community-topbar-inner teammate-topbar-inner">
        <a class="brand-link teammate-brand" href="">
            <span class="brand-orb teammate-brand-mark"><MudIcon Icon="@Icons.Material.Filled.School" Size="Size.Small" /></span>
            <span class="brand-name">AI Study Hub</span>
        </a>

        <input id="community-nav-toggle" type="checkbox" title="Navigation menu" class="navbar-toggler" />
        <label for="community-nav-toggle" class="navbar-toggler-label" aria-label="Toggle navigation"></label>

        <nav class="community-nav teammate-nav" onclick="...">
            @if (Session.IsAuthenticated)
            {
                @if (IsAdmin)
                {
                    <a class="nav-pill @NavClass("admin")" href="admin">Admin Panel</a>
                }
                @if (IsModeratorOrAdmin)
                {
                    <a class="nav-pill @NavClass("dashboard")" href="dashboard">Dashboard</a>
                }
                <a class="nav-pill @NavClass("documents")" href="documents">Library</a>
                <a class="nav-pill @NavClass("community")" href="community">Community</a>
                <a class="nav-pill @NavClass("ai/chat")" href="ai/chat">Workspace</a>
                <a class="nav-pill @NavClass("documents/upload")" href="documents/upload">Upload</a>
            }
            else
            {
                <a class="nav-pill @GuestNavClass(string.Empty)" href="">Dashboard</a>
                <button type="button" class="nav-pill nav-pill-static">Community</button>
                <a class="nav-pill @GuestNavClass("login")" href="login">Sign In</a>
                <a class="nav-pill @GuestNavClass("register")" href="register">Get Started</a>
            }
        </nav>

        <div class="community-actions teammate-actions">
            @if (Session.IsAuthenticated)
            {
                <UserAccountMenu />
            }
            else
            {
                <a class="login-link" href="login">Sign In</a>
                <a class="join-button" href="register">Get Started</a>
            }
        </div>
    </div>
</header>

@code {
    protected override async Task OnInitializedAsync()
    {
        Session.OnChange += OnSessionChanged;
        Nav.LocationChanged += OnLocationChanged;

        if (Session.IsAuthenticated && !string.IsNullOrWhiteSpace(Session.AccessToken))
        {
            try
            {
                await Session.LoadCurrentPlanAsync(PlanApi);
            }
            catch
            {
            }
        }
    }

    private string NavClass(string href)
    {
        var rel = Nav.ToBaseRelativePath(Nav.Uri).TrimEnd('/');
        if (href == "documents")
            return (rel == "documents" || rel.StartsWith("documents/")) && !rel.StartsWith("documents/upload") ? "active" : "";
        if (href == "documents/upload")
            return rel == "documents/upload" ? "active" : "";
        if (href == "admin")
            return rel == "admin" ? "active" : "";
        if (href == "dashboard")
            return rel == "dashboard" || rel.StartsWith("dashboard/") ? "active" : "";
        return rel == href ? "active" : "";
    }

    private string GuestNavClass(string href)
    {
        var rel = Nav.ToBaseRelativePath(Nav.Uri).TrimEnd('/');
        if (string.IsNullOrWhiteSpace(href))
        {
            return string.IsNullOrWhiteSpace(rel) ? "active" : "";
        }

        return rel.Equals(href, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    }

    private bool IsAdmin =>
        AdminAccessPolicy.IsAdmin(Session.CurrentUser?.Role);

    private bool IsModerator =>
        Session.CurrentUser?.Role?.Equals(Role.ModeratorRoleName, StringComparison.OrdinalIgnoreCase) == true;

    private bool IsModeratorOrAdmin => IsAdmin || IsModerator;

    private string DisplayName =>
        Session.CurrentUser?.FullName
        ?? Session.CurrentUser?.Username
        ?? Session.CurrentUser?.Email
        ?? "Student";

    private string AccountSubtitle => FormatPlanLabel(Session.CurrentPlan);

    private static string FormatPlanLabel(string? planKey)
    {
        if (string.IsNullOrWhiteSpace(planKey))
        {
            return "Free";
        }

        return char.ToUpperInvariant(planKey[0]) + planKey[1..].ToLowerInvariant();
    }

    private string GetInitials()
    {
        var name = DisplayName;
        if (string.IsNullOrWhiteSpace(name)) return "U";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant()
            : name[..1].ToUpperInvariant();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnSessionChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Session.OnChange -= OnSessionChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }
}
