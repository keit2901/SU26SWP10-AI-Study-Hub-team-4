@inherits LayoutComponentBase
@layout MainLayout
@inject NavigationManager Nav
@inject AI_Study_Hub_v2.Services.AuthSessionState Session
@inject AI_Study_Hub_v2.Services.AuthPersistenceService AuthPersistence

<div style="display: flex; min-height: calc(100vh - 4.5rem); background: #faf9fe; overflow: hidden; font-family: 'Inter', sans-serif;">
    <!-- Sidebar -->
    <aside style="width: 16rem; flex-shrink: 0; border-right: 1px solid rgba(199,196,215,0.3); background: #fff; display: flex; flex-direction: column; justify-content: space-between; padding: 1.5rem 0;">
        <div style="padding: 0 1.5rem;">

            <!-- Brand logo -->
            <a href="/" style="display: flex; align-items: center; gap: 0.625rem; text-decoration: none; margin-bottom: 1.5rem;">
                <span style="display: flex; align-items: center; justify-content: center; width: 2rem; height: 2rem; border-radius: 0.5rem; background: #5e5ce6; color: white; font-size: 1rem;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/><path d="M14 2v20"/><path d="M8 12h4"/><path d="M8 16h4"/></svg>
                </span>
                <span style="font-size: 1.125rem; font-weight: 700; color: #1a1b1f; letter-spacing: -0.3px;">AI Study Hub</span>
            </a>

            <a href="documents/upload" style="width: 100%; background: #5e5ce6; color: #fff; border-radius: 0.375rem; padding: 0.6875rem 1rem; display: flex; align-items: center; justify-content: center; font-size: 0.875rem; font-weight: 600; text-decoration: none; border: none; cursor: pointer; box-shadow: 0 4px 14px 0 rgba(94, 92, 230, 0.39);">
                <MudIcon Icon="@Icons.Material.Filled.Add" Style="font-size: 1rem; margin-right: 0.5rem;" />
                New Document
            </a>

            <nav style="margin-top: 1.5rem; display: flex; flex-direction: column; gap: 0.25rem;">
                @foreach (var item in sidebarItems)
                {
                    <a href="@item.Href" style="@GetSidebarItemStyle(IsActive(item.Href))">
                        <MudIcon Icon="@item.Icon" Style="@($"font-size: 1.25rem; margin-right: 0.75rem; color: {(IsActive(item.Href) ? "#5e5ce6" : "#464554")};")" />
                        @item.Label
                    </a>
                }
            </nav>
        </div>

    </aside>

    <!-- Main Content inside Dashboard Layout -->
    <div style="flex: 1; display: flex; flex-direction: column; overflow-y: auto; background: #faf9fe;">

        <!-- Top Bar — user avatar + logout -->
        <div style="display: flex; align-items: center; justify-content: flex-end; gap: 0.75rem; padding: 0.5rem 1.5rem; border-bottom: 1px solid rgba(199,196,215,0.3); background: rgba(255,255,255,0.8); backdrop-filter: blur(4px); position: sticky; top: 0; z-index: 20; flex-shrink: 0;">
            @if (Session.CurrentUser != null)
            {
                <a href="/profile" title="Profile"
                   style="display: flex; align-items: center; justify-content: center; width: 2rem; height: 2rem; border-radius: 9999px; background: #5e5ce6; color: white; font-size: 0.75rem; font-weight: 700; text-decoration: none; border: 2px solid #c2c1ff; cursor: pointer; transition: opacity 0.2s;"
                   onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">
                    @(Session.CurrentUser.Username?.Substring(0, Math.Min(2, Session.CurrentUser.Username.Length)).ToUpper() ?? "US")
                </a>
                <button @onclick="Logout" title="Logout"
                        style="display: flex; align-items: center; justify-content: center; width: 2rem; height: 2rem; border-radius: 9999px; background: transparent; border: 1px solid rgba(199,196,215,0.5); cursor: pointer; transition: background 0.2s; color: #464554;"
                        onmouseover="this.style.background='#fef2f2'" onmouseout="this.style.background='transparent'">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                        <polyline points="16 17 21 12 16 7"/>
                        <line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                </button>
            }
        </div>

        @Body
    </div>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated)
        {
            var restored = await AuthPersistence.TryRestoreAsync();
            if (restored is not null)
            {
                Session.Set(restored);
            }
        }

        if (!Session.IsAuthenticated || Session.CurrentUser == null)
        {
            Nav.NavigateTo("/login");
            return;
        }
    }

    private record SidebarItem(string Icon, string Label, string Href);

    private readonly SidebarItem[] sidebarItems = new[]
    {
        new SidebarItem(Icons.Material.Filled.Dashboard, "Dashboard", "/dashboard"),
        new SidebarItem(Icons.Material.Filled.Description, "Documents", "/dashboard/documents"),
        new SidebarItem(Icons.Material.Filled.MenuBook, "Subjects", "/dashboard/subjects"),
        new SidebarItem(Icons.Material.Filled.CalendarToday, "Semesters", "/dashboard/semesters"),
        new SidebarItem(Icons.Material.Filled.BarChart, "Analytics", "/dashboard/analytics"),
    };

    private bool IsActive(string href)
    {
        var relativePath = Nav.ToBaseRelativePath(Nav.Uri);
        var cleanPath = relativePath.Split('?', '#')[0].Trim('/');
        var currentPath = "/" + cleanPath;

        if (currentPath == "/")
        {
            currentPath = "/dashboard";
        }

        return currentPath.Equals(href, StringComparison.OrdinalIgnoreCase);
    }

    private string GetSidebarItemStyle(bool active)
    {
        var bg = active ? "#e9e7ed" : "transparent";
        var color = active ? "#5e5ce6" : "#464554";
        return $"display: flex; align-items: center; padding: 0.625rem 1rem; border-radius: 0.375rem; font-size: 0.875rem; font-weight: 500; color: {color}; background: {bg}; text-decoration: none; transition: background 0.15s, color 0.15s;";
    }

    private void Logout()
    {
        Session.Clear();
        Nav.NavigateTo("/login", replace: true);
    }
}
