@inherits LayoutComponentBase
@layout MainLayout
@inject NavigationManager Nav
@inject AI_Study_Hub_v2.Services.AuthSessionState Session
@inject AI_Study_Hub_v2.Services.AuthPersistenceService AuthPersistence

<div style="display: flex; min-height: calc(100vh - 4.5rem); background: #faf9fe; overflow: hidden; font-family: 'Inter', sans-serif;">
    <!-- Sidebar -->
    <aside style="width: 16rem; flex-shrink: 0; border-right: 1px solid rgba(199,196,215,0.3); background: #fff; display: flex; flex-direction: column; justify-content: space-between; padding: 1.5rem 0;">
        <div style="padding: 0 1.5rem;">


            <a href="documents/upload" style="margin-top: 1.5rem; width: 100%; background: #5e5ce6; color: #fff; border-radius: 0.375rem; padding: 0.6875rem 1rem; display: flex; align-items: center; justify-content: center; font-size: 0.875rem; font-weight: 600; text-decoration: none; border: none; cursor: pointer; box-shadow: 0 4px 14px 0 rgba(94, 92, 230, 0.39);">
                <MudIcon Icon="@Icons.Material.Filled.Add" Style="font-size: 1rem; margin-right: 0.5rem;" />
                New Document
            </a>

            <nav style="margin-top: 1.5rem; display: flex; flex-direction: column; gap: 0.25rem;">
                @foreach (var item in sidebarItems)
                {
                    <a href="@item.Href" style="@GetSidebarItemStyle(IsActive(item.Href))">
                        <MudIcon Icon="@item.Icon" Style="@($"font-size: 1.25rem; margin-right: 0.75rem; color: {(IsActive(item.Href) ? "#5e5ce6" : "#464554")};")" />
                        @item.Label
                    </a>
                }
            </nav>
        </div>

    </aside>

    <!-- Main Content inside Dashboard Layout -->
    <div style="flex: 1; display: flex; flex-direction: column; overflow: hidden; background: #faf9fe;">
        @Body
    </div>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated)
        {
            var restored = await AuthPersistence.TryRestoreAsync();
            if (restored is not null)
            {
                Session.Set(restored);
            }
        }

        if (!Session.IsAuthenticated || Session.CurrentUser == null)
        {
            Nav.NavigateTo("/login");
            return;
        }
    }

    private record SidebarItem(string Icon, string Label, string Href);

    private readonly SidebarItem[] sidebarItems = new[]
    {
        new SidebarItem(Icons.Material.Filled.Dashboard, "Dashboard", "/dashboard"),
        new SidebarItem(Icons.Material.Filled.Description, "Documents", "/dashboard/documents"),
        new SidebarItem(Icons.Material.Filled.MenuBook, "Subjects", "/dashboard/subjects"),
        new SidebarItem(Icons.Material.Filled.CalendarToday, "Semesters", "/dashboard/semesters"),
        new SidebarItem(Icons.Material.Filled.BarChart, "Analytics", "/dashboard/analytics"),
    };

    private bool IsActive(string href)
    {
        var relativePath = "/" + Nav.ToBaseRelativePath(Nav.Uri).TrimEnd('/');
        if (relativePath == "/") relativePath = "/dashboard";
        return relativePath.Equals(href, StringComparison.OrdinalIgnoreCase);
    }

    private string GetSidebarItemStyle(bool active)
    {
        var bg = active ? "#e9e7ed" : "transparent";
        var color = active ? "#5e5ce6" : "#464554";
        return $"display: flex; align-items: center; padding: 0.625rem 1rem; border-radius: 0.375rem; font-size: 0.875rem; font-weight: 500; color: {color}; background: {bg}; text-decoration: none; transition: background 0.15s, color 0.15s;";
    }

    private void Logout()
    {
        Session.Clear();
        Nav.NavigateTo("/login", replace: true);
    }
}
