@inherits LayoutComponentBase
@implements IAsyncDisposable
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject AuthSessionState Session
@inject AuthPersistenceService AuthPersistence
@inject AuthApiClient AuthApi
@inject ISnackbar Snackbar

<MudThemeProvider Theme="@_theme" IsDarkMode="false" />

<div class="page app-shell @(IsFullBleed ? "page-fullbleed" : "") @(IsDashboard ? "dashboard-shell" : "")">
    @if (!IsDashboard)
    {
        <NavMenu />
    }

    <main class="main-stage @(UsesFullBleedMainStage ? "main-stage-fullbleed" : "")">
        <article class="content @(UsesFullBleedContent ? "content-fullbleed" : "") @(IsProfile ? "content-profile" : "")">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">x</a>
</div>

@code {
    private const int IdleTimeoutMs = 15 * 60 * 1000;
    private static readonly TimeSpan SessionRefreshInterval = TimeSpan.FromMinutes(1);
    private static readonly TimeSpan SessionRefreshWindow = TimeSpan.FromMinutes(1);

    private readonly CancellationTokenSource _sessionLoopCts = new();
    private DotNetObjectReference<MainLayout>? _idleDotNetRef;
    private Task? _sessionMaintenanceTask;
    private bool _idleMonitorStarted;
    private bool _signOutInProgress;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        Session.OnChange += OnSessionChanged;
        _sessionMaintenanceTask = RunSessionMaintenanceLoopAsync(_sessionLoopCts.Token);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        _idleDotNetRef ??= DotNetObjectReference.Create(this);
        await SyncIdleMonitorAsync();
    }

    private async Task RunSessionMaintenanceLoopAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(SessionRefreshInterval);

        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                await EnsureSessionFreshAsync(ct);
            }
        }
        catch (OperationCanceledException) when (ct.IsCancellationRequested)
        {
        }
    }

    private async Task EnsureSessionFreshAsync(CancellationToken ct)
    {
        var currentSession = Session.Session;
        if (currentSession is null || string.IsNullOrWhiteSpace(currentSession.RefreshToken))
        {
            return;
        }

        if (currentSession.ExpiresAt > DateTimeOffset.UtcNow.Add(SessionRefreshWindow))
        {
            return;
        }

        AuthResponse? restored = null;
        await InvokeAsync(async () => restored = await AuthPersistence.TryRestoreAsync());
        if (restored is not null && !string.IsNullOrWhiteSpace(restored.AccessToken))
        {
            await InvokeAsync(() =>
            {
                Session.Set(restored);
                StateHasChanged();
            });
            return;
        }

        if (currentSession.ExpiresAt <= DateTimeOffset.UtcNow)
        {
            await InvokeAsync(() => SignOutAsync("Your session has expired. Please sign in again."));
        }
    }

    private async Task SyncIdleMonitorAsync()
    {
        try
        {
            if (Session.IsAuthenticated)
            {
                await JS.InvokeVoidAsync("idleSessionMonitor.start", _idleDotNetRef, IdleTimeoutMs);
                _idleMonitorStarted = true;
            }
            else if (_idleMonitorStarted)
            {
                await JS.InvokeVoidAsync("idleSessionMonitor.stop");
                _idleMonitorStarted = false;
            }
        }
        catch (JSDisconnectedException)
        {
        }
        catch (InvalidOperationException)
        {
        }
    }

    [JSInvokable]
    public async Task HandleIdleTimeout()
    {
        await SignOutAsync("You were signed out after 15 minutes of inactivity.");
    }

    private async Task SignOutAsync(string? message = null)
    {
        if (_signOutInProgress)
        {
            return;
        }

        var hadSession = Session.Session is not null;
        if (!hadSession && !Session.IsAuthenticated)
        {
            return;
        }

        _signOutInProgress = true;
        try
        {
            var accessToken = Session.AccessToken;
            if (!string.IsNullOrWhiteSpace(accessToken))
            {
                try
                {
                    await AuthApi.LogoutAsync(accessToken);
                }
                catch
                {
                }
            }

            await AuthPersistence.ClearAsync();
            Session.Clear();

            try
            {
                await JS.InvokeVoidAsync("idleSessionMonitor.stop");
            }
            catch (JSDisconnectedException)
            {
            }
            catch (InvalidOperationException)
            {
            }

            _idleMonitorStarted = false;

            if (!string.IsNullOrWhiteSpace(message))
            {
                Snackbar.Add(message, Severity.Warning);
            }

            Nav.NavigateTo("/login", replace: true);
        }
        finally
        {
            _signOutInProgress = false;
        }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnSessionChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        Nav.LocationChanged -= OnLocationChanged;
        Session.OnChange -= OnSessionChanged;

        _sessionLoopCts.Cancel();

        if (_sessionMaintenanceTask is not null)
        {
            try
            {
                await _sessionMaintenanceTask;
            }
            catch (OperationCanceledException)
            {
            }
        }

        try
        {
            if (_idleMonitorStarted)
            {
                await JS.InvokeVoidAsync("idleSessionMonitor.dispose");
            }
        }
        catch (JSDisconnectedException)
        {
        }
        catch (InvalidOperationException)
        {
        }

        _idleDotNetRef?.Dispose();
        _sessionLoopCts.Dispose();
    }

    private bool IsFullBleed
    {
        get
        {
            var path = Nav.ToBaseRelativePath(Nav.Uri);
            var cleanPath = path.Split('?')[0];
            return cleanPath.Equals("documents", StringComparison.OrdinalIgnoreCase)
                || cleanPath.Equals("community", StringComparison.OrdinalIgnoreCase)
                || cleanPath.Equals("pricing", StringComparison.OrdinalIgnoreCase)
                || cleanPath.StartsWith("ai/chat", StringComparison.OrdinalIgnoreCase);
        }
    }

    private bool IsHomePage =>
        string.IsNullOrWhiteSpace(Nav.ToBaseRelativePath(Nav.Uri));

    private bool IsAuthPage
    {
        get
        {
            var relativePath = Nav.ToBaseRelativePath(Nav.Uri);
            return relativePath.StartsWith("login", StringComparison.OrdinalIgnoreCase)
                || relativePath.StartsWith("register", StringComparison.OrdinalIgnoreCase);
        }
    }

    private bool IsUploadPage =>
        Nav.ToBaseRelativePath(Nav.Uri).StartsWith("documents/upload", StringComparison.OrdinalIgnoreCase);

    private bool IsDashboard =>
        AdminAccessPolicy.IsDashboardPath(Nav.ToBaseRelativePath(Nav.Uri));

    private bool IsProfile =>
        Nav.ToBaseRelativePath(Nav.Uri).StartsWith("profile", StringComparison.OrdinalIgnoreCase);

    private bool UsesFullBleedMainStage => IsFullBleed || IsDashboard;

    private bool UsesFullBleedContent => IsFullBleed || IsDashboard || IsHomePage || IsAuthPage || IsUploadPage;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#4F46E5",
            Secondary = "#0F766E",
            Tertiary = "#7C3AED",
            Background = "#F8FAFC",
            Surface = "#FFFFFF",
            AppbarBackground = "rgba(255,255,255,0.86)",
            AppbarText = "#312E81",
            DrawerBackground = "#FFFFFF",
            DrawerText = "#334155",
            DrawerIcon = "#4F46E5",
            TextPrimary = "#0F172A",
            TextSecondary = "#64748B",
            LinesDefault = "#E2E8F0",
            Info = "#0284C7",
            Success = "#10B981",
            Warning = "#F59E0B",
            Error = "#E11D48"
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = new[] { "Plus Jakarta Sans", "Inter", "Segoe UI", "sans-serif" },
                FontSize = ".93rem"
            },
            H4 = new H4Typography
            {
                FontFamily = new[] { "Plus Jakarta Sans", "Inter", "sans-serif" },
                FontWeight = "800",
                LetterSpacing = "-.035em"
            },
            H5 = new H5Typography
            {
                FontFamily = new[] { "Plus Jakarta Sans", "Inter", "sans-serif" },
                FontWeight = "800",
                LetterSpacing = "-.025em"
            },
            H6 = new H6Typography
            {
                FontFamily = new[] { "Plus Jakarta Sans", "Inter", "sans-serif" },
                FontWeight = "800",
                LetterSpacing = "-.015em"
            }
        }
    };
}
