        margin-top: 0.35rem;
        color: #776f93;
        font-size: 0.92rem;
    }

    .payment-plan-button {
        border-radius: 999px !important;
        padding-inline: 1rem !important;
        text-transform: none !important;
        font-weight: 700 !important;
    }

    .payment-history-card {
        padding: 1.1rem 1.2rem;
    }

    .payment-history-card-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .payment-history-card-head h4 {
        margin: 0;
        font-size: 1.15rem;
        font-weight: 800;
        color: #19132f;
    }

    .payment-history-card-head p {
        margin: 0.3rem 0 0;
        color: #7b7397;
        font-size: 0.9rem;
