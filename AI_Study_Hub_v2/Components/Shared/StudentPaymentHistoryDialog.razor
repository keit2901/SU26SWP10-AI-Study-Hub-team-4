@using AI_Study_Hub_v2.Dtos
@using AI_Study_Hub_v2.Services
@inject AuthSessionState Session
@inject AuthPersistenceService AuthPersistence
@inject PlanApiClient PlanApi
@inject NavigationManager Nav

<MudDialog Class="student-quick-dialog student-payment-dialog-root">
    <DialogContent>
        <div class="payment-dialog-shell">
            <div class="payment-dialog-head">
                <div>
                    <span class="payment-dialog-kicker">Account</span>
                    <h3>Thanh toán</h3>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="Close" />
            </div>

            @if (_loading)
            {
                <div class="payment-dialog-loading">
                    <MudProgressCircular Indeterminate="true" Size="Size.Medium" Color="Color.Primary" />
                    <span>Đang tải lịch sử thanh toán...</span>
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(_error))
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">@_error</MudAlert>
            }
            else
            {
                <div class="payment-plan-card">
                    <div>
                        <div class="payment-plan-name">@FormatPlanLabel()</div>
                        <div class="payment-plan-note">@BuildPlanCaption()</div>
                    </div>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Small"
                               Class="payment-plan-button"
                               OnClick="GoToPricing">
                        @BuildPlanButtonLabel()
                    </MudButton>
                </div>

                <div class="payment-history-card">
                    <div class="payment-history-card-head">
                        <div>
                            <h4>Lịch sử thanh toán</h4>
                            <p>Hiển thị 10 giao dịch mỗi trang.</p>
                        </div>
                        <span class="payment-history-page-size">10 / page</span>
                    </div>

                    @if (_payments.Count == 0)
                    {
                        <div class="payment-empty-state">
                            <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" Size="Size.Large" />
                            <h4>Chưa có giao dịch</h4>
                            <p>Lịch sử thanh toán của bạn sẽ xuất hiện ở đây sau khi phát sinh giao dịch.</p>
                        </div>
                    }
                    else
                    {
                        <div class="payment-history-table">
                            <div class="payment-history-grid payment-history-grid-head">
                                <span>Ngày</span>
                                <span>Số tiền</span>
                                <span>Trạng thái</span>
                                <span></span>
                            </div>

                            @foreach (var payment in PagedPayments)
                            {
                                <div class="payment-history-grid">
                                    <span>@FormatDate(payment.CreatedAt)</span>
                                    <span>@FormatAmount(payment.AmountVnd)</span>
                                    <span>
                                        <span class="payment-status-chip @GetStatusClass(payment.Status)">@FormatStatus(payment.Status)</span>
                                    </span>
                                    <button type="button" class="payment-view-button" @onclick="@(() => SelectPayment(payment))">Xem</button>
                                </div>
                            }
                        </div>

                        @if (TotalPages > 1)
                        {
                            <div class="payment-pager">
                                <button type="button" class="payment-page-button" @onclick="PreviousPage" disabled="@(_currentPage == 1)">
                                    Trước
                                </button>

                                @foreach (var pageNumber in VisiblePages)
                                {
                                    <button type="button"
                                            class="payment-page-button @(pageNumber == _currentPage ? "active" : string.Empty)"
                                            @onclick="@(() => GoToPage(pageNumber))">
                                        @pageNumber
                                    </button>
                                }

                                <button type="button" class="payment-page-button" @onclick="NextPage" disabled="@(_currentPage == TotalPages)">
                                    Sau
                                </button>
                            </div>
                        }

                        @if (_selectedPayment is not null)
                        {
                            <div class="payment-detail-card">
                                <div class="payment-detail-head">
                                    <h5>Chi tiết giao dịch</h5>
                                    <span class="payment-status-chip @GetStatusClass(_selectedPayment.Status)">@FormatStatus(_selectedPayment.Status)</span>
                                </div>

                                <div class="payment-detail-grid">
                                    <div class="payment-detail-item">
                                        <span>Gói</span>
                                        <strong>@FormatPlanName(_selectedPayment.PlanKey)</strong>
                                    </div>
                                    <div class="payment-detail-item">
                                        <span>Chu kỳ</span>
                                        <strong>@FormatBillingCycle(_selectedPayment.BillingCycle)</strong>
                                    </div>
                                    <div class="payment-detail-item">
                                        <span>Ngày tạo</span>
                                        <strong>@_selectedPayment.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</strong>
                                    </div>
                                    <div class="payment-detail-item">
                                        <span>Hoàn tất</span>
                                        <strong>@(_selectedPayment.CompletedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "Chưa hoàn tất")</strong>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            }
        </div>
    </DialogContent>
</MudDialog>

@code {
    private const int PageSize = 10;

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    private bool _loading = true;
    private string? _error;
    private int _currentPage = 1;
    private PaymentTransactionDto? _selectedPayment;
    private readonly List<PaymentTransactionDto> _payments = new();

    private IEnumerable<PaymentTransactionDto> PagedPayments =>
        _payments.Skip((_currentPage - 1) * PageSize).Take(PageSize);

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_payments.Count / (double)PageSize));

    private IEnumerable<int> VisiblePages
    {
        get
        {
            var start = Math.Max(1, _currentPage - 1);
            var end = Math.Min(TotalPages, start + 2);
            if (end - start < 2)
            {
                start = Math.Max(1, end - 2);
            }

            return Enumerable.Range(start, end - start + 1);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await RestoreSessionAsync();
        await LoadAsync();
    }

    private async Task RestoreSessionAsync()
    {
        if (Session.IsAuthenticated)
        {
            return;
        }

        var restored = await AuthPersistence.TryRestoreAsync();
        if (restored is not null)
        {
            Session.Set(restored);
        }
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        _payments.Clear();
        _selectedPayment = null;
        _currentPage = 1;

        try
        {
            if (!Session.IsAuthenticated || string.IsNullOrWhiteSpace(Session.AccessToken))
            {
                _error = "Vui lòng đăng nhập lại để xem lịch sử thanh toán.";
                return;
            }

            await Session.LoadCurrentPlanAsync(PlanApi);
            var payments = await PlanApi.GetMyPaymentTransactionsAsync(Session.AccessToken, 100);
            _payments.AddRange(payments.OrderByDescending(item => item.CreatedAt));
            _selectedPayment = _payments.FirstOrDefault();
        }
        catch (PlanApiException ex)
        {
            _error = ex.StatusCode == 401
                ? "Vui lòng đăng nhập lại để xem lịch sử thanh toán."
                : ex.Message;
        }
        catch (Exception ex)
        {
            _error = $"Không thể tải lịch sử thanh toán: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private string FormatPlanLabel()
        => string.IsNullOrWhiteSpace(Session.CurrentPlan)
            ? "Free"
            : $"{char.ToUpper(Session.CurrentPlan[0])}{Session.CurrentPlan[1..].ToLowerInvariant()}";

    private string BuildPlanButtonLabel()
        => string.Equals(Session.CurrentPlan, "free", StringComparison.OrdinalIgnoreCase)
            ? "Nâng cấp gói"
            : $"Gia hạn gói {FormatPlanLabel()}";

    private string BuildPlanCaption()
    {
        if (string.Equals(Session.CurrentPlan, "free", StringComparison.OrdinalIgnoreCase))
        {
            return "Bạn đang dùng gói miễn phí.";
        }

        var latestPaid = _payments
            .Where(item => string.Equals(item.Status, "completed", StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(item => item.CompletedAt ?? item.CreatedAt)
            .FirstOrDefault();

        var endDate = InferPlanEndDate(latestPaid);
        return endDate is null
            ? "Gói hiện tại của bạn đang hoạt động."
            : $"Gói của bạn dự kiến hết hạn vào {endDate.Value.ToLocalTime():d 'thg' M, yyyy}.";
    }

    private static DateTimeOffset? InferPlanEndDate(PaymentTransactionDto? payment)
    {
        if (payment is null || string.Equals(payment.PlanKey, "free", StringComparison.OrdinalIgnoreCase))
        {
            return null;
        }

        var baseDate = payment.CompletedAt ?? payment.CreatedAt;
        return string.Equals(payment.BillingCycle, "yearly", StringComparison.OrdinalIgnoreCase)
            ? baseDate.AddYears(1)
            : baseDate.AddMonths(1);
    }

    private static string FormatPlanName(string planKey)
        => string.IsNullOrWhiteSpace(planKey)
            ? "Unknown"
            : $"{char.ToUpper(planKey[0])}{planKey[1..].ToLowerInvariant()}";

    private static string FormatAmount(long amountVnd)
        => amountVnd <= 0 ? "0 đ" : $"{amountVnd:N0} đ";

    private static string FormatBillingCycle(string billingCycle)
        => string.Equals(billingCycle, "yearly", StringComparison.OrdinalIgnoreCase) ? "Năm" : "Tháng";

    private static string FormatStatus(string status)
        => status.ToLowerInvariant() switch
        {
            "completed" => "Đã thanh toán",
            "pending" => "Đang chờ",
            "failed" => "Thất bại",
            "expired" => "Hết hạn",
            _ => status
        };

    private static string GetStatusClass(string status)
        => status.ToLowerInvariant() switch
        {
            "completed" => "success",
            "pending" => "warning",
            "failed" => "danger",
            "expired" => "muted",
            _ => "info"
        };

    private static string FormatDate(DateTimeOffset date)
        => date.ToLocalTime().ToString("d 'thg' M, yyyy");

    private void GoToPage(int page)
    {
        _currentPage = Math.Min(Math.Max(1, page), TotalPages);
    }

    private void PreviousPage()
    {
        if (_currentPage > 1)
        {
            _currentPage--;
        }
    }

    private void NextPage()
    {
        if (_currentPage < TotalPages)
        {
            _currentPage++;
        }
    }

    private void SelectPayment(PaymentTransactionDto payment)
    {
        _selectedPayment = payment;
    }

    private void GoToPricing()
    {
        MudDialog.Close();
        Nav.NavigateTo("/pricing");
    }

    private void Close() => MudDialog.Cancel();
}

<style>
    .payment-dialog-shell {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .payment-dialog-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
    }

    .payment-dialog-kicker {
        display: inline-flex;
        padding: 0.28rem 0.7rem;
        border-radius: 999px;
        background: rgba(94, 92, 230, 0.1);
        color: #4f46d9;
