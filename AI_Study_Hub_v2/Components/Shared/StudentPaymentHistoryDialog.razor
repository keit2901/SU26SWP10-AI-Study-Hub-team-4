        color: #6f678c;
        padding: 1.5rem;
        background: rgba(250, 248, 255, 0.84);
    }

    .payment-empty-state h4,
    .payment-empty-state p {
        margin: 0;
    }

    @@media (max-width: 720px) {
        .payment-plan-card,
        .payment-history-card-head,
        .payment-detail-head {
            flex-direction: column;
            align-items: flex-start;
        }

        .payment-history-grid {
            grid-template-columns: 1fr;
        }

        .payment-history-grid-head {
            display: none;
        }

        .payment-detail-grid {
