@namespace AI_Study_Hub_v2.Components.Shared
@implements IAsyncDisposable
@inject IRecaptchaVerificationService RecaptchaVerifier
@inject IOptions<RecaptchaOptions> RecaptchaOptionsAccessor
@inject IJSRuntime Js

<div class="human-check recaptcha-check" style="padding: 8px 0;">
    <MudStack Spacing="2" AlignItems="AlignItems.Center">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="1" Style="flex-wrap: wrap;">
            <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Color="Color.Primary" Size="Size.Small" />
            <MudText Typo="Typo.subtitle2">Human verification</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">@ModeLabel</MudText>
        </MudStack>

        @if (UseRecaptcha)
        {
            <div id="@_elementId" class="recaptcha-widget" aria-label="Google reCAPTCHA verification"></div>
            @if (!string.IsNullOrWhiteSpace(_message))
            {
                <MudAlert Severity="@(IsValid ? Severity.Success : Severity.Warning)" Dense="true" Variant="Variant.Outlined">
                    @_message
                </MudAlert>
            }
        }
        else
        {
            <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Filled">
                reCAPTCHA is required but is not configured. Ask an administrator to set reCAPTCHA keys.
            </MudAlert>
        }
    </MudStack>
</div>

@code {
    private readonly string _elementId = $"recaptcha-{Guid.NewGuid():N}";
    private string? _recaptchaToken;
    private string? _message;
    private bool _recaptchaPassed;
    private bool _rendered;
    private DotNetObjectReference<HumanCheck>? _dotNetRef;

    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string Action { get; set; } = "human-check";
    [Parameter] public EventCallback<bool> ValidChanged { get; set; }

    private RecaptchaOptions RecaptchaOptions => RecaptchaOptionsAccessor.Value;

    private bool UseRecaptcha => RecaptchaVerifier.IsEnabled 
        && RecaptchaVerifier.IsConfigured 
        && !RecaptchaOptions.AllowDevelopmentFallback;

    public string? GetResponseToken() => _recaptchaToken;

    public bool IsValid => !UseRecaptcha
        || (_recaptchaPassed && !string.IsNullOrWhiteSpace(_recaptchaToken));

    private string ModeLabel => !RecaptchaVerifier.IsEnabled
        ? "Human verification is disabled."
        : RecaptchaOptions.AllowDevelopmentFallback
            ? "Development mode — verification bypassed."
            : !RecaptchaVerifier.IsConfigured
                ? "reCAPTCHA configuration is required."
                : "Google reCAPTCHA.";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!UseRecaptcha || _rendered)
        {
            return;
        }

        try
        {
            _dotNetRef ??= DotNetObjectReference.Create(this);
            await Js.InvokeVoidAsync(
                "aiStudyHubRecaptcha.render",
                _elementId,
                _dotNetRef,
                RecaptchaOptions.SiteKey,
                RecaptchaOptions.Theme,
                RecaptchaOptions.Size);
            _rendered = true;
        }
        catch (JSException)
        {
            _recaptchaToken = null;
            _recaptchaPassed = false;
            _message = "reCAPTCHA could not load. Check your connection and retry.";
            await ValidChanged.InvokeAsync(false);
            StateHasChanged();
        }
    }

    public async Task<bool> ValidateAsync()
    {
        if (!UseRecaptcha)
        {
            await ValidChanged.InvokeAsync(IsValid);
            StateHasChanged();
            return IsValid;
        }

        if (string.IsNullOrWhiteSpace(_recaptchaToken))
        {
            var token = await Js.InvokeAsync<string>("aiStudyHubRecaptcha.getResponse", _elementId);
            if (!string.IsNullOrWhiteSpace(token))
            {
                _recaptchaToken = token;
                _recaptchaPassed = true;
            }
        }

        if (string.IsNullOrWhiteSpace(_recaptchaToken))
        {
            _recaptchaPassed = false;
            _message = "Complete the reCAPTCHA challenge before continuing.";
            await ValidChanged.InvokeAsync(false);
            StateHasChanged();
            return false;
        }

        _message = "reCAPTCHA challenge completed. The server will verify it before processing.";
        await ValidChanged.InvokeAsync(IsValid);
        StateHasChanged();
        return IsValid;
    }

    public bool Validate()
    {
        _ = ValidChanged.InvokeAsync(IsValid);
        StateHasChanged();
        return IsValid;
    }

    public async Task ResetAsync()
    {
        _recaptchaToken = null;
        _recaptchaPassed = false;
        _message = null;
        await ValidChanged.InvokeAsync(false);
        await ResetRecaptchaWidgetAsync();
        StateHasChanged();
    }

    public void Reset()
    {
        _recaptchaToken = null;
        _recaptchaPassed = false;
        _message = null;
        _ = ValidChanged.InvokeAsync(false);
        _ = ResetRecaptchaWidgetAsync();
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnRecaptchaSuccess(string token)
    {
        _recaptchaToken = token;
        _recaptchaPassed = true;
        _message = "reCAPTCHA challenge completed.";
        await ValidChanged.InvokeAsync(true);
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnRecaptchaError(string errorCode)
    {
        _recaptchaToken = null;
        _recaptchaPassed = false;
        _message = $"reCAPTCHA challenge failed ({errorCode}). Please retry.";
        await ValidChanged.InvokeAsync(false);
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnRecaptchaExpired()
    {
        _recaptchaToken = null;
        _recaptchaPassed = false;
        _message = "reCAPTCHA challenge expired. Please retry.";
        await ValidChanged.InvokeAsync(false);
        StateHasChanged();
    }

    private async Task ResetRecaptchaWidgetAsync()
    {
        if (!UseRecaptcha || !_rendered)
        {
            return;
        }

        await Js.InvokeVoidAsync("aiStudyHubRecaptcha.reset", _elementId);
    }

    public async ValueTask DisposeAsync()
    {
        if (_rendered)
        {
            try
            {
                await Js.InvokeVoidAsync("aiStudyHubRecaptcha.remove", _elementId);
            }
            catch (JSDisconnectedException)
            {
                // Circuit disconnected during navigation; widget cleanup is no longer needed.
            }
        }

        _dotNetRef?.Dispose();
    }
}
