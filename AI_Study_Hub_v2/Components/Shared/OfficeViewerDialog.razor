@using AI_Study_Hub_v2.Dtos
@inject NavigationManager Nav

<MudDialog>
    <TitleContent>
        <div class="ov-dialog-header">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
            <span>@FileName</span>
            <span class="ov-badge">MICROSOFT OFFICE VIEWER</span>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="ov-iframe-wrapper">
            @if (!string.IsNullOrEmpty(ViewerUrl))
            {
                <iframe src="@ViewerUrl"
                        width="100%"
                        height="100%"
                        frameborder="0"
                        title="Microsoft Office Online Viewer">
                    <p>Your browser does not support iframes.</p>
                </iframe>
            }
            else
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
                    The document viewer URL could not be generated.
                </MudAlert>
            }
        </div>
        <div class="ov-fallback">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            <span>The embedded viewer requires the file to be publicly accessible. If the viewer does not load,</span>
            @if (!string.IsNullOrEmpty(DownloadUrl))
            {
                <a href="@DownloadUrl" target="_blank" class="ov-download-link">download the file directly</a>
            }
            <span>and open it in Word/PowerPoint.</span>
        </div>
    </DialogContent>
    <DialogActions>
        <div class="ov-footer">
            <span class="ov-footer-hint">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                Powered by Microsoft Office Online. Proxy link expires in 5 minutes.
            </span>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Close">Close</MudButton>
        </div>
    </DialogActions>
</MudDialog>

<style>
.ov-dialog-header {
    display: flex;
    align-items: center;
    gap: 10px;
    color: #11181c;
    font-family: "Inter","DM Sans","Plus Jakarta Sans",sans-serif;
    font-size: 16px;
    font-weight: 600;
}
.ov-badge {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .06em;
    color: #4f46e5;
    background: #eef2ff;
    padding: 2px 8px;
    border-radius: 4px;
    text-transform: uppercase;
    margin-left: auto;
}
.ov-iframe-wrapper {
    width: 100%;
    height: calc(85vh - 200px);
    min-height: 400px;
    border: 1px solid rgba(0,0,0,.08);
    border-radius: 8px;
    overflow: hidden;
}
.ov-iframe-wrapper iframe {
    display: block;
}
.ov-fallback {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 10px;
    padding: 10px 14px;
    background: #fffbeb;
    border: 1px solid rgba(0,0,0,.08);
    border-radius: 8px;
    font-size: 12px;
    color: #92400e;
    line-height: 1.4;
    flex-wrap: wrap;
}
.ov-fallback svg { flex-shrink: 0; }
.ov-download-link {
    color: #4f46e5;
    font-weight: 600;
    text-decoration: none;
}
.ov-download-link:hover { text-decoration: underline; }
.ov-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    gap: 12px;
}
.ov-footer-hint {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: #687076;
}
.ov-footer-hint svg { flex-shrink: 0; }
</style>

@code {
    [Parameter] public string FileName { get; set; } = string.Empty;
    [Parameter] public string ViewerUrl { get; set; } = string.Empty;
    [Parameter] public string? DownloadUrl { get; set; }

    [CascadingParameter] public IMudDialogInstance MudDialog { get; set; } = default!;

    private void Close() => MudDialog.Close();
}
