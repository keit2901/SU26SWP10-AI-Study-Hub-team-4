<MudDialog Class="student-quick-dialog student-profile-dialog">
    <DialogContent>
        <div class="dialog-shell">
            <div class="dialog-head">
                <div>
                    <span class="dialog-kicker">Account</span>
                    <h3>Profile</h3>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="Close" />
            </div>

            <StudentProfilePanel Compact="true" ShowCloseAction="false" />
        </div>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    private void Close() => MudDialog.Cancel();
}

<style>
    .student-profile-dialog.mud-dialog {
        border-radius: 36px !important;
    }

    .student-profile-dialog .mud-dialog-content {
        padding: 1rem 1rem 0.95rem !important;
        overflow: hidden !important;
    }

    .dialog-shell {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .dialog-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 0.35rem;
    }

    .dialog-kicker {
        display: inline-flex;
        padding: 0.28rem 0.7rem;
        border-radius: 999px;
        background: rgba(94, 92, 230, 0.1);
        color: #4f46d9;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .dialog-head h3 {
        margin: 0.72rem 0 0;
        font-size: 1.42rem;
        font-weight: 900;
        color: #19132f;
    }
</style>
