@namespace AI_Study_Hub_v2.Components.Shared
@using System.ComponentModel.DataAnnotations

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.h5">Rename Folder</MudText>
            <MudTextField T="string"
                          @bind-Value="_name"
                          Label="Folder name"
                          Required="true"
                          RequiredError="Folder name is required"
                          MaxLength="100"
                          Validation="@(new StringLengthAttribute(100) { MinimumLength = 1, ErrorMessage = "Folder name must be between 1 and 100 characters." })"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Immediate="true" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@string.IsNullOrWhiteSpace(_name)" OnClick="Confirm">
            Rename
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string FolderName { get; set; } = string.Empty;

    private string _name = string.Empty;

    protected override void OnInitialized()
    {
        _name = FolderName;
    }

    private void Confirm()
    {
        MudDialog.Close(DialogResult.Ok(_name.Trim()));
    }

    private void Cancel() => MudDialog.Cancel();
}
