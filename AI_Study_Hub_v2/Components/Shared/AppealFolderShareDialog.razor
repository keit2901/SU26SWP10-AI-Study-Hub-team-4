@namespace AI_Study_Hub_v2.Components.Shared

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            <MudText Typo="Typo.h6">Review by human</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Folder: <strong>@FolderName</strong>
            </MudText>
            @if (!string.IsNullOrWhiteSpace(AiReason))
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">
                    AI reason: @AiReason
                </MudAlert>
            }
            <MudTextField T="string"
                          @bind-Value="_message"
                          Label="Explain why this folder should be reviewed again"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Lines="4"
                          Immediate="true" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Confirm">
            Send request
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string FolderName { get; set; } = string.Empty;

    [Parameter] public string? AiReason { get; set; }

    private string? _message;

    private void Confirm() => MudDialog.Close(DialogResult.Ok(_message?.Trim()));

    private void Cancel() => MudDialog.Cancel();
}
