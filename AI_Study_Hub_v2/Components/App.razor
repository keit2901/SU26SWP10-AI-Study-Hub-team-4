@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&amp;family=Space+Grotesk:wght@500;600;700&amp;display=swap" />
    <link rel="stylesheet" href="bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="_content/MudBlazor/MudBlazor.min.css" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="AI_Study_Hub_v2.styles.css" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="new InteractiveServerRenderMode(prerender: false)" />
</head>

<body>
    <div id="blazor-app-root">
        <Routes @rendermode="new InteractiveServerRenderMode(prerender: false)" />
    </div>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script src="recaptcha.js"></script>
    <script src="aichat.js"></script>
    <script>window.openFilePicker=id=>document.getElementById(id).click()</script>
    <script>
        window.codexTableFilter = {
            getAnchorRect: function (element, preferredWidth) {
                if (!element) {
                    return null;
                }

                const rect = element.getBoundingClientRect();
                const viewportWidth = window.innerWidth || document.documentElement.clientWidth || 0;
                const viewportHeight = window.innerHeight || document.documentElement.clientHeight || 0;
                const margin = 16;
                const clampMargin = 8;
                const requestedWidth = typeof preferredWidth === "number" && preferredWidth > 0
                    ? preferredWidth
                    : rect.width;
                let minLeft = margin;
                let maxRight = viewportWidth - margin;

                const clampToRect = function (boundsRect, innerMargin) {
                    if (!boundsRect) {
                        return;
                    }

                    minLeft = Math.max(minLeft, boundsRect.left + innerMargin);
                    maxRight = Math.min(maxRight, boundsRect.right - innerMargin);
                };

                const tableElement = element.closest("table");
                if (tableElement) {
                    clampToRect(tableElement.getBoundingClientRect(), clampMargin);
                }

                let current = element.parentElement;
                while (current && current !== document.body) {
                    const styles = window.getComputedStyle(current);
                    const overflowX = (styles && styles.overflowX ? styles.overflowX : "").toLowerCase();
                    const clipsHorizontally = overflowX === "auto"
                        || overflowX === "scroll"
                        || overflowX === "hidden"
                        || overflowX === "clip"
                        || current.scrollWidth > current.clientWidth + 1;

                    if (clipsHorizontally) {
                        clampToRect(current.getBoundingClientRect(), clampMargin);
                        break;
                    }

                    current = current.parentElement;
                }

                if (maxRight - minLeft < 160) {
                    minLeft = margin;
                    maxRight = viewportWidth - margin;
                }

                const width = Math.min(requestedWidth, Math.max(160, maxRight - minLeft));
                let left = rect.left + (rect.width - width) / 2;
                left = Math.min(Math.max(left, minLeft), Math.max(minLeft, maxRight - width));
                const top = Math.min(rect.bottom + 8, Math.max(96, viewportHeight - 96));

                return {
                    left: left,
                    top: top,
                    width: width
                };
            },
            focusElement: function (element, selectText) {
                if (!element) {
                    return;
                }

                requestAnimationFrame(function () {
                    try {
                        element.focus({ preventScroll: true });

                        if (selectText && typeof element.select === "function") {
                            element.select();
                        }
                    } catch (error) {
                    }
                });
            },
            scrollOptionIntoViewByIndex: function (container, optionIndex) {
                if (!container || typeof optionIndex !== "number" || optionIndex < 0) {
                    return;
                }

                requestAnimationFrame(function () {
                    try {
                        const options = container.querySelectorAll("button");
                        if (!options || optionIndex >= options.length) {
                            return;
                        }

                        options[optionIndex].scrollIntoView({
                            block: "nearest",
                            inline: "nearest"
                        });
                    } catch (error) {
                    }
                });
            }
        };
    </script>
    <script src="_framework/blazor.web.js"></script>
</body>

</html>
