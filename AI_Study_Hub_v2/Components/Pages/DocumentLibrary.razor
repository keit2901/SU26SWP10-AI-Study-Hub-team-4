    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated)
        {
            var restored = await AuthPersistence.TryRestoreAsync();
            if (restored is not null)
                Session.Set(restored);
            if (!Session.IsAuthenticated)
            {
                Nav.NavigateTo("/login", replace: true);
                return;
            }
        }
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        if (string.IsNullOrEmpty(Session.AccessToken)) return;
        _loading = true;
        _error = null;
        StateHasChanged();
        try
        {
            var docsTask = DocumentsApi.ListAsync(Session.AccessToken!);
            var foldersTask = FoldersApi.ListAsync(Session.AccessToken!);
            await Task.WhenAll(docsTask, foldersTask);
            _documents = docsTask.Result.OrderByDescending(d => d.UpdatedAt).ToList();
            _folders = foldersTask.Result.OrderByDescending(f => f.IsFavorite).ThenByDescending(f => f.UpdatedAt).ToList();
            _folderPage = 1;
            _sidebarFolderPage = 1;
        }
        catch (DocumentApiException ex)
        {
            _error = MapError(ex);
            Snackbar.Add(_error ?? ex.Message, Severity.Warning);
            if (ex.StatusCode == 401)
            {
                Session.Clear();
                Nav.NavigateTo("/login", replace: true);
            }
        }
        catch (Exception ex)
        {
            _error = $"Could not load library: {ex.Message}";
            Snackbar.Add(_error, Severity.Warning);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

