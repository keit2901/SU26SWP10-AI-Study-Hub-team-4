    private async Task ConfirmDeleteDocumentAsync(DocumentDto doc)
    {
        if (doc is null) return;
        var parameters = new DialogParameters
        {
            ["Title"] = "Delete document?",
            ["Message"] = $"Delete \"{doc.FileName}\"? This cannot be undone.",
            ["ConfirmText"] = "Delete",
            ["ConfirmColor"] = Color.Error,
            ["Icon"] = Icons.Material.Filled.DeleteForever,
            ["IconColor"] = Color.Error,
        };
        var options = new DialogOptions { CloseOnEscapeKey = true };
        var dialogRef = await Dialogs.ShowAsync<ConfirmDialog>("Delete document", parameters, options);
        var result = await dialogRef.Result;
        if (result is null || result.Canceled) return;
        await DeleteDocumentAsync(doc);
    }

    private async Task DeleteDocumentAsync(DocumentDto doc)
    {
        if (string.IsNullOrEmpty(Session.AccessToken) || doc is null) return;
        _loading = true;
        try
        {
            await DocumentsApi.DeleteAsync(Session.AccessToken!, doc.Id);
            _documents = _documents.Where(d => d.Id != doc.Id).ToList();
            if (_filteredDocuments.Count == 0 && _currentPage > 1)
            {
                _currentPage--;
            }
            if (doc.FolderId.HasValue)
            {
                var folder = _folders.FirstOrDefault(f => f.Id == doc.FolderId.Value);
                if (folder is not null && folder.DocumentCount > 0)
                    folder.DocumentCount--;
            }
            Snackbar.Add($"Deleted \"{doc.FileName}\".", Severity.Success);
            StateHasChanged();
        }
        catch (DocumentApiException ex)
        {
            Snackbar.Add(MapError(ex) ?? ex.Message, Severity.Error);
            if (ex.StatusCode == 401)
            {
                Session.Clear();
                Nav.NavigateTo("/login", replace: true);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Network error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

