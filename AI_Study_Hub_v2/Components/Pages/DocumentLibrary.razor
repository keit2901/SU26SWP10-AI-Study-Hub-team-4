        }
    }

    private async Task ConfirmDeleteFolderAsync(FolderDto folder)
    {
        if (folder is null) return;
        var docCount = folder.DocumentCount;
        var msg = docCount > 0
            ? $"Delete \"{folder.Name}\"? This will also delete all {docCount} documents inside it. This cannot be undone."
            : $"Delete \"{folder.Name}\"? This cannot be undone.";
        var parameters = new DialogParameters
        {
            ["Title"] = "Delete folder?",
            ["Message"] = msg,
            ["ConfirmText"] = "Delete",
            ["ConfirmColor"] = Color.Error,
            ["Icon"] = Icons.Material.Filled.DeleteForever,
            ["IconColor"] = Color.Error,
        };
        var options = new DialogOptions { CloseOnEscapeKey = true };
        var dialogRef = await Dialogs.ShowAsync<ConfirmDialog>("Delete folder", parameters, options);
        var result = await dialogRef.Result;
        if (result is null || result.Canceled) return;
        await DeleteFolderAsync(folder);
    }

    private async Task DeleteFolderAsync(FolderDto folder)
    {
        if (string.IsNullOrWhiteSpace(Session.AccessToken) || folder is null) return;
        try
        {
            await FoldersApi.DeleteAsync(Session.AccessToken!, folder.Id);
            _folders.Remove(folder);
            if (_filterFolderId == folder.Id) _filterFolderId = null;
            Snackbar.Add($"Deleted \"{folder.Name}\".", Severity.Success);
            StateHasChanged();
        }
        catch (DocumentApiException ex)
        {
            Snackbar.Add(MapError(ex) ?? ex.Message, Severity.Error);
            if (ex.StatusCode == 401)
            {
                Session.Clear();
                Nav.NavigateTo("/login", replace: true);
            }
        }
    }

    private async Task RequestShareAsync(FolderDto folder)
    {
        if (folder.ShareStatus == Data.Entities.FolderStatus.PendingShare
            || folder.ShareStatus == Data.Entities.FolderStatus.Approved) return;

        if (string.IsNullOrWhiteSpace(Session.AccessToken)) return;
        try
        {
            var updated = await FoldersApi.RequestShareAsync(Session.AccessToken!, folder.Id);
            var idx = _folders.FindIndex(f => f.Id == folder.Id);
            if (idx >= 0)
            {
                _folders[idx] = updated;
                _folders = _folders.OrderByDescending(f => f.IsFavorite).ThenByDescending(f => f.UpdatedAt).ToList();
                StateHasChanged();
            }
            Snackbar.Add(GetShareDecisionMessage(updated), GetShareDecisionSeverity(updated));
        }
        catch (DocumentApiException ex)
        {
            Snackbar.Add(MapError(ex) ?? ex.Message, Severity.Error);
        }
    }

    private async Task ShowHumanReviewDialogAsync(FolderDto folder)
    {
        if (!CanRequestHumanReview(folder)) return;

        var parameters = new DialogParameters
        {
            ["FolderName"] = folder.Name,
            ["AiReason"] = folder.AiReviewReason,
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialogRef = await Dialogs.ShowAsync<AppealFolderShareDialog>("Review by human", parameters, options);
        var result = await dialogRef.Result;
        if (result is null || result.Canceled) return;
        var message = result.Data as string;
        await RequestHumanReviewAsync(folder, message);
    }

    private async Task RequestHumanReviewAsync(FolderDto folder, string? message)
    {
        if (string.IsNullOrWhiteSpace(Session.AccessToken)) return;

        try
        {
            var updated = await FoldersApi.AppealShareReviewAsync(
                Session.AccessToken!,
                folder.Id,
                new AppealFolderShareRequest { Message = message });
            var idx = _folders.FindIndex(f => f.Id == folder.Id);
            if (idx >= 0)
            {
                _folders[idx] = updated;
                _folders = _folders.OrderByDescending(f => f.IsFavorite).ThenByDescending(f => f.UpdatedAt).ToList();
                StateHasChanged();
            }

            Snackbar.Add("Human review requested. Your folder is now waiting for moderator review.", Severity.Info);
        }
        catch (DocumentApiException ex)
        {
            Snackbar.Add(MapError(ex) ?? ex.Message, Severity.Error);
        }
    }

    private static bool CanRequestHumanReview(FolderDto folder) =>
        folder.ShareStatus == Data.Entities.FolderStatus.Rejected
        && folder.AiReviewFailureCount >= 2
        && !string.Equals(folder.ShareReviewSource, "HUMAN", StringComparison.OrdinalIgnoreCase);

    private static string GetShareButtonText(FolderDto folder)
    {
        if (folder.ShareStatus == Data.Entities.FolderStatus.PendingShare && folder.AppealRequestedAt.HasValue)
        {
            return "Human Review Pending";
        }

        return folder.ShareStatus switch
        {
            Data.Entities.FolderStatus.PendingShare => "Human Review Pending",
            Data.Entities.FolderStatus.Approved => "Shared",
            Data.Entities.FolderStatus.Rejected => "Share Again",
            _ => "Share"
        };
    }

    private static string GetShareDecisionMessage(FolderDto folder)
    {
        var reason = string.IsNullOrWhiteSpace(folder.AiReviewReason)
            ? string.Empty
            : $" Reason: {folder.AiReviewReason}";

        return folder.ShareStatus switch
        {
            Data.Entities.FolderStatus.Approved => $"AI approved this folder for community sharing.{reason}",
            Data.Entities.FolderStatus.Rejected when folder.AiReviewFailureCount >= 2 => $"AI did not approve this folder after {folder.AiReviewFailureCount} review attempts. Human review is now available.{reason}",
            Data.Entities.FolderStatus.Rejected => $"AI did not approve this folder. You can try sharing again.{reason}",
            Data.Entities.FolderStatus.PendingShare => $"Human review requested. Your folder is waiting in the moderator queue.{reason}",
            _ => $"Share request submitted.{reason}"
        };
    }

    private static Severity GetShareDecisionSeverity(FolderDto folder) => folder.ShareStatus switch
    {
        Data.Entities.FolderStatus.Approved => Severity.Success,
        Data.Entities.FolderStatus.Rejected => Severity.Warning,
        Data.Entities.FolderStatus.PendingShare when folder.RequiresHumanReview => Severity.Info,
        _ => Severity.Success
    };

