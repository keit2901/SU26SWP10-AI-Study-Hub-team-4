    private IReadOnlyList<int> GetFolderPageNumbers()
    {
        var total = _totalFolderPages;
        var current = _displayFolderPage;
        return BuildSlidingPageNumbers(total, current);
    }

    private static IReadOnlyList<int> BuildSlidingPageNumbers(int total, int current)
    {
        var pages = new List<int>();

        if (total <= 4)
        {
            for (var index = 1; index <= total; index++)
            {
                pages.Add(index);
            }

            return pages;
        }

        if (current <= 2)
        {
            for (var index = 1; index <= 3; index++)
            {
                pages.Add(index);
            }

            pages.Add(-1);
            pages.Add(total);
            return pages;
        }

        if (current >= total - 1)
        {
            pages.Add(1);
            pages.Add(-1);

            for (var index = total - 2; index <= total; index++)
            {
                pages.Add(index);
            }

            return pages;
        }

        for (var index = current - 1; index <= current + 1; index++)
        {
            pages.Add(index);
        }

        pages.Add(-1);
        pages.Add(total);
        return pages;
    }

