@page "/documents"
@rendermode InteractiveServer
@using AI_Study_Hub_v2.Data.Entities
@using AI_Study_Hub_v2.Dtos
@using AI_Study_Hub_v2.Services
@inject DocumentApiClient DocumentsApi
@inject AuthSessionState Session
@inject NavigationManager Nav
@inject IDialogService Dialogs
@inject ISnackbar Snackbar

<PageTitle>My documents - AI Study Hub v2</PageTitle>

<MudStack Spacing="3" Class="pa-4" Style="max-width: 1100px; margin: 0 auto;">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="flex-wrap: wrap; gap: 0.5rem;">
        <div>
            <MudText Typo="Typo.h5">My documents</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Documents you have uploaded. Newest first.
            </MudText>
        </div>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.UploadFile"
                   Href="/documents/upload">
            Upload document
        </MudButton>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="0" Outlined="true">
        <MudStack Row="true" Spacing="2" Style="flex-wrap: wrap;">
            <MudTextField T="string"
                          Label="Subject code"
                          @bind-Value="_subjectFilter"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Clearable="true"
                          Style="min-width: 160px;" />
            <MudTextField T="string"
                          Label="Semester"
                          @bind-Value="_semesterFilter"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Clearable="true"
                          Style="min-width: 140px;" />
            <MudTextField T="string"
                          Label="Search file name"
                          @bind-Value="_textFilter"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Clearable="true"
                          Style="min-width: 220px; flex: 1;" />
            <MudButton Variant="Variant.Filled"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.Search"
                       OnClick="ApplyFiltersAsync"
                       Disabled="_busy">
                Apply
            </MudButton>
            <MudButton Variant="Variant.Text"
                       OnClick="ClearFiltersAsync"
                       Disabled="_busy || (string.IsNullOrEmpty(_subjectFilter) && string.IsNullOrEmpty(_semesterFilter) && string.IsNullOrEmpty(_textFilter))">
                Clear
            </MudButton>
        </MudStack>
    </MudPaper>

    @if (!string.IsNullOrEmpty(_error))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true">@_error</MudAlert>
    }

    <MudTable Items="_rows"
              Hover="true"
              Bordered="false"
              Striped="true"
              Dense="false"
              Loading="_busy"
              LoadingProgressColor="Color.Primary"
              Class="mud-elevation-1">
        <HeaderContent>
            <MudTh>File</MudTh>
            <MudTh>Subject</MudTh>
            <MudTh>Semester</MudTh>
            <MudTh>Size</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Uploaded</MudTh>
            <MudTh Style="width: 1%; white-space: nowrap;">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="File">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@GetFileIcon(context.MimeType)" Color="Color.Primary" />
                    <MudLink Href="@($"/documents/{context.Id}")">@context.FileName</MudLink>
                </MudStack>
            </MudTd>
            <MudTd DataLabel="Subject">@context.SubjectCode</MudTd>
            <MudTd DataLabel="Semester">@context.Semester</MudTd>
            <MudTd DataLabel="Size">@FormatBytes(context.FileSizeBytes)</MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Status)" Variant="Variant.Filled">
                    @context.Status.ToString()
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Uploaded">@context.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudTd>
            <MudTd DataLabel="Actions">
                <MudStack Row="true" Spacing="1">
                    <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   Href="@($"/documents/{context.Id}")"
                                   title="View detail" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   OnClick="() => ConfirmDeleteAsync(context)"
                                   title="Delete" />
                </MudStack>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudStack AlignItems="AlignItems.Center" Class="pa-6" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.FolderOff" Size="Size.Large" Color="Color.Default" />
                <MudText Typo="Typo.subtitle1">No documents yet.</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    @(HasFilters ? "Try clearing the filters above." : "Upload your first study material to get started.")
                </MudText>
                @if (!HasFilters)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.UploadFile"
                               Href="/documents/upload">
                        Upload document
                    </MudButton>
                }
            </MudStack>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager PageSizeOptions="new[] { 10, 25, 50, 100 }" />
        </PagerContent>
    </MudTable>
</MudStack>

@code {
    private bool _busy;
    private string? _error;
    private string? _subjectFilter;
    private string? _semesterFilter;
    private string? _textFilter;
    private List<DocumentDto> _rows = new();

    private bool HasFilters =>
        !string.IsNullOrWhiteSpace(_subjectFilter) ||
        !string.IsNullOrWhiteSpace(_semesterFilter) ||
        !string.IsNullOrWhiteSpace(_textFilter);

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated)
        {
            Nav.NavigateTo("/login", replace: true);
            return;
        }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        if (string.IsNullOrEmpty(Session.AccessToken)) return;
        _busy = true;
        _error = null;
        StateHasChanged();
        try
        {
            var query = new DocumentListQuery
            {
                SubjectCode = NormalizeOrNull(_subjectFilter),
                Semester = NormalizeOrNull(_semesterFilter),
                Q = string.IsNullOrWhiteSpace(_textFilter) ? null : _textFilter.Trim(),
            };
            var rows = await DocumentsApi.ListAsync(Session.AccessToken!, query);
            _rows = rows.ToList();
        }
        catch (DocumentApiException ex)
        {
            _error = MapError(ex);
            if (ex.StatusCode == 401)
            {
                Session.Clear();
                Nav.NavigateTo("/login", replace: true);
            }
        }
        catch (Exception ex)
        {
            _error = $"Network error: {ex.Message}";
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    private Task ApplyFiltersAsync() => LoadAsync();

    private async Task ClearFiltersAsync()
    {
        _subjectFilter = null;
        _semesterFilter = null;
        _textFilter = null;
        await LoadAsync();
    }

    private async Task ConfirmDeleteAsync(DocumentDto doc)
    {
        var parameters = new DialogParameters
        {
            ["Title"] = "Delete document?",
            ["Message"] = $"Delete \"{doc.FileName}\"? This cannot be undone — chunks and the stored file will be removed.",
            ["ConfirmText"] = "Delete",
            ["ConfirmColor"] = Color.Error,
            ["Icon"] = Icons.Material.Filled.DeleteForever,
            ["IconColor"] = Color.Error,
        };
        var options = new DialogOptions { CloseOnEscapeKey = true };
        var dialogRef = await Dialogs.ShowAsync<AI_Study_Hub_v2.Components.Admin.Shared.ConfirmDialog>("Delete document", parameters, options);
        var result = await dialogRef.Result;
        if (result is null || result.Canceled) return;

        await DeleteAsync(doc);
    }

    private async Task DeleteAsync(DocumentDto doc)
    {
        if (string.IsNullOrEmpty(Session.AccessToken)) return;
        _busy = true;
        StateHasChanged();
        try
        {
            await DocumentsApi.DeleteAsync(Session.AccessToken!, doc.Id);
            _rows.RemoveAll(d => d.Id == doc.Id);
            Snackbar.Add($"Deleted \"{doc.FileName}\".", Severity.Success);
        }
        catch (DocumentApiException ex)
        {
            Snackbar.Add(MapError(ex), Severity.Error);
            if (ex.StatusCode == 401)
            {
                Session.Clear();
                Nav.NavigateTo("/login", replace: true);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Network error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    private static string? NormalizeOrNull(string? s) =>
        string.IsNullOrWhiteSpace(s) ? null : s.Trim().ToUpperInvariant();

    private static string MapError(DocumentApiException ex) => ex.StatusCode switch
    {
        401 => "Your session has expired. Please sign in again.",
        403 => "You do not have access to that document.",
        404 => "Document not found — it may have been deleted already.",
        _ => ex.Message,
    };

    private static Color StatusColor(DocumentStatus s) => s switch
    {
        DocumentStatus.Ready => Color.Success,
        DocumentStatus.Uploading => Color.Info,
        DocumentStatus.Processing => Color.Warning,
        DocumentStatus.Failed => Color.Error,
        _ => Color.Default,
    };

    private static string GetFileIcon(string? mime) => mime switch
    {
        "application/pdf" => Icons.Material.Filled.PictureAsPdf,
        "application/msword" => Icons.Material.Filled.Description,
        "application/vnd.openxmlformats-officedocument.wordprocessingml.document" => Icons.Material.Filled.Description,
        "application/vnd.ms-powerpoint" => Icons.Material.Filled.Slideshow,
        "application/vnd.openxmlformats-officedocument.presentationml.presentation" => Icons.Material.Filled.Slideshow,
        _ => Icons.Material.Filled.InsertDriveFile,
    };

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024L * 1024) return $"{bytes / 1024.0:0.#} KB";
        if (bytes < 1024L * 1024 * 1024) return $"{bytes / (1024.0 * 1024):0.#} MB";
        return $"{bytes / (1024.0 * 1024 * 1024):0.##} GB";
    }
}
