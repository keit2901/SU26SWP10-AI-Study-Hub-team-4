<div style="background: #fff; padding: 1.5rem; border-radius: 1rem; box-shadow: 0 2px 10px -4px rgba(0,0,0,0.05); border: 1px solid #f1f5f9; display: flex; flex-direction: column; justify-content: space-between; min-height: 130px;">
    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.5rem;">
        <div style="padding: 0.625rem; border-radius: 9999px; background: @BgColor;">
            <MudIcon Icon="@Icon" Style="@($"font-size: 1.25rem; color: {IconColor};")" />
        </div>
        <span style="font-size: 1.875rem; font-weight: 600; color: #111827;">@Count</span>
    </div>
    <div style="margin-top: 0.5rem;">
        <h3 style="font-size: 0.875rem; font-weight: 600; color: #111827; margin: 0;">@Title</h3>
        <p style="font-size: 0.6875rem; color: #6b7280; margin-top: 0.25rem; margin-bottom: 0;">@Description</p>
    </div>
</div>

@code {
    [Parameter] public string Icon { get; set; } = string.Empty;
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Count { get; set; } = "0";
    [Parameter] public string Description { get; set; } = string.Empty;
    [Parameter] public string BgColor { get; set; } = "#eef2ff";
    [Parameter] public string IconColor { get; set; } = "#4f46e5";
}
