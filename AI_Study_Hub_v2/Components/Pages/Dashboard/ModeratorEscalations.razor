@page "/dashboard/escalations"
@layout AI_Study_Hub_v2.Components.Layout.DashboardLayout
@using AI_Study_Hub_v2.Components.Layout
@using AI_Study_Hub_v2.Dtos
@using AI_Study_Hub_v2.Services
@using Microsoft.AspNetCore.Components
@using MudBlazor
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject AuthSessionState Session
@inject EscalationApiClient EscalationClient

<PageTitle>My Escalations - AI Study Hub</PageTitle>

<div style="padding: 2rem 1.5rem; width: 100%; box-sizing: border-box;">
    <div style="margin-bottom: 2rem; display: flex; flex-direction: column; gap: 0.5rem;">
        <h1 style="font-size: 1.875rem; font-weight: 700; line-height: 1.2; letter-spacing: -0.6px; color: #1a1b1f; margin: 0;">
            My Escalations
        </h1>
        <p style="font-size: 1rem; font-weight: 400; color: #464554; margin: 0;">
            Track escalations you've sent to admin for review.
        </p>
    </div>

    <!-- KPI Cards -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.25rem; margin-bottom: 2rem;">
        <div style="background: #ffffff; border: 1px solid rgba(199, 196, 215, 0.3); border-radius: 12px; padding: 1.25rem; box-shadow: 0px 4px 20px rgba(0, 0, 0, 0.03);">
            <div style="display: flex; justify-content: space-between; align-items: start;">
                <div>
                    <div style="font-size: 11px; font-weight: 700; color: #767586; letter-spacing: 0.05em; text-transform: uppercase;">Pending</div>
                    <div style="font-size: 28px; font-weight: 800; color: #1a1b1f; margin-top: 4px; line-height: 1;">@_pendingCount</div>
                    <div style="font-size: 12px; color: #767586; font-weight: 500; margin-top: 8px;">Awaiting admin review</div>
                </div>
                <div style="width: 40px; height: 40px; border-radius: 50%; background: rgba(245, 158, 11, 0.1); color: #d97706; display: flex; align-items: center; justify-content: center;">
                    <MudIcon Icon="@Icons.Material.Outlined.Flag" />
                </div>
            </div>
        </div>
        <div style="background: #ffffff; border: 1px solid rgba(199, 196, 215, 0.3); border-radius: 12px; padding: 1.25rem; box-shadow: 0px 4px 20px rgba(0, 0, 0, 0.03);">
            <div style="display: flex; justify-content: space-between; align-items: start;">
                <div>
                    <div style="font-size: 11px; font-weight: 700; color: #767586; letter-spacing: 0.05em; text-transform: uppercase;">Resolved</div>
                    <div style="font-size: 28px; font-weight: 800; color: #1a1b1f; margin-top: 4px; line-height: 1;">@_resolvedCount</div>
                    <div style="font-size: 12px; color: #767586; font-weight: 500; margin-top: 8px;">Total resolved</div>
                </div>
                <div style="width: 40px; height: 40px; border-radius: 50%; background: rgba(16, 185, 129, 0.1); color: #10b981; display: flex; align-items: center; justify-content: center;">
                    <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" />
                </div>
            </div>
        </div>
    </div>

    <!-- Loading / Error / Empty -->
    @if (_isLoading)
    {
        <div style="padding: 1.5rem;">
            <MudSkeleton Height="44px" Animation="Animation.Wave" />
            <MudSkeleton Height="44px" Animation="Animation.Wave" />
            <MudSkeleton Height="44px" Animation="Animation.Wave" />
        </div>
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="ma-4">
            @_errorMessage
        </MudAlert>
    }
    else if (_escalations.Count == 0)
    {
        <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 3rem 1rem; text-align: center; gap: 0.5rem;">
            <MudIcon Icon="@Icons.Material.Filled.Flag" Size="Size.Large" Color="Color.Secondary" />
            <div style="font-weight: 700; font-size: 1.125rem; color: #1a1b1f;">No escalations yet</div>
            <div style="font-size: 0.875rem; color: #767586;">When you escalate a rejected document, it will appear here.</div>
        </div>
    }
    else
    {
        <!-- Escalation Cards -->
        <div style="display: flex; flex-direction: column; gap: 1rem;">
            @foreach (var escalation in _escalations)
            {
                <div style="background: #ffffff; border-radius: 12px; border: 1px solid rgba(199, 196, 215, 0.3); padding: 1.25rem; transition: transform 0.2s ease, box-shadow 0.2s ease;"
                     onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 8px 24px rgba(0,0,0,0.08)'"
                     onmouseout="this.style.transform=''; this.style.boxShadow=''">
                    <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 0.75rem;">
                        <div>
                            <div style="display: flex; align-items: center; gap: 0.5rem;">
                                <span style="font-size: 10px; font-weight: 700; padding: 3px 8px; border-radius: 4px; letter-spacing: 0.02em;
                                    @(escalation.EscalationStatus == "Pending" ? "background: #fffdf5; border: 1px solid #fef3c7; color: #d97706;" : "background: rgba(16, 185, 129, 0.05); border: 1px solid rgba(16, 185, 129, 0.2); color: #10b981;")">
                                    @escalation.EscalationStatus.ToUpper()
                                </span>
                                <span style="font-weight: 700; font-size: 15px; color: #1a1b1f;">Escalation</span>
                            </div>
                            <div style="font-size: 12px; color: #767586; margin-top: 4px;">
                                @escalation.CreatedAt.LocalDateTime.ToString("MMM dd, yyyy HH:mm")
                            </div>
                        </div>
                    </div>

                    <!-- Reason -->
                    <div style="background: #f8fafc; border-radius: 8px; padding: 12px; margin-bottom: 0.75rem;">
                        <div style="font-size: 11px; font-weight: 700; color: #767586; letter-spacing: 0.05em; margin-bottom: 4px;">ESCALATION REASON</div>
                        <div style="font-size: 13px; color: #1a1b1f;">@escalation.Reason</div>
                    </div>

                    <!-- Admin Response (if resolved) -->
                    @if (!string.IsNullOrEmpty(escalation.AdminResponse))
                    {
                        <div style="background: rgba(94, 92, 230, 0.04); border-radius: 8px; padding: 12px; border-left: 3px solid #5e5ce6; margin-bottom: 0.75rem;">
                            <div style="font-size: 11px; font-weight: 700; color: #5e5ce6; letter-spacing: 0.05em; margin-bottom: 4px;">ADMIN RESPONSE</div>
                            <div style="font-size: 13px; color: #1a1b1f;">@escalation.AdminResponse</div>
                        </div>
                    }

                    <!-- Documents -->
                    <div>
                        <div style="font-size: 12px; font-weight: 700; color: #767586; margin-bottom: 0.5rem;">
                            Documents (@escalation.Items.Count)
                        </div>
                        <div style="display: flex; flex-direction: column; gap: 4px;">
                            @foreach (var item in escalation.Items)
                            {
                                <div style="display: flex; align-items: center; padding: 0.5rem; background: #f8fafc; border-radius: 6px; gap: 0.5rem;">
                                    <MudIcon Icon="@Icons.Material.Filled.Description" Style="font-size: 16px; color: #767586;" />
                                    <div style="flex: 1; overflow: hidden;">
                                        <div style="font-weight: 700; font-size: 12px; color: #1a1b1f; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@item.FileName</div>
                                        <div style="font-size: 11px; color: #767586;">@item.RejectReason</div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<DocumentEscalationDto> _escalations = new();
    private bool _isLoading = true;
    private string? _errorMessage;

    private int _pendingCount;
    private int _resolvedCount;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var token = Session.AccessToken;
            if (string.IsNullOrEmpty(token))
            {
                _errorMessage = "Authentication required. Please log in.";
                return;
            }

            var all = await EscalationClient.GetMyAsync(token);
            _escalations = all.ToList();
            _pendingCount = _escalations.Count(e => e.EscalationStatus == "Pending");
            _resolvedCount = _escalations.Count(e => e.EscalationStatus != "Pending");
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to load escalations: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }
}