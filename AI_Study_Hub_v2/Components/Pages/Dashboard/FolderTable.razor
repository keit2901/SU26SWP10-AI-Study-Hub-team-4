    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var focusColumn = _pendingFocusColumn;
        _pendingFocusColumn = null;

        if (!string.IsNullOrWhiteSpace(focusColumn))
        {
            switch (focusColumn)
            {
                case "name":
                    await JS.InvokeVoidAsync("codexTableFilter.focusElement", _nameSearchInput, true);
                    break;
                case "owner":
                    await JS.InvokeVoidAsync("codexTableFilter.focusElement", _ownerSearchInput, true);
                    break;
                case "subject":
                    await JS.InvokeVoidAsync("codexTableFilter.focusElement", _subjectSearchInput, true);
                    break;
                case "semester":
                    await JS.InvokeVoidAsync("codexTableFilter.focusElement", _semesterSearchInput, true);
                    break;
                case "status":
                    await JS.InvokeVoidAsync("codexTableFilter.focusElement", _statusSearchInput, true);
                    break;
            }
        }

        if (_pendingSuggestionScrollIndex.HasValue && !string.IsNullOrWhiteSpace(_pendingSuggestionScrollColumn))
        {
            var scrollIndex = _pendingSuggestionScrollIndex.Value;
            var scrollColumn = _pendingSuggestionScrollColumn;
            _pendingSuggestionScrollIndex = null;
            _pendingSuggestionScrollColumn = null;

            if (string.Equals(OpenMenuColumn, scrollColumn, StringComparison.OrdinalIgnoreCase))
            {
                var suggestionsList = scrollColumn switch
                {
                    "name" => _nameSuggestionsList,
                    "owner" => _ownerSuggestionsList,
                    "subject" => _subjectSuggestionsList,
                    "semester" => _semesterSuggestionsList,
                    "status" => _statusSuggestionsList,
                    _ => default
                };

                await JS.InvokeVoidAsync("codexTableFilter.scrollOptionIntoViewByIndex", suggestionsList, scrollIndex);
            }
        }
    }

    private void ApplySearch(string columnKey)
    {
        var value = columnKey switch
        {
            "name" => NameSearchTerm,
            "owner" => OwnerSearchTerm,
            "subject" => SubjectSearchTerm,
            "semester" => SemesterSearchTerm,
            "status" => StatusSearchTerm,
            _ => string.Empty
        };

        switch (columnKey)
        {
            case "name":
                FilterNameQuery = value;
                ResetHighlightedSuggestion("name");
                break;
            case "owner":
                FilterOwnerQuery = value;
                ResetHighlightedSuggestion("owner");
                break;
            case "subject":
                FilterSubjectQuery = value;
                ResetHighlightedSuggestion("subject");
                break;
            case "semester":
                FilterSemesterQuery = value;
                ResetHighlightedSuggestion("semester");
                break;
            case "status":
                FilterStatus = value;
                ResetHighlightedSuggestion("status");
                break;
        }

        CurrentPage = 1;
        CloseOpenMenu();
    }

    private void HandleSearchKeyDown(string columnKey, KeyboardEventArgs e)
    {
        if (string.Equals(e.Key, "ArrowDown", StringComparison.OrdinalIgnoreCase))
        {
            MoveSuggestionSelection(columnKey, 1);
            return;
        }

        if (string.Equals(e.Key, "ArrowUp", StringComparison.OrdinalIgnoreCase))
        {
            MoveSuggestionSelection(columnKey, -1);
            return;
        }

        if (string.Equals(e.Key, "Enter", StringComparison.OrdinalIgnoreCase))
        {
            ApplyHighlightedOrTypedSearch(columnKey);
            return;
        }

        if (string.Equals(e.Key, "Escape", StringComparison.OrdinalIgnoreCase))
        {
            CloseOpenMenu();
        }
    }

    private void MoveSuggestionSelection(string columnKey, int offset)
    {
        var suggestions = GetSuggestions(columnKey);
        if (suggestions.Count == 0)
        {
            ResetHighlightedSuggestion(columnKey);
            return;
        }

        var highlightedIndex = GetHighlightedSuggestionIndex(columnKey);
        if (highlightedIndex < 0)
        {
            SetHighlightedSuggestionIndex(columnKey, offset > 0 ? 0 : suggestions.Count - 1);
        }
        else
        {
            SetHighlightedSuggestionIndex(columnKey, (highlightedIndex + offset + suggestions.Count) % suggestions.Count);
        }

        _pendingSuggestionScrollColumn = columnKey;
        _pendingSuggestionScrollIndex = GetHighlightedSuggestionIndex(columnKey);
    }

    private void ApplyHighlightedOrTypedSearch(string columnKey)
    {
        var selectedValue = columnKey switch
        {
            "name" => NameSearchTerm,
            "owner" => OwnerSearchTerm,
            "subject" => SubjectSearchTerm,
            "semester" => SemesterSearchTerm,
            "status" => StatusSearchTerm,
            _ => string.Empty
        };

        var suggestions = GetSuggestions(columnKey);
        var highlightedIndex = GetHighlightedSuggestionIndex(columnKey);
        if (highlightedIndex >= 0 && highlightedIndex < suggestions.Count)
        {
            selectedValue = suggestions[highlightedIndex];
        }

        switch (columnKey)
        {
            case "name":
                NameSearchTerm = selectedValue;
                break;
            case "owner":
                OwnerSearchTerm = selectedValue;
                break;
            case "subject":
                SubjectSearchTerm = selectedValue;
                break;
            case "semester":
                SemesterSearchTerm = selectedValue;
                break;
            case "status":
                StatusSearchTerm = selectedValue;
                break;
        }

        ApplySearch(columnKey);
    }

