@inject NavigationManager Nav
@inject IJSRuntime JS

<style>
    .moderator-folder-pagination-bar { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 16px; border-top: 1px solid #f1f5f9; flex-wrap: wrap; }
    .moderator-folder-pagination-actions { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; justify-content: flex-end; }
    .moderator-folder-pagination-controls { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
    .moderator-folder-pagination-jump { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    .moderator-folder-view-all-link { display: inline-flex; align-items: center; font-size: 0.875rem; font-weight: 500; color: #4f46e5; text-decoration: none; }
    .moderator-folder-page-nav-btn { border: 1px solid #e2e8f0; border-radius: 8px; background: #fff; color: #475569; padding: 6px 10px; font-size: 12px; font-weight: 700; cursor: pointer; }
    .moderator-folder-page-nav-btn:disabled { opacity: 0.4; cursor: default; }
    .moderator-folder-page-nav-btn:hover:not(:disabled) { border-color: #6366f1; color: #4f46e5; background: #f8fafc; }
    .moderator-folder-page-number-btn { min-width: 34px; height: 34px; border-radius: 8px; border: 1px solid #e2e8f0; background: #fff; color: #475569; font-size: 12px; font-weight: 700; cursor: pointer; }
    .moderator-folder-page-number-btn:hover { border-color: #6366f1; color: #4f46e5; background: #f8fafc; }
    .moderator-folder-page-number-btn.active { border-color: #6366f1; background: #6366f1; color: #fff; }
    .moderator-folder-page-ellipsis { color: #94a3b8; font-size: 12px; font-weight: 700; padding: 0 2px; }
    .moderator-folder-page-jump-input { width: 86px; border: 1px solid #cbd5e1; border-radius: 8px; background: #fff; color: #1e293b; padding: 7px 10px; font-size: 12px; outline: none; }
    .moderator-folder-page-jump-input:focus { border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,0.12); }
</style>

<div style="background: #fff; border-radius: 1rem; box-shadow: 0 2px 10px -4px rgba(0,0,0,0.05); border: 1px solid #f1f5f9; overflow: visible; margin-top: 2rem;">
    <div style="padding: 1.5rem; display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; flex-wrap: wrap;">
        <div>
            <h2 style="font-size: 1.125rem; font-weight: 600; color: #111827; margin: 0;">Folder Management</h2>
            <p style="font-size: 0.875rem; color: #6b7280; margin-top: 0.25rem; margin-bottom: 0;">Your current academic structure.</p>
        </div>
        <button @onclick="ResetTable"
                style="display: inline-flex; align-items: center; justify-content: center; gap: 0.4rem; border-radius: 9999px; border: 1px solid rgba(94,92,230,0.22); background: rgba(94,92,230,0.08); color: #4441CC; padding: 0.55rem 0.95rem; font-size: 0.8125rem; font-weight: 700; cursor: pointer;">
            <MudIcon Icon="@Icons.Material.Filled.RestartAlt" Style="font-size: 1rem;" />
            <span>Reset table</span>
        </button>
    </div>

    <div style="padding: 0 1.5rem 1rem;">
        <div style="display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 0.75rem; padding: 0.95rem 1rem; border: 1px solid #f1f5f9; border-radius: 0.875rem; background: #fff;">
            <label style="display: flex; flex-direction: column; gap: 0.35rem; min-width: 0;">
                <span style="font-size: 0.6875rem; font-weight: 700; color: #6b7280; text-transform: uppercase; letter-spacing: 0.08em;">Folder Name</span>
                <input type="text"
                       value="@FilterNameQuery"
                       @oninput='e => UpdateAppliedFilter("name", e.Value?.ToString())'
                       placeholder="Search folder name"
                       style='@GetTopFilterInputStyle()' />
            </label>
            <label style="display: flex; flex-direction: column; gap: 0.35rem; min-width: 0;">
                <span style="font-size: 0.6875rem; font-weight: 700; color: #6b7280; text-transform: uppercase; letter-spacing: 0.08em;">Owner</span>
                <input type="text"
                       value="@FilterOwnerQuery"
                       @oninput='e => UpdateAppliedFilter("owner", e.Value?.ToString())'
                       placeholder="Search owner"
                       style='@GetTopFilterInputStyle()' />
            </label>
            <label style="display: flex; flex-direction: column; gap: 0.35rem; min-width: 0;">
                <span style="font-size: 0.6875rem; font-weight: 700; color: #6b7280; text-transform: uppercase; letter-spacing: 0.08em;">Subject Code</span>
                <input type="text"
                       value="@FilterSubjectQuery"
                       @oninput='e => UpdateAppliedFilter("subject", e.Value?.ToString())'
                       placeholder="Search subject code"
                       style='@GetTopFilterInputStyle()' />
            </label>
            <label style="display: flex; flex-direction: column; gap: 0.35rem; min-width: 0;">
                <span style="font-size: 0.6875rem; font-weight: 700; color: #6b7280; text-transform: uppercase; letter-spacing: 0.08em;">Semester</span>
                <input type="text"
                       value="@FilterSemesterQuery"
                       @oninput='e => UpdateAppliedFilter("semester", e.Value?.ToString())'
                       placeholder="Search semester"
                       style='@GetTopFilterInputStyle()' />
            </label>
            <label style="display: flex; flex-direction: column; gap: 0.35rem; min-width: 0;">
                <span style="font-size: 0.6875rem; font-weight: 700; color: #6b7280; text-transform: uppercase; letter-spacing: 0.08em;">Status</span>
                <select value="@FilterStatus"
                        @onchange='e => UpdateAppliedFilter("status", e.Value?.ToString())'
                        style='@GetTopFilterInputStyle()'>
                    <option value="">All status</option>
                    @foreach (var statusOption in StatusOptions)
                    {
                        <option value="@statusOption">@statusOption</option>
                    }
                </select>
            </label>
        </div>
    </div>

    <div style="position: relative;">
        @if (!string.IsNullOrWhiteSpace(OpenMenuColumn))
        {
            <button type="button"
                    @onclick="CloseOpenMenu"
                    aria-label="Close filter menu"
                    style="position: fixed; inset: 0; z-index: 4; border: none; background: transparent; padding: 0; margin: 0;"></button>
        }
    <div style="overflow-x: auto; overflow-y: visible;">
        <table style="width: 100%; text-align: left; border-collapse: collapse;">
            <thead>
                <tr style="background: rgba(249,250,251,0.8); border-top: 1px solid #f1f5f9; border-bottom: 1px solid #f1f5f9;">
                    <th style="padding: 0.8rem 1rem 0.8rem 24px; text-align: left; position: relative;">
                        <button @ref="_nameHeaderButton" @onclick='() => ToggleSort("name")' style='@GetHeaderButtonStyle("name", true)'>
                            <span>Folder Name</span>
                            <MudIcon Icon='@GetSortIcon("name")' Style='@GetSortIconStyle("name")' />
                        </button>
                        @if (OpenMenuColumn == "name")
                        {
                            var nameSuggestions = GetSuggestions("name");
                            <div style='@GetHeaderMenuStyle("16rem", true)'>
                                <span style='@GetMenuSectionLabelStyle()'>Filter</span>
                                <div style='@GetFilterSearchRowStyle()'>
                                    <input type="text"
                                           @ref="_nameSearchInput"
                                           value="@NameSearchTerm"
                                           @oninput='e => UpdateTextSearch("name", e.Value?.ToString())'
                                           @onkeydown='e => HandleSearchKeyDown("name", e)'
                                           placeholder="Search folder name"
                                           style='@GetFilterInputStyle()' />
                                </div>
                                <div @ref="_nameSuggestionsList" style='@GetFilterOptionsListStyle()'>
                                    @if (nameSuggestions.Count > 0)
                                    {
                                        @for (var suggestionIndex = 0; suggestionIndex < nameSuggestions.Count; suggestionIndex++)
                                        {
                                            var option = nameSuggestions[suggestionIndex];
                                            var isHighlightedSuggestion = suggestionIndex == _highlightedNameSuggestionIndex;
                                            <button type="button" @onclick='() => ApplyTextSuggestion("name", option)' style='@GetFilterMenuItemStyle(isHighlightedSuggestion || (_highlightedNameSuggestionIndex < 0 && string.Equals(NameSearchTerm, option, StringComparison.OrdinalIgnoreCase)))'>@option</button>
                                        }
                                    }
                                    else
                                    {
                                        <span style='@GetMenuEmptyStateStyle()'>No matching folder names</span>
                                    }
                                </div>
                                <div style='@GetMenuDividerStyle()'></div>
                                <span style='@GetMenuSectionLabelStyle()'>Sort</span>
                                <button @onclick='() => ApplySortOption("name", "name-asc")' style='@GetSortMenuItemStyle("name-asc")'>A to Z</button>
                                <button @onclick='() => ApplySortOption("name", "name-desc")' style='@GetSortMenuItemStyle("name-desc")'>Z to A</button>
                            </div>
                        }
                    </th>
                    <th style="padding: 0.75rem 1.5rem; text-align: center; position: relative;">
                        <button @ref="_ownerHeaderButton" @onclick='() => ToggleSort("owner")' style='@GetHeaderButtonStyle("owner")'>
                            <span>Owner</span>
                            <MudIcon Icon='@GetSortIcon("owner")' Style='@GetSortIconStyle("owner")' />
                        </button>
                        @if (OpenMenuColumn == "owner")
                        {
                            var ownerSuggestions = GetSuggestions("owner");
                            <div style='@GetHeaderMenuStyle("14rem", true)'>
                                <span style='@GetMenuSectionLabelStyle()'>Filter</span>
                                <div style='@GetFilterSearchRowStyle()'>
                                    <input type="text"
                                           @ref="_ownerSearchInput"
                                           value="@OwnerSearchTerm"
                                           @oninput='e => UpdateTextSearch("owner", e.Value?.ToString())'
                                           @onkeydown='e => HandleSearchKeyDown("owner", e)'
                                           placeholder="Search owner"
                                           style='@GetFilterInputStyle()' />
                                </div>
                                <div @ref="_ownerSuggestionsList" style='@GetFilterOptionsListStyle()'>
                                    @if (ownerSuggestions.Count > 0)
                                    {
                                        @for (var suggestionIndex = 0; suggestionIndex < ownerSuggestions.Count; suggestionIndex++)
                                        {
                                            var option = ownerSuggestions[suggestionIndex];
                                            var isHighlightedSuggestion = suggestionIndex == _highlightedOwnerSuggestionIndex;
                                            <button type="button" @onclick='() => ApplyTextSuggestion("owner", option)' style='@GetFilterMenuItemStyle(isHighlightedSuggestion || (_highlightedOwnerSuggestionIndex < 0 && string.Equals(OwnerSearchTerm, option, StringComparison.OrdinalIgnoreCase)))'>@option</button>
                                        }
                                    }
                                    else
                                    {
                                        <span style='@GetMenuEmptyStateStyle()'>No matching owners</span>
                                    }
                                </div>
                                <div style='@GetMenuDividerStyle()'></div>
                                <span style='@GetMenuSectionLabelStyle()'>Sort</span>
                                <button @onclick='() => ApplySortOption("owner", "owner-asc")' style='@GetSortMenuItemStyle("owner-asc")'>A to Z</button>
                                <button @onclick='() => ApplySortOption("owner", "owner-desc")' style='@GetSortMenuItemStyle("owner-desc")'>Z to A</button>
                            </div>
                        }
                    </th>
                    <th style="padding: 0.75rem 1.5rem; text-align: center; position: relative;">
                        <button @ref="_subjectHeaderButton" @onclick='() => ToggleSort("subject")' style='@GetHeaderButtonStyle("subject")'>
                            <span>Subject Code</span>
                            <MudIcon Icon='@GetSortIcon("subject")' Style='@GetSortIconStyle("subject")' />
                        </button>
                        @if (OpenMenuColumn == "subject")
                        {
                            var subjectSuggestions = GetSuggestions("subject");
                            <div style='@GetHeaderMenuStyle("14rem", true)'>
                                <span style='@GetMenuSectionLabelStyle()'>Filter</span>
                                <div style='@GetFilterSearchRowStyle()'>
                                    <input type="text"
                                           @ref="_subjectSearchInput"
                                           value="@SubjectSearchTerm"
                                           @oninput='e => UpdateTextSearch("subject", e.Value?.ToString())'
                                           @onkeydown='e => HandleSearchKeyDown("subject", e)'
                                           placeholder="Search subject code"
                                           style='@GetFilterInputStyle()' />
                                </div>
                                <div @ref="_subjectSuggestionsList" style='@GetFilterOptionsListStyle()'>
                                    @if (subjectSuggestions.Count > 0)
                                    {
                                        @for (var suggestionIndex = 0; suggestionIndex < subjectSuggestions.Count; suggestionIndex++)
                                        {
                                            var option = subjectSuggestions[suggestionIndex];
                                            var isHighlightedSuggestion = suggestionIndex == _highlightedSubjectSuggestionIndex;
                                            <button type="button" @onclick='() => ApplyTextSuggestion("subject", option)' style='@GetFilterMenuItemStyle(isHighlightedSuggestion || (_highlightedSubjectSuggestionIndex < 0 && string.Equals(SubjectSearchTerm, option, StringComparison.OrdinalIgnoreCase)))'>@option</button>
                                        }
                                    }
                                    else
                                    {
                                        <span style='@GetMenuEmptyStateStyle()'>No matching subjects</span>
                                    }
                                </div>
                                <div style='@GetMenuDividerStyle()'></div>
                                <span style='@GetMenuSectionLabelStyle()'>Sort</span>
                                <button @onclick='() => ApplySortOption("subject", "subject-asc")' style='@GetSortMenuItemStyle("subject-asc")'>A to Z</button>
                                <button @onclick='() => ApplySortOption("subject", "subject-desc")' style='@GetSortMenuItemStyle("subject-desc")'>Z to A</button>
                            </div>
                        }
                    </th>
                    <th style="padding: 0.75rem 1.5rem; text-align: center; position: relative;">
                        <button @ref="_semesterHeaderButton" @onclick='() => ToggleSort("semester")' style='@GetHeaderButtonStyle("semester")'>
                            <span>Semester</span>
                            <MudIcon Icon='@GetSortIcon("semester")' Style='@GetSortIconStyle("semester")' />
                        </button>
                        @if (OpenMenuColumn == "semester")
                        {
                            var semesterSuggestions = GetSuggestions("semester");
                            <div style='@GetHeaderMenuStyle("13rem", true)'>
                                <span style='@GetMenuSectionLabelStyle()'>Filter</span>
                                <div style='@GetFilterSearchRowStyle()'>
                                    <input type="text"
                                           @ref="_semesterSearchInput"
                                           value="@SemesterSearchTerm"
                                           @oninput='e => UpdateTextSearch("semester", e.Value?.ToString())'
                                           @onkeydown='e => HandleSearchKeyDown("semester", e)'
                                           placeholder="Search semester"
                                           style='@GetFilterInputStyle()' />
                                </div>
                                <div @ref="_semesterSuggestionsList" style='@GetFilterOptionsListStyle()'>
                                    @if (semesterSuggestions.Count > 0)
                                    {
                                        @for (var suggestionIndex = 0; suggestionIndex < semesterSuggestions.Count; suggestionIndex++)
                                        {
                                            var option = semesterSuggestions[suggestionIndex];
                                            var isHighlightedSuggestion = suggestionIndex == _highlightedSemesterSuggestionIndex;
                                            <button type="button" @onclick='() => ApplyTextSuggestion("semester", option)' style='@GetFilterMenuItemStyle(isHighlightedSuggestion || (_highlightedSemesterSuggestionIndex < 0 && string.Equals(SemesterSearchTerm, option, StringComparison.OrdinalIgnoreCase)))'>@option</button>
                                        }
                                    }
                                    else
                                    {
                                        <span style='@GetMenuEmptyStateStyle()'>No matching semesters</span>
                                    }
                                </div>
                                <div style='@GetMenuDividerStyle()'></div>
                                <span style='@GetMenuSectionLabelStyle()'>Sort</span>
                                <button @onclick='() => ApplySortOption("semester", "semester-asc")' style='@GetSortMenuItemStyle("semester-asc")'>A to Z</button>
                                <button @onclick='() => ApplySortOption("semester", "semester-desc")' style='@GetSortMenuItemStyle("semester-desc")'>Z to A</button>
                            </div>
                        }
                    </th>
                    <th style="padding: 0.75rem 1.5rem; text-align: left; position: relative;">
                        <span style="display: inline-flex; align-items: center; justify-content: flex-start; color: #464554; font-size: 0.8125rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.65px;">
                            Status
                        </span>
                        @if (OpenMenuColumn == "status")
                        {
                            var statusSuggestions = GetSuggestions("status");
                            <div style='@GetHeaderMenuStyle("14rem", true)'>
                                <span style='@GetMenuSectionLabelStyle()'>Filter</span>
                                <div style='@GetFilterSearchRowStyle()'>
                                    <input type="text"
                                           @ref="_statusSearchInput"
                                           value="@StatusSearchTerm"
                                           @oninput='e => UpdateTextSearch("status", e.Value?.ToString())'
                                           @onkeydown='e => HandleSearchKeyDown("status", e)'
                                           placeholder="Search status"
                                           style='@GetFilterInputStyle()' />
                                </div>
                                <div @ref="_statusSuggestionsList" style='@GetFilterOptionsListStyle()'>
                                    @if (statusSuggestions.Count > 0)
                                    {
                                        @for (var suggestionIndex = 0; suggestionIndex < statusSuggestions.Count; suggestionIndex++)
                                        {
                                            var statusOption = statusSuggestions[suggestionIndex];
                                            var isHighlightedSuggestion = suggestionIndex == _highlightedStatusSuggestionIndex;
                                            <button type="button" @onclick='() => ApplyTextSuggestion("status", statusOption)' style='@GetFilterMenuItemStyle(isHighlightedSuggestion || (_highlightedStatusSuggestionIndex < 0 && string.Equals(StatusSearchTerm, statusOption, StringComparison.OrdinalIgnoreCase)))'>@statusOption</button>
                                        }
                                    }
                                    else
                                    {
                                        <span style='@GetMenuEmptyStateStyle()'>No matching status</span>
                                    }
                                </div>
                                <div style='@GetMenuDividerStyle()'></div>
                                <span style='@GetMenuSectionLabelStyle()'>Sort</span>
                                <button @onclick='() => ApplySortOption("status", "status-asc")' style='@GetSortMenuItemStyle("status-asc")'>A to Z</button>
                                <button @onclick='() => ApplySortOption("status", "status-desc")' style='@GetSortMenuItemStyle("status-desc")'>Z to A</button>
                            </div>
                        }
                    </th>
                </tr>
            </thead>
            <tbody>
                @if (FilteredFolders.Any())
                {
                    @foreach (var folder in VisibleFolders)
                    {
                        <tr style="border-bottom: 1px solid #f1f5f9; cursor: pointer;" class="dashboard-row" @onclick="() => HandleRowClick(folder.Id)">
                            <td style="padding: 1rem 1.5rem 1rem 24px;">
                                <div style="display: flex; align-items: center;">
                                    <MudIcon Icon="@Icons.Material.Filled.Folder" Style="font-size: 1rem; color: #9ca3af; margin-right: 0.75rem;" />
                                    <span style="font-weight: 500; color: #1f2937; font-size: 0.875rem;">@folder.Name</span>
                                </div>
                            </td>
                            <td style="padding: 1rem 1.5rem; text-align: center; font-size: 0.85rem; color: #6b7280; font-weight: 500;">
                                @folder.OwnerName
                            </td>
                            <td style="padding: 1rem 1.5rem; text-align: center;">
                                <span style="@GetSubjectStyle(folder.Status)">@folder.SubjectCode</span>
                            </td>
                            <td style="padding: 1rem 1.5rem; text-align: center; font-size: 0.875rem; color: #6b7280; font-weight: 500;">
                                @folder.Semester
                            </td>
                            <td style="padding: 1rem 1.5rem;">
                                <span style="@GetStatusStyle(folder.Status)">
                                    <span style="@GetDotStyle(folder.Status)"></span>
                                    @folder.Status
                                </span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" style="padding: 2.25rem 1.5rem; text-align: center;">
                            <div style="display: flex; flex-direction: column; align-items: center; gap: 0.75rem;">
                                <MudIcon Icon="@Icons.Material.Filled.FilterAltOff" Style="font-size: 2.25rem; color: #a1a1aa;" />
                                <h3 style="font-size: 1rem; font-weight: 700; color: #111827; margin: 0;">No folders available</h3>
                                <p style="font-size: 0.875rem; color: #6b7280; margin: 0;">
                                    @(HasActiveFilters()
                                        ? "No folders match the current filter values."
                                        : "No folders were found for this moderation view.")
                                </p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    </div>

    <div class="moderator-folder-pagination-bar">
        <a href="community" class="moderator-folder-view-all-link">
            View all folders
            <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Style="font-size: 1rem; margin-left: 0.375rem;" />
        </a>

        @if (TotalPages > 1)
        {
            <div class="moderator-folder-pagination-actions">
                <div class="moderator-folder-pagination-controls">
                    <button type="button"
                            class="moderator-folder-page-nav-btn"
                            @onclick="() => GoToPage(CurrentPage - 1)"
                            disabled="@(CurrentPage == 1)">
                        Prev
                    </button>
                    @foreach (var pageNumber in GetPageWindow())
                    {
                        if (pageNumber == -1)
                        {
                            <span class="moderator-folder-page-ellipsis">...</span>
                        }
                        else
                        {
                            var isActivePage = pageNumber == CurrentPage;
                            <button type="button"
                                    class="moderator-folder-page-number-btn @(isActivePage ? "active" : "")"
                                    @onclick="() => GoToPage(pageNumber)">
                                @pageNumber
                            </button>
                        }
                    }
                    <button type="button"
                            class="moderator-folder-page-nav-btn"
                            @onclick="() => GoToPage(CurrentPage + 1)"
                            disabled="@(CurrentPage == TotalPages)">
                        Next
                    </button>
                </div>
                <div class="moderator-folder-pagination-jump">
                    <input type="text"
                           class="moderator-folder-page-jump-input"
                           value="@PageJumpInput"
                           placeholder="Page..."
                           inputmode="numeric"
                           @oninput="HandlePageJumpInput"
                           @onkeydown="HandlePageJumpKeyDown" />
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public IEnumerable<FolderViewModel> Folders { get; set; } = new List<FolderViewModel>();

    [Parameter]
    public EventCallback<FolderViewModel> OnFolderClick { get; set; }

    private string? OpenMenuColumn;
    private ElementReference _nameHeaderButton;
    private ElementReference _ownerHeaderButton;
    private ElementReference _subjectHeaderButton;
    private ElementReference _semesterHeaderButton;
    private ElementReference _nameSearchInput;
    private ElementReference _ownerSearchInput;
    private ElementReference _subjectSearchInput;
    private ElementReference _semesterSearchInput;
    private ElementReference _statusSearchInput;
    private ElementReference _nameSuggestionsList;
    private ElementReference _ownerSuggestionsList;
    private ElementReference _subjectSuggestionsList;
    private ElementReference _semesterSuggestionsList;
    private ElementReference _statusSuggestionsList;
    private double _menuLeft = 16;
    private double _menuTop = 112;
    private double _menuWidth = 256;
    private string NameSearchTerm = string.Empty;
    private string OwnerSearchTerm = string.Empty;
    private string SubjectSearchTerm = string.Empty;
    private string SemesterSearchTerm = string.Empty;
    private string StatusSearchTerm = string.Empty;
    private string FilterNameQuery = string.Empty;
    private string FilterOwnerQuery = string.Empty;
    private string FilterSubjectQuery = string.Empty;
    private string FilterSemesterQuery = string.Empty;
    private string FilterStatus = string.Empty;
    private string SortBy = string.Empty;
    private const int PageSize = 10;
    private int CurrentPage = 1;
    private string PageJumpInput = string.Empty;
    private string? _pendingFocusColumn;
    private string? _pendingSuggestionScrollColumn;
    private int? _pendingSuggestionScrollIndex;
    private int _highlightedNameSuggestionIndex = -1;
    private int _highlightedOwnerSuggestionIndex = -1;
    private int _highlightedSubjectSuggestionIndex = -1;
    private int _highlightedSemesterSuggestionIndex = -1;
    private int _highlightedStatusSuggestionIndex = -1;

    private IReadOnlyList<FolderViewModel> SourceFolders => Folders?.ToList() ?? [];

    private IReadOnlyList<FolderViewModel> FilteredFolders => GetFilteredFolders();

    private IReadOnlyList<FolderViewModel> VisibleFolders
    {
        get
        {
            EnsureCurrentPage();
            return FilteredFolders
                .Skip((CurrentPage - 1) * PageSize)
                .Take(PageSize)
                .ToList();
        }
    }

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(FilteredFolders.Count / (double)PageSize));

    private IReadOnlyList<string> NameOptions => SourceFolders
        .Select(folder => folder.Name)
        .Where(name => !string.IsNullOrWhiteSpace(name))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(name => name, StringComparer.OrdinalIgnoreCase)
        .ToList();

    private IReadOnlyList<string> OwnerOptions => SourceFolders
        .Select(folder => folder.OwnerName)
        .Where(owner => !string.IsNullOrWhiteSpace(owner))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(owner => owner, StringComparer.OrdinalIgnoreCase)
        .ToList();

    private IReadOnlyList<string> SubjectOptions => SourceFolders
        .Select(folder => folder.SubjectCode)
        .Where(subject => !string.IsNullOrWhiteSpace(subject))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(subject => subject, StringComparer.OrdinalIgnoreCase)
        .ToList();

    private IReadOnlyList<string> SemesterOptions => SourceFolders
        .Select(folder => folder.Semester)
        .Where(semester => !string.IsNullOrWhiteSpace(semester))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(semester => semester, StringComparer.OrdinalIgnoreCase)
        .ToList();

    private IReadOnlyList<string> StatusOptions => SourceFolders
        .Select(folder => folder.Status)
        .Where(status => !string.IsNullOrWhiteSpace(status))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(status => status, StringComparer.OrdinalIgnoreCase)
        .ToList();

    private IReadOnlyList<FolderViewModel> GetFilteredFolders()
    {
        IEnumerable<FolderViewModel> query = SourceFolders;

        if (!string.IsNullOrWhiteSpace(FilterNameQuery))
        {
            query = query.Where(folder => folder.Name.Contains(FilterNameQuery, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrWhiteSpace(FilterOwnerQuery))
        {
            query = query.Where(folder => folder.OwnerName.Contains(FilterOwnerQuery, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrWhiteSpace(FilterSubjectQuery))
        {
            query = query.Where(folder => folder.SubjectCode.Contains(FilterSubjectQuery, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrWhiteSpace(FilterSemesterQuery))
        {
            query = query.Where(folder => folder.Semester.Contains(FilterSemesterQuery, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrWhiteSpace(FilterStatus))
        {
            query = query.Where(folder => folder.Status.Contains(FilterStatus, StringComparison.OrdinalIgnoreCase));
        }

        query = SortBy switch
        {
            "name-asc" => query.OrderBy(folder => folder.Name, StringComparer.OrdinalIgnoreCase),
            "name-desc" => query.OrderByDescending(folder => folder.Name, StringComparer.OrdinalIgnoreCase),
            "owner-asc" => query.OrderBy(folder => folder.OwnerName, StringComparer.OrdinalIgnoreCase),
            "owner-desc" => query.OrderByDescending(folder => folder.OwnerName, StringComparer.OrdinalIgnoreCase),
            "subject-asc" => query.OrderBy(folder => folder.SubjectCode, StringComparer.OrdinalIgnoreCase),
            "subject-desc" => query.OrderByDescending(folder => folder.SubjectCode, StringComparer.OrdinalIgnoreCase),
            "semester-asc" => query.OrderBy(folder => folder.Semester, StringComparer.OrdinalIgnoreCase),
            "semester-desc" => query.OrderByDescending(folder => folder.Semester, StringComparer.OrdinalIgnoreCase),
            "status-asc" => query.OrderBy(folder => folder.Status, StringComparer.OrdinalIgnoreCase),
            "status-desc" => query.OrderByDescending(folder => folder.Status, StringComparer.OrdinalIgnoreCase),
            _ => query
        };

        return query.ToList();
    }

    private void EnsureCurrentPage()
    {
        if (CurrentPage < 1)
        {
            CurrentPage = 1;
        }
        else if (CurrentPage > TotalPages)
        {
            CurrentPage = TotalPages;
        }
    }

    private IReadOnlyList<string> GetSuggestions(string columnKey)
    {
        IReadOnlyList<string> options = columnKey switch
        {
            "name" => NameOptions,
            "owner" => OwnerOptions,
            "subject" => SubjectOptions,
            "semester" => SemesterOptions,
            "status" => StatusOptions,
            _ => []
        };

        var searchValue = columnKey switch
        {
            "name" => NameSearchTerm,
            "owner" => OwnerSearchTerm,
            "subject" => SubjectSearchTerm,
            "semester" => SemesterSearchTerm,
            "status" => StatusSearchTerm,
            _ => string.Empty
        };

        IEnumerable<string> query = options;
        if (!string.IsNullOrWhiteSpace(searchValue))
        {
            query = query.Where(option => option.Contains(searchValue, StringComparison.OrdinalIgnoreCase));
        }

        return query.ToList();
    }

