    private IReadOnlyList<int> GetPageWindow() =>
        BuildSlidingPageNumbers(TotalPages, CurrentPage);

    private static IReadOnlyList<int> BuildSlidingPageNumbers(int total, int current)
    {
        var pages = new List<int>();

        if (total <= 4)
        {
            for (var index = 1; index <= total; index++)
            {
                pages.Add(index);
            }

            return pages;
        }

        if (current <= 2)
        {
            for (var index = 1; index <= 3; index++)
            {
                pages.Add(index);
            }

            pages.Add(-1);
            pages.Add(total);
            return pages;
        }

        if (current >= total - 1)
        {
            pages.Add(1);
            pages.Add(-1);

            for (var index = total - 2; index <= total; index++)
            {
                pages.Add(index);
            }

            return pages;
        }

        for (var index = current - 1; index <= current + 1; index++)
        {
            pages.Add(index);
        }

        pages.Add(-1);
        pages.Add(total);
        return pages;
    }

    private void GoToPage(int pageNumber)
    {
        CurrentPage = Math.Clamp(pageNumber, 1, TotalPages);
    }

    private void HandlePageJumpInput(ChangeEventArgs e)
    {
        PageJumpInput = e.Value?.ToString()?.Trim() ?? string.Empty;
    }

    private void HandlePageJumpKeyDown(KeyboardEventArgs e)
    {
        if (string.Equals(e.Key, "Enter", StringComparison.OrdinalIgnoreCase))
        {
            GoToPageJump();
        }
    }

    private void GoToPageJump()
    {
        if (int.TryParse(PageJumpInput, out var page))
        {
            GoToPage(page);
        }

        PageJumpInput = string.Empty;
    }

    private void HandleRowClick(Guid folderId)
    {
        Nav.NavigateTo($"/dashboard/analytics?folderId={folderId}");
    }
}
