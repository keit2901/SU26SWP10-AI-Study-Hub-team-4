@page "/dashboard/subjects"
@layout AI_Study_Hub_v2.Components.Layout.DashboardLayout
@using AI_Study_Hub_v2.Components.Layout
@using AI_Study_Hub_v2.Dtos
@inject AI_Study_Hub_v2.Services.IDashboardService DashboardService
@inject AI_Study_Hub_v2.Services.AuthSessionState Session
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Subjects - AI Study Hub</PageTitle>

<div style="display: flex; flex-direction: column; flex: 1; height: 100%;">
    
    <!-- Content -->
    <div style="flex: 1; overflow: visible; padding: 2rem 1.5rem;">
        <div style="margin-bottom: 2rem; display: flex; flex-direction: column; gap: 0.5rem;">
            <h1 style="font-size: 1.875rem; font-weight: 700; color: #1a1b1f; margin: 0;">Subjects Management</h1>
            <p style="font-size: 1rem; color: #464554; margin: 0;">View and manage registered academic subjects.</p>
        </div>

        @if (isLoading)
        {
            <div style="text-align: center; padding: 3rem;">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else if (subjects == null || !subjects.Any())
        {
            <div style="background: white; border-radius: 0.75rem; box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05); padding: 2rem; text-align: center; border: 1px solid rgba(199,196,215,0.3);">
                <MudIcon Icon="@Icons.Material.Filled.MenuBook" Style="font-size: 3rem; color: #5e5ce6; margin-bottom: 1rem;" />
                <h3 style="font-size: 1.25rem; font-weight: 600; color: #1a1b1f; margin-bottom: 0.5rem;">No Academic Subjects Found</h3>
                <p style="color: #6b7280; max-width: 24rem; margin: 0 auto 1.5rem;">Subjects will appear automatically once users upload documents with subject codes.</p>
            </div>
        }
        else
        {
            var visibleSubjects = GetVisibleSubjects();
            var totalPages = GetTotalPages(visibleSubjects.Count);
            EnsureCurrentPage(totalPages);
            var pagedSubjects = visibleSubjects
                .Skip((CurrentPage - 1) * PageSize)
                .Take(PageSize)
                .ToList();

            <div style="background: #fff; border-radius: 1rem; box-shadow: 0 2px 10px -4px rgba(0,0,0,0.05); border: 1px solid #f1f5f9; overflow: visible;">
                <div style="padding: 1.25rem 1.5rem; display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap; border-bottom: 1px solid #f1f5f9;">
                    <div style="display: flex; flex-direction: column; gap: 0.2rem;">
                        <h2 style="font-size: 1.125rem; font-weight: 600; color: #111827; margin: 0;">Subjects Table</h2>
                    </div>
                    <button @onclick="ResetTable"
                            style="display: inline-flex; align-items: center; justify-content: center; gap: 0.4rem; border-radius: 9999px; border: 1px solid rgba(94,92,230,0.22); background: rgba(94,92,230,0.08); color: #4441CC; padding: 0.55rem 0.95rem; font-size: 0.8125rem; font-weight: 700; cursor: pointer;">
                        <MudIcon Icon="@Icons.Material.Filled.RestartAlt" Style="font-size: 1rem;" />
                        <span>Reset table</span>
                    </button>
                </div>
                <div style="padding: 1rem 1.5rem 0.75rem;">
                    <div style="display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 0.75rem; padding: 0.95rem 1rem; border: 1px solid rgba(199,196,215,0.3); border-radius: 0.875rem; background: #fff;">
                        <label style="display: flex; flex-direction: column; gap: 0.35rem; min-width: 0;">
                            <span style="font-size: 0.6875rem; font-weight: 700; color: #6b7280; text-transform: uppercase; letter-spacing: 0.08em;">Subject Code</span>
                            <input type="text"
                                   value="@FilterSubjectQuery"
                                   @oninput='e => UpdateAppliedFilter("subject", e.Value?.ToString())'
                                   placeholder="Search subject code"
                                   style='@GetTopFilterInputStyle()' />
                        </label>
                        <label style="display: flex; flex-direction: column; gap: 0.35rem; min-width: 0;">
                            <span style="font-size: 0.6875rem; font-weight: 700; color: #6b7280; text-transform: uppercase; letter-spacing: 0.08em;">Latest Upload From</span>
                            <input type="datetime-local"
                                   value="@FilterDateFrom"
                                   @oninput='e => UpdateDateFilter("from", e.Value?.ToString())'
                                   style='@GetTopFilterInputStyle()' />
                        </label>
                        <label style="display: flex; flex-direction: column; gap: 0.35rem; min-width: 0;">
                            <span style="font-size: 0.6875rem; font-weight: 700; color: #6b7280; text-transform: uppercase; letter-spacing: 0.08em;">Latest Upload To</span>
                            <input type="datetime-local"
                                   value="@FilterDateTo"
                                   @oninput='e => UpdateDateFilter("to", e.Value?.ToString())'
                                   style='@GetTopFilterInputStyle()' />
                        </label>
                    </div>
                </div>
                <div style="position: relative;">
                    @if (!string.IsNullOrWhiteSpace(OpenMenuColumn))
                    {
                        <button type="button"
                                @onclick="CloseOpenMenu"
                                aria-label="Close filter menu"
                                style="position: fixed; inset: 0; z-index: 4; border: none; background: transparent; padding: 0; margin: 0;"></button>
                    }
                <div style="overflow-x: auto; overflow-y: visible;">
                    <table style="width: 100%; text-align: left; border-collapse: collapse;">
                        <thead>
                            <tr style="background: rgba(249,250,251,0.8); border-top: 1px solid #f1f5f9; border-bottom: 1px solid #f1f5f9;">
                                <th style="padding: 1rem 1.5rem 1rem 10px; position: relative; text-align: left;">
                                    <button @ref="_subjectHeaderButton" @onclick='() => ToggleSort("subject")' style='@GetHeaderButtonStyle("subject")'>
                                        <span>Subject Code</span>
                                        <MudIcon Icon='@GetSortIcon("subject")' Style='@GetSortIconStyle("subject")' />
                                    </button>
                                    @if (OpenMenuColumn == "subject")
                                    {
                                        var subjectSuggestions = GetSubjectSuggestions();
                                        <div style='@GetHeaderMenuStyle("14rem", true)'>
                                            <span style='@GetMenuSectionLabelStyle()'>Filter</span>
                                            <input type="text"
                                                   @ref="_subjectSearchInput"
                                                   value="@SubjectSearchTerm"
                                                   @oninput='e => UpdateTextSearch(e.Value?.ToString())'
                                                   @onkeydown='HandleSearchKeyDown'
                                                   placeholder="Search subject code"
                                                   style='@GetFilterInputStyle()' />
                                            <div @ref="_subjectSuggestionsList" style='@GetFilterOptionsListStyle()'>
                                                @if (subjectSuggestions.Count > 0)
                                                {
                                                    @for (var suggestionIndex = 0; suggestionIndex < subjectSuggestions.Count; suggestionIndex++)
                                                    {
                                                        var option = subjectSuggestions[suggestionIndex];
                                                        var isHighlightedSuggestion = suggestionIndex == _highlightedSubjectSuggestionIndex;
                                                        <button type="button"
                                                                @onclick='() => ApplySubjectSuggestion(option)'
                                                                style='@GetFilterMenuItemStyle(isHighlightedSuggestion || (_highlightedSubjectSuggestionIndex < 0 && string.Equals(SubjectSearchTerm, option, StringComparison.OrdinalIgnoreCase)))'>@option</button>
                                                    }
                                                }
                                                else
                                                {
                                                    <span style='@GetMenuEmptyStateStyle()'>No matching subjects</span>
                                                }
                                            </div>
                                            <div style='@GetMenuDividerStyle()'></div>
                                            <span style='@GetMenuSectionLabelStyle()'>Sort</span>
                                            <button @onclick='() => ApplySortOption("subject-asc")' style='@GetSortMenuItemStyle("subject-asc")'>A to Z</button>
                                            <button @onclick='() => ApplySortOption("subject-desc")' style='@GetSortMenuItemStyle("subject-desc")'>Z to A</button>
                                        </div>
                                    }
                                </th>
                                <th style="padding: 1rem 1.5rem; text-align: center;">
                                    <button @onclick='() => ToggleSort("documents")' style='@GetHeaderButtonStyle("documents")'>
                                        <span>Total Documents</span>
                                        <MudIcon Icon='@GetSortIcon("documents")' Style='@GetSortIconStyle("documents")' />
                                    </button>
                                </th>
                                <th style="padding: 1rem 1.5rem; text-align: center;">
                                    <button @onclick='() => ToggleSort("storage")' style='@GetHeaderButtonStyle("storage")'>
                                        <span>Storage Used</span>
                                        <MudIcon Icon='@GetSortIcon("storage")' Style='@GetSortIconStyle("storage")' />
                                    </button>
                                </th>
                                <th style="padding: 1rem 1.5rem; position: relative; text-align: center;">
                                    <button @ref="_dateHeaderButton" @onclick='() => ToggleSort("date")' style='@GetHeaderButtonStyle("date")'>
                                        <span>Latest Upload</span>
                                        <MudIcon Icon='@GetSortIcon("date")' Style='@GetSortIconStyle("date")' />
                                    </button>
                                    @if (OpenMenuColumn == "date")
                                    {
                                        <div style='@GetHeaderMenuStyle("18rem", true)'>
                                            <span style='@GetMenuSectionLabelStyle()'>Filter</span>
                                            <div style="display: flex; flex-direction: column; gap: 0.45rem;">
                                                <div style="display: flex; flex-direction: column; gap: 0.2rem;">
                                                    <span style="font-size: 0.75rem; font-weight: 600; color: #5f6372; text-align: left;">From</span>
                                                    <input type="datetime-local"
                                                           @ref="_dateFromInput"
                                                           value="@FilterDateFrom"
                                                           @oninput='e => UpdateDateFilter("from", e.Value?.ToString())'
                                                           style='@GetFilterInputStyle()' />
                                                </div>
                                                <div style="display: flex; flex-direction: column; gap: 0.2rem;">
                                                    <span style="font-size: 0.75rem; font-weight: 600; color: #5f6372; text-align: left;">To</span>
                                                    <input type="datetime-local"
                                                           value="@FilterDateTo"
                                                           @oninput='e => UpdateDateFilter("to", e.Value?.ToString())'
                                                           style='@GetFilterInputStyle()' />
                                                </div>
                                            </div>
                                            <button @onclick="ClearDateFilter" style='@GetFilterMenuItemStyle(false)'>Clear date range</button>
                                            <div style='@GetMenuDividerStyle()'></div>
                                            <span style='@GetMenuSectionLabelStyle()'>Sort</span>
                                            <button @onclick='() => ApplySortOption("date-desc")' style='@GetSortMenuItemStyle("date-desc")'>Newest first</button>
                                            <button @onclick='() => ApplySortOption("date-asc")' style='@GetSortMenuItemStyle("date-asc")'>Oldest first</button>
                                        </div>
                                    }
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (pagedSubjects.Any())
                            {
                                @foreach (var subject in pagedSubjects)
                                {
                                    <tr style="border-bottom: 1px solid #f1f5f9;">
                                        <td style="padding: 1.25rem 1.5rem 1.25rem 10px; font-weight: 600; color: #1f2937; text-align: left;">
                                            <div style="display: flex; align-items: center; justify-content: flex-start; gap: 0.75rem;">
                                                <MudIcon Icon="@Icons.Material.Filled.MenuBook" Style="color: #5e5ce6;" />
                                                @subject.SubjectCode
                                            </div>
                                        </td>
                                        <td style="padding: 1.25rem 1.5rem; color: #4b5563; font-weight: 500; text-align: center;">
                                            @subject.DocumentCount files
                                        </td>
                                        <td style="padding: 1.25rem 1.5rem; color: #4b5563; font-weight: 500; text-align: center;">
                                            @subject.StorageUsedMb MB
                                        </td>
                                        <td style="padding: 1.25rem 1.5rem; color: #6b7280; font-size: 0.875rem; text-align: center;">
                                            @(subject.LatestUploadDate?.ToString("MMM dd, yyyy HH:mm") ?? "N/A")
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" style="padding: 2.25rem 1.5rem; text-align: center;">
                                        <div style="display: flex; flex-direction: column; align-items: center; gap: 0.75rem;">
                                            <MudIcon Icon="@Icons.Material.Filled.FilterAltOff" Style="font-size: 2.25rem; color: #a1a1aa;" />
                                            <h3 style="font-size: 1rem; font-weight: 700; color: #111827; margin: 0;">No subjects available</h3>
                                            <p style="font-size: 0.875rem; color: #6b7280; margin: 0;">
                                                @(HasActiveFilters()
                                                    ? "No subjects match the current filter values."
                                                    : "No subjects were found.")
                                            </p>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (totalPages > 1)
                {
                    <div style="display: flex; align-items: center; justify-content: flex-end; gap: 1rem; flex-wrap: wrap; border-top: 1px solid rgba(199,196,215,0.2); padding: 1rem 1.25rem;">
                        <div class="folder-pagination-actions">
                            <div class="folder-pagination-controls">
                                <button class="folder-page-nav-btn" @onclick="() => GoToPage(CurrentPage - 1)"
                                        disabled="@(CurrentPage == 1)">
                                    <MudIcon Icon="@Icons.Material.Filled.ChevronLeft" Style="font-size: 1rem;" />
                                </button>

                                @foreach (var pageNumber in GetPageWindow(totalPages))
                                {
                                    if (pageNumber == -1)
                                    {
                                        <span class="folder-page-ellipsis">...</span>
                                    }
                                    else
                                    {
                                        var isActivePage = pageNumber == CurrentPage;
                                        <button class="folder-page-number-btn @(isActivePage ? "active" : "")" @onclick="() => GoToPage(pageNumber)">
                                            @pageNumber
                                        </button>
                                    }
                                }

                                <button class="folder-page-nav-btn" @onclick="() => GoToPage(CurrentPage + 1)"
                                        disabled="@(CurrentPage == totalPages)">
                                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Style="font-size: 1rem;" />
                                </button>
                            </div>
                            <div class="folder-pagination-jump">
                                <input type="text"
                                       class="folder-page-jump-input"
                                       placeholder="Page..."
                                       value="@_pageJumpInput"
                                       @oninput="HandlePageJumpInput"
                                       @onkeydown="HandlePageJumpKeyDown" />
                            </div>
                        </div>
                    </div>
                }
                </div>
            </div>
        }
    </div>
</div>

@code {
    private const int PageSize = 10;
    private bool isLoading = true;
    private List<DashboardSubjectDto>? subjects;
    private int CurrentPage = 1;
    private string _pageJumpInput = string.Empty;
    private string? OpenMenuColumn;
    private ElementReference _subjectHeaderButton;
    private ElementReference _dateHeaderButton;
    private ElementReference _subjectSearchInput;
    private ElementReference _dateFromInput;
    private ElementReference _subjectSuggestionsList;
    private double _menuLeft = 16;
    private double _menuTop = 112;
    private double _menuWidth = 224;
    private string SubjectSearchTerm = string.Empty;
    private string FilterSubjectQuery = string.Empty;
    private string FilterDateFrom = string.Empty;
    private string FilterDateTo = string.Empty;
    private string SortBy = "date-desc";
    private string? _pendingFocusColumn;
    private int _highlightedSubjectSuggestionIndex = -1;
    private int? _pendingSubjectSuggestionScrollIndex;

    private IReadOnlyList<DashboardSubjectDto> SourceSubjects => subjects ?? [];

    private IReadOnlyList<string> SubjectOptions => SourceSubjects
        .Select(subject => subject.SubjectCode)
        .Where(code => !string.IsNullOrWhiteSpace(code))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(code => code, StringComparer.OrdinalIgnoreCase)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated || Session.CurrentUser == null)
        {
            Nav.NavigateTo("/login");
            return;
        }

        try
        {
            subjects = await DashboardService.GetSubjectsStatsAsync();
        }
        finally
        {
            isLoading = false;
        }
    }

    private IReadOnlyList<DashboardSubjectDto> GetVisibleSubjects()
    {
        IEnumerable<DashboardSubjectDto> query = SourceSubjects;

        if (!string.IsNullOrWhiteSpace(FilterSubjectQuery))
        {
            query = query.Where(subject => subject.SubjectCode.Contains(FilterSubjectQuery, StringComparison.OrdinalIgnoreCase));
        }

        var fromDate = ParseLocalDateTimeFilter(FilterDateFrom);
        if (fromDate.HasValue)
        {
            query = query.Where(subject => subject.LatestUploadDate.HasValue && subject.LatestUploadDate.Value.ToLocalTime().DateTime >= fromDate.Value);
        }

        var toDate = ParseLocalDateTimeFilter(FilterDateTo);
        if (toDate.HasValue)
        {
            query = query.Where(subject => subject.LatestUploadDate.HasValue && subject.LatestUploadDate.Value.ToLocalTime().DateTime <= toDate.Value);
        }

        query = SortBy switch
        {
            "subject-asc" => query.OrderBy(subject => subject.SubjectCode, StringComparer.OrdinalIgnoreCase),
            "subject-desc" => query.OrderByDescending(subject => subject.SubjectCode, StringComparer.OrdinalIgnoreCase),
            "documents-asc" => query.OrderBy(subject => subject.DocumentCount),
            "documents-desc" => query.OrderByDescending(subject => subject.DocumentCount),
            "storage-asc" => query.OrderBy(subject => subject.StorageUsedMb),
            "storage-desc" => query.OrderByDescending(subject => subject.StorageUsedMb),
            "date-asc" => query.OrderBy(subject => subject.LatestUploadDate ?? DateTimeOffset.MinValue),
            "date-desc" => query.OrderByDescending(subject => subject.LatestUploadDate ?? DateTimeOffset.MinValue),
            _ => query
        };

        return query.ToList();
    }

    private IReadOnlyList<string> GetSubjectSuggestions()
    {
        IEnumerable<string> query = SubjectOptions;
        if (!string.IsNullOrWhiteSpace(SubjectSearchTerm))
        {
            query = query.Where(option => option.Contains(SubjectSearchTerm, StringComparison.OrdinalIgnoreCase));
        }

        return query.ToList();
    }

    private void UpdateTextSearch(string? value)
    {
        SubjectSearchTerm = value?.Trim() ?? string.Empty;
        ResetHighlightedSubjectSuggestion();
    }

    private void ApplySubjectSuggestion(string value)
    {
        SubjectSearchTerm = value;
        ResetHighlightedSubjectSuggestion();
        ApplySearch();
    }

    private void ClearSubjectFilter()
    {
        FilterSubjectQuery = string.Empty;
        SubjectSearchTerm = string.Empty;
        CloseOpenMenu();
    }

    private void UpdateDateFilter(string boundary, string? value)
    {
        var normalizedValue = value?.Trim() ?? string.Empty;
        if (string.Equals(boundary, "from", StringComparison.OrdinalIgnoreCase))
        {
            SetFilterValue(ref FilterDateFrom, normalizedValue);
        }
        else
        {
            SetFilterValue(ref FilterDateTo, normalizedValue);
        }
    }

    private void ClearDateFilter()
    {
        SetFilterValue(ref FilterDateFrom, string.Empty);
        SetFilterValue(ref FilterDateTo, string.Empty);
    }

    private DateTime? ParseLocalDateTimeFilter(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        return DateTime.TryParseExact(
            value,
            "yyyy-MM-ddTHH:mm",
            System.Globalization.CultureInfo.InvariantCulture,
            System.Globalization.DateTimeStyles.AssumeLocal,
            out var parsedDate)
            ? parsedDate
            : null;
    }

    private void ResetTable()
    {
        OpenMenuColumn = null;
        SubjectSearchTerm = string.Empty;
        FilterSubjectQuery = string.Empty;
        FilterDateFrom = string.Empty;
        FilterDateTo = string.Empty;
        SortBy = "date-desc";
        CurrentPage = 1;
        _pageJumpInput = string.Empty;
        _pendingFocusColumn = null;
        ResetHighlightedSubjectSuggestion();
    }

    private void UpdateAppliedFilter(string columnKey, string? value)
    {
        var normalizedValue = value?.Trim() ?? string.Empty;
        if (string.Equals(columnKey, "subject", StringComparison.OrdinalIgnoreCase))
        {
            SetFilterValue(ref FilterSubjectQuery, normalizedValue);
            SubjectSearchTerm = normalizedValue;
        }
    }

    private async Task HandleHeaderMenuClick(string columnKey)
    {
        if (string.Equals(OpenMenuColumn, columnKey, StringComparison.OrdinalIgnoreCase))
        {
            OpenMenuColumn = null;
            return;
        }

        ClearDraftSearch();
        OpenMenuColumn = columnKey;
        _pendingFocusColumn = columnKey;
        await PositionMenuAsync(columnKey);
    }

    private void ApplySortOption(string sortKey)
    {
        SortBy = sortKey;
        CurrentPage = 1;
        CloseOpenMenu();
    }

    private void ToggleSort(string columnKey)
    {
        SortBy = columnKey switch
        {
            "subject" => SortBy == "subject-asc" ? "subject-desc" : "subject-asc",
            "documents" => SortBy == "documents-asc" ? "documents-desc" : "documents-asc",
            "storage" => SortBy == "storage-asc" ? "storage-desc" : "storage-asc",
            "date" => SortBy == "date-desc" ? "date-asc" : "date-desc",
            _ => "date-desc"
        };

        OpenMenuColumn = null;
        CurrentPage = 1;
    }

    private void CloseOpenMenu()
    {
        if (!string.IsNullOrWhiteSpace(OpenMenuColumn))
        {
            ClearDraftSearch();
        }

        OpenMenuColumn = null;
        _pendingFocusColumn = null;
        _pendingSubjectSuggestionScrollIndex = null;
    }

    private bool HasActiveFilters() =>
        !string.IsNullOrWhiteSpace(FilterSubjectQuery)
        || !string.IsNullOrWhiteSpace(FilterDateFrom)
        || !string.IsNullOrWhiteSpace(FilterDateTo);

    private bool IsSortedBy(string columnKey) =>
        SortBy.StartsWith($"{columnKey}-", StringComparison.OrdinalIgnoreCase);

    private bool IsSortDescending(string columnKey) =>
        string.Equals(SortBy, $"{columnKey}-desc", StringComparison.OrdinalIgnoreCase);

    private string GetSortIcon(string columnKey)
    {
        if (!IsSortedBy(columnKey))
        {
            return Icons.Material.Filled.UnfoldMore;
        }

        return IsSortDescending(columnKey)
            ? Icons.Material.Filled.KeyboardArrowDown
            : Icons.Material.Filled.KeyboardArrowUp;
    }

    private string GetTopFilterInputStyle() =>
        "width: 100%; border: 1px solid rgba(199,196,215,0.65); border-radius: 0.7rem; background: #fff; color: #1a1b1f; padding: 0.62rem 0.75rem; font-size: 0.8125rem; outline: none; box-sizing: border-box;";

    private string GetHeaderButtonStyle(string columnKey, bool alignLeft = false)
    {
        var isActive = IsSortedBy(columnKey);
        var color = isActive ? "#5e5ce6" : "#464554";
        var justifyContent = alignLeft ? "flex-start" : "center";
        return $"display: inline-flex; align-items: center; justify-content: {justifyContent}; gap: 0.3rem; width: auto; max-width: 100%; border: none; background: transparent; padding: 0; cursor: pointer; color: {color}; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;";
    }

    private string GetSortIconStyle(string columnKey)
    {
        var color = IsSortedBy(columnKey) ? "#5e5ce6" : "#9ca3af";
        return $"font-size: 1rem; color: {color};";
    }

    private string GetSortMenuItemStyle(string sortKey)
    {
        var isActive = string.Equals(SortBy, sortKey, StringComparison.OrdinalIgnoreCase);
        var bg = isActive ? "rgba(94,92,230,0.08)" : "transparent";
        var color = isActive ? "#4441CC" : "#464554";
        return $"display: block; width: 100%; border: none; background: {bg}; color: {color}; border-radius: 0.55rem; padding: 0.55rem 0.7rem; text-align: left; font-size: 0.8125rem; font-weight: 600; cursor: pointer;";
    }

    private string GetFilterMenuItemStyle(bool isActive)
    {
        var bg = isActive ? "rgba(94,92,230,0.08)" : "transparent";
        var color = isActive ? "#4441CC" : "#464554";
        return $"display: block; width: 100%; border: none; background: {bg}; color: {color}; border-radius: 0.55rem; padding: 0.5rem 0.7rem; text-align: left; font-size: 0.8125rem; font-weight: 600; cursor: pointer; white-space: normal; word-break: break-word; line-height: 1.35;";
    }

    private string GetMenuSectionLabelStyle() =>
        "display: block; padding: 0.35rem 0.55rem 0.2rem; font-size: 0.675rem; font-weight: 700; color: #7c7f8f; text-transform: uppercase; letter-spacing: 0.08em; text-align: center;";

    private string GetMenuDividerStyle() =>
        "height: 1px; background: rgba(199,196,215,0.35); margin: 0.35rem 0;";

    private string GetHeaderMenuStyle(string minWidth, bool alignLeft = false)
    {
        return $"position: fixed; top: {FormatMenuValue(_menuTop)}px; left: {FormatMenuValue(_menuLeft)}px; z-index: 5; width: {FormatMenuValue(_menuWidth)}px; max-width: calc(100vw - 2rem); max-height: calc(100vh - {FormatMenuValue(_menuTop + 24)}px); overflow-y: auto; border-radius: 0.75rem; border: 1px solid rgba(199,196,215,0.45); background: #fff; box-shadow: 0 18px 42px rgba(26,27,31,0.16); padding: 0.45rem;";
    }

    private async Task PositionMenuAsync(string columnKey)
    {
        var anchor = string.Equals(columnKey, "subject", StringComparison.OrdinalIgnoreCase)
            ? _subjectHeaderButton
            : _dateHeaderButton;

        var rect = await JS.InvokeAsync<MenuAnchorRect?>("codexTableFilter.getAnchorRect", anchor, GetMenuWidthPx(columnKey));
        if (rect is null)
        {
            return;
        }

        _menuLeft = rect.Left;
        _menuTop = rect.Top;
        _menuWidth = rect.Width;
    }

    private static double GetMenuWidthPx(string columnKey) =>
        string.Equals(columnKey, "date", StringComparison.OrdinalIgnoreCase) ? 288 : 224;

    private static string FormatMenuValue(double value) =>
        value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);

    private sealed class MenuAnchorRect
    {
        public double Left { get; set; }
        public double Top { get; set; }
        public double Width { get; set; }
    }

    private string GetFilterInputStyle() =>
        "width: 100%; border: 1px solid rgba(199,196,215,0.65); border-radius: 0.6rem; background: #fbfbfe; color: #1a1b1f; padding: 0.58rem 0.7rem; font-size: 0.8125rem; outline: none; box-sizing: border-box;";

    private string GetFilterOptionsListStyle() =>
        "display: flex; flex-direction: column; gap: 0.2rem; margin-top: 0.4rem; max-height: 12.25rem; overflow-y: auto; padding-right: 0.15rem;";

    private string GetMenuEmptyStateStyle() =>
        "display: block; padding: 0.55rem 0.7rem; font-size: 0.78125rem; color: #7c7f8f; text-align: left;";

    private bool IsColumnFiltered(string columnKey) =>
        columnKey switch
        {
            "subject" => !string.IsNullOrWhiteSpace(FilterSubjectQuery),
            "date" => !string.IsNullOrWhiteSpace(FilterDateFrom) || !string.IsNullOrWhiteSpace(FilterDateTo),
            _ => false
        };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var focusColumn = _pendingFocusColumn;
        _pendingFocusColumn = null;

        if (!string.IsNullOrWhiteSpace(focusColumn))
        {
            if (string.Equals(focusColumn, "subject", StringComparison.OrdinalIgnoreCase))
            {
                await JS.InvokeVoidAsync("codexTableFilter.focusElement", _subjectSearchInput, true);
            }
            else if (string.Equals(focusColumn, "date", StringComparison.OrdinalIgnoreCase))
            {
                await JS.InvokeVoidAsync("codexTableFilter.focusElement", _dateFromInput, false);
            }
        }

        if (_pendingSubjectSuggestionScrollIndex.HasValue && string.Equals(OpenMenuColumn, "subject", StringComparison.OrdinalIgnoreCase))
        {
            var scrollIndex = _pendingSubjectSuggestionScrollIndex.Value;
            _pendingSubjectSuggestionScrollIndex = null;
            await JS.InvokeVoidAsync("codexTableFilter.scrollOptionIntoViewByIndex", _subjectSuggestionsList, scrollIndex);
        }
    }

    private void ApplySearch()
    {
        SetFilterValue(ref FilterSubjectQuery, SubjectSearchTerm);
        ResetHighlightedSubjectSuggestion();
        CloseOpenMenu();
    }

    private void HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (string.Equals(e.Key, "ArrowDown", StringComparison.OrdinalIgnoreCase))
        {
            MoveSubjectSuggestionSelection(1);
            return;
        }

        if (string.Equals(e.Key, "ArrowUp", StringComparison.OrdinalIgnoreCase))
        {
            MoveSubjectSuggestionSelection(-1);
            return;
        }

        if (string.Equals(e.Key, "Enter", StringComparison.OrdinalIgnoreCase))
        {
            ApplyHighlightedOrTypedSubjectSearch();
            return;
        }

        if (string.Equals(e.Key, "Escape", StringComparison.OrdinalIgnoreCase))
        {
            CloseOpenMenu();
        }
    }

    private void ClearDraftSearch()
    {
        SubjectSearchTerm = string.Empty;
        ResetHighlightedSubjectSuggestion();
    }

    private void MoveSubjectSuggestionSelection(int offset)
    {
        var suggestions = GetSubjectSuggestions();
        if (suggestions.Count == 0)
        {
            ResetHighlightedSubjectSuggestion();
            return;
        }

        if (_highlightedSubjectSuggestionIndex < 0)
        {
            _highlightedSubjectSuggestionIndex = offset > 0 ? 0 : suggestions.Count - 1;
        }
        else
        {
            _highlightedSubjectSuggestionIndex = (_highlightedSubjectSuggestionIndex + offset + suggestions.Count) % suggestions.Count;
        }

        _pendingSubjectSuggestionScrollIndex = _highlightedSubjectSuggestionIndex;
    }

    private void ResetHighlightedSubjectSuggestion()
    {
        _highlightedSubjectSuggestionIndex = -1;
        _pendingSubjectSuggestionScrollIndex = null;
    }

    private void ApplyHighlightedOrTypedSubjectSearch()
    {
        var selectedValue = SubjectSearchTerm;

        if (_highlightedSubjectSuggestionIndex >= 0)
        {
            var suggestions = GetSubjectSuggestions();
            if (_highlightedSubjectSuggestionIndex < suggestions.Count)
            {
                selectedValue = suggestions[_highlightedSubjectSuggestionIndex];
            }
        }

        SubjectSearchTerm = selectedValue;
        ApplySearch();
    }

    private int GetTotalPages(int itemCount) =>
        Math.Max(1, (int)Math.Ceiling(itemCount / (double)PageSize));

    private void EnsureCurrentPage(int totalPages)
    {
        if (CurrentPage < 1)
        {
            CurrentPage = 1;
        }
        else if (CurrentPage > totalPages)
        {
            CurrentPage = totalPages;
        }
    }

    private IReadOnlyList<int> GetPageWindow(int totalPages) =>
        BuildSlidingPageNumbers(totalPages, CurrentPage);

    private static IReadOnlyList<int> BuildSlidingPageNumbers(int total, int current)
    {
        var pages = new List<int>();

        if (total <= 4)
        {
            for (var i = 1; i <= total; i++) pages.Add(i);
            return pages;
        }

        if (current <= 2)
        {
            for (var i = 1; i <= 3; i++) pages.Add(i);
            pages.Add(-1);
            pages.Add(total);
            return pages;
        }

        if (current >= total - 1)
        {
            pages.Add(1);
            pages.Add(-1);
            for (var i = total - 2; i <= total; i++) pages.Add(i);
            return pages;
        }

        for (var i = current - 1; i <= current + 1; i++) pages.Add(i);
        pages.Add(-1);
        pages.Add(total);
        return pages;
    }

    private void GoToPage(int pageNumber)
    {
        var totalPages = GetTotalPages(GetVisibleSubjects().Count);
        CurrentPage = Math.Clamp(pageNumber, 1, totalPages);
    }

    private void HandlePageJumpInput(ChangeEventArgs e)
    {
        _pageJumpInput = e.Value?.ToString()?.Trim() ?? string.Empty;
    }

    private void HandlePageJumpKeyDown(KeyboardEventArgs e)
    {
        if (string.Equals(e.Key, "Enter", StringComparison.OrdinalIgnoreCase))
        {
            GoToPageJump();
        }
    }

    private void GoToPageJump()
    {
        if (int.TryParse(_pageJumpInput, out var page))
        {
            GoToPage(page);
        }

        _pageJumpInput = string.Empty;
    }

    private void SetFilterValue(ref string field, string value)
    {
        if (!string.Equals(field, value, StringComparison.Ordinal))
        {
            field = value;
            CurrentPage = 1;
        }
    }
}

