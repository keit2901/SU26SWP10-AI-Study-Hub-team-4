@page "/dashboard/documents"
@layout AI_Study_Hub_v2.Components.Layout.DashboardLayout
@using AI_Study_Hub_v2.Components.Layout
@using AI_Study_Hub_v2.Dtos
@using AI_Study_Hub_v2.Data.Entities
@inject AI_Study_Hub_v2.Services.IDashboardService DashboardService
@inject AI_Study_Hub_v2.Services.IDocumentService DocumentService
@inject AI_Study_Hub_v2.Services.AuthSessionState Session
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>Review Pending Documents - AI Study Hub</PageTitle>

<div style="display: flex; flex-direction: column; flex: 1; height: 100%;">
    <!-- Header -->
    <div style="display: flex; height: 4rem; align-items: center; justify-content: flex-end; border-bottom: 1px solid rgba(199,196,215,0.3); background: #faf9fe; padding: 0 1.5rem; gap: 1rem;">
        <button style="display: flex; align-items: center; justify-content: center; border-radius: 9999px; padding: 0.5rem; background: transparent; border: none; cursor: pointer;">
            <MudIcon Icon="@Icons.Material.Filled.Notifications" Style="font-size: 1.25rem; color: #464554;" />
        </button>
        <button style="display: flex; align-items: center; justify-content: center; border-radius: 9999px; padding: 0.5rem; background: transparent; border: none; cursor: pointer;">
            <MudIcon Icon="@Icons.Material.Filled.Settings" Style="font-size: 1.25rem; color: #464554;" />
        </button>
        <div style="display: flex; height: 2rem; width: 2rem; align-items: center; justify-content: center; border-radius: 9999px; background: #5e5ce6;">
            <span style="font-size: 0.8125rem; font-weight: 600; color: #fff; letter-spacing: 0.39px;">
                @(Session.CurrentUser?.Username?.Substring(0, Math.Min(2, Session.CurrentUser.Username.Length)).ToUpper() ?? "US")
            </span>
        </div>
    </div>

    <!-- Page Content -->
    <div style="flex: 1; overflow-y: auto; padding: 2rem 1.5rem;">
        <!-- Page Header -->
        <div style="margin-bottom: 2rem; display: flex; flex-direction: column; gap: 0.5rem;">
            <h1 style="font-size: 1.875rem; font-weight: 700; line-height: 1.2; letter-spacing: -0.6px; color: #1a1b1f; margin: 0;">
                Review Pending Documents
            </h1>
            <p style="font-size: 1rem; font-weight: 400; color: #464554; margin: 0;">
                Evaluate and process documents awaiting approval.
            </p>
        </div>

        @if (isLoading)
        {
            <div style="text-align: center; padding: 3rem;">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else if (pendingDocuments == null || !pendingDocuments.Any())
        {
            <div style="background: white; border-radius: 0.75rem; box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05); padding: 2rem; text-align: center; border: 1px solid rgba(199,196,215,0.3);">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Style="font-size: 3rem; color: #34C759; margin-bottom: 1rem;" />
                <h3 style="font-size: 1.25rem; font-weight: 600; color: #1a1b1f; margin-bottom: 0.5rem;">All caught up!</h3>
                <p style="color: #6b7280; max-width: 24rem; margin: 0 auto;">No pending documents awaiting moderation.</p>
            </div>
        }
        else
        {
            <!-- Pending Items Card -->
            <div style="border-radius: 0.75rem; background: #fff; box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05);">
                <!-- Card Header -->
                <div style="display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid rgba(199,196,215,0.3); padding: 1rem 1.5rem;">
                    <h2 style="font-size: 1.25rem; font-weight: 600; color: #1a1b1f; margin: 0;">
                        Pending Items (@pendingDocuments.Count)
                    </h2>
                </div>

                <!-- Table -->
                <div style="width: 100%; overflow-x: auto;">
                    <table style="width: 100%; text-align: left; border-collapse: collapse;">
                        <thead>
                            <tr style="background: #f4f3f8;">
                                <th style="padding: 1.3125rem 1.5rem; font-size: 0.8125rem; font-weight: 600; color: #464554; text-transform: uppercase; letter-spacing: 0.65px;">DOCUMENT NAME</th>
                                <th style="padding: 0.75rem 1.5rem; font-size: 0.8125rem; font-weight: 600; color: #464554; text-transform: uppercase; letter-spacing: 0.65px;">SUBJECT<br />CODE</th>
                                <th style="padding: 1.3125rem 1.5rem; font-size: 0.8125rem; font-weight: 600; color: #464554; text-transform: uppercase; letter-spacing: 0.65px;">SEMESTER</th>
                                <th style="padding: 0.75rem 1.5rem; font-size: 0.8125rem; font-weight: 600; color: #464554; text-transform: uppercase; letter-spacing: 0.65px;">UPLOAD<br />DATE</th>
                                <th style="padding: 1.3125rem 1.5rem; font-size: 0.8125rem; font-weight: 600; color: #464554; text-transform: uppercase; letter-spacing: 0.65px; text-align: right;">ACTIONS</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in pendingDocuments)
                            {
                                <tr style="border-top: 1px solid rgba(199,196,215,0.2);">
                                    <td style="padding: 1rem 1.5rem;">
                                        <div style="display: flex; align-items: center; gap: 0.75rem;">
                                            <div style="display: flex; height: 2rem; align-items: center; justify-content: center; border-radius: 0.25rem; background: rgba(94,92,230,0.1); padding: 0 0.5rem;">
                                                <MudIcon Icon="@GetFileIcon(item.MimeType)" Style="font-size: 1rem; color: #4441CC;" />
                                            </div>
                                            <div style="font-size: 0.875rem; font-weight: 500; color: #1a1b1f;">
                                                @item.FileName
                                            </div>
                                        </div>
                                    </td>
                                    <td style="padding: 1.5rem 1.5rem;">
                                        <div style="display: inline-flex; align-items: center; border-radius: 0.25rem; background: rgba(223,223,228,0.5); padding: 0.25rem 0.5rem;">
                                            <span style="font-size: 0.75rem; font-weight: 500; color: #616267;">@item.SubjectCode</span>
                                        </div>
                                    </td>
                                    <td style="padding: 1rem 1.5rem;">
                                        <div style="font-size: 0.875rem; font-weight: 400; color: #464554;">
                                            @item.Semester
                                        </div>
                                    </td>
                                    <td style="padding: 1rem 1.5rem;">
                                        <div style="font-size: 0.875rem; font-weight: 400; color: #464554;">
                                            @item.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")
                                        </div>
                                    </td>
                                    <td style="padding: 1rem 1.5rem;">
                                        <div style="display: flex; align-items: center; justify-content: flex-end; gap: 0.5rem;">
                                            <button @onclick="() => InspectDocumentAsync(item.Id)" style="display: flex; align-items: center; gap: 0.25rem; border-radius: 0.375rem; border: 1px solid rgba(199,196,215,0.5); background: #e9e7ed; padding: 0.4375rem 0.8125rem; cursor: pointer; transition: background 0.2s;">
                                                <MudIcon Icon="@Icons.Material.Filled.Visibility" Style="font-size: 0.75rem; color: #464554;" />
                                                <span style="font-size: 0.75rem; font-weight: 500; color: #464554;">Inspect</span>
                                            </button>
                                            <button @onclick="() => ApproveDocumentAsync(item.Id, item.FileName)" style="display: flex; align-items: center; gap: 0.25rem; border-radius: 0.375rem; border: 1px solid rgba(52,199,89,0.2); background: rgba(52,199,89,0.1); padding: 0.4375rem 0.8125rem; cursor: pointer; transition: background 0.2s;">
                                                <MudIcon Icon="@Icons.Material.Filled.Check" Style="font-size: 0.75rem; color: #34C759;" />
                                                <span style="font-size: 0.75rem; font-weight: 500; color: #34c759;">Approve</span>
                                            </button>
                                            <button @onclick="() => RejectDocumentAsync(item.Id, item.FileName)" style="display: flex; align-items: center; gap: 0.25rem; border-radius: 0.375rem; border: 1px solid rgba(255,59,48,0.2); background: rgba(255,59,48,0.1); padding: 0.4375rem 0.8125rem; cursor: pointer; transition: background 0.2s;">
                                                <MudIcon Icon="@Icons.Material.Filled.Close" Style="font-size: 0.75rem; color: #FF3B30;" />
                                                <span style="font-size: 0.75rem; font-weight: 500; color: #ff3b30;">Reject</span>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private bool isLoading = true;
    private List<DocumentDto>? pendingDocuments;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated || Session.CurrentUser == null)
        {
            Nav.NavigateTo("/login");
            return;
        }

        await LoadPendingDocumentsAsync();
    }

    private async Task LoadPendingDocumentsAsync()
    {
        isLoading = true;
        try
        {
            pendingDocuments = await DashboardService.GetPendingDocumentsAsync();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task InspectDocumentAsync(Guid docId)
    {
        try
        {
            var doc = await DocumentService.GetByIdAsync(Session.CurrentUser.Id, docId);
            if (!string.IsNullOrWhiteSpace(doc.DownloadUrl))
            {
                await JS.InvokeVoidAsync("open", doc.DownloadUrl, "_blank");
            }
            else
            {
                Snackbar.Add("Could not retrieve document signed download URL.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task ApproveDocumentAsync(Guid docId, string fileName)
    {
        try
        {
            var success = await DashboardService.ApproveDocumentAsync(docId);
            if (success)
            {
                Snackbar.Add($"Document '{fileName}' approved successfully.", Severity.Success);
                await LoadPendingDocumentsAsync();
            }
            else
            {
                Snackbar.Add("Failed to approve document.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task RejectDocumentAsync(Guid docId, string fileName)
    {
        try
        {
            var success = await DashboardService.RejectDocumentAsync(docId);
            if (success)
            {
                Snackbar.Add($"Document '{fileName}' rejected.", Severity.Warning);
                await LoadPendingDocumentsAsync();
            }
            else
            {
                Snackbar.Add("Failed to reject document.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private string GetFileIcon(string mimeType)
    {
        return mimeType.ToLowerInvariant() switch
        {
            "application/pdf" => Icons.Material.Filled.PictureAsPdf,
            "application/vnd.openxmlformats-officedocument.wordprocessingml.document" => Icons.Material.Filled.Article,
            "application/vnd.openxmlformats-officedocument.presentationml.presentation" => Icons.Material.Filled.Slideshow,
            _ => Icons.Material.Filled.Folder
        };
    }
}
