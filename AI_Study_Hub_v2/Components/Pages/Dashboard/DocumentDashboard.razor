@page "/dashboard/documents"
@layout AI_Study_Hub_v2.Components.Layout.DashboardLayout
@using AI_Study_Hub_v2.Data
@using AI_Study_Hub_v2.Data.Entities
@using Microsoft.EntityFrameworkCore
@inject AppDbContext DbContext
@inject AI_Study_Hub_v2.Services.AuthSessionState Session
@inject NavigationManager Nav

<PageTitle>My Documents - AI Study Hub</PageTitle>

<div style="display: flex; flex-direction: column; flex: 1; overflow-y: auto;">
    <div style="padding: 2rem 2.5rem 2.5rem; display: flex; flex-direction: column; gap: 1.25rem;">
        <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; flex-wrap: wrap;">
            <div>
                <h1 style="font-size: 1.9rem; font-weight: 800; letter-spacing: -0.04em; color: #111827; margin: 0;">My Documents</h1>
                <p style="font-size: 0.95rem; color: #6b7280; margin: 0.45rem 0 0;">Track what is ready for AI study, what is still indexing, and what needs another upload pass.</p>
            </div>
            <a href="/documents/upload" style="display: inline-flex; align-items: center; gap: 0.5rem; min-height: 2.95rem; padding: 0 1rem; border-radius: 0.9rem; background: #4f46e5; color: #fff; text-decoration: none; font-size: 0.9rem; font-weight: 700;">
                <MudIcon Icon="@Icons.Material.Filled.UploadFile" Style="font-size: 1rem;" />
                Add document
            </a>
        </div>

        @if (isLoading)
        {
            <div style="text-align: center; padding: 3rem;">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else
        {
            <div style="display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 1rem;">
                <StatCard Icon="@Icons.Material.Filled.Description" Title="All Files" Count="@allDocuments.ToString()" Description="Documents in your vault" BgColor="rgba(238,242,255,0.8)" IconColor="#4f46e5" />
                <StatCard Icon="@Icons.Material.Filled.CheckCircle" Title="Ready" Count="@readyDocuments.ToString()" Description="Prepared for AI chat" BgColor="rgba(236,253,245,0.9)" IconColor="#059669" />
                <StatCard Icon="@Icons.Material.Filled.HourglassTop" Title="Processing" Count="@processingDocuments.ToString()" Description="Still being indexed" BgColor="rgba(250,245,255,0.95)" IconColor="#9333ea" />
                <StatCard Icon="@Icons.Material.Filled.ReportProblem" Title="Needs Retry" Count="@failedDocuments.ToString()" Description="Upload or OCR issue" BgColor="rgba(254,242,242,0.95)" IconColor="#dc2626" />
            </div>

            <section style="background: #fff; border: 1px solid #eef2f7; border-radius: 1rem; overflow: hidden; box-shadow: 0 12px 24px rgba(15,23,42,0.04);">
                <div style="padding: 1.25rem 1.5rem; border-bottom: 1px solid #eef2f7; display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap;">
                    <div>
                        <h2 style="font-size: 1.05rem; font-weight: 700; color: #111827; margin: 0;">Recent Library Activity</h2>
                        <p style="font-size: 0.85rem; color: #6b7280; margin: 0.35rem 0 0;">Your newest uploads and their current study-readiness.</p>
                    </div>
                    <a href="/documents" style="font-size: 0.85rem; font-weight: 700; color: #4f46e5; text-decoration: none;">Open full library</a>
                </div>

                @if (rows.Count == 0)
                {
                    <div style="padding: 2.4rem 1.5rem; text-align: center; color: #6b7280;">
                        <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Style="font-size: 2rem; color: #a5b4fc; margin-bottom: 0.75rem;" />
                        <p style="margin: 0; font-size: 0.95rem;">No documents yet. Upload a file to start building your study vault.</p>
                    </div>
                }
                else
                {
                    <div style="overflow-x: auto;">
                        <table style="width: 100%; border-collapse: collapse;">
                            <thead>
                                <tr style="background: #f8fafc;">
                                    <th style="@HeaderCellStyle">Document</th>
                                    <th style="@HeaderCellStyle">Folder</th>
                                    <th style="@HeaderCellStyle">Subject</th>
                                    <th style="@HeaderCellStyle">Semester</th>
                                    <th style="@HeaderCellStyle">Status</th>
                                    <th style="@HeaderCellStyle">Updated</th>
                                    <th style="@HeaderCellStyle">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in rows)
                                {
                                    <tr style="border-top: 1px solid #eef2f7;">
                                        <td style="@BodyCellStyle">
                                            <div style="display: flex; align-items: center; gap: 0.75rem;">
                                                <div style="width: 2.2rem; height: 2.2rem; border-radius: 0.8rem; background: #eef2ff; color: #4f46e5; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                                    <MudIcon Icon="@Icons.Material.Filled.Description" Style="font-size: 1rem;" />
                                                </div>
                                                <div style="min-width: 0;">
                                                    <div style="font-size: 0.9rem; font-weight: 700; color: #111827; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@row.FileName</div>
                                                    <div style="font-size: 0.78rem; color: #6b7280;">@row.MimeType</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td style="@BodyCellStyle">@row.FolderName</td>
                                        <td style="@BodyCellStyle">@row.SubjectCode</td>
                                        <td style="@BodyCellStyle">@row.Semester</td>
                                        <td style="@BodyCellStyle">
                                            <span style="@GetStatusChipStyle(row.StatusLabel)">
                                                <span style="@GetStatusDotStyle(row.StatusLabel)"></span>
                                                @row.StatusLabel
                                            </span>
                                        </td>
                                        <td style="@BodyCellStyle">@row.UpdatedText</td>
                                        <td style="@BodyCellStyle">
                                            <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                                                <a href="/documents/@row.Id" style="@GhostActionStyle">Open</a>
                                                <a href="@row.ChatHref" style="@PrimaryActionStyle">Ask AI</a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>
        }
    </div>
</div>

@code {
    private sealed record DocumentRowVm(
        Guid Id,
        string FileName,
        string FolderName,
        string SubjectCode,
        string Semester,
        string MimeType,
        string StatusLabel,
        string UpdatedText,
        string ChatHref);

    private bool isLoading = true;
    private int allDocuments;
    private int readyDocuments;
    private int processingDocuments;
    private int failedDocuments;
    private List<DocumentRowVm> rows = new();

    private const string HeaderCellStyle = "padding: 0.85rem 1.25rem; text-align: left; font-size: 0.72rem; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em;";
    private const string BodyCellStyle = "padding: 1rem 1.25rem; font-size: 0.86rem; color: #475569; vertical-align: middle;";
    private const string GhostActionStyle = "display: inline-flex; align-items: center; justify-content: center; min-height: 2.2rem; padding: 0 0.8rem; border-radius: 0.7rem; text-decoration: none; font-size: 0.78rem; font-weight: 700; color: #374151; background: #f8fafc; border: 1px solid #e5e7eb;";
    private const string PrimaryActionStyle = "display: inline-flex; align-items: center; justify-content: center; min-height: 2.2rem; padding: 0 0.8rem; border-radius: 0.7rem; text-decoration: none; font-size: 0.78rem; font-weight: 700; color: #ffffff; background: #4f46e5; border: 1px solid #4f46e5;";

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated || Session.CurrentUser == null)
        {
            Nav.NavigateTo("/login");
            return;
        }

        var documents = await DbContext.Documents
            .Include(d => d.Folder)
            .Where(d => d.UserId == Session.CurrentUser.Id)
            .OrderByDescending(d => d.UpdatedAt)
            .ToListAsync();

        allDocuments = documents.Count;
        readyDocuments = documents.Count(d => d.Status == DocumentStatus.Ready);
        processingDocuments = documents.Count(d => d.Status == DocumentStatus.Uploading || d.Status == DocumentStatus.Processing);
        failedDocuments = documents.Count(d => d.Status == DocumentStatus.Failed);

        rows = documents
            .Take(12)
            .Select(d => new DocumentRowVm(
                d.Id,
                d.FileName,
                d.Folder?.Name ?? "Unassigned",
                string.IsNullOrWhiteSpace(d.SubjectCode) ? "Not tagged" : d.SubjectCode,
                string.IsNullOrWhiteSpace(d.Semester) ? "Unassigned" : d.Semester,
                d.MimeType,
                ToStatusLabel(d.Status),
                ToUpdatedText(d.UpdatedAt),
                d.Status == DocumentStatus.Ready ? $"/ai/chat?documentId={d.Id}" : $"/documents/{d.Id}"))
            .ToList();

        isLoading = false;
    }

    private static string ToStatusLabel(DocumentStatus status) =>
        status switch
        {
            DocumentStatus.Ready => "Ready",
            DocumentStatus.Uploading or DocumentStatus.Processing => "Processing",
            DocumentStatus.Failed => "Needs Retry",
            _ => "Processing"
        };

    private static string ToUpdatedText(DateTimeOffset updatedAt)
    {
        var local = updatedAt.ToLocalTime();
        return $"{local:dd MMM yyyy} • {local:HH:mm}";
    }

    private static string GetStatusChipStyle(string status)
    {
        var (bg, color) = status switch
        {
            "Ready" => ("#eefbf3", "#047857"),
            "Processing" => ("#f5f3ff", "#7c3aed"),
            _ => ("#fef2f2", "#dc2626")
        };

        return $"display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.28rem 0.68rem; border-radius: 9999px; background: {bg}; color: {color}; font-size: 0.74rem; font-weight: 700;";
    }

    private static string GetStatusDotStyle(string status)
    {
        var color = status switch
        {
            "Ready" => "#10b981",
            "Processing" => "#8b5cf6",
            _ => "#ef4444"
        };

        return $"width: 0.42rem; height: 0.42rem; border-radius: 9999px; background: {color};";
    }
}
