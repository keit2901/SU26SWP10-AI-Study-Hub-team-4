@page "/dashboard/analytics"
@layout AI_Study_Hub_v2.Components.Layout.DashboardLayout
@using AI_Study_Hub_v2.Data
@using AI_Study_Hub_v2.Data.Entities
@using Microsoft.EntityFrameworkCore
@inject AppDbContext DbContext
@inject AI_Study_Hub_v2.Services.AuthSessionState Session
@inject NavigationManager Nav

<PageTitle>Study Analytics - AI Study Hub</PageTitle>

<div style="display: flex; flex-direction: column; flex: 1; overflow-y: auto;">
    <div style="padding: 2rem 2.5rem 2.5rem; display: flex; flex-direction: column; gap: 1.25rem;">
        <div>
            <h1 style="font-size: 1.9rem; font-weight: 800; letter-spacing: -0.04em; color: #111827; margin: 0;">Study Analytics</h1>
            <p style="font-size: 0.95rem; color: #6b7280; margin: 0.45rem 0 0;">A student-friendly summary of readiness, coverage, and sharing across your study library.</p>
        </div>

        @if (isLoading)
        {
            <div style="text-align: center; padding: 3rem;">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else
        {
            <div style="display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 1rem;">
                <StatCard Icon="@Icons.Material.Filled.Description" Title="Documents" Count="@totalDocuments.ToString()" Description="Files tracked by your vault" BgColor="rgba(238,242,255,0.8)" IconColor="#4f46e5" />
                <StatCard Icon="@Icons.Material.Filled.CheckCircle" Title="Ready Rate" Count="@($"{readyRate}%")" Description="Share of study-ready files" BgColor="rgba(236,253,245,0.9)" IconColor="#059669" />
                <StatCard Icon="@Icons.Material.Filled.Groups" Title="Shared Folders" Count="@sharedFolders.ToString()" Description="Visible to the community" BgColor="rgba(255,247,237,0.95)" IconColor="#ea580c" />
                <StatCard Icon="@Icons.Material.Filled.MenuBook" Title="Subjects" Count="@subjectCount.ToString()" Description="Distinct subject tracks" BgColor="rgba(250,245,255,0.95)" IconColor="#9333ea" />
            </div>

            <div style="display: grid; grid-template-columns: minmax(0, 1.3fr) minmax(320px, 0.9fr); gap: 1rem;">
                <section style="background: #fff; border: 1px solid #eef2f7; border-radius: 1rem; padding: 1.35rem 1.5rem; box-shadow: 0 12px 24px rgba(15,23,42,0.04);">
                    <div style="margin-bottom: 1rem;">
                        <h2 style="font-size: 1.05rem; font-weight: 700; color: #111827; margin: 0;">Pipeline Health</h2>
                        <p style="font-size: 0.85rem; color: #6b7280; margin: 0.35rem 0 0;">How much of your material is ready for retrieval versus still waiting or needing another upload.</p>
                    </div>

                    @foreach (var metric in pipelineMetrics)
                    {
                        <div style="display: flex; flex-direction: column; gap: 0.45rem; margin-bottom: 1rem;">
                            <div style="display: flex; justify-content: space-between; gap: 1rem; font-size: 0.84rem;">
                                <span style="font-weight: 700; color: #111827;">@metric.Label</span>
                                <span style="color: #6b7280;">@metric.Count file(s)</span>
                            </div>
                            <div style="height: 0.65rem; border-radius: 9999px; background: #edf2f7; overflow: hidden;">
                                <div style="@($"height: 100%; width: {metric.Percent}%; background: {metric.BarColor}; border-radius: 9999px;")"></div>
                            </div>
                        </div>
                    }
                </section>

                <section style="background: #fff; border: 1px solid #eef2f7; border-radius: 1rem; padding: 1.35rem 1.5rem; box-shadow: 0 12px 24px rgba(15,23,42,0.04); display: flex; flex-direction: column; gap: 0.9rem;">
                    <div>
                        <h2 style="font-size: 1.05rem; font-weight: 700; color: #111827; margin: 0;">Coverage Snapshot</h2>
                        <p style="font-size: 0.85rem; color: #6b7280; margin: 0.35rem 0 0;">Your current footprint across semesters and public sharing.</p>
                    </div>

                    <div style="display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.8rem;">
                        <div style="padding: 1rem; border-radius: 0.95rem; background: #f8fafc;">
                            <div style="font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b;">Semesters</div>
                            <strong style="display: block; margin-top: 0.35rem; font-size: 1.5rem; color: #111827;">@semesterCount</strong>
                        </div>
                        <div style="padding: 1rem; border-radius: 0.95rem; background: #f8fafc;">
                            <div style="font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b;">Favorites</div>
                            <strong style="display: block; margin-top: 0.35rem; font-size: 1.5rem; color: #111827;">@favoriteFolders</strong>
                        </div>
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 0.7rem;">
                        @foreach (var item in topSubjects)
                        {
                            <div style="display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 0.9rem 1rem; border-radius: 0.95rem; background: #fafbff; border: 1px solid #eef2f7;">
                                <div>
                                    <div style="font-size: 0.9rem; font-weight: 700; color: #111827;">@item.Code</div>
                                    <div style="font-size: 0.78rem; color: #6b7280;">@item.DocumentCount document(s)</div>
                                </div>
                                <span style="display: inline-flex; align-items: center; padding: 0.28rem 0.65rem; border-radius: 9999px; background: #eef2ff; color: #4338ca; font-size: 0.74rem; font-weight: 700;">@item.ReadyCount ready</span>
                            </div>
                        }
                    </div>
                </section>
            </div>
        }
    </div>
</div>

@code {
    private sealed record PipelineMetric(string Label, int Count, int Percent, string BarColor);
    private sealed record SubjectMetric(string Code, int DocumentCount, int ReadyCount);

    private bool isLoading = true;
    private int totalDocuments;
    private int readyRate;
    private int sharedFolders;
    private int subjectCount;
    private int semesterCount;
    private int favoriteFolders;
    private List<PipelineMetric> pipelineMetrics = new();
    private List<SubjectMetric> topSubjects = new();

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated || Session.CurrentUser == null)
        {
            Nav.NavigateTo("/login");
            return;
        }

        var folders = await DbContext.Folders
            .Where(f => f.UserId == Session.CurrentUser.Id)
            .ToListAsync();

        var documents = await DbContext.Documents
            .Where(d => d.UserId == Session.CurrentUser.Id)
            .ToListAsync();

        totalDocuments = documents.Count;
        var readyCount = documents.Count(d => d.Status == DocumentStatus.Ready);
        var processingCount = documents.Count(d => d.Status == DocumentStatus.Uploading || d.Status == DocumentStatus.Processing);
        var retryCount = documents.Count(d => d.Status == DocumentStatus.Failed);
        readyRate = totalDocuments == 0 ? 0 : (int)Math.Round(readyCount * 100d / totalDocuments);
        sharedFolders = folders.Count(f => f.IsShared);
        favoriteFolders = folders.Count(f => f.IsFavorite);
        subjectCount = documents.Select(d => d.SubjectCode).Where(s => !string.IsNullOrWhiteSpace(s)).Distinct(StringComparer.OrdinalIgnoreCase).Count();
        semesterCount = documents.Select(d => d.Semester).Where(s => !string.IsNullOrWhiteSpace(s)).Distinct(StringComparer.OrdinalIgnoreCase).Count();

        pipelineMetrics =
        [
            new PipelineMetric("Ready for study", readyCount, PercentOf(readyCount, totalDocuments), "#10b981"),
            new PipelineMetric("Still processing", processingCount, PercentOf(processingCount, totalDocuments), "#8b5cf6"),
            new PipelineMetric("Needs retry", retryCount, PercentOf(retryCount, totalDocuments), "#ef4444")
        ];

        topSubjects = documents
            .Where(d => !string.IsNullOrWhiteSpace(d.SubjectCode))
            .GroupBy(d => d.SubjectCode.Trim().ToUpperInvariant())
            .OrderByDescending(g => g.Count())
            .ThenBy(g => g.Key)
            .Take(4)
            .Select(g => new SubjectMetric(
                g.Key,
                g.Count(),
                g.Count(d => d.Status == DocumentStatus.Ready)))
            .ToList();

        isLoading = false;
    }

    private static int PercentOf(int count, int total) =>
        total == 0 ? 0 : (int)Math.Round(count * 100d / total);
}
