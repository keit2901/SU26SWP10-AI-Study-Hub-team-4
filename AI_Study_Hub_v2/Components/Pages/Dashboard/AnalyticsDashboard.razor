@page "/dashboard/analytics"
@layout AI_Study_Hub_v2.Components.Layout.DashboardLayout
@using AI_Study_Hub_v2.Components.Layout
@using AI_Study_Hub_v2.Dtos
@using AI_Study_Hub_v2.Data
@inject AI_Study_Hub_v2.Services.IDashboardService DashboardService
@inject AI_Study_Hub_v2.Services.AuthSessionState Session
@inject NavigationManager Nav
@inject AppDbContext DbContext

<PageTitle>Analytics - AI Study Hub</PageTitle>

<div style="display: flex; flex-direction: column; flex: 1; height: 100%;">
    <!-- Header -->
    <div style="display: flex; height: 4rem; align-items: center; justify-content: space-between; border-bottom: 1px solid rgba(199,196,215,0.3); background: rgba(255,255,255,0.8); backdrop-filter: blur(4px); padding: 0 2rem; position: sticky; top: 0; z-index: 10;">
        <div style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem;">
            <span style="font-weight: 600; color: #464554;">Analytics</span>
            <span style="color: #c7c4d7;">›</span>
            <span style="font-weight: 700; color: #1a1b1f;">@PageSubtitle</span>
        </div>

        <div style="display: flex; align-items: center; gap: 1.5rem;">
            <div style="position: relative;">
                <MudIcon Icon="@Icons.Material.Filled.Search" Style="position: absolute; left: 0.75rem; top: 50%; transform: translateY(-50%); font-size: 1rem; color: #464554;" />
                <input type="text" placeholder="Search analytics..." style="background: #faf9fe; border: 1px solid #c7c4d7; border-radius: 9999px; padding: 0.5rem 1rem 0.5rem 2.5rem; font-size: 0.875rem; width: 16rem; outline: none;" />
            </div>
            <div style="display: flex; align-items: center; gap: 1rem;">
                <button style="padding: 0.25rem; border-radius: 9999px; background: transparent; border: none; cursor: pointer;">
                    <MudIcon Icon="@Icons.Material.Filled.Notifications" Style="font-size: 1.25rem; color: #464554;" />
                </button>
                <div style="width: 2rem; height: 2rem; border-radius: 9999px; background: #5e5ce6; border: 2px solid #c2c1ff; overflow: hidden; display: flex; align-items: center; justify-content: center;">
                    <span style="font-size: 0.75rem; color: white; font-weight: bold;">
                        @(Session.CurrentUser?.Username?.Substring(0, Math.Min(2, Session.CurrentUser.Username.Length)).ToUpper() ?? "US")
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Content Area -->
    <div style="padding: 2rem; max-width: 80rem; margin: 0 auto; width: 100%; display: flex; flex-direction: column; gap: 2rem;">
        
        <!-- Page Title Row -->
        <div style="display: flex; align-items: flex-end; justify-content: space-between;">
            <div style="display: flex; flex-direction: column; gap: 0.25rem;">
                <h2 style="font-size: 1.875rem; font-weight: 700; letter-spacing: -0.025em; margin: 0;">Performance & Processing Metrics</h2>
                <p style="color: #464554; margin: 0; font-size: 1rem;">@PageSubtitleDescription</p>
            </div>
            @if (FolderId.HasValue)
            {
                <button @onclick="NavigateToFolderDocuments" style="display: inline-flex; align-items: center; gap: 0.5rem; background: #5e5ce6; color: white; border: none; border-radius: 0.5rem; padding: 0.625rem 1.25rem; font-size: 0.875rem; font-weight: 600; cursor: pointer; transition: all 0.2s ease-in-out; box-shadow: 0 4px 12px rgba(94, 92, 230, 0.25);"
                        onmouseover="this.style.background='#4a48cc'; this.style.transform='translateY(-1px)';"
                        onmouseout="this.style.background='#5e5ce6'; this.style.transform='none';">
                    <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Style="font-size: 1.25rem; color: white;" />
                    Inspect Documents
                </button>
            }
        </div>

        @if (isLoading)
        {
            <div style="text-align: center; padding: 3rem;">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else
        {
            <!-- Stats Grid -->
            <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem;">
                <!-- Card 1 -->
                <div style="background: white; padding: 1.5rem; border-radius: 0.75rem; border: 1px solid rgba(199,196,215,0.5); box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05); position: relative; overflow: hidden;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
                        <div style="display: flex; flex-direction: column; gap: 0.25rem;">
                            <p style="font-size: 0.75rem; font-weight: 600; color: #464554; text-transform: uppercase; letter-spacing: 0.05em; margin: 0;">Total Documents</p>
                            <div style="display: flex; align-items: baseline; gap: 0.25rem;">
                                <h3 style="font-size: 1.875rem; font-weight: 700; color: #1a1b1f; margin: 0;">@totalDocuments</h3>
                            </div>
                        </div>
                        <div style="background: rgba(94,92,230,0.1); padding: 0.5rem; border-radius: 9999px; display: flex; align-items: center; justify-content: center;">
                            <MudIcon Icon="@Icons.Material.Filled.Description" Style="font-size: 1.5rem; color: #5e5ce6;" />
                        </div>
                    </div>
                    <div style="display: flex; align-items: center; gap: 0.375rem; height: 1.5rem;">
                        <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Style="font-size: 1rem; color: #006424;" />
                        <span style="font-size: 0.8125rem; font-weight: 600; color: #006424;">Active documents</span>
                    </div>
                </div>

                <!-- Card 2 -->
                <div style="background: white; padding: 1.5rem; border-radius: 0.75rem; border: 1px solid rgba(199,196,215,0.5); box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05); position: relative; overflow: hidden;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
                        <div style="display: flex; flex-direction: column; gap: 0.25rem;">
                            <p style="font-size: 0.75rem; font-weight: 600; color: #464554; text-transform: uppercase; letter-spacing: 0.05em; margin: 0;">Completion Rate</p>
                            <div style="display: flex; align-items: baseline; gap: 0.25rem;">
                                <h3 style="font-size: 1.875rem; font-weight: 700; color: #1a1b1f; margin: 0;">@completionRate</h3>
                                <span style="font-size: 1.125rem; font-weight: 700; color: #1a1b1f;">%</span>
                            </div>
                        </div>
                        <div style="background: rgba(0,100,36,0.1); padding: 0.5rem; border-radius: 9999px; display: flex; align-items: center; justify-content: center;">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Style="font-size: 1.5rem; color: #006424;" />
                        </div>
                    </div>
                    <div style="width: 100%; background: #e3e2e7; height: 0.375rem; border-radius: 9999px; overflow: hidden; margin-top: 0.5rem;">
                        <div style="background: #006424; height: 100%; width: @(completionRate)%; border-radius: 9999px;"></div>
                    </div>
                </div>

                <!-- Card 3 -->
                <div style="background: white; padding: 1.5rem; border-radius: 0.75rem; border: 1px solid rgba(199,196,215,0.5); box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05); position: relative; overflow: hidden;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
                        <div style="display: flex; flex-direction: column; gap: 0.25rem;">
                            <p style="font-size: 0.75rem; font-weight: 600; color: #464554; text-transform: uppercase; letter-spacing: 0.05em; margin: 0;">Avg Processing</p>
                            <div style="display: flex; align-items: baseline; gap: 0.25rem;">
                                <h3 style="font-size: 1.875rem; font-weight: 700; color: #1a1b1f; margin: 0;">@avgProcessingTimeHrs</h3>
                                <span style="font-size: 1.125rem; font-weight: 700; color: #1a1b1f;">sec</span>
                            </div>
                        </div>
                        <div style="background: rgba(223,223,228,0.3); padding: 0.5rem; border-radius: 9999px; display: flex; align-items: center; justify-content: center;">
                            <MudIcon Icon="@Icons.Material.Filled.Schedule" Style="font-size: 1.5rem; color: #616267;" />
                        </div>
                    </div>
                    <div style="display: flex; align-items: center; gap: 0.375rem; height: 1.5rem;">
                        <MudIcon Icon="@Icons.Material.Filled.Remove" Style="font-size: 1rem; color: #464554;" />
                        <span style="font-size: 0.8125rem; font-weight: 600; color: #464554;">Stable system status</span>
                    </div>
                </div>

                <!-- Card 4 -->
                <div style="background: white; padding: 1.5rem; border-radius: 0.75rem; border: 1px solid rgba(199,196,215,0.5); box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05); position: relative; overflow: hidden;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
                        <div style="display: flex; flex-direction: column; gap: 0.25rem;">
                            <p style="font-size: 0.75rem; font-weight: 600; color: #464554; text-transform: uppercase; letter-spacing: 0.05em; margin: 0;">Storage Used</p>
                            <div style="display: flex; align-items: baseline; gap: 0.25rem;">
                                <h3 style="font-size: 1.875rem; font-weight: 700; color: #1a1b1f; margin: 0;">@storageUsedMb</h3>
                                <span style="font-size: 1.125rem; font-weight: 700; color: #1a1b1f;">MB</span>
                            </div>
                        </div>
                        <div style="background: rgba(199,196,215,0.3); padding: 0.5rem; border-radius: 9999px; display: flex; align-items: center; justify-content: center;">
                            <MudIcon Icon="@Icons.Material.Filled.Storage" Style="font-size: 1.5rem; color: #464554;" />
                        </div>
                    </div>
                    <div style="display: flex; align-items: center; gap: 0.375rem; height: 1.5rem;">
                        <span style="font-size: 0.8125rem; font-weight: 600; color: #464554;">@(System.Math.Round(storageUsedMb * 100 / 1024, 2))% of 1GB quota</span>
                    </div>
                </div>
            </div>

            <!-- Charts & Issues Section -->
            <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 1.5rem;">
                <!-- Chart Container -->
                <div style="background: white; padding: 1.5rem; border-radius: 0.75rem; border: 1px solid rgba(199,196,215,0.5); box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05);">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem;">
                        <h3 style="font-size: 1.25rem; font-weight: 700; margin: 0;">Document Upload Progress</h3>
                        <div style="background: #1a1b1f; color: white; font-size: 0.6875rem; font-weight: 700; padding: 0.25rem 0.75rem; border-radius: 0.25rem; display: flex; align-items: center; gap: 0.375rem;">
                            <span style="width: 0.5rem; height: 0.5rem; border-radius: 9999px; background: #5e5ce6;"></span>
                            Last 7 Days Activity
                        </div>
                    </div>
                    
                    @if (Series.Any())
                    {
                        <MudChart ChartType="ChartType.Line" ChartSeries="@Series" XAxisLabels="@XAxisLabels" Width="100%" Height="320px" ChartOptions="options" />
                    }
                    else
                    {
                        <div style="height: 320px; display: flex; align-items: center; justify-content: center; color: #6b7280;">
                            No upload activity data available.
                        </div>
                    }
                </div>

                <!-- Issues Container -->
                <div style="background: #faf9fe; padding: 1.5rem; border-radius: 0.75rem; border: 1px solid rgba(199,196,215,0.5); box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05);">
                    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem;">
                        <h3 style="font-size: 1.25rem; font-weight: 700; margin: 0;">Common Issues</h3>
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Style="font-size: 1.25rem; color: #464554;" />
                    </div>
                    <p style="font-size: 0.875rem; color: #464554; margin-bottom: 1.5rem;">Reasons for OCR or ingestion failures across your documents.</p>
                    
                    <div style="display: flex; flex-direction: column; gap: 1rem;">
                        @if (issuesList == null || !issuesList.Any())
                        {
                            <div style="background: white; padding: 2rem 1rem; border-radius: 0.75rem; border: 1px solid rgba(199,196,215,0.4); text-align: center; display: flex; flex-direction: column; align-items: center; gap: 0.5rem;">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircleOutline" Style="font-size: 2.5rem; color: #006424;" />
                                <h4 style="font-weight: 700; font-size: 0.875rem; margin: 0; color: #1a1b1f;">No Issues Detected</h4>
                                <p style="font-size: 0.8125rem; color: #464554; margin: 0;">All uploaded documents processed successfully!</p>
                            </div>
                        }
                        else
                        {
                            @foreach (var issue in issuesList)
                            {
                                <div style="background: white; padding: 1rem; border-radius: 0.75rem; border: 1px solid rgba(199,196,215,0.4); box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05);">
                                    <div style="display: flex; align-items: center; gap: 1rem;">
                                        <div style="width: 2.5rem; height: 2.5rem; border-radius: 0.5rem; background: #faf9fe; border: 1px solid rgba(199,196,215,0.3); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                            <MudIcon Icon="@Icons.Material.Filled.Error" Style="font-size: 1.25rem; color: #ef4444;" />
                                        </div>
                                        <div style="display: flex; flex-direction: column; gap: 0.25rem; flex: 1;">
                                            <h4 style="font-weight: 700; font-size: 0.875rem; margin: 0; word-break: break-word;">@issue.ErrorMessage</h4>
                                            <div style="margin-top: 0.25rem;">
                                                <span style="font-size: 0.625rem; font-weight: 700; background: #faf9fe; border: 1px solid rgba(199,196,215,0.3); color: #464554; padding: 0.25rem 0.625rem; border-radius: 9999px; text-transform: uppercase; letter-spacing: 0.05em;">
                                                    @issue.IncidentCount @(issue.IncidentCount == 1 ? "incident" : "incidents")
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            <!-- Bottom Table Section -->
            <div style="background: white; border-radius: 0.75rem; border: 1px solid #f1f5f9; box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05); overflow: hidden; margin-bottom: 2rem;">
                <div style="padding: 1.5rem; border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; justify-content: space-between;">
                    <h3 style="font-size: 1.25rem; font-weight: 600; margin: 0;">Recent Documents</h3>
                </div>
                <div style="overflow-x: auto;">
                    @if (documentsList == null || !documentsList.Any())
                    {
                        <div style="padding: 3rem; text-align: center; color: #6b7280;">
                            No documents found.
                        </div>
                    }
                    else
                    {
                        <table style="width: 100%; text-align: left; border-collapse: collapse;">
                            <thead style="background: #faf9fe;">
                                <tr>
                                    <th style="padding: 1rem 1.5rem; font-size: 0.75rem; font-weight: 700; color: #464554; text-transform: uppercase; letter-spacing: 0.05em;">Document Name</th>
                                    <th style="padding: 1rem 1.5rem; font-size: 0.75rem; font-weight: 700; color: #464554; text-transform: uppercase; letter-spacing: 0.05em;">Status</th>
                                    <th style="padding: 1rem 1.5rem; font-size: 0.75rem; font-weight: 700; color: #464554; text-transform: uppercase; letter-spacing: 0.05em;">Upload Date</th>
                                    <th style="padding: 1rem 1.5rem; font-size: 0.75rem; font-weight: 700; color: #464554; text-transform: uppercase; letter-spacing: 0.05em;">Structure</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var doc in documentsList)
                                {
                                    <tr style="border-top: 1px solid #f1f5f9;">
                                        <td style="padding: 1rem 1.5rem;">
                                            <div style="display: flex; align-items: center; gap: 0.75rem;">
                                                <MudIcon Icon="@Icons.Material.Filled.Description" Style="font-size: 1.25rem; color: #464554;" />
                                                <span style="font-weight: 600; font-size: 0.875rem; color: #1a1b1f;">@doc.Name</span>
                                            </div>
                                        </td>
                                        <td style="padding: 1rem 1.5rem;">
                                            @{
                                                var isReady = string.Equals(doc.Status, "Ready", StringComparison.OrdinalIgnoreCase);
                                                var isPending = string.Equals(doc.Status, "Uploading", StringComparison.OrdinalIgnoreCase) || string.Equals(doc.Status, "Processing", StringComparison.OrdinalIgnoreCase);
                                                
                                                var bg = isReady ? "rgba(0,100,36,0.1)" : isPending ? "rgba(94,92,230,0.1)" : "rgba(194,60,33,0.1)";
                                                var color = isReady ? "#006424" : isPending ? "#5e5ce6" : "#c23c21";
                                                var text = isReady ? "Approved" : isPending ? "Pending" : "Rejected";
                                            }
                                            <span style="padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 600; display: inline-flex; align-items: center; gap: 0.375rem; background: @bg; color: @color;">
                                                <span style="width: 0.375rem; height: 0.375rem; border-radius: 9999px; background: @color;"></span>
                                                @text
                                            </span>
                                        </td>
                                        <td style="padding: 1rem 1.5rem;">
                                            <div style="display: flex; flex-direction: column; gap: 0.125rem;">
                                                <span style="font-size: 0.875rem; font-weight: 500; color: #464554;">@doc.CreatedAt.ToLocalTime().ToString("MMM dd")</span>
                                                <span style="font-size: 0.75rem; color: #9ca3af;">@doc.CreatedAt.ToLocalTime().ToString("yyyy")</span>
                                            </div>
                                        </td>
                                        <td style="padding: 1rem 1.5rem;">
                                            <div style="display: flex; align-items: center; gap: 0.75rem;">
                                                <span style="font-size: 0.875rem; font-weight: 700; color: #5e5ce6;">@doc.ChunkCount chunks</span>
                                                <span style="font-size: 0.75rem; color: #6b7280;">(@(doc.PageCount?.ToString() ?? "N/A") pages)</span>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    private ChartOptions options = new ChartOptions
    {
        ChartPalette = new[] { "#5e5ce6" }
    };
    public List<ChartSeries<double>> Series = new List<ChartSeries<double>>();
    public string[] XAxisLabels = Array.Empty<string>();

    [Parameter]
    [SupplyParameterFromQuery(Name = "folderId")]
    public Guid? FolderId { get; set; }

    private string PageSubtitle => string.IsNullOrEmpty(FolderName) ? "Overall Account Analytics" : $"Folder: {FolderName}";
    private string PageSubtitleDescription => string.IsNullOrEmpty(FolderName) ? "Detailed analytics for all your uploaded study materials." : $"Detailed analytics for the folder \"{FolderName}\".";
    private string FolderName = string.Empty;

    private bool isLoading = true;
    private int totalDocuments;
    private double completionRate;
    private double avgProcessingTimeHrs;
    private double storageUsedMb;
    private List<AnalyticsIssueDto>? issuesList;
    private List<AnalyticsDocumentDto>? documentsList;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated || Session.CurrentUser == null)
        {
            Nav.NavigateTo("/login");
            return;
        }

        try
        {
            if (FolderId.HasValue)
            {
                var folder = await DbContext.Folders.FindAsync(FolderId.Value);
                FolderName = folder?.Name ?? string.Empty;
            }

            var analytics = await DashboardService.GetUserAnalyticsAsync(Session.CurrentUser.Id, FolderId);
            
            totalDocuments = analytics.TotalDocuments;
            completionRate = analytics.CompletionRate;
            avgProcessingTimeHrs = analytics.AvgProcessingTimeHrs;
            storageUsedMb = analytics.StorageUsedMb;

            Series = new List<ChartSeries<double>>
            {
                new ChartSeries<double> { Name = "Uploads", Data = analytics.DailyUploadCounts.ToArray() }
            };
            XAxisLabels = analytics.DailyUploadLabels.ToArray();
            issuesList = analytics.CommonIssues;
            documentsList = analytics.RecentDocuments;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void NavigateToFolderDocuments()
    {
        if (FolderId.HasValue)
        {
            Nav.NavigateTo($"/documents?folderId={FolderId.Value}");
        }
    }
}
