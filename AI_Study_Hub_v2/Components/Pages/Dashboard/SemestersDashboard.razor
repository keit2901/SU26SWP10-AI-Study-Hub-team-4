@page "/dashboard/semesters"
@layout AI_Study_Hub_v2.Components.Layout.DashboardLayout
@using AI_Study_Hub_v2.Data
@using AI_Study_Hub_v2.Data.Entities
@using Microsoft.EntityFrameworkCore
@inject AppDbContext DbContext
@inject AI_Study_Hub_v2.Services.AuthSessionState Session
@inject NavigationManager Nav

<PageTitle>Semester Timeline - AI Study Hub</PageTitle>

<div style="display: flex; flex-direction: column; flex: 1; overflow-y: auto;">
    <div style="padding: 2rem 2.5rem 2.5rem; display: flex; flex-direction: column; gap: 1.25rem;">
        <div>
            <h1 style="font-size: 1.9rem; font-weight: 800; letter-spacing: -0.04em; color: #111827; margin: 0;">Semester Timeline</h1>
            <p style="font-size: 0.95rem; color: #6b7280; margin: 0.45rem 0 0;">Understand how your study material is spread across academic terms and where each semester still needs coverage.</p>
        </div>

        @if (isLoading)
        {
            <div style="text-align: center; padding: 3rem;">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else if (semesters.Count == 0)
        {
            <div style="background: #fff; border-radius: 1rem; border: 1px solid #eef2f7; padding: 2.5rem; text-align: center;">
                <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Style="font-size: 3rem; color: #818cf8; margin-bottom: 1rem;" />
                <h2 style="font-size: 1.2rem; color: #111827; margin: 0 0 0.5rem;">No semester tags yet</h2>
                <p style="font-size: 0.9rem; color: #6b7280; margin: 0;">Once your uploaded documents include semester labels, this timeline will group and compare them automatically.</p>
            </div>
        }
        else
        {
            <div style="display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1rem;">
                <StatCard Icon="@Icons.Material.Filled.CalendarToday" Title="Semesters" Count="@semesters.Count.ToString()" Description="Terms in your library" BgColor="rgba(238,242,255,0.8)" IconColor="#4f46e5" />
                <StatCard Icon="@Icons.Material.Filled.MenuBook" Title="Subject Spread" Count="@totalSubjects.ToString()" Description="Subject-semester coverage points" BgColor="rgba(236,253,245,0.9)" IconColor="#059669" />
                <StatCard Icon="@Icons.Material.Filled.Description" Title="Documents" Count="@totalDocuments.ToString()" Description="Files tagged to semesters" BgColor="rgba(255,247,237,0.95)" IconColor="#ea580c" />
            </div>

            <div style="display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem;">
                @foreach (var semester in semesters)
                {
                    <article style="background: #fff; border: 1px solid #eef2f7; border-radius: 1rem; padding: 1.25rem 1.35rem; box-shadow: 0 12px 24px rgba(15,23,42,0.04); display: flex; flex-direction: column; gap: 1rem;">
                        <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem;">
                            <div>
                                <div style="display: inline-flex; align-items: center; gap: 0.35rem; padding: 0.3rem 0.65rem; border-radius: 9999px; background: #eef2ff; color: #4338ca; font-size: 0.72rem; font-weight: 700;">@semester.Name</div>
                                <h2 style="font-size: 1.05rem; font-weight: 700; color: #111827; margin: 0.7rem 0 0;">@semester.DocumentCount document(s)</h2>
                            </div>
                            <span style="font-size: 0.78rem; color: #6b7280;">Updated @semester.LastUpdatedText</span>
                        </div>

                        <div style="display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 0.75rem;">
                            <div style="padding: 0.85rem; border-radius: 0.9rem; background: #f8fafc;">
                                <div style="font-size: 0.72rem; color: #64748b; text-transform: uppercase; font-weight: 700;">Ready</div>
                                <strong style="display: block; font-size: 1.3rem; color: #111827; margin-top: 0.3rem;">@semester.ReadyCount</strong>
                            </div>
                            <div style="padding: 0.85rem; border-radius: 0.9rem; background: #f8fafc;">
                                <div style="font-size: 0.72rem; color: #64748b; text-transform: uppercase; font-weight: 700;">Subjects</div>
                                <strong style="display: block; font-size: 1.3rem; color: #111827; margin-top: 0.3rem;">@semester.SubjectCount</strong>
                            </div>
                            <div style="padding: 0.85rem; border-radius: 0.9rem; background: #f8fafc;">
                                <div style="font-size: 0.72rem; color: #64748b; text-transform: uppercase; font-weight: 700;">Shared</div>
                                <strong style="display: block; font-size: 1.3rem; color: #111827; margin-top: 0.3rem;">@semester.SharedFolderCount</strong>
                            </div>
                        </div>

                        <div style="display: flex; flex-wrap: wrap; gap: 0.45rem;">
                            @foreach (var subject in semester.SubjectCodes)
                            {
                                <span style="display: inline-flex; align-items: center; padding: 0.3rem 0.65rem; border-radius: 9999px; background: #f8fafc; color: #475569; font-size: 0.76rem; font-weight: 600; border: 1px solid #eef2f7;">@subject</span>
                            }
                        </div>
                    </article>
                }
            </div>
        }
    </div>
</div>

@code {
    private sealed record SemesterCardVm(
        string Name,
        int DocumentCount,
        int ReadyCount,
        int SubjectCount,
        int SharedFolderCount,
        IReadOnlyList<string> SubjectCodes,
        string LastUpdatedText);

    private bool isLoading = true;
    private int totalDocuments;
    private int totalSubjects;
    private List<SemesterCardVm> semesters = new();

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated || Session.CurrentUser == null)
        {
            Nav.NavigateTo("/login");
            return;
        }

        var documents = await DbContext.Documents
            .Include(d => d.Folder)
            .Where(d => d.UserId == Session.CurrentUser.Id && !string.IsNullOrWhiteSpace(d.Semester))
            .OrderByDescending(d => d.UpdatedAt)
            .ToListAsync();

        totalDocuments = documents.Count;

        semesters = documents
            .GroupBy(d => d.Semester.Trim().ToUpperInvariant())
            .OrderByDescending(g => g.Key)
            .Select(g =>
            {
                var items = g.ToList();
                var subjectCodes = items
                    .Select(d => d.SubjectCode)
                    .Where(s => !string.IsNullOrWhiteSpace(s))
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .OrderBy(s => s)
                    .ToList();

                return new SemesterCardVm(
                    g.Key,
                    items.Count,
                    items.Count(d => d.Status == DocumentStatus.Ready),
                    subjectCodes.Count,
                    items.Where(d => d.Folder?.IsShared == true).Select(d => d.FolderId).Distinct().Count(),
                    subjectCodes,
                    items.Max(d => d.UpdatedAt).ToLocalTime().ToString("dd MMM yyyy"));
            })
            .ToList();

        totalSubjects = semesters.Sum(s => s.SubjectCount);
        isLoading = false;
    }
}
