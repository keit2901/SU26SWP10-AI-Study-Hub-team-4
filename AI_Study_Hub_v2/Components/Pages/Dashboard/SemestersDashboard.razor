@page "/dashboard/semesters"
@layout AI_Study_Hub_v2.Components.Layout.DashboardLayout
@using AI_Study_Hub_v2.Components.Layout
@using AI_Study_Hub_v2.Dtos
@inject AI_Study_Hub_v2.Services.IDashboardService DashboardService
@inject AI_Study_Hub_v2.Services.AuthSessionState Session
@inject NavigationManager Nav

<PageTitle>Semesters - AI Study Hub</PageTitle>

<div style="display: flex; flex-direction: column; flex: 1; height: 100%;">
    <!-- Header -->
    <div style="display: flex; height: 4rem; align-items: center; justify-content: flex-end; border-bottom: 1px solid rgba(199,196,215,0.3); background: #faf9fe; padding: 0 1.5rem; gap: 1rem;">
        <button style="display: flex; align-items: center; justify-content: center; border-radius: 9999px; padding: 0.5rem; background: transparent; border: none; cursor: pointer;">
            <MudIcon Icon="@Icons.Material.Filled.Notifications" Style="font-size: 1.25rem; color: #464554;" />
        </button>
        <div style="display: flex; height: 2rem; width: 2rem; align-items: center; justify-content: center; border-radius: 9999px; background: #5e5ce6;">
            <span style="font-size: 0.8125rem; font-weight: 600; color: #fff; letter-spacing: 0.39px;">
                @(Session.CurrentUser?.Username?.Substring(0, Math.Min(2, Session.CurrentUser.Username.Length)).ToUpper() ?? "US")
            </span>
        </div>
    </div>

    <!-- Content -->
    <div style="flex: 1; overflow-y: auto; padding: 2rem 1.5rem;">
        <div style="margin-bottom: 2rem; display: flex; flex-direction: column; gap: 0.5rem;">
            <h1 style="font-size: 1.875rem; font-weight: 700; color: #1a1b1f; margin: 0;">Semesters Management</h1>
            <p style="font-size: 1rem; color: #464554; margin: 0;">Track, configure, and manage active academic semesters.</p>
        </div>

        @if (isLoading)
        {
            <div style="text-align: center; padding: 3rem;">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else if (semesters == null || !semesters.Any())
        {
            <div style="background: white; border-radius: 0.75rem; box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05); padding: 2rem; text-align: center; border: 1px solid rgba(199,196,215,0.3);">
                <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Style="font-size: 3rem; color: #5e5ce6; margin-bottom: 1rem;" />
                <h3 style="font-size: 1.25rem; font-weight: 600; color: #1a1b1f; margin-bottom: 0.5rem;">No Active Configuration</h3>
                <p style="color: #6b7280; max-width: 24rem; margin: 0 auto 1.5rem;">Semesters will appear automatically once users upload documents tagged with semester values.</p>
            </div>
        }
        else
        {
            <div style="background: #fff; border-radius: 1rem; box-shadow: 0 2px 10px -4px rgba(0,0,0,0.05); border: 1px solid #f1f5f9; overflow: hidden;">
                <div style="overflow-x: auto;">
                    <table style="width: 100%; text-align: left; border-collapse: collapse;">
                        <thead>
                            <tr style="background: rgba(249,250,251,0.8); border-top: 1px solid #f1f5f9; border-bottom: 1px solid #f1f5f9;">
                                <th style="padding: 1rem 1.5rem; font-size: 0.75rem; font-weight: 600; color: #6b7280; text-transform: uppercase;">Semester</th>
                                <th style="padding: 1rem 1.5rem; font-size: 0.75rem; font-weight: 600; color: #6b7280; text-transform: uppercase;">Total Documents</th>
                                <th style="padding: 1rem 1.5rem; font-size: 0.75rem; font-weight: 600; color: #6b7280; text-transform: uppercase;">Storage Used</th>
                                <th style="padding: 1rem 1.5rem; font-size: 0.75rem; font-weight: 600; color: #6b7280; text-transform: uppercase;">Latest Upload</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var semester in semesters)
                            {
                                <tr style="border-bottom: 1px solid #f1f5f9;">
                                    <td style="padding: 1.25rem 1.5rem; font-weight: 600; color: #1f2937;">
                                        <div style="display: flex; align-items: center; gap: 0.75rem;">
                                            <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Style="color: #5e5ce6;" />
                                            @semester.Semester
                                        </div>
                                    </td>
                                    <td style="padding: 1.25rem 1.5rem; color: #4b5563; font-weight: 500;">
                                        @semester.DocumentCount files
                                    </td>
                                    <td style="padding: 1.25rem 1.5rem; color: #4b5563; font-weight: 500;">
                                        @semester.StorageUsedMb MB
                                    </td>
                                    <td style="padding: 1.25rem 1.5rem; color: #6b7280; font-size: 0.875rem;">
                                        @(semester.LatestUploadDate?.ToString("MMM dd, yyyy HH:mm") ?? "N/A")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private bool isLoading = true;
    private List<DashboardSemesterDto>? semesters;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated || Session.CurrentUser == null)
        {
            Nav.NavigateTo("/login");
            return;
        }

        try
        {
            semesters = await DashboardService.GetSemestersStatsAsync();
        }
        finally
        {
            isLoading = false;
        }
    }
}
