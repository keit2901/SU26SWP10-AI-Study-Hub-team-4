@inject AuthSessionState Session
@inject PlanApiClient PlanApi

<MudDialog>
    <DialogContent>
        <div class="checkout-dialog">
            @if (!_completed)
            {
                <div class="checkout-icon">
                    <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Size="Size.Large" />
                </div>
                <h3 class="checkout-title">Upgrade to @Plan.DisplayName</h3>
                <p class="checkout-subtitle">Confirm your plan upgrade</p>

                <div class="checkout-amount-box">
                    <span class="checkout-label">Payment Amount (Demo)</span>
                    <span class="checkout-amount">@FormatPrice(Plan.MonthlyPriceVnd)</span>
                </div>

                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="checkout-error">
                        <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Size="Size.Small" />
                        <span>@_error</span>
                    </div>
                }

                <div class="checkout-info">
                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Style="color:#4F46E5;" />
                    <span>This is a simulated transaction. No actual payments will be processed.</span>
                </div>

                <div class="checkout-actions">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                               OnClick="ConfirmPayment" Disabled="_isLoading"
                               Style="text-transform:none; font-weight:700; border-radius:12px; height:48px; font-size:1rem;">
                        @if (_isLoading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Inherit" />
                            <span style="margin-left:0.5rem;">Processing...</span>
                        }
                        else
                        {
                            <span>Confirm Payment</span>
                        }
                    </MudButton>
                    <MudButton Variant="Variant.Text" Color="Color.Default" FullWidth="true"
                               OnClick="Cancel" Disabled="_isLoading"
                               Style="text-transform:none; margin-top:0.5rem;">
                        Cancel
                    </MudButton>
                </div>
            }
            else
            {
                <div class="checkout-success">
                    <div class="success-icon-ring">
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Large" Style="color:#10B981; font-size:3.5rem;" />
                    </div>
                    <h3 class="checkout-title" style="color:#10B981;">Upgrade Successful!</h3>
                    <p class="checkout-subtitle">The <strong>@Plan.DisplayName</strong> plan is now active on your account.</p>

                    <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true"
                               OnClick="Close" Style="text-transform:none; font-weight:700; border-radius:12px; height:48px; margin-top:1.5rem; font-size:1rem;">
                        Get Started
                    </MudButton>
                </div>
            }
        </div>
    </DialogContent>
</MudDialog>

<style>
    .checkout-dialog {
        padding: 1.5rem 0.5rem;
        text-align: center;
    }
    .checkout-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 64px; height: 64px;
        border-radius: 50%;
        background: linear-gradient(135deg, #EEF2FF, #E0E7FF);
        color: #4F46E5;
        margin: 0 auto 1rem;
    }
    .checkout-title {
        font-size: 1.35rem;
        font-weight: 800;
        color: #1E293B;
        margin: 0 0 0.25rem;
    }
    .checkout-subtitle {
        font-size: 0.9rem;
        color: #64748B;
        margin: 0 0 1.5rem;
    }
    .checkout-amount-box {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #F8FAFC;
        border: 1px solid #E2E8F0;
        border-radius: 12px;
        padding: 1rem 1.25rem;
        margin-bottom: 1rem;
    }
    .checkout-label {
        font-size: 0.85rem;
        color: #64748B;
        font-weight: 500;
    }
    .checkout-amount {
        font-size: 1.5rem;
        font-weight: 800;
        color: #4F46E5;
    }
    .checkout-error {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
        background: #FEF2F2;
        border-radius: 10px;
        padding: 0.75rem 1rem;
        margin-bottom: 1rem;
        text-align: left;
        font-size: 0.8rem;
        color: #DC2626;
    }
    .checkout-info {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
        background: #EEF2FF;
        border-radius: 10px;
        padding: 0.75rem 1rem;
        margin-bottom: 1.5rem;
        text-align: left;
        font-size: 0.8rem;
        color: #4338CA;
    }
    .checkout-actions {
        margin-top: 0.5rem;
    }
    .checkout-success {
        padding: 1rem 0;
    }
    .success-icon-ring {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 80px; height: 80px;
        border-radius: 50%;
        background: #ECFDF5;
        margin: 0 auto 1rem;
        animation: successPop 0.4s ease-out;
    }
    @@keyframes successPop {
        0% { transform: scale(0.5); opacity: 0; }
        60% { transform: scale(1.1); }
        100% { transform: scale(1); opacity: 1; }
    }
</style>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public PlanDto Plan { get; set; } = null!;

    private bool _completed;
    private bool _isLoading;
    private string? _error;

    private async Task ConfirmPayment()
    {
        _isLoading = true;
        _error = null;
        StateHasChanged();

        try
        {
            var accessToken = Session.AccessToken;
            if (string.IsNullOrWhiteSpace(accessToken))
            {
                _error = "You must be logged in to upgrade your plan.";
                _isLoading = false;
                return;
            }

            await PlanApi.PurchasePlanAsync(accessToken, Plan.PlanKey, "monthly");
            _completed = true;
        }
        catch (PlanApiException ex)
        {
            _error = ex.Message;
        }
        catch (Exception)
        {
            _error = "An unexpected error occurred. Please try again.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string FormatPrice(long? priceVnd)
    {
        if (priceVnd is null or 0) return "Free";
        return $"{priceVnd.Value:N0}₫";
    }

    private void Close() => MudDialog.Close(DialogResult.Ok(true));
    private void Cancel() => MudDialog.Cancel();
}
