@inject AuthSessionState Session
@inject PlanApiClient PlanApi
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<MudDialog>
    <DialogContent>
        <div class="checkout-dialog">
            @if (!_completed)
            {
                <div class="checkout-icon">
                    <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Size="Size.Large" />
                </div>
                <h3 class="checkout-title">Upgrade to @Plan.DisplayName</h3>
                <p class="checkout-subtitle">Confirm your plan upgrade</p>

                <div class="checkout-amount-box">
                    <div style="display:flex; flex-direction:column; align-items:flex-start; gap:0.5rem;">
                        <span class="checkout-label">Payment Amount</span>
                        <div class="billing-cycle-selector">
                            <MudButton Variant="@(_billingCycle == "monthly" ? Variant.Filled : Variant.Outlined)"
                                       Color="Color.Primary"
                                       OnClick="@(() => _billingCycle = "monthly")"
                                       Style="text-transform:none; font-weight:600; flex:1; min-width:0;">
                                Monthly
                            </MudButton>
                            <MudButton Variant="@(_billingCycle == "yearly" ? Variant.Filled : Variant.Outlined)"
                                       Color="Color.Primary"
                                       OnClick="@(() => _billingCycle = "yearly")"
                                       Style="text-transform:none; font-weight:600; flex:1; min-width:0;">
                                Yearly
                            </MudButton>
                        </div>
                    </div>
                    <span class="checkout-amount">@FormatPrice(SelectedPrice)</span>
                </div>

                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="checkout-error">
                        <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Size="Size.Small" />
                        <span>@_error</span>
                    </div>
                }

                <div class="checkout-info">
                    <MudIcon Icon="@Icons.Material.Filled.Timer" Size="Size.Small" />
                    <span>Payment links expire after 5 minutes. If the payment is not completed in time, we will send you back to the pricing page to start again.</span>
                </div>

                <div class="checkout-actions">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                               OnClick="ConfirmPayment" Disabled="_isLoading"
                               Style="text-transform:none; font-weight:700; border-radius:12px; height:48px; font-size:1rem;">
                        @if (_isLoading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Inherit" />
                            <span style="margin-left:0.5rem;">Processing...</span>
                        }
                        else
                        {
                            <span>Proceed to Payment</span>
                        }
                    </MudButton>
                    <MudButton Variant="Variant.Text" Color="Color.Default" FullWidth="true"
                               OnClick="Cancel" Disabled="_isLoading"
                               Style="text-transform:none; margin-top:0.5rem;">
                        Cancel
                    </MudButton>
                </div>
            }
            else
            {
                <div class="checkout-success">
                    <div class="success-icon-ring">
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Large" Style="color:#10B981; font-size:3.5rem;" />
                    </div>
                    <h3 class="checkout-title" style="color:#10B981;">Upgrade Successful!</h3>
                    <p class="checkout-subtitle">The <strong>@Plan.DisplayName</strong> plan is now active on your account.</p>

                    <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true"
                               OnClick="Close" Style="text-transform:none; font-weight:700; border-radius:12px; height:48px; margin-top:1.5rem; font-size:1rem;">
                        Get Started
                    </MudButton>
                </div>
            }
        </div>
    </DialogContent>
</MudDialog>

<style>
    .checkout-dialog {
        padding: 1.5rem 0.5rem;
        text-align: center;
    }
    .checkout-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 64px; height: 64px;
        border-radius: 50%;
        background: linear-gradient(135deg, #EEF2FF, #E0E7FF);
        color: #4F46E5;
        margin: 0 auto 1rem;
    }
    .checkout-title {
        font-size: 1.35rem;
        font-weight: 800;
        color: #1E293B;
        margin: 0 0 0.25rem;
    }
    .checkout-subtitle {
        font-size: 0.9rem;
        color: #64748B;
        margin: 0 0 1.5rem;
    }
    .checkout-amount-box {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #F8FAFC;
        border: 1px solid #E2E8F0;
        border-radius: 12px;
        padding: 1rem 1.25rem;
        margin-bottom: 1rem;
    }
    .checkout-label {
        font-size: 0.85rem;
        color: #64748B;
        font-weight: 500;
    }
    .checkout-amount {
        font-size: 1.5rem;
        font-weight: 800;
        color: #4F46E5;
    }
    .checkout-error {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
        background: #FEF2F2;
        border-radius: 10px;
        padding: 0.75rem 1rem;
        margin-bottom: 1rem;
        text-align: left;
        font-size: 0.8rem;
        color: #DC2626;
    }
    .checkout-info {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
        background: #EEF2FF;
        border-radius: 10px;
        padding: 0.75rem 1rem;
        margin-bottom: 1.5rem;
        text-align: left;
        font-size: 0.8rem;
        color: #4338CA;
    }
    .checkout-actions {
        margin-top: 0.5rem;
    }
    .billing-cycle-selector {
        display: flex;
        gap: 0.5rem;
        width: 100%;
    }
    .checkout-success {
        padding: 1rem 0;
    }
    .success-icon-ring {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 80px; height: 80px;
        border-radius: 50%;
        background: #ECFDF5;
        margin: 0 auto 1rem;
        animation: successPop 0.4s ease-out;
    }
    @@keyframes successPop {
        0% { transform: scale(0.5); opacity: 0; }
        60% { transform: scale(1.1); }
        100% { transform: scale(1); opacity: 1; }
    }
</style>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public PlanDto Plan { get; set; } = null!;

    private bool _completed;
    private bool _isLoading;
    private string? _error;
    private string _billingCycle = "monthly";
    private long? SelectedPrice => _billingCycle == "yearly"
        ? Plan.YearlyPriceVnd
        : Plan.MonthlyPriceVnd;

    private async Task ConfirmPayment()
    {
        _isLoading = true;
        _error = null;
        StateHasChanged();

        try
        {
            var accessToken = Session.AccessToken;
            if (string.IsNullOrWhiteSpace(accessToken))
            {
                _error = "You must be logged in to upgrade your plan.";
                _isLoading = false;
                return;
            }

            await Session.LoadCurrentPlanAsync(PlanApi);
            if (string.Equals(Session.CurrentPlan, Plan.PlanKey, StringComparison.OrdinalIgnoreCase))
            {
                _error = $"Your account is already on the {Plan.DisplayName} plan.";
                _isLoading = false;
                return;
            }

            // Free plan: immediate activation
            if (Plan.PlanKey == "free")
            {
                await PlanApi.PurchaseFreePlanAsync(accessToken, Plan.PlanKey);
                await Session.LoadCurrentPlanAsync(PlanApi);
                _completed = true;
                _isLoading = false;
                return;
            }

            // Paid plan: get VNPay redirect URL
            var result = await PlanApi.PurchasePlanAsync(
                accessToken, Plan.PlanKey, _billingCycle,
                idempotencyKey: Guid.NewGuid().ToString("N"));

            // Redirect to VNPay
            await JS.InvokeVoidAsync("eval", $"window.location.href = '{result.PaymentUrl}'");
        }
        catch (PlanApiException ex)
        {
            var statusCode = (System.Net.HttpStatusCode)ex.StatusCode;
            var message = statusCode switch
            {
                System.Net.HttpStatusCode.Unauthorized => "Please log in again to continue.",
                System.Net.HttpStatusCode.Conflict => ex.Code switch
                {
                    "already_on_plan" => $"Your account is already on the {Plan.DisplayName} plan.",
                    "payment_pending" => "A payment for this account is already in progress. Please wait a moment and try again.",
                    "concurrent_purchase" => "Another purchase is already being processed. Please try again in a moment.",
                    _ => ex.Message
                },
                System.Net.HttpStatusCode.BadRequest => ex.Message,
                System.Net.HttpStatusCode.TooManyRequests => "Too many attempts. Please wait a moment and try again.",
                System.Net.HttpStatusCode.ServiceUnavailable => "The payment gateway is temporarily unavailable. Please try again in a moment.",
                System.Net.HttpStatusCode.PaymentRequired => "Your current usage exceeds the target plan limits. Upgrade or free up space first.",
                _ => $"Purchase failed: {ex.Message}"
            };
            _error = message;
        }
        catch (Exception)
        {
            _error = "A network error occurred. Please check your connection and try again.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string FormatPrice(long? priceVnd)
    {
        if (priceVnd is null or 0) return "Free";
        return $"{priceVnd.Value:N0}₫";
    }

    private void Close() => MudDialog.Close(DialogResult.Ok(true));
    private void Cancel() => MudDialog.Cancel();
}
