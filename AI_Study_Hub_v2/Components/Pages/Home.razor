@page "/"
@inject AuthSessionState Session
@inject NavigationManager Nav

<PageTitle>AI Study Hub - Notebook Community</PageTitle>

<main class="home-hub teammate-community-home">
    <aside class="home-source-sidebar" aria-label="AI Study Hub navigation">
        <section class="home-brand-block">
            <div class="home-brand-mark"><MudIcon Icon="@Icons.Material.Filled.AutoStories" /></div>
            <h1>AI Study<br />Hub</h1>
        </section>

        <section class="home-ai-card">
            <div class="home-ai-card-title">
                <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" />
                <span>AI Study</span>
            </div>
            <p>Sử dụng AI để đặt câu hỏi về tài liệu, tóm tắt nội dung, tạo đề cương, tìm kiếm và luyện quiz từ nguồn đã upload.</p>
            <a class="home-ai-button" href="@(Session.IsAuthenticated ? "/ai/chat" : "/login")">
                Mở AI Chat
                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
            </a>
        </section>

        <nav class="home-side-nav" aria-label="Library shortcuts">
            <p>Thư viện học tập</p>
            <a class="active" href="@(Session.IsAuthenticated ? "/documents" : "/login")">
                <span><MudIcon Icon="@Icons.Material.Filled.Article" Size="Size.Small" /> Tất cả tài liệu</span>
                <MudIcon Icon="@Icons.Material.Filled.ArrowForwardIos" Size="Size.Small" />
            </a>
            <a href="@(Session.IsAuthenticated ? "/documents/upload" : "/login")">
                <span><MudIcon Icon="@Icons.Material.Filled.FolderOff" Size="Size.Small" /> Tài liệu chưa phân loại</span>
                <MudIcon Icon="@Icons.Material.Filled.ArrowForwardIos" Size="Size.Small" />
            </a>
            <a href="#public-community">
                <span><MudIcon Icon="@Icons.Material.Filled.Public" Size="Size.Small" /> Public Community</span>
                <MudIcon Icon="@Icons.Material.Filled.ArrowForwardIos" Size="Size.Small" />
            </a>
        </nav>

        <footer class="home-sidebar-footer">
            <a href="/profile"><MudIcon Icon="@Icons.Material.Filled.PersonOutline" Size="Size.Small" /> Profile</a>
            <a href="#features"><MudIcon Icon="@Icons.Material.Filled.HelpOutline" Size="Size.Small" /> Help</a>
        </footer>
    </aside>

    <section class="home-hub-main">
        <header class="home-hub-header">
            <div class="home-search-box">
                <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" />
                <span>Search notebooks, folders, and shared resources…</span>
            </div>
            <div class="home-header-actions">
                <a class="home-header-link" href="/documents">Library</a>
                <a class="home-header-link" href="/ai/chat">Workspace</a>
                <a class="home-header-primary" href="@(Session.IsAuthenticated ? "/documents/upload" : "/register")">Upload</a>
            </div>
        </header>

        <section class="home-hero-panel" aria-labelledby="home-title">
            <div>
                <span class="home-kicker">Notebook Workspace</span>
                <h2 id="home-title">Build notebooks, chat with sources, and share study paths.</h2>
                <p>
                    Turn uploaded documents into notebook-style study hubs. Move from your private library to
                    AI workspace, source-grounded quiz practice, and community-ready study collections.
                </p>
            </div>
            <div class="home-hero-actions">
                <a class="home-primary-button" href="@(Session.IsAuthenticated ? "/documents" : "/register")">Create new notebook</a>
                <a class="home-secondary-button" href="#public-community">Browse community</a>
            </div>
        </section>

        <section class="home-notebook-section" aria-labelledby="notebooks-title">
            <div class="home-section-toolbar">
                <div>
                    <span class="home-kicker">Private library</span>
                    <h2 id="notebooks-title">My Notebooks</h2>
                </div>
                <div class="home-filter-tabs" aria-label="Notebook filters">
                    <span class="active">All</span>
                    <span>Recent</span>
                    <span>Shared</span>
                </div>
            </div>

            <div class="home-card-grid">
                <a class="home-create-card" href="@(Session.IsAuthenticated ? "/documents/upload" : "/register")">
                    <span><MudIcon Icon="@Icons.Material.Filled.Add" /></span>
                    <strong>Create new notebook</strong>
                </a>

                @foreach (var card in MyNotebooks)
                {
                    @NotebookCard(card)
                }
            </div>
        </section>

        <section id="public-community" class="home-notebook-section community" aria-labelledby="community-title">
            <div class="home-section-toolbar">
                <div>
                    <span class="home-kicker">Public Community</span>
                    <h2 id="community-title">Shared study notebooks</h2>
                </div>
                <a class="home-view-all" href="@(Session.IsAuthenticated ? "/documents" : "/login")">Connect to Library</a>
            </div>

            <div class="home-card-grid">
                @foreach (var card in CommunityCards)
                {
                    @NotebookCard(card)
                }
            </div>
        </section>

        <section id="features" class="home-workflow-strip" aria-label="Integrated teammate UI sources">
            <article><strong>Library</strong><span>folder-first dashboard</span></article>
            <article><strong>Workspace</strong><span>document-aware AI chat</span></article>
            <article><strong>Quiz</strong><span>exam modal with feedback</span></article>
            <article><strong>Community</strong><span>shared notebook discovery</span></article>
        </section>
    </section>
</main>

@code {
    protected override void OnInitialized()
    {
        if (!Session.IsAuthenticated)
        {
            return;
        }

        var target = Session.CurrentUser?.Role?.Equals("Admin", StringComparison.OrdinalIgnoreCase) == true
            ? "/admin"
            : "/documents";
        Nav.NavigateTo(target, replace: true);
    }

    private static readonly HubCard[] MyNotebooks =
    [
        new("Large Language Models for Study", "May 29, 2026", 38, Icons.Material.Filled.Science, "red"),
        new("Knowledge Matters: Project-Aware RAG", "May 27, 2026", 38, Icons.Material.Filled.Psychology, "violet"),
        new("SciVal Quick Reference Guide", "May 16, 2026", 56, Icons.Material.Filled.Analytics, "blue"),
        new("PixelLab Image Editing Tools", "May 22, 2026", 48, Icons.Material.Filled.Palette, "slate"),
    ];

    private static readonly HubCard[] CommunityCards =
    [
        new("Advanced Calculus II", "Dr. Sarah Miller", 124, Icons.Material.Filled.Functions, "indigo", "Dr. Sarah Miller"),
        new("Organic Chemistry Notes", "James Wilson", 86, Icons.Material.Filled.Biotech, "red", "James Wilson"),
        new("Modern World History", "Prof. Elena Rossi", 210, Icons.Material.Filled.School, "violet", "Prof. Elena Rossi"),
        new("Structural Engineering Basics", "David Chen", 54, Icons.Material.Filled.Explore, "blue", "David Chen"),
    ];

    private RenderFragment NotebookCard(HubCard card) => @<article class="home-notebook-card @($"tone-{card.Tone}")">
        <header>
            <span class="home-card-icon"><MudIcon Icon="@card.Icon" /></span>
            <span class="home-card-more" aria-hidden="true"><MudIcon Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" /></span>
        </header>
        <div class="home-card-copy">
            <h3>@card.Title</h3>
            <div class="home-card-meta">
                @if (!string.IsNullOrWhiteSpace(card.Author))
                {
                    <span class="home-author-avatar"><MudIcon Icon="@Icons.Material.Filled.Group" Size="Size.Small" /></span>
                    <span>@card.Author</span>
                }
                else
                {
                    <span>@card.Subtitle</span>
                }
                <span>@card.Sources sources</span>
            </div>
        </div>
    </article>;

    private sealed record HubCard(string Title, string Subtitle, int Sources, string Icon, string Tone, string? Author = null);
}
