@page "/documents/{Id:guid}"
@using AI_Study_Hub_v2.Data.Entities
@using AI_Study_Hub_v2.Dtos
@using AI_Study_Hub_v2.Services
@inject DocumentApiClient DocumentsApi
@inject FolderApiClient FoldersApi
@inject AuthSessionState Session
@inject NavigationManager Nav
@inject IDialogService Dialogs
@inject ISnackbar Snackbar

<PageTitle>@(_doc?.FileName ?? "Document") - AI Study Hub v2</PageTitle>

<MudStack Spacing="3" Class="workspace-shell document-detail-shell pa-4">
    @if (_busy && _doc is null)
    {
        <MudPaper Class="detail-loading glass-card" Elevation="0" Outlined="false">
            <MudStack AlignItems="AlignItems.Center" Spacing="2">
                <MudProgressCircular Indeterminate="true" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Loading document workspace…</MudText>
            </MudStack>
        </MudPaper>
    }
    else if (_error is not null)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled">@_error</MudAlert>
        <MudButton Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   Href="/documents">
            Back to list
        </MudButton>
    }
    else if (_doc is not null)
    {
        <section class="detail-hero" aria-labelledby="detail-title">
            <div class="detail-hero-main">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                               Href="/documents"
                               title="Back to list"
                               Class="detail-back-button" />
                <div class="detail-file-orb">
                    <MudIcon Icon="@GetFileIcon(_doc.MimeType)" />
                </div>
                <div class="detail-title-wrap">
                    <span class="section-kicker">Document workspace</span>
                    <MudText id="detail-title" Typo="Typo.h3" Class="detail-title">@_doc.FileName</MudText>
                    <MudText Typo="Typo.body1" Class="detail-subtitle">
                        @FormatBytes(_doc.FileSizeBytes) — @_doc.MimeType
                    </MudText>
                    <div class="detail-chip-row">
                        <MudChip T="string" Size="Size.Small" Color="@StatusColor(_doc.Status)" Variant="Variant.Filled" Icon="@StatusIcon(_doc.Status)">
                            @_doc.Status.ToString()
                        </MudChip>
                        <span>@_doc.SubjectCode</span>
                        <span>@_doc.Semester</span>
                        <span>@FolderName(_doc.FolderId)</span>
                    </div>
                </div>
            </div>
            <div class="detail-hero-actions">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Refresh"
                           OnClick="LoadAsync"
                           Disabled="_busy">
                    Refresh
                </MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.Delete"
                           OnClick="ConfirmDeleteAsync"
                           Disabled="_busy">
                    Delete
                </MudButton>
            </div>
        </section>

        <section class="detail-metrics-grid" aria-label="Document facts">
            <MudPaper Class="detail-metric-card accent-cyan" Elevation="0" Outlined="false">
                <span class="metric-icon"><MudIcon Icon="@StatusIcon(_doc.Status)" /></span>
                <div><small>Status</small><strong>@_doc.Status</strong><em>@StatusHint(_doc.Status)</em></div>
            </MudPaper>
            <MudPaper Class="detail-metric-card accent-violet" Elevation="0" Outlined="false">
                <span class="metric-icon"><MudIcon Icon="@Icons.Material.Filled.AutoStories" /></span>
                <div><small>Pages</small><strong>@(_doc.PageCount?.ToString() ?? "—")</strong><em>Extracted page count</em></div>
            </MudPaper>
            <MudPaper Class="detail-metric-card accent-green" Elevation="0" Outlined="false">
                <span class="metric-icon"><MudIcon Icon="@Icons.Material.Filled.FolderOpen" /></span>
                <div><small>Folder</small><strong>@FolderName(_doc.FolderId)</strong><em>Current cabinet</em></div>
            </MudPaper>
            <MudPaper Class="detail-metric-card accent-amber" Elevation="0" Outlined="false">
                <span class="metric-icon"><MudIcon Icon="@Icons.Material.Filled.Schedule" /></span>
                <div><small>Updated</small><strong>@_doc.UpdatedAt.ToLocalTime().ToString("MMM dd")</strong><em>@_doc.UpdatedAt.ToLocalTime().ToString("HH:mm")</em></div>
            </MudPaper>
        </section>

        @if (!string.IsNullOrWhiteSpace(_doc.ErrorMessage))
        {
            <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Filled">@_doc.ErrorMessage</MudAlert>
        }

        <section class="detail-workspace-grid" aria-label="Document workspace controls">
            <MudPaper Class="detail-panel detail-metadata-panel glass-card" Elevation="0" Outlined="false">
                <div class="detail-panel-header">
                    <span class="detail-panel-icon"><MudIcon Icon="@Icons.Material.Filled.DataObject" /></span>
                    <div>
                        <MudText Typo="Typo.h6">Metadata registry</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Canonical fields used by library search and RAG scoping.</MudText>
                    </div>
                </div>

                <dl class="detail-meta-list">
                    <div><dt>Subject</dt><dd>@_doc.SubjectCode</dd></div>
                    <div><dt>Semester</dt><dd>@_doc.Semester</dd></div>
                    <div><dt>Folder</dt><dd>@FolderName(_doc.FolderId)</dd></div>
                    <div><dt>Uploaded</dt><dd>@_doc.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</dd></div>
                    <div><dt>Updated</dt><dd>@_doc.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</dd></div>
                    <div class="wide"><dt>Document ID</dt><dd><code>@_doc.Id</code></dd></div>
                </dl>
            </MudPaper>

            <div class="detail-action-stack">
                <MudPaper Class="detail-action-card ai glass-card-soft" Elevation="0" Outlined="false">
                    <span class="detail-action-icon"><MudIcon Icon="@Icons.Material.Filled.AutoAwesome" /></span>
                    <div>
                        <MudText Typo="Typo.h6">AI study chat</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Ask questions scoped to this document and review cited chunks.</MudText>
                    </div>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Class="premium-button"
                               StartIcon="@Icons.Material.Filled.Chat"
                               Href="@($"/ai/chat?documentId={_doc.Id}")"
                               Disabled="_busy || _doc.Status != DocumentStatus.Ready">
                        Ask AI about this document
                    </MudButton>
                    @if (_doc.Status != DocumentStatus.Ready)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">AI chat unlocks when ingestion status is Ready.</MudText>
                    }
                </MudPaper>

            </div>

            <aside class="detail-side-rail" aria-label="Download and source actions">
                <MudPaper Class="detail-rail-card download glass-card-soft" Elevation="0" Outlined="false">
                    <span class="section-kicker">Source file</span>
                    <MudIcon Icon="@GetFileIcon(_doc.MimeType)" Class="detail-rail-file-icon" />
                    <MudText Typo="Typo.subtitle2">Download original</MudText>
                    @if (!string.IsNullOrEmpty(_doc.DownloadUrl))
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Signed link, valid for ~5 minutes. Open in a new tab or refresh for a fresh URL.</MudText>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Download"
                                   Href="@_doc.DownloadUrl"
                                   Target="_blank">
                            Open file
                        </MudButton>
                        <MudButton Variant="Variant.Text"
                                   StartIcon="@Icons.Material.Filled.Refresh"
                                   OnClick="LoadAsync"
                                   Disabled="_busy">
                            Get fresh link
                        </MudButton>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true" Variant="Variant.Outlined">
                            Download link is not available right now. Try refreshing.
                        </MudAlert>
                    }
                </MudPaper>

                <MudPaper Class="detail-rail-card lifecycle glass-card-soft" Elevation="0" Outlined="false">
                    <MudText Typo="Typo.subtitle2">Ingestion lifecycle</MudText>
                    <ol class="detail-lifecycle">
                        <li class="done"><span></span>Uploaded</li>
                        <li class="@(IsAtLeastProcessing(_doc.Status) ? "done" : null)"><span></span>Processing</li>
                        <li class="@(_doc.Status == DocumentStatus.Ready ? "done" : null)"><span></span>Ready for AI</li>
                    </ol>
                </MudPaper>
            </aside>
        </section>
    }
</MudStack>

@code {
    [Parameter] public Guid Id { get; set; }

    private bool _busy;
    private string? _error;
    private DocumentDto? _doc;
    private List<FolderDto> _folders = new();

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated)
        {
            Nav.NavigateTo("/login", replace: true);
            return;
        }
        await LoadFoldersAsync();
        await LoadAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        // Reload when navigating between /documents/{id1} and /documents/{id2}.
        if (_doc is not null && _doc.Id != Id)
        {
            _doc = null;
            await LoadAsync();
        }
    }

    private async Task LoadFoldersAsync()
    {
        if (string.IsNullOrEmpty(Session.AccessToken)) return;
        try
        {
            _folders = (await FoldersApi.ListAsync(Session.AccessToken!)).ToList();
        }
        catch (DocumentApiException ex)
        {
            Snackbar.Add(MapError(ex), Severity.Warning);
            if (ex.StatusCode == 401)
            {
                Session.Clear();
                Nav.NavigateTo("/login", replace: true);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not load folders: {ex.Message}", Severity.Warning);
        }
    }

    private async Task LoadAsync()
    {
        if (string.IsNullOrEmpty(Session.AccessToken)) return;
        _busy = true;
        _error = null;
        StateHasChanged();
        try
        {
            _doc = await DocumentsApi.GetAsync(Session.AccessToken!, Id);
        }
        catch (DocumentApiException ex)
        {
            _doc = null;
            _error = MapError(ex);
            if (ex.StatusCode == 401)
            {
                Session.Clear();
                Nav.NavigateTo("/login", replace: true);
            }
        }
        catch (Exception ex)
        {
            _error = $"Network error: {ex.Message}";
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    private async Task ConfirmDeleteAsync()
    {
        if (_doc is null) return;
        var parameters = new DialogParameters
        {
            ["Title"] = "Delete document?",
            ["Message"] = $"Delete \"{_doc.FileName}\"? This cannot be undone — chunks and the stored file will be removed.",
            ["ConfirmText"] = "Delete",
            ["ConfirmColor"] = Color.Error,
            ["Icon"] = Icons.Material.Filled.DeleteForever,
            ["IconColor"] = Color.Error,
        };
        var options = new DialogOptions { CloseOnEscapeKey = true };
        var dialogRef = await Dialogs.ShowAsync<AI_Study_Hub_v2.Components.Admin.Shared.ConfirmDialog>("Delete document", parameters, options);
        var result = await dialogRef.Result;
        if (result is null || result.Canceled) return;

        await DeleteAsync();
    }

    private async Task DeleteAsync()
    {
        if (_doc is null || string.IsNullOrEmpty(Session.AccessToken)) return;
        _busy = true;
        StateHasChanged();
        try
        {
            await DocumentsApi.DeleteAsync(Session.AccessToken!, _doc.Id);
            Snackbar.Add($"Deleted \"{_doc.FileName}\".", Severity.Success);
            Nav.NavigateTo("/documents");
        }
        catch (DocumentApiException ex)
        {
            Snackbar.Add(MapError(ex), Severity.Error);
            if (ex.StatusCode == 401)
            {
                Session.Clear();
                Nav.NavigateTo("/login", replace: true);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Network error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    private string FolderName(Guid? folderId)
        => folderId is { } id
            ? _folders.FirstOrDefault(f => f.Id == id)?.Name ?? "Unknown folder"
            : "Loose document";

    private static string MapError(DocumentApiException ex) => ex.StatusCode switch
    {
        401 => "Your session has expired. Please sign in again.",
        403 => "You do not have access to that document.",
        404 => ex.Code == "folder_not_found" ? "Folder not found." : "Document not found — it may have been deleted already.",
        _ => ex.Message,
    };

    private static Color StatusColor(DocumentStatus s) => s switch
    {
        DocumentStatus.Ready => Color.Success,
        DocumentStatus.Uploading => Color.Info,
        DocumentStatus.Processing => Color.Warning,
        DocumentStatus.Failed => Color.Error,
        _ => Color.Default,
    };

    private static string StatusIcon(DocumentStatus s) => s switch
    {
        DocumentStatus.Ready => Icons.Material.Filled.TaskAlt,
        DocumentStatus.Uploading => Icons.Material.Filled.CloudUpload,
        DocumentStatus.Processing => Icons.Material.Filled.AutoMode,
        DocumentStatus.Failed => Icons.Material.Filled.Error,
        _ => Icons.Material.Filled.RadioButtonUnchecked,
    };

    private static string StatusHint(DocumentStatus s) => s switch
    {
        DocumentStatus.Ready => "Available for cited chat",
        DocumentStatus.Uploading => "Source is being stored",
        DocumentStatus.Processing => "Chunks are being prepared",
        DocumentStatus.Failed => "Review the ingestion error",
        _ => "Pipeline status",
    };

    private static bool IsAtLeastProcessing(DocumentStatus s)
        => s is DocumentStatus.Processing or DocumentStatus.Ready or DocumentStatus.Failed;

    private static string GetFileIcon(string? mime) => mime switch
    {
        "application/pdf" => Icons.Material.Filled.PictureAsPdf,
        "application/msword" => Icons.Material.Filled.Description,
        "application/vnd.openxmlformats-officedocument.wordprocessingml.document" => Icons.Material.Filled.Description,
        "application/vnd.ms-powerpoint" => Icons.Material.Filled.Slideshow,
        "application/vnd.openxmlformats-officedocument.presentationml.presentation" => Icons.Material.Filled.Slideshow,
        _ => Icons.Material.Filled.InsertDriveFile,
    };

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024L * 1024) return $"{bytes / 1024.0:0.#} KB";
        if (bytes < 1024L * 1024 * 1024) return $"{bytes / (1024.0 * 1024):0.#} MB";
        return $"{bytes / (1024.0 * 1024 * 1024):0.##} GB";
    }
}
