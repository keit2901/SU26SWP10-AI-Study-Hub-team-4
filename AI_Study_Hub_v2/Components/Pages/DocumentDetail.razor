@page "/documents/{Id:guid}"
@using AI_Study_Hub_v2.Data.Entities
@using AI_Study_Hub_v2.Dtos
@using AI_Study_Hub_v2.Services
@inject DocumentApiClient DocumentsApi
@inject FolderApiClient FoldersApi
@inject AuthSessionState Session
@inject AuthPersistenceService AuthPersistence
@inject NavigationManager Nav
@inject IDialogService Dialogs
@inject ISnackbar Snackbar

<PageTitle>@(_doc?.FileName ?? "Document") - AI Study Hub v2</PageTitle>

<MudStack Spacing="0" Class="detail-page">
    @if (_busy && _doc is null)
    {
        <div class="detail-loading-card">
            <MudProgressCircular Indeterminate="true" Size="Size.Small" />
            <span>Loading document workspace…</span>
        </div>
    }
    else if (_error is not null)
    {
        <div class="detail-error">
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="detail-alert">@_error</MudAlert>
            <a href="/documents" class="detail-back-link">&larr; Back to list</a>
        </div>
    }
    else if (_doc is not null)
    {
        @* ── Breadcrumb ── *@
        <div class="detail-breadcrumb">
            <svg class="bc-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>
            <span>DOCUMENT WORKSPACE</span>
            <svg class="bc-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            <span class="bc-current">@_doc.FileName</span>
        </div>


        @* ── Document Header Card ── *@
        <div class="detail-header-card">
            <div class="dh-top-row">
                <div class="dh-left">
                    <a href="/documents" class="dh-back-btn" title="Back to list">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                    </a>
                    <div class="dh-icon-box">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
                    </div>
                    <div class="dh-title-area">
                        @if (_renaming)
                        {
                            <div class="dh-rename-row">
                                <input class="dh-rename-input"
                                       @bind="_renameValue"
                                       @bind:event="oninput"
                                       @onkeydown="HandleRenameKeyDown"
                                       @ref="_renameInput" />
                                <button class="dh-rename-confirm" @onclick="CommitRename" title="Confirm">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                                </button>
                                <button class="dh-rename-cancel" @onclick="CancelRename" title="Cancel">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="dh-title-group">
                                <h1 class="dh-title">@_doc.FileName</h1>
                                <button class="dh-pencil-btn" @onclick="BeginRename" title="Rename">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                                </button>
                            </div>
                        }
                        <p class="dh-meta-line">@FormatBytes(_doc.FileSizeBytes) &middot; @_doc.MimeType</p>
                    </div>
                </div>
                <div class="dh-actions">
                    <button class="dh-action-btn" @onclick="BeginRename">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                        Rename
                    </button>
                    <button class="dh-action-btn" @onclick="LoadAsync" disabled="@_busy">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M3 21v-5h5"/></svg>
                        Refresh
                    </button>
                    <button class="dh-action-btn dh-action-delete" @onclick="ConfirmDeleteAsync" disabled="@_busy">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                        Delete
                    </button>
                </div>
            </div>
            <div class="dh-tags">
                <span class="dh-status-badge status-@StatusCssClass">
                    <span class="dh-status-dot"></span>
                    @DisplayStatusText
                </span>
                <span class="dh-tag"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z"/><path d="M7 7h.01"/></svg>@_doc.SubjectCode</span>
                <span class="dh-tag"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z"/><path d="M7 7h.01"/></svg>@_doc.Semester</span>
                <span class="dh-tag"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z"/><path d="M7 7h.01"/></svg>@FolderName(_doc.FolderId)</span>
            </div>
        </div>

        @* ── Stats Row ── *@
        <div class="detail-stats-grid">
            <div class="ds-card">
                <div class="ds-icon-box ds-icon-emerald">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                </div>
                <div>
                    <p class="ds-label">STATUS</p>
                    <p class="ds-value">@DisplayStatusText</p>
                </div>
            </div>
            <div class="ds-card">
                <div class="ds-icon-box ds-icon-indigo">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"/><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17"/></svg>
                </div>
                <div>
                    <p class="ds-label">PAGES</p>
                    <p class="ds-value">@(_doc.PageCount?.ToString() ?? "—")</p>
                </div>
            </div>
            <div class="ds-card">
                <div class="ds-icon-box ds-icon-amber">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg>
                </div>
                <div>
                    <p class="ds-label">FOLDER</p>
                    <p class="ds-value">@FolderName(_doc.FolderId)</p>
                </div>
            </div>
            <div class="ds-card">
                <div class="ds-icon-box ds-icon-slate">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
                </div>
                <div>
                    <p class="ds-label">UPDATED</p>
                    <p class="ds-value">@_doc.UpdatedAt.ToLocalTime().ToString("MMM dd")</p>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_doc.ErrorMessage))
        {
            <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Filled">@_doc.ErrorMessage</MudAlert>
        }

        @* ── Three-column body ── *@
        <div class="detail-body-grid">
            @* ── Left: Metadata ── *@
            <aside class="db-panel">
                <div class="db-panel-head">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                    <h2>Metadata registry</h2>
                </div>
                <p class="db-panel-desc">Canonical fields used by library search and RAG scoping.</p>
                <div class="db-meta-list">
                    <div class="db-meta-item">
                        <span class="db-meta-label">SUBJECT</span>
                        <span class="db-meta-value">@_doc.SubjectCode</span>
                    </div>
                    <div class="db-meta-item">
                        <span class="db-meta-label">SEMESTER</span>
                        <span class="db-meta-value">@_doc.Semester</span>
                    </div>
                    <div class="db-meta-item">
                        <span class="db-meta-label">FOLDER</span>
                        <span class="db-meta-value">@FolderName(_doc.FolderId)</span>
                    </div>
                    <div class="db-meta-item">
                        <span class="db-meta-label">INDEXED</span>
                        <span class="db-meta-value db-mono">@_doc.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</span>
                    </div>
                    <div class="db-meta-item">
                        <span class="db-meta-label">DOCUMENT ID</span>
                        <span class="db-meta-value db-mono">@_doc.Id</span>
                    </div>
                    <div class="db-meta-item">
                        <span class="db-meta-label">MIME TYPE</span>
                        <span class="db-meta-value db-mono">@_doc.MimeType</span>
                    </div>
                    <div class="db-meta-item">
                        <span class="db-meta-label">FILE SIZE</span>
                        <span class="db-meta-value db-mono">@FormatBytes(_doc.FileSizeBytes)</span>
                    </div>
                </div>
            </aside>

            @* ── Center: View Document + Ask AI ── *@
            <div class="db-center">
                <section class="db-action-card">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                    <div>
                        <h2 class="db-action-title">View Document</h2>
                        <p class="db-action-desc">Read the extracted text content. Supported: PDF, DOCX, PPTX — full text with page markers shown.</p>
                    </div>
                    <button class="db-cta-primary" @onclick="OpenViewDocumentDialogAsync" disabled="@_busy">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                        View Document
                    </button>
                    @if (_doc?.Status != DocumentStatus.Ready)
                    {
                        <p class="db-action-hint">Ingestion must complete before content is available.</p>
                    }
                </section>

                <section class="db-action-card">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 0 0-2.455 2.456ZM16.894 20.567 16 20.25l.894-.317a3.375 3.375 0 0 0 2.04-2.039L19.25 17l.317.894a3.375 3.375 0 0 0 2.04 2.039L22.5 20.25l-.894.317a3.375 3.375 0 0 0-2.04 2.039L19.25 23.5l-.317-.894a3.375 3.375 0 0 0-2.04-2.039Z"/></svg>
                    <div>
                        <h2 class="db-action-title">Ask AI</h2>
                        <p class="db-action-desc">Ask questions scoped to this document via AI chat.</p>
                    </div>
                    <a href="@(_doc.Status == DocumentStatus.Ready ? $"/ai/chat?documentId={_doc.Id}" : "#")" class="db-cta-outline @(_doc.Status != DocumentStatus.Ready ? "disabled" : "")">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
                        OPEN IN WORKSPACE
                    </a>
                </section>

                @* SUSPENDED (D3): Office Viewer replaced by Gotenberg PDF conversion in future sprint.
                @if (IsOfficeViewerSupported(_doc?.MimeType))
                {
                    <section class="db-action-card">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
                        <div>
                            <h2 class="db-action-title">View Original (@OfficeViewerFormatLabel(_doc!.MimeType))</h2>
                            <p class="db-action-desc">Open the original file in Microsoft Office Online Viewer — high-fidelity rendering with native formatting preserved.</p>
                        </div>
                        <button class="db-cta-primary" @onclick="OpenOfficeViewerAsync" disabled="@_busy">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                            Open Viewer
                        </button>
                    </section>
                }
                *@
            </div>

            @* ── Right: Source file + Lifecycle ── *@
            <aside class="db-side">
                <div class="db-side-card">
                    <div class="db-side-head">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        <h2>Source File</h2>
                    </div>
                    <p class="db-side-desc">Signed link, valid for 5 minutes. Open in browser or request a fresh URL.</p>
                    @if (!string.IsNullOrEmpty(_doc.DownloadUrl))
                    {
                        <div class="db-side-btns">
                            <a href="@_doc.DownloadUrl" target="_blank" class="db-btn-primary">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" x2="3" y1="12" y2="12"/></svg>
                                Open File
                            </a>
                            <a href="@_doc.DownloadUrl" target="_blank" class="db-btn-outline">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                                Download
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="db-side-warning">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                            <span>Download link is not available right now. Try refreshing.</span>
                        </div>
                    }
                </div>

                <div class="db-side-card">
                    <h2 class="db-side-heading">Ingestion Lifecycle</h2>
                    <div class="db-lifecycle">
                        @{ var steps = new[] { ("Uploaded", true), ("Processing", IsAtLeastProcessing(_doc.Status)), ("Ready for AI", _doc.Status == DocumentStatus.Ready) }; }
                        @for (int i = 0; i < steps.Length; i++)
                        {
                            var (label, done) = steps[i];
                            <div class="lc-row">
                                <div class="lc-track">
                                    <div class="lc-dot @(done ? "lc-dot-done" : "lc-dot-pending")">
                                        @if (done)
                                        {
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                                        }
                                    </div>
                                    @if (i < steps.Length - 1)
                                    {
                                        <div class="lc-line @(done ? "lc-line-done" : "")"></div>
                                    }
                                </div>
                                <div class="lc-content">
                                    <span class="lc-label @(done ? "lc-label-done" : "")">@label</span>
                                    @if (done)
                                    {
                                        <span class="lc-status">Completed</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                    @if (_doc.Status is DocumentStatus.Ready or DocumentStatus.Failed)
                    {
                        <button class="dh-action-btn" style="margin-top:12px;width:100%" @onclick="ReIngestAsync" disabled="@_busy">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
                            Reprocess
                        </button>
                    }
                </div>
            </aside>
        </div>
    }
</MudStack>

@code {
    [Parameter] public Guid Id { get; set; }

    private bool _busy;
    private string? _error;
    private DocumentDto? _doc;
    private string DisplayStatusText => _doc?.Status.ToString() ?? "";
    private string StatusCssClass => DisplayStatusText.ToLowerInvariant();
    private List<FolderDto> _folders = new();
    private bool _renaming;
    private string _renameValue = string.Empty;
    private ElementReference _renameInput;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated)
        {
            var restored = await AuthPersistence.TryRestoreAsync();
            if (restored is not null)
                Session.Set(restored);
            if (!Session.IsAuthenticated)
            {
                Nav.NavigateTo("/login", replace: true);
                return;
            }
        }
        await LoadFoldersAsync();
        await LoadAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_doc is not null && _doc.Id != Id)
        {
            _doc = null;
            await LoadAsync();
        }
    }

    private async Task LoadFoldersAsync()
    {
        if (string.IsNullOrEmpty(Session.AccessToken)) return;
        try
        {
            _folders = (await FoldersApi.ListAsync(Session.AccessToken!)).ToList();
        }
        catch (DocumentApiException ex)
        {
            Snackbar.Add(MapError(ex), Severity.Warning);
            if (ex.StatusCode == 401)
            {
                Session.Clear();
                Nav.NavigateTo("/login", replace: true);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not load folders: {ex.Message}", Severity.Warning);
        }
    }

    private async Task LoadAsync()
    {
        if (string.IsNullOrEmpty(Session.AccessToken)) return;
        _busy = true;
        _error = null;
        StateHasChanged();
        try
        {
            _doc = await DocumentsApi.GetAsync(Session.AccessToken!, Id);
            _renameValue = _doc.FileName;
        }
        catch (DocumentApiException ex)
        {
            _doc = null;
            _error = MapError(ex);
            if (ex.StatusCode == 401)
            {
                Session.Clear();
                Nav.NavigateTo("/login", replace: true);
            }
        }
        catch (Exception ex)
        {
            _error = $"Network error: {ex.Message}";
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    private void BeginRename()
    {
        _renameValue = _doc?.FileName ?? string.Empty;
        _renaming = true;
    }

    private async Task CommitRename()
    {
        var trimmed = _renameValue?.Trim();
        if (string.IsNullOrEmpty(trimmed) || _doc is null)
        {
            CancelRename();
            return;
        }
        if (string.Equals(trimmed, _doc.FileName, StringComparison.Ordinal))
        {
            _renaming = false;
            return;
        }

        try
        {
            _doc = await DocumentsApi.RenameAsync(Session.AccessToken!, _doc.Id, trimmed);
            Snackbar.Add("Document renamed.", Severity.Success);
            _renaming = false;
        }
        catch (DocumentApiException ex)
        {
            Snackbar.Add(MapError(ex), Severity.Error);
            if (ex.StatusCode == 401)
            {
                Session.Clear();
                Nav.NavigateTo("/login", replace: true);
                return;
            }
            _renameValue = _doc.FileName;
            _renaming = false;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Rename failed: {ex.Message}", Severity.Error);
            _renameValue = _doc.FileName;
            _renaming = false;
        }
        StateHasChanged();
    }

    private void CancelRename()
    {
        _renameValue = _doc?.FileName ?? string.Empty;
        _renaming = false;
        StateHasChanged();
    }

    private async Task HandleRenameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await CommitRename();
        else if (e.Key == "Escape") CancelRename();
    }

    private async Task OpenViewDocumentDialogAsync()
    {
        if (_doc is null || string.IsNullOrEmpty(Session.AccessToken)) return;

        _busy = true;
        StateHasChanged();

        try
        {
            var content = await DocumentsApi.GetContentAsync(Session.AccessToken, _doc.Id);

            var parameters = new DialogParameters
            {
                ["DocumentContent"] = content,
                ["FileName"] = _doc.FileName,
                ["MimeType"] = _doc.MimeType,
                ["PageCount"] = _doc.PageCount,
            };
            var options = new DialogOptions
            {
                CloseOnEscapeKey = true,
                MaxWidth = MaxWidth.Large,
                FullWidth = true,
            };

            await Dialogs.ShowAsync<ViewDocumentDialog>("View Document", parameters, options);
        }
        catch (DocumentApiException ex)
        {
            Snackbar.Add(MapError(ex), Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load content: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    private async Task ConfirmDeleteAsync()
    {
        if (_doc is null) return;
        var parameters = new DialogParameters
        {
            ["Title"] = "Delete document?",
            ["Message"] = $"Delete \"{_doc.FileName}\"? This cannot be undone — chunks and the stored file will be removed.",
            ["ConfirmText"] = "Delete",
            ["ConfirmColor"] = Color.Error,
            ["Icon"] = Icons.Material.Filled.DeleteForever,
            ["IconColor"] = Color.Error,
        };
        var options = new DialogOptions { CloseOnEscapeKey = true };
        var dialogRef = await Dialogs.ShowAsync<AI_Study_Hub_v2.Components.Admin.Shared.ConfirmDialog>("Delete document", parameters, options);
        var result = await dialogRef.Result;
        if (result is null || result.Canceled) return;

        await DeleteAsync();
    }

    private async Task DeleteAsync()
    {
        if (_doc is null || string.IsNullOrEmpty(Session.AccessToken)) return;
        _busy = true;
        StateHasChanged();
        try
        {
            await DocumentsApi.DeleteAsync(Session.AccessToken!, _doc.Id);
            Snackbar.Add($"Deleted \"{_doc.FileName}\".", Severity.Success);
            Nav.NavigateTo("/documents");
        }
        catch (DocumentApiException ex)
        {
            Snackbar.Add(MapError(ex), Severity.Error);
            if (ex.StatusCode == 401)
            {
                Session.Clear();
                Nav.NavigateTo("/login", replace: true);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Network error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    private string FolderName(Guid? folderId)
        => folderId is { } id
            ? _folders.FirstOrDefault(f => f.Id == id)?.Name ?? "Unknown folder"
            : "Loose document";

    private static string MapError(DocumentApiException ex) => ex.StatusCode switch
    {
        401 => "Your session has expired. Please sign in again.",
        403 => "You do not have access to that document.",
        404 => ex.Code == "folder_not_found" ? "Folder not found." : "Document not found — it may have been deleted already.",
        _ => ex.Message,
    };

    private async Task ReIngestAsync()
    {
        if (_doc is null || string.IsNullOrEmpty(Session.AccessToken)) return;
        _busy = true;
        StateHasChanged();
        try
        {
            var result = await DocumentsApi.ReIngestAsync(Session.AccessToken, _doc.Id);
            if (result.Success)
            {
                Snackbar.Add($"Reprocessed — {result.ChunkCount} chunks created.", Severity.Success);
            }
            else
            {
                Snackbar.Add($"Reprocess failed: {result.ErrorMessage}", Severity.Error);
            }
            await LoadAsync();
        }
        catch (DocumentApiException ex)
        {
            Snackbar.Add(MapError(ex), Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Network error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    private async Task OpenOfficeViewerAsync()
