    private Task LoadScopeAsync() => LoadScopeAsync(_appliedQueryFolderId, _appliedQueryDocumentId, _workspaceVersion);

    private async Task LoadScopeAsync(Guid? queryFolderId, Guid? queryDocumentId, int workspaceVersion)
    {
        if (string.IsNullOrEmpty(Session.AccessToken))
        {
            return;
        }

        _scopeCts?.Cancel();
        _scopeCts?.Dispose();
        var scopeCts = _scopeCts = new CancellationTokenSource();
        _loadingScope = true;
        _error = null;
        try
        {
            var documentsTask = DocumentsApi.ListAsync(Session.AccessToken!, ct: scopeCts.Token);
            var foldersTask = FoldersApi.ListAsync(Session.AccessToken!, scopeCts.Token);
            await Task.WhenAll(documentsTask, foldersTask);
            if (!IsCurrentWorkspace(workspaceVersion) || scopeCts.IsCancellationRequested) return;

            _documents = documentsTask.Result.ToList();
            _folders = foldersTask.Result.OrderBy(f => f.Name).ToList();

            if (queryFolderId.HasValue)
            {
                var isPersonalFolder = _folders.Any(f => f.Id == queryFolderId.Value);
                if (!isPersonalFolder)
                {
                    try
                    {
                        var sharedFolder = await FoldersApi.GetAsync(Session.AccessToken!, queryFolderId.Value, scopeCts.Token);
                        if (!IsCurrentWorkspace(workspaceVersion) || scopeCts.IsCancellationRequested) return;

                        if (sharedFolder != null)
                        {
                            var sharedDocs = await DocumentsApi.ListAsync(
                                Session.AccessToken!,
                                new DocumentListQuery { FolderId = queryFolderId.Value },
                                scopeCts.Token);
                            if (!IsCurrentWorkspace(workspaceVersion) || scopeCts.IsCancellationRequested) return;

                            var updatedFolders = _folders.Append(sharedFolder).ToList();
                            var updatedDocuments = sharedDocs.Count > 0
                                ? _documents.Concat(sharedDocs).DistinctBy(d => d.Id).ToList()
                                : _documents;

                            _folders = updatedFolders;
                            _documents = updatedDocuments;
                        }
                    }
                    catch (Exception ex)
                    {
                        if (!IsCurrentWorkspace(workspaceVersion) || scopeCts.IsCancellationRequested) return;
                        _error = $"Could not load shared folder: {ex.Message}";
                    }
                }
            }

            RefreshSubjectFilters();
            ApplyQueryScope(queryFolderId, queryDocumentId);
        }
        catch (DocumentApiException ex)
        {
            if (!IsCurrentWorkspace(workspaceVersion) || scopeCts.IsCancellationRequested) return;
            var message = MapDocumentError(ex);
            _error = message;
            Snackbar.Add(message, Severity.Warning);
            if (ex.StatusCode == 401)
            {
                Session.Clear();
                Nav.NavigateTo("/login", replace: true);
            }
        }
        catch (Exception ex)
        {
            if (!IsCurrentWorkspace(workspaceVersion) || scopeCts.IsCancellationRequested) return;
            _error = $"Could not load chat scope: {ex.Message}";
        }
        finally
        {
            if (IsCurrentWorkspace(workspaceVersion) && !scopeCts.IsCancellationRequested)
            {
                _loadingScope = false;
                StateHasChanged();
            }
        }

        if (IsCurrentWorkspace(workspaceVersion) && !scopeCts.IsCancellationRequested)
        {
            _ = LoadSessionsAsync(workspaceVersion);
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey && !_busy && !string.IsNullOrWhiteSpace(_question) && ScopeDocuments.Count > 0)
        {
            await AskAsync();
        }
    }

    private async Task AskAsync()
    {
        if (_disposed || _busy)
        {
            return;
        }

        var workspaceVersion = _workspaceVersion;
        _composerError = null;
        _error = null;

        if (!Session.IsAuthenticated || string.IsNullOrWhiteSpace(Session.AccessToken))
        {
            Nav.NavigateTo("/login", replace: true);
            return;
        }

        if (_chatApi is null)
        {
            _error = "AI chat client is not available.";
            return;
        }

        var question = _question?.Trim();
        if (string.IsNullOrWhiteSpace(question))
        {
            _composerError = "Enter a question before asking AI.";
            return;
        }

        if (ScopeDocuments.Count == 0)
        {
            _error = _folderId.HasValue
                ? "No indexed documents are available in this folder yet."
                : "No indexed documents are available for chat yet.";
            return;
        }

        var folderId = _folderId;
        var documentIds = SelectedDocumentIdsForRequest;
        var scopeLabel = BuildScopeLabel();
        _askCts?.Cancel();
        _askCts?.Dispose();
        var askCts = _askCts = new CancellationTokenSource(TimeSpan.FromMinutes(2));
        _busy = true;
        var askedAt = DateTimeOffset.Now;
        try
        {
            // A duplicate send is blocked before this cancellable creation await.
            if (_currentSessionId is null)
            {
                var session = await _chatApi.CreateSessionAsync(Session.AccessToken!, new CreateChatSessionRequest
                {
                    FolderId = folderId,
                    Model = _selectedModel,
                    TopK = Math.Clamp(_topK, 1, 10),
                }, askCts.Token);
                if (!IsCurrentWorkspace(workspaceVersion)) return;
                _currentSessionId = session.Id;
                _sessions.Insert(0, session);
            }

            var request = new AiChatAskRequest(
                question,
                DocumentId: null,
                FolderId: folderId,
                SubjectCode: _quizSubjectCode,
                Semester: _quizSemester,
                TopK: Math.Clamp(_topK, 1, 10),
                DocumentIds: documentIds,
                Model: _selectedModel,
                SessionId: _currentSessionId);
            var response = await _chatApi.AskAsync(Session.AccessToken!, request, askCts.Token);
            if (!IsCurrentWorkspace(workspaceVersion)) return;
            ChatSession.Add(new AiChatHistoryExchange(question, scopeLabel, response, askedAt));
            _question = string.Empty;
            Snackbar.Add("AI answer ready.", Severity.Success);
        }
        catch (OperationCanceledException)
        {
            if (!IsCurrentWorkspace(workspaceVersion)) return;
            _error = "The AI request timed out. Try again with a narrower scope.";
        }
        catch (AiChatApiException ex)
        {
            if (!IsCurrentWorkspace(workspaceVersion)) return;
            _error = MapChatError(ex);
            if (ex.StatusCode == 401)
            {
                Session.Clear();
                Nav.NavigateTo("/login", replace: true);
            }
        }
        catch (Exception ex)
        {
            if (!IsCurrentWorkspace(workspaceVersion)) return;
            _error = $"Network error while asking AI: {ex.Message}";
        }
        finally
        {
            if (IsCurrentWorkspace(workspaceVersion) && ReferenceEquals(_askCts, askCts))
            {
                _busy = false;
                _askCts.Dispose();
                _askCts = null;
                StateHasChanged();
            }
        }
    }

    private void ClearHistory()
    {
        ChatSession.Clear();
        _copiedIndexes.Clear();
        _error = null;
        _currentSessionId = null;
        _resumeQuiz = null;
        _sessions.Clear();
        StateHasChanged();
    }

    private async Task CopyAnswerAsync(string text, int index)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
            _copiedIndexes.Add(index);
            StateHasChanged();
            await Task.Delay(2000);
            _copiedIndexes.Remove(index);
            StateHasChanged();
        }
        catch { /* clipboard not available */ }
    }

