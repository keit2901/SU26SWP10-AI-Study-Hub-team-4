@page "/ai/chat"
@using AI_Study_Hub_v2.Data.Entities
@implements IDisposable
@inject AuthSessionState Session
@inject DocumentApiClient DocumentsApi
@inject FolderApiClient FoldersApi
@inject IHttpClientFactory HttpClientFactory
@inject IServiceProvider Services
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject AiChatSessionState ChatSession

<PageTitle>AI Chat - AI Study Hub v2</PageTitle>

<MudStack Spacing="0" Class="ai-chat-shell workspace-shell teammate-workspace-shell">
    @if (!Session.IsAuthenticated)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
            Sign in to ask questions about your documents.
        </MudAlert>
    }
    else if (_loadingScope)
    {
        <MudPaper Class="pa-5" Elevation="0" Outlined="true">
            <MudStack Spacing="2">
                <MudSkeleton Height="44px" Animation="Animation.Wave" />
                <MudSkeleton Height="120px" Animation="Animation.Wave" />
                <MudSkeleton Height="220px" Animation="Animation.Wave" />
            </MudStack>
        </MudPaper>
    }
    else
    {
        <div class="ai-chat-grid" role="region" aria-label="AI chat workspace">
            <section class="ai-chat-column ai-chat-column-left">
                <aside class="ai-chat-left-rail">
                    <section class="workspace-folder-head">
                        <div class="workspace-folder-title-row">
                            <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Small" />
                            <h2>@FolderTitle</h2>
                        </div>
                        <p>@ScopeDocuments.Count files · <span>@ActiveContextCount active context</span></p>
                    </section>

                    <div class="workspace-column-labels" aria-hidden="true">
                        <span>✓</span>
                        <span>Document</span>
                    </div>

                    <div class="workspace-document-list">
                        @foreach (var document in ScopeDocuments)
                        {
                            var active = IsDocumentSelected(document.Id);
                            <button type="button"
                                    class="@($"workspace-document-card {(active ? "is-active" : string.Empty)}")"
                                    disabled="@_busy"
                                    title="@document.FileName"
                                    @onclick="() => ToggleDocumentSelection(document.Id)">
                                <span class="workspace-doc-check">@if (active) { <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" /> }</span>
                                <span class="@($"workspace-doc-ext ext-{DocumentExtension(document)}")">@DocumentExtension(document)</span>
                                <span class="workspace-doc-meta">
                                    <strong>@ShortFileName(document.FileName, 28)</strong>
                                    <small>@DocumentDetailLine(document)</small>
                                </span>
                            </button>
                        }

                        @if (ScopeDocuments.Count == 0)
                        {
                            <div class="workspace-empty-docs">
                                <MudIcon Icon="@Icons.Material.Filled.LibraryBooks" />
                                <strong>No indexed files yet</strong>
                                <span>Upload a document or wait for ingestion before asking AI.</span>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.UploadFile" Href="/documents/upload">
                                    Upload document
                                </MudButton>
                            </div>
                        }
                    </div>

                    <section class="workspace-scope-drawer">
                        <div class="workspace-selected-summary">
                            <span>Selected context</span>
                            <strong>@SelectedContextLabel</strong>
                            <small>Tick any files in this folder to choose what RAG can search.</small>
                        </div>

                        <MudSelect T="int"
                                   Label="Sources to retrieve"
                                   @bind-Value="_topK"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Disabled="_busy">
                            <MudSelectItem T="int" Value="3">3 sources</MudSelectItem>
                            <MudSelectItem T="int" Value="5">5 sources</MudSelectItem>
                            <MudSelectItem T="int" Value="8">8 sources</MudSelectItem>
                            <MudSelectItem T="int" Value="10">10 sources</MudSelectItem>
                        </MudSelect>
                    </section>

                    <footer class="workspace-left-footer">
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" />
                        <span>@ActiveContextCount active context</span>
                    </footer>
                </aside>
            </section>

            <section class="ai-chat-column ai-chat-column-center">
                <main class="ai-chat-center-stage">
                    <section class="workspace-chat-header">
                        <div>
                            <p>AI Assistant</p>
                            <h1>Chat with your documents</h1>
                            <span>Ask questions directly from checked context with source-backed citations.</span>
                        </div>
                        <MudButton Variant="Variant.Text"
                                   Class="workspace-refresh-button"
                                   StartIcon="@Icons.Material.Filled.Refresh"
                                   OnClick="LoadScopeAsync"
                                   Disabled="_busy || _loadingScope">
                            Refresh
                        </MudButton>
                    </section>

                    <section class="workspace-message-scroll" aria-live="polite">
                        <div class="ai-chat-message ai-chat-message-assistant">
                            <div class="ai-chat-message-avatar"><MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Small" /></div>
                            <div class="ai-chat-message-content">
                                <div class="ai-chat-message-bubble">
                                    I can read your indexed documents, compare concepts, draft exam prep, and return citations for every grounded answer.
                                </div>
                                <div class="workspace-citation-pills">
                                    <span>@ScopeSummary</span>
                                    <span>@_topK source retrieval</span>
                                </div>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_error))
                        {
                            <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="workspace-error-alert">
                                @_error
                            </MudAlert>
                        }

                        @if (!_busy && ChatSession.History.Count == 0 && string.IsNullOrWhiteSpace(_error))
                        {
                            <div class="workspace-empty-state">
                                <div class="workspace-empty-icon"><MudIcon Icon="@Icons.Material.Filled.AutoAwesome" /></div>
                                <strong>Ready when your notes are indexed</strong>
                                <span>Select one or more files on the left, then ask a question. If nothing is selected, the current folder scope is used.</span>
                                <div class="workspace-suggestion-row">
                                    @foreach (var prompt in SuggestedPrompts)
                                    {
                                        <button type="button" @onclick="() => UsePrompt(prompt)" disabled="@_busy">
                                            @prompt
                                        </button>
                                    }
                                </div>
                            </div>
                        }

                        @foreach (var exchange in ChatSession.History)
                        {
                            @RenderExchange(exchange, false)
                        }

                        @if (_busy)
                        {
                            <div class="ai-chat-message ai-chat-message-assistant">
                                <div class="ai-chat-message-avatar"><MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Small" /></div>
                                <div class="ai-chat-typing-bubble" aria-label="AI is thinking">
                                    <span></span><span></span><span></span>
                                </div>
                            </div>
                        }
                    </section>

                    <section class="workspace-composer-panel">
                        <div class="workspace-composer-box">
                            <MudButton Variant="Variant.Text"
                                       Href="/documents/upload"
                                       Class="workspace-attach-button"
                                       Disabled="_busy"
                                       aria-label="Upload file">
                                <MudIcon Icon="@Icons.Material.Filled.AttachFile" />
                            </MudButton>
                            <MudTextField T="string"
                                          @bind-Value="_question"
                                          Variant="Variant.Text"
                                          Placeholder="Ask AI assistant..."
                                          Lines="1"
                                          Clearable="true"
                                          Disabled="_busy"
                                          Error="@(!string.IsNullOrWhiteSpace(_composerError))"
                                          ErrorText="@_composerError"
                                          Class="workspace-question-input" />
                            <MudButton Variant="Variant.Filled"
                                       Class="workspace-send-button"
                                       StartIcon="@Icons.Material.Filled.Send"
                                       OnClick="AskAsync"
                                       Disabled="_busy || ScopeDocuments.Count == 0 || string.IsNullOrWhiteSpace(_question)">
                                @if (_busy)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                }
                                else
                                {
                                    <span>Send</span>
                                }
                            </MudButton>
                        </div>
                        <p class="workspace-composer-note">Answers depend on extracted chunks and may be incomplete.</p>
                    </section>
                </main>
            </section>

            <section class="ai-chat-column ai-chat-column-right">
                <aside class="ai-chat-right-rail">
                    <section class="workspace-smart-actions">
                        <div class="workspace-panel-heading">
                            <span>Smart Actions</span>
                            <small>Generate study assets</small>
                        </div>

                        <button type="button" class="workspace-tool-card tool-summary" @onclick="UseSummaryPrompt" disabled="@_busy">
                            <span class="workspace-tool-icon"><MudIcon Icon="@Icons.Material.Filled.MenuBook" /></span>
                            <span><strong>Create Summary</strong><small>Auto-generate a structured summary from your checked documents.</small></span>
                        </button>

                        <button type="button" class="workspace-tool-card tool-exam" @onclick="UseQuizPrompt" disabled="@_busy">
                            <span class="workspace-tool-icon"><MudIcon Icon="@Icons.Material.Filled.AssignmentTurnedIn" /></span>
                            <span><strong>Generate Quiz</strong><small>Create multiple-choice questions with answer options and an answer key.</small></span>
                        </button>
                    </section>

                    <section class="workspace-active-context">
                        <div class="workspace-panel-heading">
                            <span>Active Context</span>
                            <small>@ActiveContextCount selected · @_topK source depth</small>
                        </div>

                        <div class="workspace-context-preview">
                            @foreach (var document in ActiveContextDocuments.Take(3))
                            {
                                <div class="workspace-context-file" title="@document.FileName">
                                    <span class="@($"workspace-doc-ext ext-{DocumentExtension(document)}")">@DocumentExtension(document)</span>
                                    <strong>@ShortFileName(document.FileName, 25)</strong>
                                </div>
                            }

                            @if (!ActiveContextDocuments.Any())
                            {
                                <div class="workspace-context-empty">All indexed files are available until you pin one document.</div>
                            }
                        </div>

                        <div class="ai-chat-context-row"><span>Scope</span><strong>@ScopeSummary</strong></div>
                        <div class="ai-chat-context-row"><span>Indexed files</span><strong>@ScopeDocuments.Count</strong></div>
                        <div class="ai-chat-context-row"><span>Folders</span><strong>@_folders.Count</strong></div>
                        <div class="ai-chat-context-row"><span>Retrieval depth</span><strong>@_topK sources</strong></div>
                    </section>
                </aside>
            </section>
        </div>
    }
</MudStack>

@code {
    [SupplyParameterFromQuery(Name = "documentId")]
    public Guid? QueryDocumentId { get; set; }

    [SupplyParameterFromQuery(Name = "folderId")]
    public Guid? QueryFolderId { get; set; }

    private static readonly string[] SuggestedPrompts =
    {
        "Summarize the key ideas from my selected files.",
        "Explain this topic as if I am preparing for an exam.",
        "Generate multiple-choice quiz questions with A-D options and answer keys.",
    };

    private AiChatApiClient? _chatApi;
    private CancellationTokenSource? _askCts;
    private bool _busy;
    private bool _loadingScope;
    private string? _error;
    private string? _composerError;
    private string? _question;
    private Guid? _folderId;
    private int _topK = 5;
    private List<DocumentDto> _documents = new();
    private List<FolderDto> _folders = new();
    private readonly HashSet<Guid> _selectedDocumentIds = new();

    private List<DocumentDto> ReadyDocuments => _documents
        .Where(d => d.Status == DocumentStatus.Ready)
        .OrderByDescending(d => d.UpdatedAt)
        .ToList();

    private List<DocumentDto> ScopeDocuments => ReadyDocuments
        .Where(d => !_folderId.HasValue || d.FolderId == _folderId.Value)
        .ToList();

    private IReadOnlyList<DocumentDto> ActiveContextDocuments
    {
        get
        {
            var scopedDocuments = ScopeDocuments;
            var selected = scopedDocuments.Where(d => _selectedDocumentIds.Contains(d.Id)).ToList();
            return selected.Count > 0 ? selected : scopedDocuments;
        }
    }

    private int ActiveContextCount => ActiveContextDocuments.Count;

    private IReadOnlyList<Guid>? SelectedDocumentIdsForRequest
    {
        get
        {
            var selected = ScopeDocuments
                .Where(d => _selectedDocumentIds.Contains(d.Id))
                .Select(d => d.Id)
                .Distinct()
                .ToArray();
            return selected.Length == 0 ? null : selected;
        }
    }

    private string SelectedContextLabel => _selectedDocumentIds.Count == 0
        ? $"All files in {FolderTitle}"
        : $"{ActiveContextCount} selected file{(ActiveContextCount == 1 ? string.Empty : "s")}";

    private string FolderTitle => _folderId is { } folderId
        ? _folders.FirstOrDefault(f => f.Id == folderId)?.Name ?? "Selected folder"
        : "All Study Documents";

    private string ScopeSummary => _folderId.HasValue
        ? FolderTitle
        : "All indexed documents";

    private bool IsDocumentSelected(Guid documentId) => _selectedDocumentIds.Contains(documentId);

    private void ToggleDocumentSelection(Guid documentId)
    {
        if (!_selectedDocumentIds.Add(documentId))
        {
            _selectedDocumentIds.Remove(documentId);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _chatApi = ResolveChatApiClient();

        if (!Session.IsAuthenticated)
        {
            Nav.NavigateTo("/login", replace: true);
            return;
        }

        await LoadScopeAsync();
    }

    private async Task LoadScopeAsync()
    {
        if (string.IsNullOrEmpty(Session.AccessToken))
        {
            return;
        }

        _loadingScope = true;
        _error = null;
        try
        {
            var documentsTask = DocumentsApi.ListAsync(Session.AccessToken!);
            var foldersTask = FoldersApi.ListAsync(Session.AccessToken!);
            await Task.WhenAll(documentsTask, foldersTask);

            _documents = documentsTask.Result.ToList();
            _folders = foldersTask.Result.OrderBy(f => f.Name).ToList();
            ApplyQueryScope();
        }
        catch (DocumentApiException ex)
        {
            var message = MapDocumentError(ex);
            _error = message;
            Snackbar.Add(message, Severity.Warning);
            if (ex.StatusCode == 401)
            {
                Session.Clear();
                Nav.NavigateTo("/login", replace: true);
            }
        }
        catch (Exception ex)
        {
            _error = $"Could not load chat scope: {ex.Message}";
        }
        finally
        {
            _loadingScope = false;
            StateHasChanged();
        }
    }

    private async Task AskAsync()
    {
        _composerError = null;
        _error = null;

        if (!Session.IsAuthenticated || string.IsNullOrWhiteSpace(Session.AccessToken))
        {
            Nav.NavigateTo("/login", replace: true);
            return;
        }

        if (_chatApi is null)
        {
            _error = "AI chat client is not available.";
            return;
        }

        var question = _question?.Trim();
        if (string.IsNullOrWhiteSpace(question))
        {
            _composerError = "Enter a question before asking AI.";
            return;
        }

        if (ScopeDocuments.Count == 0)
        {
            _error = _folderId.HasValue
                ? "No indexed documents are available in this folder yet."
                : "No indexed documents are available for chat yet.";
            return;
        }

        var request = new AiChatAskRequest(
            question,
            DocumentId: null,
            FolderId: _folderId,
            SubjectCode: null,
            Semester: null,
            TopK: Math.Clamp(_topK, 1, 10),
            DocumentIds: SelectedDocumentIdsForRequest);

        _askCts?.Cancel();
        _askCts?.Dispose();
        _askCts = new CancellationTokenSource(TimeSpan.FromMinutes(2));

        _busy = true;
        var askedAt = DateTimeOffset.Now;
        try
        {
            var response = await _chatApi.AskAsync(Session.AccessToken!, request, _askCts.Token);
            ChatSession.Add(new AiChatHistoryExchange(question, BuildScopeLabel(), response, askedAt));
            _question = string.Empty;
            Snackbar.Add("AI answer ready.", Severity.Success);
        }
        catch (OperationCanceledException)
        {
            _error = "The AI request timed out. Try again with a narrower scope.";
        }
        catch (AiChatApiException ex)
        {
            _error = MapChatError(ex);
            if (ex.StatusCode == 401)
            {
                Session.Clear();
                Nav.NavigateTo("/login", replace: true);
            }
        }
        catch (Exception ex)
        {
            _error = $"Network error while asking AI: {ex.Message}";
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    private RenderFragment RenderExchange(AiChatHistoryExchange exchange, bool featured) => @<div class="@(featured ? "workspace-exchange" : "workspace-exchange workspace-exchange-compact")">
        <div class="ai-chat-message ai-chat-message-user">
            <div class="ai-chat-message-content">
                <div class="ai-chat-message-bubble">@exchange.Question</div>
                <div class="workspace-message-meta">@exchange.ScopeLabel · @exchange.AskedAt.ToString("HH:mm")</div>
            </div>
        </div>

        <div class="ai-chat-message ai-chat-message-assistant">
            <div class="ai-chat-message-avatar"><MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Small" /></div>
            <div class="ai-chat-message-content">
                @if (!string.IsNullOrWhiteSpace(exchange.Response.RefusalReason))
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">
                        @exchange.Response.RefusalReason
                    </MudAlert>
                }

                <div class="ai-chat-message-bubble">
                    @((MarkupString)FormatAnswerMarkup(exchange.Response.Answer))
                </div>

                <div class="workspace-citation-pills">
                    <span>@SourceCountText(exchange.Response.Sources)</span>
                    @if (exchange.Response.DurationMs is { } duration)
                    {
                        <span>@duration ms</span>
                    }
                    @if (exchange.Response.Sources is not null)
                    {
                        @foreach (var source in exchange.Response.Sources.Take(3).Select((value, index) => new { value, index }))
                        {
                            <span>@SourceLabel(source.value, source.index)</span>
                        }
                    }
                </div>

                @if (exchange.Response.Sources is null || exchange.Response.Sources.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="workspace-no-source-alert">
                        No source citations were returned for this answer.
                    </MudAlert>
                }
                else
                {
                    <div class="workspace-source-grid">
                        @foreach (var source in exchange.Response.Sources.Select((value, index) => new { value, index }))
                        {
                            <article class="ai-chat-source-card">
                                <header>
                                    <span>@SourceLabel(source.value, source.index)</span>
                                    <MudLink Href="@($"/documents/{source.value.DocumentId}")" Typo="Typo.caption">Open</MudLink>
                                </header>
                                <strong title="@source.value.FileName">@ShortFileName(source.value.FileName, 30)</strong>
                                <div class="workspace-source-meta">
                                    @if (source.value.PageNumber is { } pageNumber)
                                    {
                                        <span>Page @pageNumber</span>
                                    }
                                    <span>Chunk @source.value.ChunkIndex</span>
                                    @if (source.value.Score is { } score)
                                    {
                                        <span>Score @score.ToString("0.###")</span>
                                    }
                                </div>
                                <p>@source.value.Excerpt</p>
                            </article>
                        }
                    </div>
                }
            </div>
        </div>
    </div>;

    private AiChatApiClient ResolveChatApiClient()
    {
        if (Services.GetService(typeof(AiChatApiClient)) is AiChatApiClient registeredClient)
        {
            return registeredClient;
        }

        var http = HttpClientFactory.CreateClient();
        http.BaseAddress ??= new Uri(Nav.BaseUri);
        http.Timeout = TimeSpan.FromMinutes(2);
        return new AiChatApiClient(http);
    }

    private void ApplyQueryScope()
    {
        _selectedDocumentIds.RemoveWhere(id => ReadyDocuments.All(d => d.Id != id));

        if (QueryDocumentId is { } documentId)
        {
            var document = ReadyDocuments.FirstOrDefault(d => d.Id == documentId);
            if (document is not null)
            {
                _folderId = document.FolderId;
                _selectedDocumentIds.Clear();
                _selectedDocumentIds.Add(document.Id);
                return;
            }
        }

        if (QueryFolderId is { } folderId && _folders.Any(f => f.Id == folderId))
        {
            _folderId = folderId;
            _selectedDocumentIds.RemoveWhere(id => ScopeDocuments.All(d => d.Id != id));
        }
    }

    private void UsePrompt(string prompt)
    {
        _question = prompt;
        _composerError = null;
    }

    private void UseQuizPrompt()
        => UsePrompt("Generate 8 multiple-choice quiz questions from my selected context. Each question must have A-D answer choices, mark the correct option, include a short explanation, and cite the source for each answer.");

    private void UseSummaryPrompt()
        => UsePrompt("Create an auto summary for my selected context with key concepts, exam tips, and citations for the most important points.");

    private static string DocumentExtension(DocumentDto document)
    {
        var extension = Path.GetExtension(document.FileName).TrimStart('.').ToLowerInvariant();
        return string.IsNullOrWhiteSpace(extension) ? "file" : extension;
    }

    private static string DocumentDetailLine(DocumentDto document)
    {
        var pages = document.PageCount is { } pageCount && pageCount > 0 ? $"{pageCount} pages" : "Indexed";
        return $"{pages} · {FormatFileSize(document.FileSizeBytes)} · {document.UpdatedAt:MMM d}";
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes <= 0)
        {
            return "—";
        }

        string[] units = ["B", "KB", "MB", "GB"];
        var size = (double)bytes;
        var unit = 0;
        while (size >= 1024 && unit < units.Length - 1)
        {
            size /= 1024;
            unit++;
        }

        return unit == 0 ? $"{bytes} B" : $"{size:0.#} {units[unit]}";
    }

    private static string ShortFileName(string fileName, int maxLength = 34)
    {
        if (string.IsNullOrWhiteSpace(fileName) || fileName.Length <= maxLength)
        {
            return fileName;
        }

        var extension = Path.GetExtension(fileName);
        var nameWithoutExtension = Path.GetFileNameWithoutExtension(fileName);
        var reserved = string.IsNullOrEmpty(extension) ? 1 : extension.Length + 1;
        var available = Math.Max(8, maxLength - reserved);
        var prefix = nameWithoutExtension.Length <= available
            ? nameWithoutExtension
            : nameWithoutExtension[..available];
        return $"{prefix}…{extension}";
    }

    private string BuildScopeLabel()
    {
        var selectedCount = SelectedDocumentIdsForRequest?.Count ?? 0;
        var scope = _folderId is { } folderId
            ? $"Folder: {_folders.FirstOrDefault(f => f.Id == folderId)?.Name ?? "Unknown folder"}"
            : "All indexed documents";

        return selectedCount > 0
            ? $"{scope} | {selectedCount} selected file{(selectedCount == 1 ? string.Empty : "s")}"
            : scope;
    }


    private static string SourceLabel(AiChatSourceDto source, int index)
        => string.IsNullOrWhiteSpace(source.Label) ? $"S{index + 1}" : source.Label;

    private static string SourceCountText(IReadOnlyList<AiChatSourceDto>? sources)
    {
        var count = sources?.Count ?? 0;
        return $"{count} source{(count == 1 ? string.Empty : "s")}";
    }

    private static string FormatAnswerMarkup(string answer)
    {
        var encoded = System.Net.WebUtility.HtmlEncode(answer ?? string.Empty);
        encoded = System.Text.RegularExpressions.Regex.Replace(
            encoded,
            @"\*\*(.+?)\*\*",
            "<strong>$1</strong>",
            System.Text.RegularExpressions.RegexOptions.Singleline);
        return encoded.Replace("\r\n", "<br />").Replace("\n", "<br />");
    }

    private static string MapDocumentError(DocumentApiException ex) => ex.StatusCode switch
    {
        401 => "Your session has expired. Please sign in again.",
        403 => "You do not have access to these documents.",
        _ => ex.Message,
    };

    private static string MapChatError(AiChatApiException ex) => ex.StatusCode switch
    {
        400 => ex.Message,
        401 => "Your session has expired. Please sign in again.",
        403 => "You do not have permission to use AI chat.",
        404 => "The AI chat endpoint is not available yet. Merge the Sprint 2 chat API before browser smoke.",
        408 => "The AI request timed out. Try again with fewer sources or a narrower scope.",
        429 => "The AI provider is rate limited right now. Wait a moment and try again.",
        500 or 502 or 503 => $"AI service error: {ex.Message}",
        _ => ex.Message,
    };

    public void Dispose()
    {
        _askCts?.Cancel();
        _askCts?.Dispose();
    }
}
