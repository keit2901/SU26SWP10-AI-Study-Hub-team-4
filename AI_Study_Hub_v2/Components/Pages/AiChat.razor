    private AiChatApiClient ResolveChatApiClient()
    {
        if (Services.GetService(typeof(AiChatApiClient)) is AiChatApiClient registeredClient)
        {
            return registeredClient;
        }

        var http = HttpClientFactory.CreateClient();
        http.BaseAddress ??= new Uri(Nav.BaseUri);
        http.Timeout = TimeSpan.FromMinutes(2);
        return new AiChatApiClient(http);
    }

    private void SelectAllScopeDocuments()
    {
        _selectedDocumentIds.Clear();
        foreach (var doc in ScopeDocuments)
        {
            _selectedDocumentIds.Add(doc.Id);
        }
    }

    private void ApplyQueryScope(Guid? queryFolderId, Guid? queryDocumentId)
    {
        _folderId = null;
        _workspaceFolderIdStr = string.Empty;
        if (queryDocumentId is { } documentId)
        {
            var document = ReadyDocuments.FirstOrDefault(d => d.Id == documentId);
            if (document is not null)
            {
                _folderId = document.FolderId;
                _workspaceFolderIdStr = _folderId?.ToString() ?? "";
                _selectedDocumentIds.Clear();
                _selectedDocumentIds.Add(document.Id);
                return;
            }
        }

        if (queryFolderId is { } folderId && _folders.Any(f => f.Id == folderId))
        {
            _folderId = folderId;
            _workspaceFolderIdStr = folderId.ToString();
        }

        SelectAllScopeDocuments();
    }

    private void OnWorkspaceFolderChanged()
    {
        if (string.IsNullOrEmpty(_workspaceFolderIdStr))
        {
            _folderId = null;
        }
        else if (Guid.TryParse(_workspaceFolderIdStr, out var parsed))
        {
            _folderId = parsed;
        }

        InvalidateWorkspace();
        _expectedFolderId = _folderId;
        StateHasChanged();

        SelectAllScopeDocuments();
        _ = LoadSessionsAsync(_workspaceVersion);
    }

    private void InvalidateWorkspace()
    {
        _workspaceVersion++;
        _sessionLoadVersion++;
        _scopeCts?.Cancel();
        _askCts?.Cancel();
        _quizCts?.Cancel();
        _loadingScope = false;
        _busy = false;
        _generatingQuiz = false;
        _currentSessionId = null;
        _expectedFolderId = null;
        _sessions.Clear();
        _selectedDocumentIds.Clear();
        _copiedIndexes.Clear();
        _quizCache.Clear();
        _resumeQuiz = null;
        _question = null;
        _error = null;
        _composerError = null;
        ChatSession.Clear();
    }

    private bool IsCurrentWorkspace(int workspaceVersion)
        => !_disposed && workspaceVersion == _workspaceVersion;

    private void ClearSessionBoundVisibleState()
    {
        _sessions.Clear();
        _currentSessionId = null;
        _resumeQuiz = null;
        _quizCache.Clear();
        _copiedIndexes.Clear();
        ChatSession.Clear();
    }

    private void UsePrompt(string prompt)
    {
        _question = prompt;
        _composerError = null;
    }

    private async Task GenerateQuizAsync()
    {
        if (_disposed || _generatingQuiz || string.IsNullOrWhiteSpace(Session.AccessToken) || _chatApi is null)
        {
            return;
        }

        var workspaceVersion = _workspaceVersion;
        var folderId = _folderId;
        var documentIds = SelectedDocumentIdsForRequest;
        var scopeLabel = BuildScopeLabel();
        _quizCts?.Cancel();
        _quizCts?.Dispose();
        var quizCts = _quizCts = new CancellationTokenSource(TimeSpan.FromMinutes(2));
        _generatingQuiz = true;
        _error = null;
        try
        {
            if ((documentIds is null || documentIds.Count == 0) && !folderId.HasValue)
            {
                Snackbar.Add("Select at least one document or folder to generate a quiz.", Severity.Warning);
                return;
            }

            if (_currentSessionId is null)
            {
                var createRequest = new CreateChatSessionRequest
                {
                    FolderId = folderId,
                    Model = _selectedModel,
                    TopK = _topK,
                };
                var session = await _chatApi.CreateSessionAsync(Session.AccessToken!, createRequest, quizCts.Token);
                if (!IsCurrentWorkspace(workspaceVersion)) return;
                _currentSessionId = session.Id;
                _sessions.Insert(0, session);
            }

            var quizRequest = new GenerateQuizRequest(
                SessionId: _currentSessionId!.Value,
                DocumentIds: documentIds,
                FolderId: folderId,
                Title: $"Quiz: {FolderTitle}",
                Count: 8,
                Difficulty: "medium",
                Model: _selectedModel,
                ScopeLabel: scopeLabel,
                SubjectCode: _quizSubjectCode,
                Semester: _quizSemester);

            var quiz = await _chatApi.GenerateQuizAsync(Session.AccessToken!, quizRequest, quizCts.Token);
            if (!IsCurrentWorkspace(workspaceVersion)) return;

            var exchange = new AiChatHistoryExchange(
                $"Generate quiz: {quiz.Title}",
                scopeLabel,
                new AiChatAnswerResponse(string.Empty, Array.Empty<AiChatSourceDto>()),
                DateTimeOffset.Now,
                Quiz: quiz);

            ChatSession.Add(exchange);

            await OpenQuizDialogAsync(quiz, workspaceVersion);
            if (!IsCurrentWorkspace(workspaceVersion)) return;
            Snackbar.Add($"Quiz \"{quiz.Title}\" generated with {quiz.TotalQuestions} questions.", Severity.Success);
        }
        catch (OperationCanceledException)
        {
            if (!IsCurrentWorkspace(workspaceVersion)) return;
            Snackbar.Add("Quiz generation cancelled.", Severity.Info);
        }
        catch (AiChatApiException ex)
        {
            if (!IsCurrentWorkspace(workspaceVersion)) return;
            var errorQuiz = new QuizDto(
                Guid.NewGuid(),
                $"Quiz: {FolderTitle}",
                QuizStatus.GeneratingFailed,
                0, 0,
                Array.Empty<QuizQuestionDto>(),
                new Dictionary<int, string?>(),
                new Dictionary<int, bool>(),
                null,
                default,
                ErrorMessage: MapChatError(ex));

            var exchange = new AiChatHistoryExchange(
                "Generate quiz",
                scopeLabel,
                new AiChatAnswerResponse(string.Empty, Array.Empty<AiChatSourceDto>()),
                DateTimeOffset.Now,
                Quiz: errorQuiz);

            ChatSession.Add(exchange);
            _error = MapChatError(ex);
        }
        catch (Exception ex)
        {
            if (!IsCurrentWorkspace(workspaceVersion)) return;
            var errorQuiz = new QuizDto(
                Guid.NewGuid(),
                $"Quiz: {FolderTitle}",
                QuizStatus.GeneratingFailed,
                0, 0,
                Array.Empty<QuizQuestionDto>(),
                new Dictionary<int, string?>(),
                new Dictionary<int, bool>(),
                null,
                default,
                ErrorMessage: $"Failed to generate quiz: {ex.Message}");

            var exchange = new AiChatHistoryExchange(
                "Generate quiz",
                scopeLabel,
                new AiChatAnswerResponse(string.Empty, Array.Empty<AiChatSourceDto>()),
                DateTimeOffset.Now,
                Quiz: errorQuiz);

            ChatSession.Add(exchange);
            _error = $"Failed to generate quiz: {ex.Message}";
        }
        finally
        {
            if (IsCurrentWorkspace(workspaceVersion) && ReferenceEquals(_quizCts, quizCts))
            {
                _generatingQuiz = false;
                _quizCts.Dispose();
                _quizCts = null;
                StateHasChanged();
            }
        }
    }

    private async Task OpenQuizDialogAsync(QuizDto quiz, int? workspaceVersion = null)
    {
        if (_quizCache.TryGetValue(quiz.Id, out var cached))
        {
            quiz = cached;
        }

        // Always fetch the full quiz from the API for the current DB status
        if (!string.IsNullOrWhiteSpace(Session.AccessToken) && _chatApi is not null)
        {
            try
            {
                var full = await _chatApi.GetQuizAsync(Session.AccessToken, quiz.Id);
                if (_disposed || (workspaceVersion.HasValue && workspaceVersion.Value != _workspaceVersion)) return;
                if (full is not null)
                {
                    quiz = full;
                    _quizCache[quiz.Id] = full;
                    ChatSession.UpdateExchangeQuiz(quiz.Id, full);
                    if (!_disposed) StateHasChanged();
                }
            }
            catch
            {
                // Best-effort — fall back to cached QuizDto
            }
        }

        if (_disposed || (workspaceVersion.HasValue && workspaceVersion.Value != _workspaceVersion)) return;

        var parameters = new DialogParameters<QuizDialog>
        {
            { d => d.Quiz, quiz },
            { d => d.OnQuizUpdated, EventCallback.Factory.Create<QuizDto>(this, OnQuizUpdatedAsync) },
            { d => d.OnQuizCompleted, EventCallback.Factory.Create<QuizDto>(this, OnQuizCompletedAsync) },
        };

        var dialog = await DialogService.ShowAsync<QuizDialog>("", parameters);
        await dialog.Result;
    }

    private async Task OnQuizUpdatedAsync(QuizDto updated)
    {
        if (_disposed) return;
        _quizCache[updated.Id] = updated;
        ChatSession.UpdateExchangeQuiz(updated.Id, updated);
        StateHasChanged();
    }

    private async Task OnQuizCompletedAsync(QuizDto completed)
    {
        if (_disposed) return;
        _quizCache[completed.Id] = completed;
        ChatSession.UpdateExchangeQuiz(completed.Id, completed);
        _resumeQuiz = null;
        StateHasChanged();
    }

    private async Task CancelQuizAsync()
    {
        if (_disposed) return;
        _quizCts?.Cancel();
        _generatingQuiz = false;
        StateHasChanged();
    }

    private async Task OnQuizCardOpenAsync(QuizDto quiz)
    {
        if (quiz.Status == QuizStatus.GeneratingFailed)
        {
            await GenerateQuizAsync();
        }
        else
        {
            await OpenQuizDialogAsync(quiz);
        }
    }

    private async Task OnDismissQuizAsync(QuizDto quiz)
    {
        ChatSession.RemoveExchangeByQuizId(quiz.Id);
        _quizCache.Remove(quiz.Id);
        StateHasChanged();
    }

    private async Task CheckResumeQuizAsync(int workspaceVersion)
    {
        if (!IsCurrentWorkspace(workspaceVersion) || _currentSessionId is null || _chatApi is null || string.IsNullOrWhiteSpace(Session.AccessToken))
        {
            return;
        }

        try
        {
            var quiz = await _chatApi.ResumeQuizAsync(Session.AccessToken!, _currentSessionId.Value);
            if (!IsCurrentWorkspace(workspaceVersion)) return;
            if (quiz is not null && quiz.Status == QuizStatus.InProgress)
            {
                _resumeQuiz = quiz;
                StateHasChanged();
            }
        }
        catch
        {
            // Resume is best-effort
        }
    }

    private void UseSummaryPrompt()
        => UsePrompt("Create an auto summary for my selected context with key concepts, exam tips, and citations for the most important points.");

    private static string DocumentExtension(DocumentDto document)
    {
        var extension = Path.GetExtension(document.FileName).TrimStart('.').ToLowerInvariant();
        return string.IsNullOrWhiteSpace(extension) ? "file" : extension;
    }

    private static string DocumentDetailLine(DocumentDto document)
    {
        var pages = document.PageCount is { } pageCount && pageCount > 0 ? $"{pageCount} pages" : "Indexed";
        return $"{pages} · {FormatFileSize(document.FileSizeBytes)} · {document.UpdatedAt:MMM d}";
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes <= 0)
        {
            return "—";
        }

        string[] units = ["B", "KB", "MB", "GB"];
        var size = (double)bytes;
        var unit = 0;
        while (size >= 1024 && unit < units.Length - 1)
        {
            size /= 1024;
            unit++;
        }

        return unit == 0 ? $"{bytes} B" : $"{size:0.#} {units[unit]}";
    }

    private static string ShortFileName(string fileName, int maxLength = 34)
    {
        if (string.IsNullOrWhiteSpace(fileName) || fileName.Length <= maxLength)
        {
            return fileName;
        }

        var extension = Path.GetExtension(fileName);
        var nameWithoutExtension = Path.GetFileNameWithoutExtension(fileName);
        var reserved = string.IsNullOrEmpty(extension) ? 1 : extension.Length + 1;
        var available = Math.Max(8, maxLength - reserved);
        var prefix = nameWithoutExtension.Length <= available
            ? nameWithoutExtension
            : nameWithoutExtension[..available];
        return $"{prefix}…{extension}";
    }

    private string BuildScopeLabel()
    {
        var selectedCount = SelectedDocumentIdsForRequest?.Count ?? 0;
        var scope = _folderId is { } folderId
            ? $"Folder: {_folders.FirstOrDefault(f => f.Id == folderId)?.Name ?? "Unknown folder"}"
            : "All indexed documents";

        return selectedCount > 0
            ? $"{scope} | {selectedCount} selected file{(selectedCount == 1 ? string.Empty : "s")}"
            : scope;
    }

    private static string SourceLabel(AiChatSourceDto source, int index)
        => string.IsNullOrWhiteSpace(source.Label) ? $"S{index + 1}" : source.Label;

    private static string CitationBadgeChar(int index)
    {
        // ① ② ③ ④ ⑤ ⑥ ⑦ ⑧ ⑨ ⑩
        string[] badges = ["①", "②", "③", "④", "⑤", "⑥", "⑦", "⑧", "⑨", "⑩"];
        return index < badges.Length ? badges[index] : $"[{index + 1}]";
    }

    private static string SourceCountText(IReadOnlyList<AiChatSourceDto>? sources)
    {
        var count = sources?.Count ?? 0;
        return $"{count} source{(count == 1 ? string.Empty : "s")}";
    }

    private static string FormatAnswerMarkup(string answer)
    {
        var encoded = System.Net.WebUtility.HtmlEncode(answer ?? string.Empty);

        // Bold: **text**
        encoded = System.Text.RegularExpressions.Regex.Replace(
            encoded,
            @"\*\*(.+?)\*\*",
            "<strong>$1</strong>",
            System.Text.RegularExpressions.RegexOptions.Singleline);

        // Italic: *text*
        encoded = System.Text.RegularExpressions.Regex.Replace(
            encoded,
            @"\*(.+?)\*",
            "<em>$1</em>",
            System.Text.RegularExpressions.RegexOptions.Singleline);

        // Inline code: `code`
        encoded = System.Text.RegularExpressions.Regex.Replace(
            encoded,
            @"`(.+?)`",
            "<code class=\"ai-inline-code\">$1</code>",
            System.Text.RegularExpressions.RegexOptions.Singleline);

        // Numbered list items: 1. text
        encoded = System.Text.RegularExpressions.Regex.Replace(
            encoded,
            @"(?m)^(\d+)\.\s+(.+)$",
            "<div class=\"ai-list-item ai-numbered-item\"><span class=\"ai-list-num\">$1.</span><span>$2</span></div>");

        // Bullet list items: - text or • text
        encoded = System.Text.RegularExpressions.Regex.Replace(
            encoded,
            @"(?m)^[-•]\s+(.+)$",
            "<div class=\"ai-list-item ai-bullet-item\"><span class=\"ai-list-bullet\">•</span><span>$1</span></div>");

        // Newlines to br
        encoded = encoded.Replace("\r\n", "<br />").Replace("\n", "<br />");

        return encoded;
    }

    private static string MapDocumentError(DocumentApiException ex) => ex.StatusCode switch
    {
        401 => "Your session has expired. Please sign in again.",
        403 => "You do not have access to these documents.",
        _ => ex.Message,
    };

    private static string MapChatError(AiChatApiException ex) => ex.Code switch
    {
        "insufficient_content" => ex.Message,
        "invalid_quiz_json" => ex.Message,
        "quiz_too_large" => ex.Message,
        "documents_not_found" => ex.Message,
        "session_not_found" => ex.Message,
        "no_active_quiz" => ex.Message,
        "quiz_save_failed" => ex.Message,
        "quiz_load_failed" => ex.Message,
        "empty_ai_response" => "The AI returned an empty response. Please try again.",
        "rate_limited" => "You've made too many requests. Please wait a moment and try again.",
        _ => ex.StatusCode switch
        {
            400 => ex.Message,
            401 => "Your session has expired. Please sign in again.",
            403 => "You do not have permission to use AI chat.",
            404 => "The AI chat endpoint is not available yet. Merge the Sprint 2 chat API before browser smoke.",
            408 => "The AI request timed out. Try again with fewer sources or a narrower scope.",
            429 => "The AI provider is rate limited right now. Wait a moment and try again.",
            500 or 502 or 503 => $"AI service error: {ex.Message}",
            _ => ex.Message,
        },
    };

    public void Dispose()
    {
        _disposed = true;
        _workspaceVersion++;
        _sessionLoadVersion++;
        _scopeCts?.Cancel();
        _scopeCts?.Dispose();
        _askCts?.Cancel();
        _askCts?.Dispose();
        _quizCts?.Cancel();
        _quizCts?.Dispose();
    }
}
