@page "/ai/chat"
@using System.Text.Json
@using AI_Study_Hub_v2.Data.Entities
@using AI_Study_Hub_v2.Components.Shared.Quiz
@using AI_Study_Hub_v2.Options
@using Microsoft.Extensions.Options
@implements IDisposable
@inject AuthSessionState Session
@inject DocumentApiClient DocumentsApi
@inject FolderApiClient FoldersApi
@inject IHttpClientFactory HttpClientFactory
@inject IServiceProvider Services
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject AiChatSessionState ChatSession
@inject IJSRuntime JS
@inject IDialogService DialogService
@inject IOptions<GroqOptions> GroqOptions
@inject IOptions<GeminiOptions> GeminiOptions

<PageTitle>AI Chat - AI Study Hub v2</PageTitle>

<MudStack Spacing="0" Class="ai-chat-shell workspace-shell teammate-workspace-shell">
    @if (!Session.IsAuthenticated)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
            Sign in to ask questions about your documents.
        </MudAlert>
    }
    else if (_loadingScope)
    {
        <MudPaper Class="pa-5" Elevation="0" Outlined="true">
            <MudStack Spacing="2">
                <MudSkeleton Height="44px" Animation="Animation.Wave" />
                <MudSkeleton Height="120px" Animation="Animation.Wave" />
                <MudSkeleton Height="220px" Animation="Animation.Wave" />
            </MudStack>
        </MudPaper>
    }
    else
    {
        <div class="ai-chat-grid" role="region" aria-label="AI chat workspace">
            <section class="ai-chat-column ai-chat-column-left">
                <aside class="ai-chat-left-rail">
                    <section class="workspace-folder-head">
                        <div class="workspace-folder-title-row">
                            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" Variant="Variant.Text" Href="/documents" title="Back to Library" />
                            @if (_isFolderLocked)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Class="workspace-folder-lock-icon" />
                                <h2 class="workspace-folder-static-title">@FolderTitle</h2>
                            }
                            else
                            {
                                <MudSelect T="string"
                                           Value="@_workspaceFolderIdStr"
                                           ValueChanged="@(s => { _workspaceFolderIdStr = s; OnWorkspaceFolderChanged(); })"
                                           Variant="Variant.Text"
                                           Class="workspace-folder-select"
                                           AnchorOrigin="Origin.BottomCenter"
                                           Disabled="_loadingScope"
                                           Dense="true">
                                    <MudSelectItem T="string" Value="@string.Empty">All Study Documents</MudSelectItem>
                                    @foreach (var f in _folders)
                                    {
                                        <MudSelectItem T="string" Value="@f.Id.ToString()">@f.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            }
                        </div>
                        <p>@ScopeDocuments.Count files · <span>@ActiveContextCount active context</span></p>
                    </section>

                    <div class="workspace-column-labels" aria-hidden="true">
                        <span>✓</span>
                        <span>Document</span>
                    </div>

                    <div class="workspace-add-file-wrap">
                        <MudButton Variant="Variant.Outlined"
                                   Class="workspace-add-file-button"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   Href="@UploadUrl"
                                   FullWidth="true"
                                   Disabled="_busy">
                            Upload document
                        </MudButton>
                    </div>

                    <div class="workspace-document-list">
                        @foreach (var document in ScopeDocuments)
                        {
                            var active = IsDocumentSelected(document.Id);
                            <button type="button"
                                    class="@($"workspace-document-card {(active ? "is-active" : string.Empty)}")"
                                    disabled="@_busy"
                                    title="@document.FileName"
                                    @onclick="() => ToggleDocumentSelection(document.Id)">
                                <span class="workspace-doc-check">@if (active) { <span class="workspace-doc-check-mark"></span> }</span>
                                <span class="@($"workspace-doc-ext ext-{DocumentExtension(document)}")">@DocumentExtension(document)</span>
                                <span class="workspace-doc-meta">
                                    <strong>@ShortFileName(document.FileName, 28)</strong>
                                    <small>@DocumentDetailLine(document)</small>
                                </span>
                            </button>
                        }

                        @if (ScopeDocuments.Count == 0)
                        {
                            <div class="workspace-empty-docs">
                                <MudIcon Icon="@Icons.Material.Filled.LibraryBooks" />
                                <strong>No indexed files yet</strong>
                                <span>Upload a document or wait for ingestion before asking AI.</span>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.UploadFile" Href="@UploadUrl">
                                    Upload document
                                </MudButton>
                            </div>
                        }
                    </div>

                    <section class="workspace-scope-drawer">
                        <div class="workspace-selected-summary">
                            <span>Selected context</span>
                            <strong>@SelectedContextLabel</strong>
                            <small>Tick any files in this folder to choose what RAG can search.</small>
                        </div>

                        <MudSelect T="int"
                                   Label="Sources to retrieve"
                                   @bind-Value="_topK"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Disabled="_busy">
                            <MudSelectItem T="int" Value="3">3 sources</MudSelectItem>
                            <MudSelectItem T="int" Value="5">5 sources</MudSelectItem>
                            <MudSelectItem T="int" Value="8">8 sources</MudSelectItem>
                            <MudSelectItem T="int" Value="10">10 sources</MudSelectItem>
                        </MudSelect>
                    </section>

                    <footer class="workspace-left-footer">
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" />
                        <span>@ActiveContextCount active context</span>
                    </footer>
                </aside>
            </section>

            <section class="ai-chat-column ai-chat-column-center">
                <main class="ai-chat-center-stage">
                    <section class="workspace-chat-header">
                        <div class="workspace-chat-header-info">
                            <div class="workspace-chat-header-folder-badge">
                                <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Small" />
                                <span class="workspace-chat-folder-name">@FolderTitle</span>
                            </div>
                            <h1>Chat with <span class="workspace-chat-header-highlight">@FolderTitle</span></h1>
                            <span class="workspace-chat-header-sub">Ask questions directly from checked context with source-backed citations.</span>
                        </div>
                        <div class="workspace-chat-header-actions">
                            @if (ChatSession.History.Count > 0)
                            {
                                <MudButton Variant="Variant.Text"
                                           Class="workspace-clear-button"
                                           StartIcon="@Icons.Material.Filled.DeleteSweep"
                                           OnClick="ClearHistory"
                                           Disabled="_busy">
                                    Clear
                                </MudButton>
                            }
                            <MudButton Variant="Variant.Text"
                                       Class="workspace-refresh-button"
                                       StartIcon="@Icons.Material.Filled.Refresh"
                                       OnClick="LoadScopeAsync"
                                       Disabled="_busy || _loadingScope">
                                Refresh
                            </MudButton>
                        </div>
                    </section>

                    <section class="workspace-message-scroll" id="chat-message-scroll" aria-live="polite">
                        <div class="ai-chat-message ai-chat-message-assistant">
                            <div class="ai-chat-message-avatar"><MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Small" /></div>
                            <div class="ai-chat-message-content">
                                <div class="ai-chat-message-bubble">
                                    I can read your indexed documents, compare concepts, draft exam prep, and return citations for every grounded answer.
                                </div>
                                <div class="workspace-citation-pills">
                                    <span>@ScopeSummary</span>
                                    <span>@_topK source retrieval</span>
                                </div>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_error))
                        {
                            <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="workspace-error-alert">
                                @_error
                            </MudAlert>
                        }

                        @if (!_busy && ChatSession.History.Count == 0 && string.IsNullOrWhiteSpace(_error))
                        {
                            <div class="workspace-empty-state">
                                <div class="workspace-empty-icon"><MudIcon Icon="@Icons.Material.Filled.AutoAwesome" /></div>
                                <strong>Ready when your notes are indexed</strong>
                                <span>Select one or more files on the left, then ask a question. If nothing is selected, the current folder scope is used.</span>
                                <div class="workspace-suggestion-row">
                                    @foreach (var prompt in SuggestedPrompts)
                                    {
                                        <button type="button" @onclick="() => UsePrompt(prompt)" disabled="@_busy">
                                            @prompt
                                        </button>
                                    }
                                </div>
                            </div>
                        }

                        @if (_resumeQuiz is not null)
                        {
                            <div class="workspace-quiz-resume-banner">
                                <div class="workspace-quiz-resume-info">
                                    <MudIcon Icon="@Icons.Material.Filled.AssignmentTurnedIn" Size="Size.Small" />
                                    <span>You have an active quiz: <strong>@_resumeQuiz.Title</strong></span>
                                </div>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                           OnClick="() => OpenQuizDialogAsync(_resumeQuiz)" Class="workspace-quiz-resume-btn">
                                    Resume Quiz
                                </MudButton>
                            </div>
                        }

                        @foreach (var (exchange, idx) in ChatSession.History.Select((e, i) => (e, i)))
                        {
                            @RenderExchange(exchange, idx)
                        }

                        @if (_busy)
                        {
                            <div class="ai-chat-message ai-chat-message-assistant">
                                <div class="ai-chat-message-avatar"><MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Small" /></div>
                                <div class="ai-chat-typing-bubble" aria-label="AI is thinking">
                                    <span></span><span></span><span></span>
                                </div>
                            </div>
                        }

                        <div id="chat-bottom-anchor"></div>
                    </section>

                    <section class="workspace-composer-panel">
                        <div class="workspace-composer-box @(_focused ? "is-focused" : "")">
                            <MudButton Variant="Variant.Text"
                                        Href="@UploadUrl"
                                       Class="workspace-attach-button"
                                       Disabled="_busy"
                                       aria-label="Upload file">
                                <MudIcon Icon="@Icons.Material.Filled.AttachFile" />
                            </MudButton>
                            <MudTextField T="string"
                                          @bind-Value="_question"
                                          Variant="Variant.Text"
                                          Placeholder="Ask AI assistant… (Enter to send)"
                                          Lines="1"
                                          Clearable="true"
                                          Disabled="_busy"
                                          Error="@(!string.IsNullOrWhiteSpace(_composerError))"
                                          ErrorText="@_composerError"
                                          Class="workspace-question-input"
                                          @onkeydown="HandleKeyDown"
                                          @onfocus="() => _focused = true"
                                          @onblur="() => _focused = false" />
                            <MudButton Variant="Variant.Filled"
                                       Class="workspace-send-button"
                                       StartIcon="@Icons.Material.Filled.Send"
                                       OnClick="AskAsync"
                                       Disabled="_busy || ScopeDocuments.Count == 0 || string.IsNullOrWhiteSpace(_question)">
                                @if (_busy)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                }
                                else
                                {
                                    <span>Send</span>
                                }
                            </MudButton>
                        </div>
                        <div class="workspace-composer-footer">
                            <p class="workspace-composer-note">Answers depend on extracted chunks and may be incomplete.</p>
                            <span class="workspace-composer-hint">Enter ↵ to send</span>
                        </div>
                    </section>
                </main>
            </section>

            <section class="ai-chat-column ai-chat-column-right">
                <aside class="ai-chat-right-rail">
                    <section class="workspace-smart-actions">
                        <div class="workspace-panel-heading">
                            <span>Smart Actions</span>
                            <small>Generate study assets</small>
                        </div>

                        <button type="button" class="workspace-tool-card tool-summary" @onclick="UseSummaryPrompt" disabled="@_busy">
                            <span class="workspace-tool-icon"><MudIcon Icon="@Icons.Material.Filled.MenuBook" /></span>
                            <span><strong>Create Summary</strong><small>Auto-generate a structured summary from your checked documents.</small></span>
                        </button>

                        <button type="button" class="workspace-tool-card tool-exam"
                                disabled="@_busy"
                                @onclick="@(_generatingQuiz ? CancelQuizAsync : GenerateQuizAsync)">
                            <span class="workspace-tool-icon"><MudIcon Icon="@Icons.Material.Filled.AssignmentTurnedIn" /></span>
                            <span>
                                @if (_generatingQuiz)
                                {
                                    <strong>Cancel</strong>
                                    <small>Click to cancel in-progress quiz generation.</small>
                                }
                                else
                                {
                                    <strong>Generate Quiz</strong>
                                    <small>Create multiple-choice questions with answer options and an answer key.</small>
                                }
                            </span>
                        </button>
                    </section>

                    <section class="workspace-model-selector">
                        <div class="workspace-panel-heading">
                            <span>AI Model</span>
                            <small>Choose which model answers questions</small>
                        </div>
                        <MudSelect T="string" Value="@_selectedModel" ValueChanged="@OnModelChanged" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@(_busy || _generatingQuiz)">
                            @foreach (var model in AvailableModels)
                            {
                                <MudSelectItem T="string" Value="@model">@model</MudSelectItem>
                            }
                        </MudSelect>
                    </section>

                    <section class="workspace-model-selector">
                        <div class="workspace-panel-heading">
                            <span>Quiz Subject Filter</span>
                            <small>Optionally filter quiz to a subject/semester</small>
                        </div>
                        <MudSelect T="string" Value="@_quizSubjectCode" ValueChanged="@(v => { _quizSubjectCode = v; StateHasChanged(); })" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@(_busy || _generatingQuiz)" Label="Subject" Clearable>
                            @foreach (var sc in _availableSubjectCodes)
                            {
                                <MudSelectItem T="string" Value="@sc">@sc</MudSelectItem>
                            }
                        </MudSelect>
                        <MudSelect T="string" Value="@_quizSemester" ValueChanged="@(v => { _quizSemester = v; StateHasChanged(); })" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@(_busy || _generatingQuiz)" Label="Semester" Clearable>
                            @foreach (var sem in _availableSemesters)
                            {
                                <MudSelectItem T="string" Value="@sem">@sem</MudSelectItem>
                            }
                        </MudSelect>
                    </section>

                    <section class="workspace-active-context">
                        <div class="workspace-panel-heading">
                            <span>Active Context</span>
                            <small>@(ActiveContextCount > 0 ? $"{ActiveContextCount} selected" : "None selected") · @_topK source depth</small>
                        </div>

                        <div class="workspace-context-preview">
                            @foreach (var document in ActiveContextDocuments.Take(3))
                            {
                                <div class="workspace-context-file" title="@document.FileName">
                                    <span class="@($"workspace-doc-ext ext-{DocumentExtension(document)}")">@DocumentExtension(document)</span>
                                    <strong>@ShortFileName(document.FileName, 25)</strong>
                                </div>
                            }

                            @if (!ActiveContextDocuments.Any())
                            {
                                <div class="workspace-context-empty">All indexed files are available until you pin one document.</div>
                            }
                        </div>

                        <div class="ai-chat-context-row"><span>Scope</span><strong>@ScopeSummary</strong></div>
                        <div class="ai-chat-context-row"><span>Indexed files</span><strong>@ScopeDocuments.Count</strong></div>
                        <div class="ai-chat-context-row"><span>Folders</span><strong>@_folders.Count</strong></div>
                        <div class="ai-chat-context-row"><span>Retrieval depth</span><strong>@_topK sources</strong></div>
                    </section>

                    @if (ChatSession.History.Count > 0)
                    {
                        <section class="workspace-session-stats">
                            <div class="workspace-panel-heading">
                                <span>Session</span>
                                <small>@ChatSession.History.Count exchange@(ChatSession.History.Count == 1 ? "" : "s")</small>
                            </div>
                            <div class="ai-chat-context-row"><span>Messages</span><strong>@(ChatSession.History.Count * 2)</strong></div>
                            <div class="ai-chat-context-row"><span>Last asked</span><strong>@(ChatSession.History.LastOrDefault()?.AskedAt.ToString("HH:mm") ?? "—")</strong></div>
                        </section>
                    }
                </aside>
            </section>
        </div>
    }
</MudStack>

@code {
    [SupplyParameterFromQuery(Name = "documentId")]
    public Guid? QueryDocumentId { get; set; }

    [SupplyParameterFromQuery(Name = "folderId")]
    public Guid? QueryFolderId { get; set; }

    private static readonly string[] SuggestedPrompts =
    {
        "Summarize the key ideas from my selected files.",
        "Explain this topic as if I am preparing for an exam.",
        "Generate multiple-choice quiz questions with A-D options and answer keys.",
    };

    private AiChatApiClient? _chatApi;
    private CancellationTokenSource? _scopeCts;
    private CancellationTokenSource? _askCts;
    private CancellationTokenSource? _quizCts;
    private bool _busy;
    private bool _generatingQuiz;
    private bool _loadingScope;
    private bool _focused;
    private QuizDto? _resumeQuiz;
    private readonly Dictionary<Guid, QuizDto> _quizCache = new();
    private string? _error;
    private string? _composerError;
    private string? _question;
    private Guid? _folderId;
    private string _workspaceFolderIdStr = "";
    private int _topK = 5;
    private string _selectedModel = string.Empty;

    private string? _quizSubjectCode;
    private string? _quizSemester;
    private IReadOnlyList<string> _availableSubjectCodes = Array.Empty<string>();
    private IReadOnlyList<string> _availableSemesters = Array.Empty<string>();

    private void RefreshSubjectFilters()
    {
        var ready = ReadyDocuments;
        _availableSubjectCodes = ready
            .Select(d => d.SubjectCode)
            .Where(s => !string.IsNullOrWhiteSpace(s))
            .Distinct()
            .OrderBy(s => s)
            .ToList();
        _availableSemesters = ready
            .Select(d => d.Semester)
            .Where(s => !string.IsNullOrWhiteSpace(s))
            .Distinct()
            .OrderBy(s => s)
            .ToList();
    }

    private void OnModelChanged(string value)
    {
        _selectedModel = value;
        StateHasChanged();
    }

    private IReadOnlyList<string> AvailableModels
    {
        get
        {
            var groqModel = GroqOptions.Value.Model?.Trim();
            var geminiModel = GeminiOptions.Value.Model?.Trim();
            var models = new List<string>();
            if (!string.IsNullOrWhiteSpace(groqModel))
            {
                models.Add(groqModel);
            }

            if (!string.IsNullOrWhiteSpace(GeminiOptions.Value.ApiKey)
                && !string.IsNullOrWhiteSpace(geminiModel)
                && !models.Contains(geminiModel, StringComparer.OrdinalIgnoreCase))
            {
                models.Add(geminiModel);
            }

            return models;
        }
    }

    private string DefaultModel => AvailableModels.FirstOrDefault() ?? string.Empty;

    private List<DocumentDto> _documents = new();
    private List<FolderDto> _folders = new();
    private readonly HashSet<Guid> _selectedDocumentIds = new();
    private readonly HashSet<int> _copiedIndexes = new();

    private Guid? _currentSessionId;
    private List<ChatSessionDto> _sessions = new();
    private int _sessionLoadVersion;
    private Guid? _expectedFolderId;
    private int _workspaceVersion;
    private bool _disposed;
    private bool _hasAppliedQueryScope;
    private Guid? _appliedQueryFolderId;
    private Guid? _appliedQueryDocumentId;

    private async Task LoadSessionsAsync(int workspaceVersion)
    {
        var version = ++_sessionLoadVersion;
        var folderId = _folderId;
        _expectedFolderId = folderId;
        try
        {
            var sessions = await _chatApi!.ListSessionsAsync(Session.AccessToken!, folderId);
            if (!IsCurrentWorkspace(workspaceVersion) || version != _sessionLoadVersion) return;

            _sessions = sessions
                .Where(s => s.FolderId == folderId)
                .ToList();

            if (_sessions.Count > 0)
            {
                var latest = _sessions[0];
                _currentSessionId = latest.Id;
                await LoadSessionMessagesAsync(latest.Id, workspaceVersion);
            }
            else
            {
                ClearSessionBoundVisibleState();
                StateHasChanged();
            }
        }
        catch
        {
            if (!IsCurrentWorkspace(workspaceVersion) || version != _sessionLoadVersion) return;
            ClearSessionBoundVisibleState();
            StateHasChanged();
        }
    }

    private async Task LoadSessionMessagesAsync(Guid sessionId, int workspaceVersion)
    {
        var version = _sessionLoadVersion;
        try
        {
            var messages = await _chatApi!.GetSessionMessagesAsync(Session.AccessToken!, sessionId, _expectedFolderId);
            if (!IsCurrentWorkspace(workspaceVersion) || version != _sessionLoadVersion) return;
            // Only render if the folder is still the one that triggered this load
            if (_expectedFolderId != _folderId) return;
            var exchanges = ConvertMessagesToExchanges(messages);

            // Refresh quiz statuses from the DB (metadata may be stale)
            await RefreshQuizStatusesAsync(exchanges, workspaceVersion);
            if (!IsCurrentWorkspace(workspaceVersion) || version != _sessionLoadVersion) return;

            ChatSession.Replace(exchanges);
        }
        catch
        {
            if (!IsCurrentWorkspace(workspaceVersion) || version != _sessionLoadVersion) return;
            ChatSession.Clear();
        }
        if (!IsCurrentWorkspace(workspaceVersion) || version != _sessionLoadVersion) return;
        StateHasChanged();
        _ = CheckResumeQuizAsync(workspaceVersion);
    }

    private static List<AiChatHistoryExchange> ConvertMessagesToExchanges(IReadOnlyList<ChatMessageDto> messages)
    {
        var exchanges = new List<AiChatHistoryExchange>();
        for (var i = 0; i < messages.Count - 1; i += 2)
        {
            var userMsg = messages[i];
            if (userMsg.Role != "user")
            {
                continue;
            }

            var assistantMsg = i + 1 < messages.Count ? messages[i + 1] : null;

            AiChatAnswerResponse response;
            var meta = DeserializeMetadata(assistantMsg?.MetadataJson);
            if (assistantMsg is not null && assistantMsg.Role == "assistant")
            {
                response = new AiChatAnswerResponse(
                    assistantMsg.Content,
                    meta?.Sources ?? Array.Empty<AiChatSourceDto>(),
                    meta?.RefusalReason,
                    meta?.DurationMs);
            }
            else
            {
                response = new AiChatAnswerResponse(
                    string.Empty,
                    Array.Empty<AiChatSourceDto>());
            }

            QuizDto? quiz = null;
            if (meta?.QuizId is not null)
            {
                var status = Enum.TryParse<QuizStatus>(meta.QuizStatus, ignoreCase: true, out var s) ? s : QuizStatus.InProgress;
                quiz = new QuizDto(
                    Guid.Parse(meta.QuizId),
                    meta.QuizTitle ?? "Quiz",
                    status,
                    0,
                    meta.QuizTotalQuestions ?? 0,
                    Array.Empty<QuizQuestionDto>(),
                    new Dictionary<int, string?>(),
                    new Dictionary<int, bool>(),
                    meta.QuizScore,
                    default);
            }

            exchanges.Add(new AiChatHistoryExchange(
                userMsg.Content,
                meta?.ScopeLabel ?? string.Empty,
                response,
                assistantMsg?.CreatedAt ?? userMsg.CreatedAt,
                Quiz: quiz));
        }

        return exchanges;
    }

    private async Task RefreshQuizStatusesAsync(List<AiChatHistoryExchange> exchanges, int workspaceVersion)
    {
        for (var i = 0; i < exchanges.Count; i++)
        {
            var quiz = exchanges[i].Quiz;
            if (quiz is null) continue;

            // Check local cache first
            if (_quizCache.TryGetValue(quiz.Id, out var cached) && cached.Status != quiz.Status)
            {
                exchanges[i] = exchanges[i] with { Quiz = cached };
                continue;
            }

            // Only fetch from API if status is not Completed in metadata
            if (quiz.Status == QuizStatus.Completed) continue;

            try
            {
                var fresh = await _chatApi!.GetQuizAsync(Session.AccessToken!, quiz.Id);
                if (!IsCurrentWorkspace(workspaceVersion)) return;
                if (fresh is not null && fresh.Status != quiz.Status)
                {
                    _quizCache[fresh.Id] = fresh;
                    exchanges[i] = exchanges[i] with { Quiz = fresh };
                }
            }
            catch
            {
                // Best-effort — keep the metadata version
            }
        }
    }

    private sealed record MetadataJsonShape(string? ScopeLabel, string? RefusalReason, long? DurationMs, IReadOnlyList<AiChatSourceDto>? Sources, string? QuizId = null, string? QuizTitle = null, string? QuizStatus = null, int? QuizTotalQuestions = null, int? QuizScore = null);

    private static MetadataJsonShape? DeserializeMetadata(string? json)
    {
        if (string.IsNullOrWhiteSpace(json))
        {
            return null;
        }

        try
        {
            return JsonSerializer.Deserialize<MetadataJsonShape>(json);
        }
        catch
        {
            return null;
        }
    }

    private List<DocumentDto> ReadyDocuments => _documents
        .Where(d => d.Status == DocumentStatus.Ready)
        .OrderByDescending(d => d.UpdatedAt)
        .ToList();

    private List<DocumentDto> ScopeDocuments => ReadyDocuments
        .Where(d => !_folderId.HasValue || d.FolderId == _folderId.Value)
        .ToList();

    private IReadOnlyList<DocumentDto> ActiveContextDocuments
    {
        get
        {
            var scopedDocuments = ScopeDocuments;
            var selected = scopedDocuments.Where(d => _selectedDocumentIds.Contains(d.Id)).ToList();
            return selected;
        }
    }

    private int ActiveContextCount => ActiveContextDocuments.Count;

    private IReadOnlyList<Guid>? SelectedDocumentIdsForRequest
    {
        get
        {
            var selected = ScopeDocuments
                .Where(d => _selectedDocumentIds.Contains(d.Id))
                .Select(d => d.Id)
                .Distinct()
                .ToArray();
            return selected.Length == 0 ? null : selected;
        }
    }

    private string SelectedContextLabel => _selectedDocumentIds.Count == 0
        ? "No file selected"
        : $"{ActiveContextCount} selected file{(ActiveContextCount == 1 ? string.Empty : "s")}";

    private string FolderTitle => _folderId is { } folderId
        ? _folders.FirstOrDefault(f => f.Id == folderId)?.Name ?? "Selected folder"
        : "All Study Documents";

    private string ScopeSummary => _folderId.HasValue
        ? FolderTitle
        : "All indexed documents";

    private string UploadUrl => _isFolderLocked && _folderId.HasValue
        ? $"/documents/upload?returnUrl=/ai/chat?folderId={_folderId}&folderId={_folderId}"
        : "/documents/upload?returnUrl=/ai/chat";

