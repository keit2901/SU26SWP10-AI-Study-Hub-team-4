@page "/pricing"
@inject AuthSessionState Session
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject PlanApiClient PlanApi
@inject ISnackbar Snackbar

<PageTitle>Pricing - AI Study Hub</PageTitle>

@if (_isLoading)
{
    <div class="pricing-loading">
        <MudProgressCircular Size="Size.Large" Indeterminate="true" Color="Color.Primary" />
        <p style="margin-top:1rem; color: var(--mud-palette-text-secondary);">Loading plans...</p>
    </div>
}
else if (_error is not null)
{
    <div class="pricing-error">
        <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Size="Size.Large" Style="color:#EF4444;" />
        <p>@_error</p>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="LoadPlansAsync">Retry</MudButton>
    </div>
}
else if (_plans is { Count: > 0 })
{
    <div class="pricing-page">
        <div class="pricing-content-wrapper">
            <section class="pricing-hero">
                <h1>Elevate your learning with AI Study Hub</h1>
                <p class="pricing-subtitle">Choose the subscription plan that fits your study and research goals.</p>
            </section>

            <section class="pricing-cards">
                @foreach (var plan in _plans)
                {
                    var isCurrent = IsCurrentPlan(plan.PlanKey);
                    var cardClass = GetCardClass(plan.PlanKey, isCurrent);
                    var isPopular = plan.PlanKey == "pro";
                    var featureColor = GetFeatureColorClass(plan.PlanKey);

                    <div class="plan-card @cardClass">
                        @if (isPopular)
                        {
                            <span class="popular-badge">POPULAR</span>
                        }
                        <div class="plan-card-body">
                            <div class="plan-header">
                                @if (isPopular)
                                {
                                    <div style="display:flex; align-items:center; gap:0.5rem;">
                                        <h2 class="plan-name">@plan.DisplayName</h2>
                                        <span class="pro-star"><MudIcon Icon="@Icons.Material.Filled.Verified" Size="Size.Small" /></span>
                                    </div>
                                }
                                else
                                {
                                    <h2 class="plan-name">@plan.DisplayName</h2>
                                }
                                <p class="plan-tagline">@(plan.Description ?? GetDefaultTagline(plan.PlanKey))</p>
                            </div>

                            <div class="plan-price @GetPriceClass(plan.PlanKey)">
                                @if (plan.MonthlyPriceVnd is null or 0)
                                {
                                    <span class="price-currency">$</span>
                                    <span class="price-amount">0</span>
                                    <span class="price-period">/ month</span>
                                }
                                else
                                {
                                    <span class="price-amount" style="font-size:2rem;">@FormatVndPrice(plan.MonthlyPriceVnd)</span>
                                    <span class="price-period">/ month</span>
                                }
                            </div>
                            @if (plan.YearlyPriceVnd > 0 && plan.MonthlyPriceVnd > 0)
                            {
                                <p class="demo-price">Yearly: @FormatVndPrice(plan.YearlyPriceVnd)</p>
                            }

                            <div class="plan-cta">
                                @if (isCurrent)
                                {
                                    <button class="btn-plan @GetCurrentBtnClass(plan.PlanKey)" disabled>Current Plan</button>
                                }
                                else if (plan.PlanKey == "free")
                                {
                                    <button class="btn-plan btn-plan-outline" @onclick='() => HandleSelectPlan(plan)'>
                                        @(Session.IsAuthenticated ? "Downgrade to Free" : "Get Started Free")
                                    </button>
                                }
                                else if (plan.PlanKey == "unlimited")
                                {
                                    <button class="btn-plan btn-plan-dark" disabled>Contact Us</button>
                                    <p class="contact-note">Reach out at <strong>support@aistudyhub.com</strong> for the Unlimited plan.</p>
                                }
                                else
                                {
                                    <button class="btn-plan btn-plan-primary" @onclick='() => HandleSelectPlan(plan)'>Upgrade to @plan.DisplayName</button>
                                }
                            </div>

                            <ul class="plan-features">
                                @foreach (var feature in GetPlanFeatures(plan))
                                {
                                    <li><MudIcon Icon="@feature.Icon" Size="Size.Small" Class="@($"feature-icon {featureColor}")" /> @feature.Label</li>
                                }
                            </ul>
                        </div>
                    </div>
                }
            </section>
        </div>
    </div>
}

@code {
    private List<PlanDto>? _plans;
    private bool _isLoading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        Session.OnChange += StateHasChanged;
        await LoadPlansAsync();
    }

    private async Task LoadPlansAsync()
    {
        _isLoading = true;
        _error = null;
        StateHasChanged();

        try
        {
            if (Session.IsAuthenticated && !string.IsNullOrWhiteSpace(Session.AccessToken))
            {
                var plans = await PlanApi.GetPlansAsync(Session.AccessToken);
                if (plans.Count > 0)
                {
                    _plans = plans.ToList();
                    return;
                }
            }
            // Fall back to default plans
            _plans = GetDefaultPlans();
        }
        catch
        {
            _plans = GetDefaultPlans();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private bool IsCurrentPlan(string planKey)
    {
        return string.Equals(Session.CurrentPlan, planKey, StringComparison.OrdinalIgnoreCase);
    }

    private async Task HandleSelectPlan(PlanDto plan)
    {
        if (!Session.IsAuthenticated)
        {
            Nav.NavigateTo("/login", replace: false);
            return;
        }

        if (plan.PlanKey == "free")
        {
            // Downgrade to free — show confirmation dialog first
            var confirmParams = new DialogParameters<ConfirmDialog>
            {
                { x => x.Title, "Downgrade to Free" },
                { x => x.Message, "Are you sure you want to downgrade to Free? You will lose Pro features." },
                { x => x.ConfirmText, "Downgrade" },
                { x => x.ConfirmColor, Color.Warning },
                { x => x.Icon, Icons.Material.Filled.ArrowDownward },
                { x => x.IconColor, Color.Warning },
            };
            var confirmOptions = new DialogOptions
            {
                MaxWidth = MaxWidth.ExtraSmall,
                FullWidth = true,
                CloseOnEscapeKey = true,
                NoHeader = true,
            };

            var confirmDialog = await DialogService.ShowAsync<ConfirmDialog>("Downgrade to Free", confirmParams, confirmOptions);
            var confirmResult = await confirmDialog.Result;

            if (confirmResult is null || confirmResult.Canceled)
            {
                return;
            }

            try
            {
                await PlanApi.PurchasePlanAsync(Session.AccessToken!, plan.PlanKey, "monthly");
                try
                {
                    await Session.LoadCurrentPlanAsync(PlanApi);
                }
                catch (Exception ex)
                {
                    Snackbar.Add($"Failed to refresh plan: {ex.Message}", Severity.Error);
                    return;
                }
                Snackbar.Add("Plan downgraded to Free.", Severity.Success);
            }
            catch
            {
                Snackbar.Add("Failed to downgrade plan. Please try again.", Severity.Error);
            }
            return;
        }

        var parameters = new DialogParameters<PricingCheckoutDialog>
        {
            { x => x.Plan, plan },
        };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true,
            NoHeader = true,
        };

        var dialog = await DialogService.ShowAsync<PricingCheckoutDialog>($"Upgrade to {plan.DisplayName}", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            try
            {
                await Session.LoadCurrentPlanAsync(PlanApi);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Failed to refresh plan: {ex.Message}", Severity.Error);
                return;
            }
            Snackbar.Add("Plan upgraded successfully!", Severity.Success);
        }
    }

    public void Dispose()
    {
        Session.OnChange -= StateHasChanged;
    }

    // ── Helpers ──

    private static string GetCardClass(string planKey, bool isCurrent)
    {
        var sb = new System.Text.StringBuilder();
        switch (planKey)
        {
            case "pro":
                sb.Append("plan-popular");
                break;
            case "unlimited":
                sb.Append("plan-unlimited");
                break;
            default:
                sb.Append("plan-free");
                break;
        }
        if (isCurrent)
        {
            sb.Append(" plan-active");
        }
        return sb.ToString();
    }

    private static string GetPriceClass(string planKey) => planKey switch
    {
        "pro" => "pro-price",
        "unlimited" => "unlimited-price",
        _ => "",
    };

    private static string GetCurrentBtnClass(string planKey) => planKey switch
    {
        "pro" => "btn-plan-current-pro",
        "unlimited" => "btn-plan-current-unlimited",
        _ => "btn-plan-current",
    };

    private static string GetFeatureColorClass(string planKey) => planKey switch
    {
        "pro" => "pro",
        "unlimited" => "unlimited",
        _ => "free",
    };

    private static string GetDefaultTagline(string planKey) => planKey switch
    {
        "pro" => "Perfect for advanced learning and academic tasks",
        "unlimited" => "Fully optimized for unlimited performance",
        _ => "Experience basic academic features",
    };

    private static string FormatVndPrice(long? priceVnd)
    {
        if (priceVnd is null or 0) return "Free";
        // Format as e.g. "49,000₫"
        return $"{priceVnd.Value:N0}₫";
    }

    private static List<PlanDto> GetDefaultPlans()
    {
        return new List<PlanDto>
        {
            new("free", "Free", "Experience basic academic features",
                2L * 1024 * 1024 * 1024, 100, 20, 25_000, 100L * 1024 * 1024, null, 0, 0),
            new("pro", "Pro", "Perfect for advanced learning and academic tasks",
                10L * 1024 * 1024 * 1024, null, null, 100_000, null, null, 49_000, 490_000),
            new("unlimited", "Unlimited", "Fully optimized for unlimited performance",
                null, null, null, null, null, null, 99_000, 990_000),
        };
    }

    private sealed record PlanFeature(string Icon, string Label);

    private static List<PlanFeature> GetPlanFeatures(PlanDto plan)
    {
        var features = new List<PlanFeature>();

        if (plan.StorageQuotaBytes.HasValue)
        {
            var label = plan.StorageQuotaBytes == 0
                ? "Unlimited Storage"
                : $"{FormatBytes(plan.StorageQuotaBytes.Value)} Storage";
            features.Add(new PlanFeature(Icons.Material.Filled.Cloud, label));
        }
        else
        {
            features.Add(new PlanFeature(Icons.Material.Filled.AllInclusive, "Unlimited Storage"));
        }

        if (plan.MaxDocumentCount.HasValue)
        {
            features.Add(new PlanFeature(Icons.Material.Filled.Description,
                $"Max {plan.MaxDocumentCount.Value:N0} Documents"));
        }
        else
        {
            features.Add(new PlanFeature(Icons.Material.Filled.Description, "Unlimited Documents"));
        }

        if (plan.MaxFolderCount.HasValue)
        {
            var folderLimit = plan.MaxDocsPerFolder.HasValue
                ? $"{plan.MaxFolderCount.Value:N0} Folders ({plan.MaxDocsPerFolder.Value:N0} docs/Folder)"
                : $"{plan.MaxFolderCount.Value:N0} Folders";
            features.Add(new PlanFeature(Icons.Material.Filled.Folder, folderLimit));
        }
        else
        {
            features.Add(new PlanFeature(Icons.Material.Filled.Folder, "Unlimited Folders"));
        }

        if (plan.DailyTokenQuota.HasValue)
        {
            features.Add(new PlanFeature(Icons.Material.Filled.Token,
                $"{plan.DailyTokenQuota.Value:N0} tokens / day"));
        }
        else
        {
            features.Add(new PlanFeature(Icons.Material.Filled.Token, "Unlimited AI tokens"));
        }

        return features;
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes >= 1_073_741_824) return $"{bytes / 1_073_741_824} GB";
        if (bytes >= 1_048_576) return $"{bytes / 1_048_576} MB";
        if (bytes >= 1_024) return $"{bytes / 1_024} KB";
        return $"{bytes} B";
    }
}

<style>
    .pricing-loading {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 50vh;
    }
    .pricing-error {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 50vh;
        gap: 1rem;
        color: var(--mud-palette-text-secondary);
    }
    .contact-note {
        font-size: 0.75rem;
        color: var(--mud-palette-text-secondary);
        margin-top: 0.5rem;
        text-align: center;
    }
</style>
