@page "/login"
@using AI_Study_Hub_v2.Dtos
@using AI_Study_Hub_v2.Services
@inject AuthApiClient AuthApi
@inject AuthSessionState Session
@inject AuthPersistenceService AuthPersistence
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Login - AI Study Hub</PageTitle>

<section class="auth-shell auth-shell-premium">
    <div class="auth-visual auth-visual-premium">
        <div class="auth-visual-grid" aria-hidden="true"></div>
        <div class="auth-orb" aria-hidden="true"></div>
        <div class="auth-matrix-card" aria-hidden="true">
            <div class="auth-matrix-topline">
                <span></span><span></span><span></span>
            </div>
            <div class="auth-matrix-core">
                <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" />
            </div>
            <p>Active Matrix Mode</p>
        </div>
        <div class="auth-hero-copy">
            <MudLink Href="/" Class="auth-brand-link" Underline="Underline.None">
                <span class="auth-brand-mark"><MudIcon Icon="@Icons.Material.Filled.School" /></span>
                <span>AI Study Hub</span>
            </MudLink>
            <span class="section-kicker">Secure access</span>
            <h1 class="workspace-title mt-4">Welcome back to your <span class="gradient-text">study hub</span>.</h1>
            <p class="workspace-copy mt-3">
                Your personalized AI library is ready. Continue research where you left off with private documents, grounded answers, and visible citations.
            </p>
            <div class="auth-chip-row">
                <span><MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Size="Size.Small" /> JWT protected</span>
                <span><MudIcon Icon="@Icons.Material.Filled.AutoStories" Size="Size.Small" /> Source backed</span>
                <span><MudIcon Icon="@Icons.Material.Filled.Bolt" Size="Size.Small" /> RAG ready</span>
            </div>
            <div class="auth-metric-row">
                <div class="auth-metric"><strong>24/7</strong><span>study workspace</span></div>
                <div class="auth-metric"><strong>RAG</strong><span>cited chat</span></div>
                <div class="auth-metric"><strong>Vault</strong><span>private library</span></div>
            </div>
        </div>
    </div>

    <MudPaper Class="auth-card glass-card auth-form-card" Elevation="0">
        <MudStack Spacing="3">
            <div class="auth-mobile-brand">
                <span class="auth-brand-mark"><MudIcon Icon="@Icons.Material.Filled.School" /></span>
                <span>AI Study Hub</span>
            </div>

            <div>
                <span class="auth-form-eyebrow">Log in</span>
                <MudText Typo="Typo.h4">Log In</MudText>
                <MudText Typo="Typo.body2" Class="workspace-copy">
                    Enter your credentials to access your academic dashboard.
                </MudText>
            </div>

            <MudForm @ref="_form" Model="_model" @bind-IsValid="_isValid" Class="auth-form-stack">
                <MudTextField T="string"
                              Label="Email address"
                              @bind-Value="_model.Email"
                              Required="true"
                              RequiredError="Email is required"
                              Validation="@(new EmailAddressAttribute() { ErrorMessage = "Invalid email" })"
                              InputType="InputType.Email"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.AlternateEmail"
                              Disabled="_busy" />

                <MudTextField T="string"
                              Label="Password"
                              @bind-Value="_model.Password"
                              Required="true"
                              RequiredError="Password is required"
                              InputType="InputType.Password"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Lock"
                              Disabled="_busy" />
            </MudForm>

            <HumanCheck @ref="_humanCheck" Action="login" Disabled="_busy" ValidChanged="OnHumanCheckChanged" />

            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Filled">@_error</MudAlert>
            }

            <MudButton Variant="Variant.Filled"
                       FullWidth="true"
                       Class="premium-button auth-submit-button"
                       EndIcon="@Icons.Material.Filled.ArrowForward"
                       OnClick="SubmitAsync"
                       Disabled="_busy || !_humanCheckValid">
                @if (_busy)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Authenticating...</MudText>
                }
                else
                {
                    <MudText>Sign in</MudText>
                }
            </MudButton>

            <div class="auth-divider"><span>Protected academic session</span></div>

            <MudStack Row="true" Justify="Justify.Center" Spacing="1" Style="flex-wrap: wrap;">
                <MudText Typo="Typo.body2" Color="Color.Secondary">No account yet?</MudText>
                <MudLink Href="/register" Underline="Underline.Always">Get started</MudLink>
            </MudStack>
        </MudStack>
    </MudPaper>
</section>

@code {
    private MudForm? _form;
    private HumanCheck? _humanCheck;
    private bool _isValid;
    private bool _humanCheckValid;
    private bool _busy;
    private string? _error;
    private readonly LoginRequest _model = new();

    protected override void OnInitialized()
    {
        if (Session.IsAuthenticated)
        {
            RedirectByRole();
        }
    }

    private void RedirectByRole()
    {
        Nav.NavigateTo(
            AdminAccessPolicy.GetAuthenticatedLandingPage(Session.CurrentUser?.Role),
            replace: true);
    }

    private Task OnHumanCheckChanged(bool valid)
    {
        _humanCheckValid = valid;
        return Task.CompletedTask;
    }

    private async Task SubmitAsync()
    {
        _error = null;
        if (_form is null) return;
        await _form.ValidateAsync();
        var humanOk = _humanCheck is not null && await _humanCheck.ValidateAsync();
        if (!_isValid || !humanOk) return;
        _model.RecaptchaToken = _humanCheck?.GetResponseToken();

        _busy = true;
        StateHasChanged();
        try
        {
            var resp = await AuthApi.LoginAsync(_model);
            Session.Set(resp);
            await AuthPersistence.SaveAsync(resp);
            Snackbar.Add($"Welcome back, {resp.User.FullName}!", Severity.Success);
            RedirectAuthenticatedUser(resp.User.Role);
        }
        catch (AuthApiException ex)
        {
            _error = ex.StatusCode == 401
                ? "Invalid email or password."
                : ex.Message;
        }
        catch (Exception ex)
        {
            _error = $"Network error: {ex.Message}";
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    private void RedirectAuthenticatedUser(string? role)
    {
        Nav.NavigateTo(AdminAccessPolicy.GetAuthenticatedLandingPage(role), replace: true);
    }
}
