@page "/login"
@rendermode InteractiveServer
@using AI_Study_Hub_v2.Dtos
@using AI_Study_Hub_v2.Services
@inject AuthApiClient AuthApi
@inject AuthSessionState Session
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Login - AI Study Hub v2</PageTitle>

<MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height: 80vh;">
    <MudPaper Class="pa-8" Elevation="4" Style="width: 100%; max-width: 420px;">
        <MudStack Spacing="3">
            <MudText Typo="Typo.h5" Align="Align.Center">Sign in</MudText>
            <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
                AI Study Hub v2 demo - login / logout
            </MudText>

            <MudForm @ref="_form" Model="_model" @bind-IsValid="_isValid">
                <MudTextField T="string"
                              Label="Email"
                              @bind-Value="_model.Email"
                              Required="true"
                              RequiredError="Email is required"
                              Validation="@(new EmailAddressAttribute() { ErrorMessage = "Invalid email" })"
                              InputType="InputType.Email"
                              Variant="Variant.Outlined"
                              Disabled="_busy" />

                <MudTextField T="string"
                              Label="Password"
                              @bind-Value="_model.Password"
                              Required="true"
                              RequiredError="Password is required"
                              InputType="InputType.Password"
                              Variant="Variant.Outlined"
                              Class="mt-3"
                              Disabled="_busy" />
            </MudForm>

            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Filled">@_error</MudAlert>
            }

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       OnClick="SubmitAsync"
                       Disabled="_busy || !_isValid">
                @if (_busy)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Signing in...</MudText>
                }
                else
                {
                    <MudText>Sign in</MudText>
                }
            </MudButton>

            <MudDivider />

            <MudStack Row="true" Justify="Justify.Center" Spacing="1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">No account yet?</MudText>
                <MudLink Href="/register" Underline="Underline.Always">Create one</MudLink>
            </MudStack>
        </MudStack>
    </MudPaper>
</MudStack>

@code {
    private MudForm? _form;
    private bool _isValid;
    private bool _busy;
    private string? _error;
    private readonly LoginRequest _model = new();

    protected override void OnInitialized()
    {
        if (Session.IsAuthenticated)
        {
            Nav.NavigateTo("/profile", replace: true);
        }
    }

    private async Task SubmitAsync()
    {
        _error = null;
        if (_form is null) return;
        await _form.ValidateAsync();
        if (!_isValid) return;

        _busy = true;
        StateHasChanged();
        try
        {
            var resp = await AuthApi.LoginAsync(_model);
            Session.Set(resp);
            Snackbar.Add($"Welcome back, {resp.User.FullName}!", Severity.Success);
            Nav.NavigateTo("/profile");
        }
        catch (AuthApiException ex)
        {
            _error = ex.StatusCode == 401
                ? "Invalid email or password."
                : ex.Message;
        }
        catch (Exception ex)
        {
            _error = $"Network error: {ex.Message}";
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }
}
