@page "/login"
@using AI_Study_Hub_v2.Dtos
@using AI_Study_Hub_v2.Services
@inject AuthApiClient AuthApi
@inject AuthSessionState Session
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Login - AI Study Hub</PageTitle>

<section class="auth-shell">
    <div class="auth-visual">
        <div class="auth-visual-grid" aria-hidden="true"></div>
        <div class="auth-orb" aria-hidden="true"></div>
        <div style="position: relative; z-index: 1; max-width: 620px;">
            <span class="section-kicker">Secure access</span>
            <h1 class="workspace-title mt-4">Enter the <span class="gradient-text">study vault</span>.</h1>
            <p class="workspace-copy mt-3">
                Continue your RAG workspace with source-backed answers, document folders, and authenticated study sessions.
            </p>
            <div class="auth-metric-row">
                <div class="auth-metric"><strong>JWT</strong><span>protected session</span></div>
                <div class="auth-metric"><strong>RAG</strong><span>cited chat</span></div>
                <div class="auth-metric"><strong>Local</strong><span>dev stack ready</span></div>
            </div>
        </div>
    </div>

    <MudPaper Class="auth-card glass-card" Elevation="0">
        <MudStack Spacing="3">
            <div>
                <MudText Typo="Typo.h4">Welcome back</MudText>
                <MudText Typo="Typo.body2" Class="workspace-copy">
                    Sign in to upload documents, open AI Chat, and manage your private study library.
                </MudText>
            </div>

            <MudForm @ref="_form" Model="_model" @bind-IsValid="_isValid">
                <MudTextField T="string"
                              Label="Email"
                              @bind-Value="_model.Email"
                              Required="true"
                              RequiredError="Email is required"
                              Validation="@(new EmailAddressAttribute() { ErrorMessage = "Invalid email" })"
                              InputType="InputType.Email"
                              Variant="Variant.Outlined"
                              Disabled="_busy" />

                <MudTextField T="string"
                              Label="Password"
                              @bind-Value="_model.Password"
                              Required="true"
                              RequiredError="Password is required"
                              InputType="InputType.Password"
                              Variant="Variant.Outlined"
                              Class="mt-3"
                              Disabled="_busy" />
            </MudForm>

            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Filled">@_error</MudAlert>
            }

            <MudButton Variant="Variant.Filled"
                       FullWidth="true"
                       Class="premium-button"
                       OnClick="SubmitAsync"
                       Disabled="_busy">
                @if (_busy)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Signing in...</MudText>
                }
                else
                {
                    <MudText>Sign in</MudText>
                }
            </MudButton>

            <MudDivider />

            <MudStack Row="true" Justify="Justify.Center" Spacing="1" Style="flex-wrap: wrap;">
                <MudText Typo="Typo.body2" Color="Color.Secondary">No account yet?</MudText>
                <MudLink Href="/register" Underline="Underline.Always">Create one</MudLink>
            </MudStack>
        </MudStack>
    </MudPaper>
</section>

@code {
    private MudForm? _form;
    private bool _isValid;
    private bool _busy;
    private string? _error;
    private readonly LoginRequest _model = new();

    protected override void OnInitialized()
    {
        if (Session.IsAuthenticated)
        {
            Nav.NavigateTo("/profile", replace: true);
        }
    }

    private async Task SubmitAsync()
    {
        _error = null;
        if (_form is null) return;
        await _form.ValidateAsync();
        if (!_isValid) return;

        _busy = true;
        StateHasChanged();
        try
        {
            var resp = await AuthApi.LoginAsync(_model);
            Session.Set(resp);
            Snackbar.Add($"Welcome back, {resp.User.FullName}!", Severity.Success);
            Nav.NavigateTo("/profile");
        }
        catch (AuthApiException ex)
        {
            _error = ex.StatusCode == 401
                ? "Invalid email or password."
                : ex.Message;
        }
        catch (Exception ex)
        {
            _error = $"Network error: {ex.Message}";
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }
}
