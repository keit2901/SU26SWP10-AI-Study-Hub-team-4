@page "/community"
@implements IDisposable
@inject AuthSessionState Session
@inject FolderApiClient FoldersApi
@inject CommunityApiClient CommunityApi
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Community - AI Study Hub v2</PageTitle>

<div class="community-page">
    <div class="community-layout">
        <aside class="community-sidebar">
            <div class="sidebar-toggle">
                <div class="sidebar-toggle-inner">
                    <button class="sidebar-toggle-btn @(_activeTab == "community" ? "active" : "")"
                            @onclick="SwitchToCommunity">
                        <MudIcon Icon="@Icons.Material.Filled.Groups" Size="Size.Small" />
                        <span>Community</span>
                    </button>
                    <button class="sidebar-toggle-btn @(_activeTab == "personal" ? "active" : "")"
                            @onclick="SwitchToPersonal">
                        <MudIcon Icon="@Icons.Material.Filled.Share" Size="Size.Small" />
                        <span>Personal Shared</span>
                    </button>
                </div>
            </div>

            <div class="sidebar-list">
                <div class="sidebar-list-label">
                    @(_activeTab == "community" ? "Public Folders" : "My Shared Folders")
                </div>
                @if (_currentFolders.Count == 0)
                {
                    <div class="sidebar-empty">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">No folders yet</MudText>
                    </div>
                }
                else
                {
                    <div class="sidebar-items">
                        @foreach (var folder in _currentFolders)
                        {
                            var isSelected = _selectedFolderId == folder.Id;
                            var cidx = _currentFolders.IndexOf(folder);
                            var colors = new[] { "#7c6fcd", "#c0392b", "#2980b9", "#27ae60", "#e67e22", "#8e44ad", "#16a085", "#d35400" };
                            var color = colors[Math.Abs(cidx % colors.Length)];
                            var bgColor = color + "18";

                            <button class="sidebar-item @(isSelected ? "selected" : "")"
                                    @onclick="() => SelectFolder(folder.Id)">
                                <div class="sidebar-item-icon" style="background:@bgColor; color:@color">
                                    <MudIcon Icon="@GetFolderIcon(folder.Icon)" Size="Size.Small" />
                                </div>
                                <div class="sidebar-item-info">
                                    <span class="sidebar-item-name">@folder.Name</span>
                                    @if (_activeTab == "personal")
                                    {
                                        <span class="sidebar-item-meta" style="display: flex; align-items: center; gap: 0.25rem; width: 100%;">
                                            <span>@folder.DocumentCount sources</span>
                                            <span style="margin-left: auto; display: inline-flex; align-items: center; gap: 0.15rem;">
                                                <MudIcon Icon="@Icons.Material.Filled.ThumbUp" Style="font-size: 0.75rem;" />
                                                @folder.LikeCount
                                                <MudIcon Icon="@Icons.Material.Filled.ThumbDown" Style="font-size: 0.75rem;" />
                                                @folder.DislikeCount
                                            </span>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="sidebar-item-meta">@folder.DocumentCount sources</span>
                                    }
                                </div>
                                <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Class="sidebar-item-chevron" />
                            </button>
                        }
                    </div>
                }
            </div>

            <div class="sidebar-footer">
                <button class="sidebar-footer-btn">
                    <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" />
                    <span>Starred</span>
                </button>
                <button class="sidebar-footer-btn">
                    <MudIcon Icon="@Icons.Material.Filled.AccessTime" Size="Size.Small" />
                    <span>Recent</span>
                </button>
                <button class="sidebar-footer-btn">
                    <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Small" />
                    <span>All Folders</span>
                </button>
            </div>
        </aside>

        <main class="community-main">
            @if (_loading)
            {
                <div class="community-loading">
                    <MudProgressCircular Indeterminate="true" Size="Size.Medium" />
                    </div>

                    @if (_activeTab == "personal" && _totalPages > 1)
                    {
                        <div class="pagination-bar">
                            <div class="pagination-info">
                                Showing @((_currentPage - 1) * PageSize + 1)-@Math.Min(_currentPage * PageSize, _filteredFolders.Count) of @_filteredFolders.Count folders
                            </div>
                            <div class="pagination-controls">
                                <button class="pagination-btn" disabled="@(_currentPage <= 1)" @onclick="() => GoToPage(_currentPage - 1)">‹ Prev</button>
                                @foreach (var p in GetPageNumbers())
                                {
                                    if (p == -1)
                                    {
                                        <span class="pagination-ellipsis">…</span>
                                    }
                                    else
                                    {
                                        <button class="pagination-btn @(p == _currentPage ? "active" : "")" @onclick="() => GoToPage(p)">@p</button>
                                    }
                                }
                                <button class="pagination-btn" disabled="@(_currentPage >= _totalPages)" @onclick="() => GoToPage(_currentPage + 1)">Next ›</button>
                            </div>
                        </div>
                    }
                }
                else
            {
                <div class="community-main-header">
                    <h1 class="community-title">
                        @(_activeTab == "community" ? "Public Community" : "Personal Shared")
                    </h1>
                    <p class="community-subtitle">
                        @(_activeTab == "community"
                            ? "Browse and rate folders shared by the community"
                            : "Engagement dashboard for your shared folders")
                    </p>
                </div>

                @if (_activeTab == "personal" && _personalFolders.Count > 0)
                {
                    <div class="personal-status-grid">
                        <div class="personal-status-card shared">
                            <div class="personal-status-icon">
                                <MudIcon Icon="@Icons.Material.Filled.Share" Size="Size.Small" />
                            </div>
                            <div class="personal-status-content">
                                <div class="personal-status-label">Shared</div>
                                <div class="personal-status-value">@_personalApprovedFolders.Count</div>
                                <p class="personal-status-note">Folders shared successfully.</p>
                            </div>
                        </div>

                        <div class="personal-status-card pending">
                            <div class="personal-status-icon">
                                <MudIcon Icon="@Icons.Material.Filled.HourglassTop" Size="Size.Small" />
                            </div>
                            <div class="personal-status-content">
                                <div class="personal-status-label">Pending Share</div>
                                <div class="personal-status-value">@_pendingPersonalShareCount</div>
                                <p class="personal-status-note">Folders waiting for moderator review.</p>
                            </div>
                        </div>

                        <div class="personal-status-card rejected">
                            <div class="personal-status-icon">
                                <MudIcon Icon="@Icons.Material.Filled.ReportProblem" Size="Size.Small" />
                            </div>
                            <div class="personal-status-content">
                                <div class="personal-status-label">Reject</div>
                                <div class="personal-status-value">@_personalFailedFolders.Count</div>
                                <p class="personal-status-note">Folders need updates before sharing again.</p>
                            </div>
                        </div>
                    </div>

                    @if (_personalFailedFolders.Count > 0)
                    {
                        <div class="review-board-panel failed personal-failed-panel">
                            <div class="review-board-header">
                                <div>
                                    <h3>Share Failed</h3>
                                </div>
                                <span class="review-board-count failed">@_personalFailedFolders.Count</span>
                            </div>

                            <div class="review-board-table-wrap">
                                <table class="review-board-table">
                                    <thead>
                                        <tr>
                                            <th>Folder</th>
                                            <th>AI reason</th>
                                            <th class="review-board-action-header">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var folder in _personalFailedFolders.Take(5))
                                        {
                                            <tr>
                                                <td>
                                                    <div class="review-board-cell-title">@folder.Name</div>
                                                </td>
                                                <td>
                                                    <div class="review-board-reason-cell">@GetShareFailureReason(folder)</div>
                                                    <div class="review-board-subtext">
                                                        AI failed @folder.AiReviewFailureCount time@(folder.AiReviewFailureCount == 1 ? string.Empty : "s")
                                                    </div>
                                                </td>
                                                <td class="review-board-action-cell">
                                                    <div class="review-board-actions" @onclick:stopPropagation>
                                                        @if (CanRequestHumanReview(folder))
                                                        {
                                                            <button type="button" class="review-board-action-btn info" @onclick="() => ShowHumanReviewDialogAsync(folder)">
                                                                Review by human
                                                            </button>
                                                        }
                                                        <button type="button" class="review-board-action-btn primary" @onclick="() => RequestShareAsync(folder)">
                                                            Share Again
                                                        </button>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                }

                <div class="community-search">
                    <div class="search-filter-row">
                        <div class="search-wrapper">
                            <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" Class="search-icon" />
                            <input type="text"
                                   class="search-input"
                                   placeholder="Search folders..."
                                   value="@_searchQuery"
                                   @oninput="HandleSearchInput" />
                        </div>
                        @if (_activeTab == "personal")
                        {
                            <div class="filter-wrapper">
                                <select class="filter-select" value="@_statusFilter" @onchange="HandleStatusFilterChange">
                                    <option value="">All Status</option>
                                    <option value="Shared">Shared</option>
                                    <option value="Pending Share">Pending Share</option>
                                    <option value="Review by human">Review by human</option>
                                    <option value="Reject">Reject</option>
                                </select>
                            </div>
                        }
                    </div>
                </div>

                @if (_filteredFolders.Count > 0)
                {
                    <div class="community-grid">
                        @if (_activeTab == "community")
                        {
                            @foreach (var folder in _filteredFolders)
                            {
                                var cidx = _allCommunityFolders.IndexOf(folder);
                                var colors = new[] { "#7c6fcd", "#c0392b", "#2980b9", "#27ae60", "#e67e22", "#8e44ad", "#16a085", "#d35400" };
                                var color = colors[Math.Abs(cidx % colors.Length)];
                                var bgColor = color + "18";
                                var vote = _votes.GetValueOrDefault(folder.Id);

                                <div class="community-card" @onclick="() => GoToFolder(folder.Id)">
                                    <div class="card-header">
                                        <div class="card-icon" style="background:@bgColor; color:@color">
                                            <MudIcon Icon="@GetFolderIcon(folder.Icon)" Size="Size.Medium" />
                                        </div>
                                        <div class="card-menu-area" @onclick:stopPropagation>
                                            <div class="card-menu-trigger" @onclick="() => ToggleMenu(folder.Id)">
                                                <MudIcon Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" />
                                            </div>
                                            @if (_openMenuFolderId == folder.Id)
                                            {
                                                <div class="card-menu-dropdown">
                                                    <button class="menu-item" @onclick="async () => { var id = folder.Id; _openMenuFolderId = null; await CopyToLibrary(id); }">Copy to Library</button>
                                                    <button class="menu-item" @onclick="async () => await OpenReportDialogAsync(folder)">Report</button>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                    <div class="card-body">
                                        <h3 class="card-title">@folder.Name</h3>
                                        <div class="card-author">
                                            <span class="card-avatar" style="background:@color">@GetInitials(folder.OwnerName)</span>
                                            <span class="card-owner">@(folder.OwnerName ?? "Unknown")</span>
                                            <span class="card-sources">@folder.DocumentCount sources</span>
                                        </div>
                                    </div>
                                    <div class="card-actions" @onclick:stopPropagation>
                                        <button class="action-btn like-btn @(vote == true ? "voted" : "")"
                                                @onclick="() => Vote(folder.Id, true)">
                                            <MudIcon Icon="@Icons.Material.Filled.ThumbUp" Size="Size.Small" />
                                            @FormatCount(GetDisplayLikes(folder))
                                        </button>
                                        <button class="action-btn dislike-btn @(vote == false ? "voted" : "")"
                                                @onclick="() => Vote(folder.Id, false)">
                                            <MudIcon Icon="@Icons.Material.Filled.ThumbDown" Size="Size.Small" />
                                            @FormatCount(GetDisplayDislikes(folder))
                                        </button>
                                        <div class="approval-bar">
                                            <div class="approval-track">
                                                <div class="approval-fill" style="width: @ApprovalPercent(folder)%"></div>
                                            </div>
                                            <span class="approval-pct">@ApprovalPercent(folder)%</span>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            @foreach (var folder in _pagedFolders)
                            {
                                var cidx = _personalFolders.IndexOf(folder);
                                var colors = new[] { "#7c6fcd", "#c0392b", "#2980b9", "#27ae60", "#e67e22", "#8e44ad", "#16a085", "#d35400" };
                                var color = colors[Math.Abs(cidx % colors.Length)];

                                <div class="personal-card" @onclick="() => GoToFolder(folder.Id)">
                                    <div class="personal-card-strip" style="background:@color"></div>
                                    <div class="personal-card-body">
                                        <div class="personal-card-header">
                                            <div class="personal-card-icon" style="background:@(color + "18"); color:@color">
                                                <MudIcon Icon="@GetFolderIcon(folder.Icon)" Size="Size.Small" />
                                            </div>
                                            <div class="personal-card-info">
                                                <h3 class="personal-card-title">@folder.Name</h3>
                                                <div style="display: flex; align-items: center; gap: 0.375rem; flex-wrap: wrap;">
                                                    <span class="personal-card-sources">@folder.DocumentCount sources</span>
                                                    @{
                                                        var badgeStyles = GetPersonalShareStatusBadgeStyles(folder);
                                                        var badgeStyleAttr = $"display: inline-flex; align-items: center; padding: 0.125rem 0.375rem; border-radius: 9999px; font-size: 0.65rem; font-weight: 600; background: {badgeStyles.Bg}; color: {badgeStyles.Color}; line-height: 1;";
                                                        var dotStyleAttr = $"display: inline-block; width: 0.3125rem; height: 0.3125rem; border-radius: 9999px; margin-right: 0.1875rem; background: {badgeStyles.DotColor};";
                                                    }
                                                    <span style="@badgeStyleAttr">
                                                        <span style="@dotStyleAttr"></span>
                                                        @GetPersonalShareStatusText(folder)
                                                    </span>
                                                </div>
                                            </div>
                                            <div class="personal-card-metrics">
                                                @if (folder.ShareStatus == Data.Entities.FolderStatus.Approved)
                                                {
                                                    <div class="personal-card-stats personal-card-stats-inline">
                                                        <div class="stat-pill stat-likes compact">
                                                            <MudIcon Icon="@Icons.Material.Filled.ThumbUp" Size="Size.Small" />
                                                            <div>
                                                                <strong>@FormatCount(folder.LikeCount)</strong>
                                                                <span>Likes</span>
                                                            </div>
                                                        </div>
                                                        <div class="stat-pill stat-dislikes compact">
                                                            <MudIcon Icon="@Icons.Material.Filled.ThumbDown" Size="Size.Small" />
                                                            <div>
                                                                <strong>@FormatCount(folder.DislikeCount)</strong>
                                                                <span>Dislikes</span>
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                }
                else
                {
                    <div class="community-empty">
                        <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Large" Color="Color.Secondary" />
                        <p class="empty-title">No folders found</p>
                        <p class="empty-subtitle">Try a different search term</p>
                    </div>
                }
            }
        </main>
    </div>
</div>

@code {
    private string _activeTab = "community";
    private string _searchQuery = "";
    private string? _statusFilter;
    private bool _loading = true;

    private const int PageSize = 10;
    private int _currentPage = 1;

    private List<FolderDto> _allCommunityFolders = new();
    private List<FolderDto> _personalFolders = new();

    private Dictionary<Guid, bool?> _votes = new();
    private Guid? _openMenuFolderId = null;
    private Guid? _selectedFolderId = null;

    private List<FolderDto> _currentFolders =>
        _activeTab == "community" ? _allCommunityFolders : _personalApprovedFolders;

    private List<FolderDto> _personalApprovedFolders => _personalFolders
        .Where(folder => folder.ShareStatus == Data.Entities.FolderStatus.Approved)
        .OrderByDescending(folder => folder.SharedAt ?? folder.UpdatedAt)
        .ToList();

    private List<FolderDto> _personalFailedFolders => _personalFolders
        .Where(folder => folder.ShareStatus == Data.Entities.FolderStatus.Rejected)
        .OrderByDescending(folder => folder.UpdatedAt)
        .ToList();

    private int _pendingPersonalShareCount => _personalFolders.Count(folder => folder.ShareStatus == Data.Entities.FolderStatus.PendingShare);

    private List<FolderDto> _filteredFolders
    {
        get
        {
            var source = _activeTab == "community" ? _allCommunityFolders : _personalFolders;

            if (!string.IsNullOrWhiteSpace(_searchQuery))
            {
                var q = _searchQuery.Trim().ToLowerInvariant();
                source = source.Where(f =>
                    f.Name.Contains(q, StringComparison.OrdinalIgnoreCase) ||
                    (f.OwnerName?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false)).ToList();
            }

            if (!string.IsNullOrWhiteSpace(_statusFilter) && _activeTab == "personal")
            {
                source = source.Where(f => MatchesPersonalStatusFilter(f, _statusFilter)).ToList();
            }

            if (_activeTab == "personal")
            {
                source = source
                    .OrderByDescending(GetPersonalActivityTimestamp)
                    .ToList();
            }

            return source;
        }
    }

    private List<FolderDto> _pagedFolders =>
        _filteredFolders
            .Skip((_currentPage - 1) * PageSize)
            .Take(PageSize)
            .ToList();

    private int _totalPages => Math.Max(1, (int)Math.Ceiling((double)_filteredFolders.Count / PageSize));

    protected override async Task OnInitializedAsync()
    {
        Session.OnChange += HandleSessionChanged;
        await LoadAsync();
    }

    private void HandleSessionChanged()
    {
        _ = InvokeAsync(LoadAsync);
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _personalFolders.Clear();
        _votes.Clear();
        try
        {
            var accessToken = Session.IsAuthenticated ? Session.AccessToken : null;
            var shared = await FoldersApi.ListSharedAsync(accessToken);
            _allCommunityFolders = shared.ToList();

            if (Session.IsAuthenticated && Session.AccessToken is not null)
            {
                var personal = await FoldersApi.ListPersonalSharedAsync(Session.AccessToken);
                _personalFolders = personal.ToList();

                foreach (var f in _allCommunityFolders)
                {
                    if (f.CurrentUserVote.HasValue)
                        _votes[f.Id] = f.CurrentUserVote.Value;
                }
                foreach (var f in _personalFolders)
                {
                    if (f.CurrentUserVote.HasValue)
                        _votes[f.Id] = f.CurrentUserVote.Value;
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("Failed to load: " + ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void SwitchToCommunity()
    {
        _activeTab = "community";
        _searchQuery = "";
        _statusFilter = null;
        _currentPage = 1;
        _openMenuFolderId = null;
    }

    private void SwitchToPersonal()
    {
        _activeTab = "personal";
        _searchQuery = "";
        _statusFilter = null;
        _currentPage = 1;
        _openMenuFolderId = null;
    }

    private void SelectFolder(Guid folderId)
    {
        _selectedFolderId = folderId;
        GoToFolder(folderId);
    }

    private void GoToFolder(Guid folderId)
    {
        Nav.NavigateTo("/ai/chat?folderId=" + folderId);
    }

    private async Task RequestShareAsync(FolderDto folder)
    {
        if (folder.ShareStatus == Data.Entities.FolderStatus.PendingShare
            || folder.ShareStatus == Data.Entities.FolderStatus.Approved) return;

        if (string.IsNullOrWhiteSpace(Session.AccessToken)) return;

        try
        {
            var updated = await FoldersApi.RequestShareAsync(Session.AccessToken!, folder.Id);
            ReplacePersonalFolder(updated);
            Snackbar.Add(GetShareDecisionMessage(updated), GetShareDecisionSeverity(updated));
        }
        catch (DocumentApiException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task ShowHumanReviewDialogAsync(FolderDto folder)
    {
        if (!CanRequestHumanReview(folder)) return;

        var parameters = new DialogParameters
        {
            ["FolderName"] = folder.Name,
            ["AiReason"] = folder.AiReviewReason,
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialogRef = await DialogService.ShowAsync<AppealFolderShareDialog>("Review by human", parameters, options);
        var result = await dialogRef.Result;
        if (result is null || result.Canceled) return;

        var message = result.Data as string;
        await RequestHumanReviewAsync(folder, message);
    }

    private async Task RequestHumanReviewAsync(FolderDto folder, string? message)
    {
        if (string.IsNullOrWhiteSpace(Session.AccessToken)) return;

        try
        {
            var updated = await FoldersApi.AppealShareReviewAsync(
                Session.AccessToken!,
                folder.Id,
                new AppealFolderShareRequest { Message = message });
            ReplacePersonalFolder(updated);
            Snackbar.Add("Human review requested. Your folder is now waiting for moderator review.", Severity.Info);
        }
        catch (DocumentApiException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private void HandleSearchInput(ChangeEventArgs e)
    {
        _searchQuery = e.Value?.ToString() ?? "";
        _currentPage = 1;
    }

    private void HandleStatusFilterChange(ChangeEventArgs e)
    {
        _statusFilter = e.Value?.ToString();
        if (string.IsNullOrWhiteSpace(_statusFilter))
            _statusFilter = null;
        _currentPage = 1;
    }

    private void GoToPage(int page)
    {
        if (page < 1 || page > _totalPages) return;
        _currentPage = page;
    }

    private List<int> GetPageNumbers()
    {
        var total = _totalPages;
        var current = _currentPage;
        var pages = new List<int>();

        if (total <= 7)
        {
            for (var i = 1; i <= total; i++) pages.Add(i);
        }
        else
        {
            pages.Add(1);
            if (current > 3) pages.Add(-1); // ellipsis

            var start = Math.Max(2, current - 1);
            var end = Math.Min(total - 1, current + 1);
            for (var i = start; i <= end; i++) pages.Add(i);

            if (current < total - 2) pages.Add(-1); // ellipsis
            pages.Add(total);
        }

        return pages;
    }

    private void ToggleMenu(Guid folderId)
    {
        _openMenuFolderId = _openMenuFolderId == folderId ? null : folderId;
    }

    private void ReplacePersonalFolder(FolderDto updated)
    {
        var index = _personalFolders.FindIndex(folder => folder.Id == updated.Id);
        if (index >= 0)
        {
            _personalFolders[index] = updated;
        }

        StateHasChanged();
    }

    private void ShowComingSoon()
    {
        Snackbar.Add("Coming soon", Severity.Info);
    }

    private async Task OpenReportDialogAsync(FolderDto folder)
    {
        _openMenuFolderId = null;
        if (!Session.IsAuthenticated || Session.AccessToken is null)
        {
            Snackbar.Add("Sign in to report", Severity.Warning);
            return;
        }

        var dialog = await DialogService.ShowAsync<ReportFolderDialog>(
            "Report shared folder",
            new DialogParameters<ReportFolderDialog>
            {
                { item => item.FolderName, folder.Name }
            },
            new DialogOptions
            {
                MaxWidth = MaxWidth.Small,
                FullWidth = true,
                CloseButton = true,
            });
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not string reason)
        {
            return;
        }

        try
        {
            await CommunityApi.ReportFolderAsync(Session.AccessToken, folder.Id, reason);
            Snackbar.Add("Report submitted", Severity.Success);
        }
        catch (DocumentApiException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task CopyToLibrary(Guid folderId)
    {
        if (!Session.IsAuthenticated || Session.AccessToken is null)
        {
            Snackbar.Add("Please sign in to copy folders", Severity.Warning);
            return;
        }

        try
        {
            var result = await FoldersApi.CopySharedFolderAsync(Session.AccessToken, folderId);
            Snackbar.Add($"Folder \"{result.Name}\" copied to your library with {result.DocumentCount} documents", Severity.Success);
        }
        catch (DocumentApiException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add("Failed to copy folder: " + ex.Message, Severity.Error);
        }
    }

    private async Task Vote(Guid folderId, bool isLike)
    {
        if (!Session.IsAuthenticated || Session.AccessToken is null)
        {
            Snackbar.Add("Please sign in to vote", Severity.Warning);
            return;
        }

        try
        {
            var result = await FoldersApi.VoteAsync(Session.AccessToken, folderId, isLike);

            if (result.CurrentUserVote.HasValue)
            {
                _votes[folderId] = result.CurrentUserVote.Value;
            }
            else
            {
                _votes.Remove(folderId);
            }

            var folder = _allCommunityFolders.FirstOrDefault(f => f.Id == folderId);
            if (folder is not null)
            {
                folder.LikeCount = result.LikeCount;
                folder.DislikeCount = result.DislikeCount;
                folder.CurrentUserVote = _votes.GetValueOrDefault(folderId);
            }

            var personalFolder = _personalFolders.FirstOrDefault(f => f.Id == folderId);
            if (personalFolder is not null)
            {
                personalFolder.LikeCount = result.LikeCount;
                personalFolder.DislikeCount = result.DislikeCount;
                personalFolder.CurrentUserVote = _votes.GetValueOrDefault(folderId);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("Vote failed: " + ex.Message, Severity.Error);
        }
    }

    private int GetDisplayLikes(FolderDto folder)
    {
        return folder.LikeCount;
    }

    private int GetDisplayDislikes(FolderDto folder)
    {
        return folder.DislikeCount;
    }

    private int ApprovalPercent(FolderDto folder)
    {
        var likes = GetDisplayLikes(folder);
        var dislikes = GetDisplayDislikes(folder);
        var total = likes + dislikes;
        return total == 0 ? 0 : (int)Math.Round((double)likes / total * 100);
    }

    private static string FormatCount(int n) => n >= 1000 ? (n / 1000.0).ToString("F1") + "k" : n.ToString();

    private static string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return string.Concat(parts.Take(2).Select(p => p[0])).ToUpperInvariant();
    }

