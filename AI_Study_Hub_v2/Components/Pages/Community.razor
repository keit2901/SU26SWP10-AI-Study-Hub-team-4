    private string GetStatusText(string? status)
    {
        return status switch
        {
            "Shared" => "Shared",
            "Pending Share" => "Pending Share",
            "Processing" => "Processing",
            "Rejected" => "Rejected",
            "Empty" => "Empty",
            _ => "Private"
        };
    }

    private static string GetPersonalShareStatusText(FolderDto folder)
    {
        if (IsHumanReviewPending(folder))
        {
            return "Review by human";
        }

        return folder.ShareStatus switch
        {
            Data.Entities.FolderStatus.Approved => "Shared",
            Data.Entities.FolderStatus.PendingShare => "Pending Share",
            Data.Entities.FolderStatus.Rejected => "Reject",
            _ => "Private"
        };
    }

    private static (string Bg, string Color, string DotColor) GetPersonalShareStatusBadgeStyles(FolderDto folder)
    {
        if (IsHumanReviewPending(folder))
        {
            return ("#eff6ff", "#1d4ed8", "#3b82f6");
        }

        return folder.ShareStatus switch
        {
            Data.Entities.FolderStatus.Approved => ("#eef2ff", "#4338ca", "#4f46e5"),
            Data.Entities.FolderStatus.PendingShare => ("#fefce8", "#a16207", "#ca8a04"),
            Data.Entities.FolderStatus.Rejected => ("#fef2f2", "#b91c1c", "#ef4444"),
            _ => ("#f9fafb", "#6b7280", "#9ca3af")
        };
    }

    private static bool CanRequestHumanReview(FolderDto folder) =>
        folder.ShareStatus == Data.Entities.FolderStatus.Rejected
        && folder.AiReviewFailureCount >= 2
        && !string.Equals(folder.ShareReviewSource, "HUMAN", StringComparison.OrdinalIgnoreCase);

    private static bool IsHumanReviewPending(FolderDto folder) =>
        folder.ShareStatus == Data.Entities.FolderStatus.PendingShare
        && folder.AppealRequestedAt.HasValue;

    private static bool MatchesPersonalStatusFilter(FolderDto folder, string statusFilter)
    {
        return statusFilter switch
        {
            "Pending Share" => folder.ShareStatus == Data.Entities.FolderStatus.PendingShare && !folder.AppealRequestedAt.HasValue,
            "Review by human" => IsHumanReviewPending(folder),
            _ => GetPersonalShareStatusText(folder) == statusFilter
        };
    }

    private static DateTimeOffset GetPersonalActivityTimestamp(FolderDto folder) =>
        folder.AppealRequestedAt
        ?? folder.SharedAt
        ?? folder.UpdatedAt;

    private static string GetShareFailureReason(FolderDto folder) =>
        string.IsNullOrWhiteSpace(folder.AiReviewReason)
            ? "AI did not approve this folder."
            : folder.AiReviewReason;

    private static string GetPersonalShareSupportMessage(FolderDto folder)
    {
        var reason = GetShareFailureReason(folder);

        return folder.ShareStatus switch
        {
            Data.Entities.FolderStatus.Rejected when folder.AiReviewFailureCount >= 2
                => $"AI rejected this folder after {folder.AiReviewFailureCount} attempts. Reason: {reason}",
            Data.Entities.FolderStatus.Rejected
                => $"AI rejected this folder. Reason: {reason}",
            Data.Entities.FolderStatus.PendingShare when folder.AppealRequestedAt.HasValue
                => string.IsNullOrWhiteSpace(folder.AppealMessage)
                    ? $"Your review request has been sent to the moderator. AI reason: {reason}"
                    : $"Moderator will review this folder. Your note: {folder.AppealMessage}",
            _ => reason
        };
    }

    private static string GetShareDecisionMessage(FolderDto folder)
    {
        var reason = string.IsNullOrWhiteSpace(folder.AiReviewReason)
            ? string.Empty
            : $" Reason: {folder.AiReviewReason}";

        return folder.ShareStatus switch
        {
            Data.Entities.FolderStatus.Approved => $"AI approved this folder for community sharing.{reason}",
            Data.Entities.FolderStatus.Rejected when folder.AiReviewFailureCount >= 2 => $"AI did not approve this folder after {folder.AiReviewFailureCount} review attempts. Human review is now available.{reason}",
            Data.Entities.FolderStatus.Rejected => $"AI did not approve this folder. You can try sharing again.{reason}",
            Data.Entities.FolderStatus.PendingShare => $"Human review requested. Your folder is waiting in the moderator queue.{reason}",
            _ => $"Share request submitted.{reason}"
        };
    }

    private static Severity GetShareDecisionSeverity(FolderDto folder) => folder.ShareStatus switch
    {
        Data.Entities.FolderStatus.Approved => Severity.Success,
        Data.Entities.FolderStatus.Rejected => Severity.Warning,
        Data.Entities.FolderStatus.PendingShare when folder.RequiresHumanReview || folder.AppealRequestedAt.HasValue => Severity.Info,
        _ => Severity.Success
    };

    private (string Bg, string Color, string DotColor) GetStatusBadgeStyles(string? status)
    {
        return status switch
        {
            "Shared" => ("#eef2ff", "#4338ca", "#4f46e5"),
            "Pending Share" => ("#fefce8", "#a16207", "#ca8a04"),
            "Processing" => ("rgba(243,232,255,0.8)", "#7e22ce", "#9333ea"),
            "Rejected" => ("#fef2f2", "#b91c1c", "#ef4444"),
            "Empty" => ("#f3f4f6", "#4b5563", "#9ca3af"),
            _ => ("#f9fafb", "#6b7280", "#9ca3af")
        };
    }

