@page "/documents/upload"
@using System.ComponentModel.DataAnnotations
@using AI_Study_Hub_v2.Dtos
@using AI_Study_Hub_v2.Services
@inject DocumentApiClient DocumentsApi
@inject FolderApiClient FoldersApi
@inject AuthSessionState Session
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Upload document - AI Study Hub v2</PageTitle>

<MudStack Class="workspace-shell pa-4" Spacing="3">
    <section class="workspace-hero">
        <span class="section-kicker">Source ingestion</span>
        <MudText Typo="Typo.h4" Class="mt-3">Upload study document</MudText>
        <MudText Typo="Typo.body1" Class="workspace-copy">
            Add PDFs, Word files, and slides to the private retrieval pipeline. Accepted files are capped at 50 MB.
        </MudText>
    </section>

    <MudPaper Class="pa-8 glass-card" Elevation="0" Style="width: 100%; max-width: 680px; margin: 0 auto;">
        <MudStack Spacing="3">

            <MudForm @ref="_form" Model="_model" @bind-IsValid="_isValid">
                <MudTextField T="string"
                              Label="Subject code (e.g. SWP391)"
                              @bind-Value="_model.SubjectCode"
                              Required="true"
                              RequiredError="Subject code is required"
                              Validation="@(new RegularExpressionAttribute(@"^[A-Z]{3}[0-9]{3}$") { ErrorMessage = "3 uppercase letters + 3 digits, e.g. SWP391" })"
                              Variant="Variant.Outlined"
                              Disabled="_busy" />

                <MudTextField T="string"
                              Label="Semester (e.g. SU26)"
                              @bind-Value="_model.Semester"
                              Required="true"
                              RequiredError="Semester is required"
                              Validation="@(new RegularExpressionAttribute(@"^(SP|SU|FA|WI)[0-9]{2}$") { ErrorMessage = "SP/SU/FA/WI + 2 digits, e.g. SU26" })"
                              Variant="Variant.Outlined"
                              Class="mt-3"
                              Disabled="_busy" />

                <MudSelect T="Guid?"
                           Label="Folder"
                           @bind-Value="_model.FolderId"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Class="mt-3"
                           Clearable="true"
                           Disabled="_busy || _foldersBusy"
                           Placeholder="Loose document">
                    <MudSelectItem T="Guid?" Value="@(null)">Loose document</MudSelectItem>
                    @foreach (var folder in _folders)
                    {
                        <MudSelectItem T="Guid?" Value="@folder.Id">@folder.Name (@folder.DocumentCount)</MudSelectItem>
                    }
                </MudSelect>

                <MudStack Row="true" Spacing="1" Class="mt-2" Style="flex-wrap: wrap;">
                    <MudTextField T="string"
                                  Label="New folder name"
                                  @bind-Value="_newFolderName"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Disabled="_busy || _foldersBusy"
                                  Style="flex: 1; min-width: 210px;" />
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.CreateNewFolder"
                               OnClick="CreateFolderAsync"
                               Disabled="_busy || _foldersBusy || string.IsNullOrWhiteSpace(_newFolderName)">
                        Create folder
                    </MudButton>
                </MudStack>
            </MudForm>

            <MudFileUpload T="IBrowserFile"
                           @ref="_uploader"
                           OnFilesChanged="OnInputFileChangedAsync"
                           Accept="@AcceptAttr"
                           MaximumFileCount="1"
                           MaxFileSize="MaxFileSizeBytes"
                           Hidden="true"
                           Disabled="_busy" />

            <MudButton Variant="Variant.Filled"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.AttachFile"
                       FullWidth="true"
                       OnClick="OpenFilePickerAsync"
                       Disabled="_busy">
                @(_file is null ? "Choose file" : "Replace file")
            </MudButton>

            @if (_file is not null)
            {
                <MudPaper Class="pa-3 glass-card-soft" Outlined="false" Elevation="0">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.body2"><b>@_file.Name</b></MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @FormatBytes(_file.Size) — @_file.ContentType
                        </MudText>
                    </MudStack>
                </MudPaper>
            }

            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Filled">@_error</MudAlert>
            }

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       OnClick="SubmitAsync"
                       Disabled="_busy || !_isValid || _file is null">
                @if (_busy)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Uploading...</MudText>
                }
                else
                {
                    <MudText>Upload</MudText>
                }
            </MudButton>
        </MudStack>
    </MudPaper>
</MudStack>

@code {
    private const long MaxFileSizeBytes = DocumentApiClient.MaxFileSizeBytes;
    private const string AcceptAttr = ".pdf,.doc,.docx,.ppt,.pptx,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-powerpoint,application/vnd.openxmlformats-officedocument.presentationml.presentation";

    private MudForm? _form;
    private MudFileUpload<IBrowserFile>? _uploader;
    private bool _isValid;
    private bool _busy;
    private bool _foldersBusy;
    private string? _error;
    private string? _newFolderName;
    private IBrowserFile? _file;
    private List<FolderDto> _folders = new();
    private readonly UploadDocumentRequest _model = new();

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated)
        {
            Nav.NavigateTo("/login", replace: true);
            return;
        }

        await LoadFoldersAsync();
    }

    private Task OpenFilePickerAsync()
        => _uploader?.OpenFilePickerAsync() ?? Task.CompletedTask;

    private async Task LoadFoldersAsync()
    {
        if (string.IsNullOrEmpty(Session.AccessToken)) return;
        _foldersBusy = true;
        try
        {
            _folders = (await FoldersApi.ListAsync(Session.AccessToken!)).ToList();
        }
        catch (DocumentApiException ex)
        {
            Snackbar.Add(MapError(ex), Severity.Warning);
            if (ex.StatusCode == 401)
            {
                Session.Clear();
                Nav.NavigateTo("/login", replace: true);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not load folders: {ex.Message}", Severity.Warning);
        }
        finally
        {
            _foldersBusy = false;
        }
    }

    private async Task CreateFolderAsync()
    {
        if (string.IsNullOrWhiteSpace(Session.AccessToken) || string.IsNullOrWhiteSpace(_newFolderName)) return;
        _foldersBusy = true;
        _error = null;
        try
        {
            var folder = await FoldersApi.CreateAsync(
                Session.AccessToken!,
                new CreateFolderRequest { Name = _newFolderName.Trim() });

            _folders.Add(folder);
            _folders = _folders.OrderBy(f => f.Name).ToList();
            _model.FolderId = folder.Id;
            _newFolderName = null;
            Snackbar.Add($"Created folder \"{folder.Name}\".", Severity.Success);
        }
        catch (DocumentApiException ex)
        {
            _error = MapError(ex);
            if (ex.StatusCode == 401)
            {
                Session.Clear();
                Nav.NavigateTo("/login", replace: true);
            }
        }
        catch (Exception ex)
        {
            _error = $"Could not create folder: {ex.Message}";
        }
        finally
        {
            _foldersBusy = false;
            StateHasChanged();
        }
    }

    private Task OnInputFileChangedAsync(InputFileChangeEventArgs e)
    {
        _error = null;
        var file = e.FileCount > 0 ? e.File : null;
        if (file is null)
        {
            _file = null;
            return Task.CompletedTask;
        }

        if (file.Size > MaxFileSizeBytes)
        {
            _file = null;
            _error = $"File is {FormatBytes(file.Size)}; the 50 MB limit applies.";
            return Task.CompletedTask;
        }

        if (!IsAllowedMime(file.ContentType, file.Name))
        {
            _file = null;
            _error = "Only PDF, DOC, DOCX, PPT, PPTX files are accepted.";
            return Task.CompletedTask;
        }

        _file = file;
        return Task.CompletedTask;
    }

    private static bool IsAllowedMime(string? contentType, string fileName)
    {
        if (!string.IsNullOrWhiteSpace(contentType) && DocumentApiClient.AllowedMimeTypes.Contains(contentType))
        {
            return true;
        }
        // Browsers occasionally drop the MIME for less common Office types — fall back to extension.
        var ext = Path.GetExtension(fileName).ToLowerInvariant();
        return ext is ".pdf" or ".doc" or ".docx" or ".ppt" or ".pptx";
    }

    private async Task SubmitAsync()
    {
        _error = null;
        if (_form is null || _file is null) return;
        await _form.ValidateAsync();
        if (!_isValid) return;

        if (!Session.IsAuthenticated || string.IsNullOrEmpty(Session.AccessToken))
        {
            _error = "Your session has expired. Please sign in again.";
            return;
        }

        _busy = true;
        StateHasChanged();
        try
        {
            // IBrowserFile streams must be opened with the size limit explicitly.
            await using var stream = _file.OpenReadStream(MaxFileSizeBytes);
            var dto = await DocumentsApi.UploadAsync(
                Session.AccessToken!,
                stream,
                _file.Name,
                _file.ContentType,
                _file.Size,
                _model);

            Snackbar.Add($"Uploaded \"{dto.FileName}\" ({FormatBytes(dto.FileSizeBytes)}).", Severity.Success);
            var selectedFolderId = _model.FolderId;
            await LoadFoldersAsync();
            // Reset for another upload, but keep the selected folder for batch uploads.
            _file = null;
            _model.SubjectCode = string.Empty;
            _model.Semester = string.Empty;
            _model.FolderId = selectedFolderId;
            await _form.ResetAsync();
            _model.FolderId = selectedFolderId;
            if (_uploader is not null)
            {
                await _uploader.ClearAsync();
            }
        }
        catch (DocumentApiException ex)
        {
            _error = ex.StatusCode switch
            {
                401 => "Your session has expired. Please sign in again.",
                413 => "File is larger than the 50 MB server limit.",
                415 => "That file type isn't supported.",
                _   => MapError(ex),
            };
        }
        catch (Exception ex)
        {
            _error = $"Network error: {ex.Message}";
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    private static string MapError(DocumentApiException ex) => ex.StatusCode switch
    {
        401 => "Your session has expired. Please sign in again.",
        409 => "A folder with that name already exists.",
        400 => ex.Code == "folder_name_required" ? "Folder name is required." : ex.Message,
        _ => ex.Message,
    };

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024L * 1024) return $"{bytes / 1024.0:0.#} KB";
        if (bytes < 1024L * 1024 * 1024) return $"{bytes / (1024.0 * 1024):0.#} MB";
        return $"{bytes / (1024.0 * 1024 * 1024):0.##} GB";
    }
}
