@page "/documents/upload"
@using System.ComponentModel.DataAnnotations
@using System.Text.RegularExpressions
@using AI_Study_Hub_v2.Dtos
@using AI_Study_Hub_v2.Services
@inject DocumentApiClient DocumentsApi
@inject FolderApiClient FoldersApi
@inject AuthSessionState Session
@inject AuthPersistenceService AuthPersistence
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>Upload document — AI Study Hub</PageTitle>

<div class="document-upload-shell">
    @* ── Back button (only when returning from workspace) ── *@
    @if (!string.IsNullOrEmpty(ReturnUrl))
    {
        <a href="@ReturnUrl" class="upload-back-link">
            <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" />
            Back to workspace
        </a>
    }

    @* ── Hero + Steps ── *@
    <div class="hero-steps-grid">
        <section class="upload-hero">
            <div class="upload-kicker">
                <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" />
                ADD STUDY MATERIAL
            </div>
            <h1 class="upload-title">Choose a source for<br />your study cabinet</h1>
            <p class="upload-description">
                Add lecture PDFs, Word notes, and slide decks, then classify them by subject and
                semester so the AI workspace can find citations later.
            </p>
            <div class="upload-tags">
                <span class="upload-tag"><MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" /> PDF / DOCX / PPTX</span>
                <span class="upload-tag"><MudIcon Icon="@Icons.Material.Filled.Storage" Size="Size.Small" /> 5 files / 50 MB max</span>
                <span class="upload-tag"><MudIcon Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Small" /> Private library</span>
            </div>
        </section>

        <section class="steps-panel">
            <div class="steps-header">Progress</div>
            @{
                var stepIndex = _uploaded ? 2 : _files.Count > 0 ? 1 : 0;
            }
            @for (int i = 0; i < _steps.Length; i++)
            {
                var s = _steps[i];
                var cls = i < stepIndex ? "step-done" : i == stepIndex ? "step-active" : "step-pending";
                <div class="step-item @cls">
                    <div class="step-circle">@if (i < stepIndex) {<MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" />} else {@(i + 1)}</div>
                    <div class="step-info">
                        <div class="step-label">@s.Label</div>
                        <div class="step-sub">@s.Sub</div>
                    </div>
                    @if (i == stepIndex)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Class="step-chevron" />
                    }
                </div>
            }
        </section>
    </div>

    @* ── Stats bar ── *@
    <div class="stats-grid">
        <MudPaper Class="stat-card" Elevation="0" Outlined="false">
            <div class="stat-card-body">
                <div class="stat-icon-box">
                    <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Small" />
                </div>
                <span class="stat-value">@_folders.Count</span>
                <span class="stat-label">Folders loaded</span>
            </div>
        </MudPaper>
        <MudPaper Class="stat-card" Elevation="0" Outlined="false">
            <div class="stat-card-body">
                <div class="stat-icon-box">
                    <MudIcon Icon="@Icons.Material.Filled.Storage" Size="Size.Small" />
                </div>
                <span class="stat-value">@_folders.Sum(f => f.DocumentCount)</span>
                <span class="stat-label">Indexed library</span>
            </div>
        </MudPaper>
        <MudPaper Class="stat-card" Elevation="0" Outlined="false">
            <div class="stat-card-body">
                <div class="stat-icon-box @(_files.Count > 0 ? "active" : "")">
                    <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" />
                </div>
                <span class="stat-value">@(_files.Count > 0 ? _files.Count.ToString() : "None")</span>
                <span class="stat-label">@(_files.Count > 0 ? $"of {MaxUploadFiles} file(s)" : "Awaiting source")</span>
            </div>
        </MudPaper>
        <MudPaper Class="stat-card" Elevation="0" Outlined="false">
            <div class="stat-card-body">
                <div class="stat-icon-box @(_files.Count > 0 ? "active" : "")">
                    <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Size="Size.Small" />
                </div>
                <span class="stat-value">@FormatBytes(_files.Sum(f => f.Size))</span>
                <span class="stat-label">of @FormatBytes(MaxTotalUploadBytes) session total</span>
            </div>
        </MudPaper>
    </div>

    @* ── Main 3-column grid ── *@
    <div class="main-grid">
        @* ── Source panel ── *@
        <section class="source-panel">
            <h3 class="panel-title">Choose source</h3>
            <p class="panel-desc">Pick one or more study files, then save it into your academic library.</p>

            <InputFile id="document-file-input"
                       OnChange="OnInputFileChangedAsync"
                       accept="@AcceptAttr"
                       multiple
                       style="display:none" />

            <div class="drop-zone @(_files.Count > 0 ? "has-file" : "")"
                 @onclick="OpenFilePickerAsync">
                @if (_files.Count > 0)
                {
                    <div class="drop-zone-icon-box success">
                        <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" />
                    </div>
                    <p class="drop-zone-filename">@_files.Count file(s) selected</p>
                    <ul class="drop-zone-file-list">
                        @foreach (var f in _files)
                        {
                            <li class="drop-zone-file-item">
                                <span class="drop-zone-file-name">@f.Name</span>
                                <button class="drop-zone-file-remove" @onclick="() => RemoveFileAsync(f)" @onclick:stopPropagation>
                                    <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" />
                                </button>
                            </li>
                        }
                    </ul>
                    <button class="drop-zone-remove" @onclick="ClearFilesAsync" @onclick:stopPropagation>
                        <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" /> Remove all
                    </button>
                }
                else
                {
                    <div class="drop-zone-icon-box">
                        <MudIcon Icon="@Icons.Material.Filled.FileUpload" Size="Size.Small" />
                    </div>
                    <p class="drop-zone-text">Drop files here or click to browse</p>
                }
            </div>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Class="browse-btn"
                       OnClick="OpenFilePickerAsync"
                       Disabled="_busy">
                <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Small" Class="me-1" />
                Browse Files
            </MudButton>

            <p class="source-footnote">
                Choose up to <strong>5 files</strong> (max <strong>50 MB</strong> total per session) in PDF, Word, or PowerPoint format. Your files stay in the private cabinet.
            </p>
        </section>

        @* ── Metadata form ── *@
        <section class="metadata-panel">
            <h3 class="panel-title">Metadata &amp; folder</h3>
            <p class="panel-desc">Required labels keep retrieval scoped and searchable.</p>

            <MudForm @ref="_form" Model="_model" @bind-IsValid="_isValid" Class="metadata-form">
                <div class="field-group">
                    <label class="field-label">
                        Subject code <span class="field-hint">(e.g. SWP391)</span>
                        @if (!string.IsNullOrEmpty(_model.SubjectCode))
                        {
                            <span class="field-validity @(Regex.IsMatch(_model.SubjectCode, @"^[A-Z]{2,4}\d{3,4}$") ? "valid" : "invalid")">
                                @(Regex.IsMatch(_model.SubjectCode, @"^[A-Z]{2,4}\d{3,4}$") ? "✓" : "·")
                            </span>
                        }
                    </label>
                    <input class="field-input mono @(!string.IsNullOrEmpty(_model.SubjectCode) && !Regex.IsMatch(_model.SubjectCode, @"^[A-Z]{2,4}\d{3,4}$") ? "field-error" : "")"
                           @bind="_model.SubjectCode"
                           @bind:event="oninput"
                           placeholder="SWP391"
                           disabled="@_busy" />
                    @if (!string.IsNullOrEmpty(_model.SubjectCode) && !Regex.IsMatch(_model.SubjectCode, @"^[A-Z]{2,4}\d{3,4}$"))
                    {
                        <p class="field-error-text">
                            <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Size="Size.Small" /> Use format like SWP391 or SDN302
                        </p>
                    }
                </div>

                <div class="field-group">
                    <label class="field-label">
                        Semester <span class="field-hint">(e.g. SU26)</span>
                        @if (!string.IsNullOrEmpty(_model.Semester))
                        {
                            <span class="field-validity @(Regex.IsMatch(_model.Semester, @"^(SPR|SU|FA|M1)\d{2}$") ? "valid" : "invalid")">
                                @(Regex.IsMatch(_model.Semester, @"^(SPR|SU|FA|M1)\d{2}$") ? "✓" : "·")
                            </span>
                        }
                    </label>
                    <input class="field-input mono @(!string.IsNullOrEmpty(_model.Semester) && !Regex.IsMatch(_model.Semester, @"^(SPR|SU|FA|M1)\d{2}$") ? "field-error" : "")"
                           @bind="_model.Semester"
                           @bind:event="oninput"
                           placeholder="SU26"
                           disabled="@_busy" />
                    @if (!string.IsNullOrEmpty(_model.Semester) && !Regex.IsMatch(_model.Semester, @"^(SPR|SU|FA|M1)\d{2}$"))
                    {
                        <p class="field-error-text">
                            <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Size="Size.Small" /> Use SPR/SU/FA/M1 + 2-digit year
                        </p>
                    }
                </div>

                <div class="field-group">
                    <label class="field-label">Folder</label>
                    <select class="field-input field-select"
                            value="@_selectedFolderIdStr"
                            @onchange="OnFolderChanged"
                            disabled="@(_busy || _foldersBusy)">
                        <option value="">Loose document</option>
                        @foreach (var folder in _folders)
                        {
                            <option value="@folder.Id.ToString()">@folder.Name (@folder.DocumentCount)</option>
                        }
                    </select>
                </div>

                <div class="field-group folder-create-row">
                    <input class="field-input flex-1"
                           placeholder="e.g. SWP391 \u2013 Spring 2026"
                           @bind="_newFolderName"
                           disabled="@(_busy || _foldersBusy)" />
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Secondary"
                               OnClick="CreateFolderAsync"
                               Disabled="@(_busy || _foldersBusy || string.IsNullOrWhiteSpace(_newFolderName))"
                               Class="create-folder-btn">
                        + Create
                    </MudButton>
                </div>
            </MudForm>

            @* ── Human check ── *@
            <div class="human-check-wrapper">
                <HumanCheck @ref="_humanCheck" Action="document-upload" Disabled="_busy" ValidChanged="OnHumanCheckChanged" />
            </div>

            @* ── Upload button ── *@
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Class="upload-btn"
                       OnClick="SubmitAsync"
                       Disabled="@(_busy || !_isValid || !_humanCheckValid || _files.Count == 0)">
                @if (_busy)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-1" />
                    <span>Uploading @_uploadProgress/@_uploadTotal...</span>
                }
                else if (_uploaded)
                {
                    <MudIcon Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" Class="me-1" />
                    <span>Indexed \u2014 re-upload</span>
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.FileUpload" Size="Size.Small" Class="me-1" />
                    <span>Upload &amp; Start Indexing</span>
                }
            </MudButton>

            @if (_uploaded)
            {
                <div class="success-banner">
                    <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" />
                    <div>
                        <p class="success-banner-title">Upload complete</p>
                        <p class="success-banner-text">
                            @_successCount file(s) uploaded successfully@(_errorCount > 0 ? $", {_errorCount} failed." : ".") Open the document detail page from the library, then check its indexing status \u2014 then ask AI with citations.
                        </p>
                        <MudButton Variant="Variant.Text" Href="@(ReturnUrl ?? "/documents")" EndIcon="@Icons.Material.Filled.ArrowForward" Class="success-banner-link">
                            Back to library
                        </MudButton>
                    </div>
                </div>
            }

            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Filled" Class="mt-3">@_error</MudAlert>
            }
        </section>

        @* ── Checklist ── *@
        <aside class="checklist-panel">
            <div class="checklist-header">
                <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" />
                <h3 class="panel-title">Checklist</h3>
            </div>

            <div class="checklist-items">
                <div class="checklist-item @(IsSubjectValid ? "done" : "")">
                    <div class="checklist-bullet @(IsSubjectValid ? "done" : "")">
                        @if (IsSubjectValid) {<MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" />}
                    </div>
                    <span>Subject code matches SWP391 style</span>
                </div>
                <div class="checklist-item @(IsSemesterValid ? "done" : "")">
                    <div class="checklist-bullet @(IsSemesterValid ? "done" : "")">
                        @if (IsSemesterValid) {<MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" />}
                    </div>
                    <span>Semester uses SPR/SU/FA/M1 + year</span>
                </div>
                <div class="checklist-item @(_files.Count > 0 ? "done" : "")">
                    <div class="checklist-bullet @(_files.Count > 0 ? "done" : "")">
                        @if (_files.Count > 0) {<MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" />}
                    </div>
                    <span>@_files.Count / @MaxUploadFiles file(s) selected</span>
                </div>
                <div class="checklist-item @(_files.Sum(f => f.Size) <= MaxTotalUploadBytes && _files.Count > 0 ? "done" : "")">
                    <div class="checklist-bullet @(_files.Sum(f => f.Size) <= MaxTotalUploadBytes && _files.Count > 0 ? "done" : "")">
                        @if (_files.Sum(f => f.Size) <= MaxTotalUploadBytes && _files.Count > 0) {<MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" />}
                    </div>
                    <span>Total @FormatBytes(_files.Sum(f => f.Size)) / @FormatBytes(MaxTotalUploadBytes)</span>
                </div>
                <div class="checklist-item @(_model.FolderId is not null ? "done" : "")">
                    <div class="checklist-bullet @(_model.FolderId is not null ? "done" : "")">
                        @if (_model.FolderId is not null) {<MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" />}
                    </div>
                    <span>Folder selected, or leave loose</span>
                </div>
            </div>

            <div class="checklist-footer">
                @{
                    var passed = new[] { IsSubjectValid, IsSemesterValid, _files.Count > 0, _files.Sum(f => f.Size) <= MaxTotalUploadBytes && _files.Count > 0, _model.FolderId is not null }.Count(x => x);
                    var totalChecks = 5;
                }
                @if (passed == totalChecks)
                {
                    <span>All checks passed \u2014 ready to upload.</span>
                }
                else
                {
                    <span>@passed/@totalChecks checks passed.</span>
                }
            </div>

            @if (_uploaded)
            {
                <div class="checklist-after-upload">
                    <p class="checklist-after-title">After upload</p>
                    <p class="checklist-after-text">
                        Open the document detail page from the library, verify its indexing status, then ask AI with citations.
                    </p>
                    <MudButton Variant="Variant.Outlined"
                               FullWidth="true"
                               Class="checklist-reset-btn"
                               OnClick="ResetForm">
                        <MudIcon Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" Class="me-1" />
                        Back to library
                    </MudButton>
                </div>
            }
        </aside>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "folderId")]
    public Guid? QueryFolderId { get; set; }

    private const long MaxFileSizeBytes = DocumentApiClient.MaxFileSizeBytes;
    private const int MaxUploadFiles = 5;
    private const long MaxTotalUploadBytes = 50L * 1024 * 1024;
    private const string AcceptAttr = ".pdf,.doc,.docx,.ppt,.pptx,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-powerpoint,application/vnd.openxmlformats-officedocument.presentationml.presentation";

    private MudForm? _form;
    private HumanCheck? _humanCheck;
    private bool _isValid;
    private bool _humanCheckValid;
    private bool _busy;
    private bool _foldersBusy;
    private bool _uploaded;
    private string? _error;
    private string? _newFolderName;
    private string _selectedFolderIdStr = "";
    private List<IBrowserFile> _files = new();
    private List<FolderDto> _folders = new();
    private readonly UploadDocumentRequest _model = new();
    private int _uploadProgress;
    private int _uploadTotal;
    private int _successCount;
    private int _errorCount;

    private static readonly (string Label, string Sub)[] _steps =
    [
        ("Select", "Choose your source"),
        ("Classify", "Subject + term"),
        ("Index", "Ready for AI"),
    ];

    private bool IsSubjectValid => Regex.IsMatch(_model.SubjectCode ?? "", @"^[A-Z]{2,4}\d{3,4}$");
    private bool IsSemesterValid => Regex.IsMatch(_model.Semester ?? "", @"^(SPR|SU|FA|M1)\d{2}$");

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated)
        {
            var restored = await AuthPersistence.TryRestoreAsync();
            if (restored is not null)
                Session.Set(restored);
            if (!Session.IsAuthenticated)
            {
                Nav.NavigateTo("/login", replace: true);
                return;
            }
        }

        await LoadFoldersAsync();

        if (QueryFolderId.HasValue && _folders.Any(f => f.Id == QueryFolderId.Value))
        {
            _model.FolderId = QueryFolderId.Value;
            _selectedFolderIdStr = QueryFolderId.Value.ToString();
        }
    }

    private Task OnHumanCheckChanged(bool valid)
    {
        _humanCheckValid = valid;
        return Task.CompletedTask;
    }

    private void OnFolderChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? "";
        _selectedFolderIdStr = val;
        _model.FolderId = string.IsNullOrEmpty(val) ? null : Guid.Parse(val);
    }

    private async Task OpenFilePickerAsync()
        => await JS.InvokeVoidAsync("openFilePicker", "document-file-input");

    private async Task LoadFoldersAsync()
    {
        if (string.IsNullOrEmpty(Session.AccessToken)) return;
        _foldersBusy = true;
        try
        {
            _folders = (await FoldersApi.ListAsync(Session.AccessToken!)).ToList();
        }
        catch (DocumentApiException ex)
        {
            Snackbar.Add(MapError(ex), Severity.Warning);
            if (ex.StatusCode == 401)
            {
                Session.Clear();
                Nav.NavigateTo("/login", replace: true);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not load folders: {ex.Message}", Severity.Warning);
        }
        finally
        {
            _foldersBusy = false;
        }
    }

    private async Task CreateFolderAsync()
    {
        if (string.IsNullOrWhiteSpace(Session.AccessToken) || string.IsNullOrWhiteSpace(_newFolderName)) return;
        _foldersBusy = true;
        _error = null;
        try
        {
            var folder = await FoldersApi.CreateAsync(
                Session.AccessToken!,
                new CreateFolderRequest { Name = _newFolderName.Trim() });

            _folders.Add(folder);
            _folders = _folders.OrderBy(f => f.Name).ToList();
            _model.FolderId = folder.Id;
            _selectedFolderIdStr = folder.Id.ToString();
            _newFolderName = null;
            Snackbar.Add($"Created folder \"{folder.Name}\".", Severity.Success);
        }
        catch (DocumentApiException ex)
        {
            _error = MapError(ex);
            if (ex.StatusCode == 401)
            {
                Session.Clear();
                Nav.NavigateTo("/login", replace: true);
            }
        }
        catch (Exception ex)
        {
            _error = $"Could not create folder: {ex.Message}";
        }
        finally
        {
            _foldersBusy = false;
            StateHasChanged();
        }
    }

    private Task OnInputFileChangedAsync(InputFileChangeEventArgs e)
    {
        _error = null;
        var selected = e.GetMultipleFiles(50);

        if (_files.Count + selected.Count > MaxUploadFiles)
        {
            _error = $"You can upload at most {MaxUploadFiles} files per session. Remove some files first.";
            return Task.CompletedTask;
        }

        var totalBytes = _files.Sum(f => f.Size);
        var valid = new List<IBrowserFile>();
        foreach (var file in selected)
        {
            if (file.Size > MaxFileSizeBytes)
            {
                _error = $"\"{file.Name}\" is {FormatBytes(file.Size)}; the 50 MB per-file limit applies.";
                continue;
            }

            if (totalBytes + file.Size > MaxTotalUploadBytes)
            {
                _error = $"Adding \"{file.Name}\" ({FormatBytes(file.Size)}) would exceed the {FormatBytes(MaxTotalUploadBytes)} total session limit. Upload in smaller batches.";
                continue;
            }

            if (!IsAllowedMime(file.ContentType, file.Name))
            {
                _error = $"\"{file.Name}\" is not a supported type. Only PDF, DOC, DOCX, PPT, PPTX files are accepted.";
                continue;
            }

            valid.Add(file);
            totalBytes += file.Size;
        }

        _files.AddRange(valid);
        return Task.CompletedTask;
    }

    private void RemoveFileAsync(IBrowserFile file)
    {
        _files.Remove(file);
    }

    private void ClearFilesAsync()
    {
        _files.Clear();
    }

    private static bool IsAllowedMime(string? contentType, string fileName)
    {
        if (!string.IsNullOrWhiteSpace(contentType) && DocumentApiClient.AllowedMimeTypes.Contains(contentType))
        {
            return true;
        }
        var ext = Path.GetExtension(fileName).ToLowerInvariant();
        return ext is ".pdf" or ".doc" or ".docx" or ".ppt" or ".pptx";
    }

    private async Task SubmitAsync()
    {
        _error = null;
        if (_form is null || _files.Count == 0) return;
        await _form.ValidateAsync();
        var humanOk = _humanCheck is not null && await _humanCheck.ValidateAsync();
        if (!_isValid || !humanOk) return;

        if (!Session.IsAuthenticated || string.IsNullOrEmpty(Session.AccessToken))
        {
            _error = "Your session has expired. Please sign in again.";
            return;
        }

        _busy = true;
        _uploadTotal = _files.Count;
        _uploadProgress = 0;
        _successCount = 0;
        _errorCount = 0;
        _uploaded = false;
        StateHasChanged();

        var selectedFolderId = _model.FolderId;
        List<string> uploaded = new();

        // Read all file data into memory before any upload StateHasChanged()
        // to avoid Blazor Server invalidating browser-side file IDs on re-render.
        var fileData = new List<(string Name, string ContentType, long Size, MemoryStream Content)>();
        try
        {
            foreach (var file in _files.ToList())
            {
                try
                {
                    var mem = new MemoryStream((int)file.Size);
                    await file.OpenReadStream(MaxFileSizeBytes).CopyToAsync(mem);
                    mem.Position = 0;
                    fileData.Add((file.Name, file.ContentType, file.Size, mem));
                }
                catch (Exception ex)
                {
                    _errorCount++;
                    _error = $"\"{file.Name}\": Could not read file data - {ex.Message}";
                }
            }

            foreach (var (name, contentType, size, content) in fileData)
            {
                _uploadProgress++;
                StateHasChanged();

                try
                {
                    var dto = await DocumentsApi.UploadAsync(
                        Session.AccessToken!,
                        content,
                        name,
                        contentType,
                        size,
                        _model);

                    _successCount++;
                    uploaded.Add($"\"{dto.FileName}\" ({FormatBytes(dto.FileSizeBytes)})");
                }
                catch (DocumentApiException ex)
                {
                    _errorCount++;
                    var msg = ex.StatusCode switch
                    {
                        401 => "Your session has expired. Please sign in again.",
                        413 => "File is larger than the 50 MB server limit.",
                        415 => "That file type isn't supported.",
                        _ => MapError(ex),
                    };
                    _error = $"\"{name}\": {msg}";
                }
                catch (Exception ex)
                {
                    _errorCount++;
                    _error = $"\"{name}\": Network error - {ex.Message}";
                }
            }

            _uploaded = _successCount > 0;
            if (_successCount > 0)
            {
                Snackbar.Add($"Uploaded {_successCount} file(s).", Severity.Success);
                await LoadFoldersAsync();
                _files.Clear();
                _model.SubjectCode = string.Empty;
                _model.Semester = string.Empty;
                _model.FolderId = selectedFolderId;
                _selectedFolderIdStr = selectedFolderId?.ToString() ?? "";
                await _form.ResetAsync();
                if (_humanCheck is not null)
                {
                    await _humanCheck.ResetAsync();
                }
                _model.FolderId = selectedFolderId;
                _selectedFolderIdStr = selectedFolderId?.ToString() ?? "";
            }
        }
        finally
        {
            foreach (var (_, _, _, content) in fileData)
            {
                await content.DisposeAsync();
            }
            _busy = false;
            StateHasChanged();
        }
    }

    private void ResetForm()
    {
        _files.Clear();
        _uploaded = false;
        _model.SubjectCode = string.Empty;
        _model.Semester = string.Empty;
        _model.FolderId = null;
        _selectedFolderIdStr = "";
        _newFolderName = null;
        _error = null;
        _form?.ResetAsync();
        _humanCheck?.ResetAsync();
        StateHasChanged();
    }

    private static string MapError(DocumentApiException ex) => (ex.StatusCode, ex.Code) switch
    {
        (401, _) => "Your session has expired. Please sign in again.",
        (409, "folder_full") => ex.Message,
        (409, "duplicate_file") => ex.Message,
        (409, _) => "A folder with that name already exists.",
        (400, "folder_name_required") => "Folder name is required.",
        (400, "empty_file") => ex.Message,
        (400, _) => $"The server rejected the request. Check that the subject code (e.g. SWP391) and semester (e.g. SU26) are correct.",
        _ => ex.Message,
    };

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024L * 1024) return $"{bytes / 1024.0:0.#} KB";
        if (bytes < 1024L * 1024 * 1024) return $"{bytes / (1024.0 * 1024):0.#} MB";
        return $"{bytes / (1024.0 * 1024 * 1024):0.##} GB";
    }
}
