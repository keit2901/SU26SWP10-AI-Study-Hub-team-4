@page "/profile"
@using AI_Study_Hub_v2.Services
@inject AuthSessionState Session
@inject AuthPersistenceService AuthPersistence
@inject NavigationManager Nav

<PageTitle>Profile - AI Study Hub</PageTitle>

@if (!_ready)
{
    <div class="profile-loading-shell">
        <MudProgressCircular Size="Size.Large" Indeterminate="true" Color="Color.Primary" />
    </div>
}
else if (!Session.IsAuthenticated)
{
    <MudStack Class="profile-page-shell" AlignItems="AlignItems.Center" Justify="Justify.Center">
        <MudPaper Class="profile-alert-card" Elevation="0">
            <MudStack AlignItems="AlignItems.Center" Spacing="2">
                <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">You are not signed in.</MudAlert>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/login">Go to login</MudButton>
            </MudStack>
        </MudPaper>
    </MudStack>
}
else
{
    <MudStack Class="profile-page-shell" AlignItems="AlignItems.Center">
        <div class="profile-page-head">
            <div>
                <span class="profile-page-kicker">Student account</span>
                <h1>Profile</h1>
                <p>Keep your account details up to date without leaving the workspace.</p>
            </div>
        </div>

        <StudentProfilePanel Compact="false" />
    </MudStack>
}

@code {
    private bool _ready;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated)
        {
            var restored = await AuthPersistence.TryRestoreAsync();
            if (restored is not null)
            {
                Session.Set(restored);
            }
        }

        if (Session.IsAuthenticated && AdminAccessPolicy.IsAdmin(Session.CurrentUser?.Role))
        {
            Nav.NavigateTo("/admin", replace: true);
            return;
        }

        _ready = true;
    }
}

<style>
    .profile-loading-shell,
    .profile-page-shell {
        min-height: calc(100vh - 4rem);
        padding: 1.5rem;
    }

    .profile-loading-shell {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .profile-page-shell {
        justify-content: flex-start;
        gap: 1rem;
        background: linear-gradient(180deg, #f7f4ff 0%, #fbfaff 100%);
    }

    .profile-alert-card {
        max-width: 28rem;
        width: 100%;
        padding: 1.5rem;
        border-radius: 24px;
        border: 1px solid rgba(199, 196, 215, 0.35);
        background: rgba(255, 255, 255, 0.9);
    }

    .profile-page-head {
        width: min(860px, 100%);
    }

    .profile-page-kicker {
        display: inline-flex;
        padding: 0.35rem 0.7rem;
        border-radius: 999px;
        background: rgba(94, 92, 230, 0.1);
        color: #4f46d9;
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .profile-page-head h1 {
        margin: 0.9rem 0 0.35rem;
        color: #221c3e;
        font-size: clamp(1.7rem, 3vw, 2.2rem);
        font-weight: 900;
    }

    .profile-page-head p {
        margin: 0;
        color: #746d90;
        font-size: 0.96rem;
    }
</style>
