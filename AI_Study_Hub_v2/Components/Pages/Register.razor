@page "/register"
@using System.ComponentModel.DataAnnotations
@using AI_Study_Hub_v2.Dtos
@using AI_Study_Hub_v2.Services
@inject AuthApiClient AuthApi
@inject AuthSessionState Session
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Register - AI Study Hub</PageTitle>

<section class="auth-shell auth-shell-premium">
    <div class="auth-visual auth-visual-premium">
        <div class="auth-visual-grid" aria-hidden="true"></div>
        <div class="auth-orb" aria-hidden="true"></div>
        <div class="auth-matrix-card" aria-hidden="true">
            <div class="auth-matrix-topline">
                <span></span><span></span><span></span>
            </div>
            <div class="auth-matrix-core">
                <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" />
            </div>
            <p>Onboarding Matrix</p>
        </div>
        <div class="auth-hero-copy">
            <MudLink Href="/" Class="auth-brand-link" Underline="Underline.None">
                <span class="auth-brand-mark"><MudIcon Icon="@Icons.Material.Filled.School" /></span>
                <span>AI Study Hub</span>
            </MudLink>
            <span class="section-kicker">Account onboarding</span>
            <h1 class="workspace-title mt-4">Unlock your full <span class="gradient-text">learning potential</span>.</h1>
            <p class="workspace-copy mt-3">
                Transform course documents into study guides, practice questions, and interactive chat sessions grounded in your own material.
            </p>
            <div class="auth-chip-row">
                <span><MudIcon Icon="@Icons.Material.Filled.PersonAdd" Size="Size.Small" /> Database-backed role</span>
                <span><MudIcon Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Small" /> Organized folders</span>
                <span><MudIcon Icon="@Icons.Material.Filled.FactCheck" Size="Size.Small" /> Cited evidence</span>
            </div>
            <div class="auth-metric-row">
                <div class="auth-metric"><strong>Start</strong><span>new study vault</span></div>
                <div class="auth-metric"><strong>Upload</strong><span>course sources</span></div>
                <div class="auth-metric"><strong>Ask</strong><span>grounded tutor</span></div>
            </div>
        </div>
    </div>

    <MudPaper Class="auth-card glass-card auth-form-card" Elevation="0">
        <MudStack Spacing="3">
            <div class="auth-mobile-brand">
                <span class="auth-brand-mark"><MudIcon Icon="@Icons.Material.Filled.School" /></span>
                <span>AI Study Hub</span>
            </div>

            <div>
                <span class="auth-form-eyebrow">Create account</span>
                <MudText Typo="Typo.h4">Create Account</MudText>
                <MudText Typo="Typo.body2" Class="workspace-copy">
                    Start your AI-powered study journey today.
                </MudText>
            </div>

            <MudForm @ref="_form" Model="_model" @bind-IsValid="_isValid" Class="auth-form-stack">
                <MudTextField T="string"
                              Label="Email address"
                              @bind-Value="_model.Email"
                              Required="true"
                              RequiredError="Email is required"
                              Validation="@(new EmailAddressAttribute() { ErrorMessage = "Invalid email" })"
                              InputType="InputType.Email"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.AlternateEmail"
                              Disabled="_busy" />

                <MudTextField T="string"
                              Label="Username (3-15, a-z 0-9 _)"
                              @bind-Value="_model.Username"
                              Required="true"
                              RequiredError="Username is required"
                              Validation="@(new RegularExpressionAttribute(@"^[a-zA-Z0-9_]{3,15}$") { ErrorMessage = "3-15 chars, alphanumeric or underscore" })"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.AlternateEmail"
                              Disabled="_busy" />

                <MudTextField T="string"
                              Label="Full name"
                              @bind-Value="_model.FullName"
                              Required="true"
                              RequiredError="Full name is required"
                              Validation="@(new StringLengthAttribute(100) { MinimumLength = 2, ErrorMessage = "2-100 characters" })"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Badge"
                              Disabled="_busy" />

                <MudTextField T="string"
                              Label="Password (min 8)"
                              @bind-Value="_model.Password"
                              Required="true"
                              RequiredError="Password is required"
                              Validation="@(new StringLengthAttribute(128) { MinimumLength = 8, ErrorMessage = "Minimum 8 characters" })"
                              InputType="InputType.Password"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Lock"
                              Disabled="_busy" />
            </MudForm>

            <HumanCheck @ref="_humanCheck" Action="register" Disabled="_busy" ValidChanged="OnHumanCheckChanged" />

            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Filled">@_error</MudAlert>
            }

            <MudButton Variant="Variant.Filled"
                       FullWidth="true"
                       Class="premium-button auth-submit-button"
                       EndIcon="@Icons.Material.Filled.ArrowForward"
                       OnClick="SubmitAsync"
                       Disabled="_busy || !_humanCheckValid">
                @if (_busy)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Creating...</MudText>
                }
                else
                {
                    <MudText>Create account</MudText>
                }
            </MudButton>

            <div class="auth-divider"><span>Private account • Real Supabase auth</span></div>

            <MudStack Row="true" Justify="Justify.Center" Spacing="1" Style="flex-wrap: wrap;">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Already have an account?</MudText>
                <MudLink Href="/login" Underline="Underline.Always">Sign in</MudLink>
            </MudStack>
        </MudStack>
    </MudPaper>
</section>

@code {
    private MudForm? _form;
    private HumanCheck? _humanCheck;
    private bool _isValid;
    private bool _humanCheckValid;
    private bool _busy;
    private string? _error;
    private readonly RegisterRequest _model = new();

    protected override void OnInitialized()
    {
        if (Session.IsAuthenticated)
        {
            RedirectByRole();
        }
    }

    private void RedirectByRole()
    {
        Nav.NavigateTo(
            AdminAccessPolicy.GetAuthenticatedLandingPage(Session.CurrentUser?.Role),
            replace: true);
    }

    private Task OnHumanCheckChanged(bool valid)
    {
        _humanCheckValid = valid;
        return Task.CompletedTask;
    }

    private async Task SubmitAsync()
    {
        _error = null;
        if (_form is null) return;
        await _form.ValidateAsync();
        var humanOk = _humanCheck is not null && await _humanCheck.ValidateAsync();
        if (!_isValid || !humanOk) return;
        _model.RecaptchaToken = _humanCheck?.GetResponseToken();

        _busy = true;
        StateHasChanged();
        try
        {
            var resp = await AuthApi.RegisterAsync(_model);
            Session.Set(resp);
            Snackbar.Add($"Account created. Welcome, {resp.User.FullName}!", Severity.Success);
            Nav.NavigateTo(AdminAccessPolicy.GetAuthenticatedLandingPage(resp.User.Role));
        }
        catch (AuthApiException ex)
        {
            if (ex.Errors is { Count: > 0 })
            {
                var details = string.Join("; ", ex.Errors.SelectMany(kv => kv.Value.Select(v => $"{kv.Key}: {v}")));
                _error = $"{ex.Message} — {details}";
            }
            else
            {
                _error = ex.Message;
            }
        }
        catch (Exception ex)
        {
            _error = $"Network error: {ex.Message}";
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }
}
