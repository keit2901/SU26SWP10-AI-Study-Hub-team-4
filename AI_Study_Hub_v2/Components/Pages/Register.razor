@page "/register"
@using System.ComponentModel.DataAnnotations
@using AI_Study_Hub_v2.Dtos
@using AI_Study_Hub_v2.Services
@inject AuthApiClient AuthApi
@inject AuthSessionState Session
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Register - AI Study Hub</PageTitle>

<section class="auth-shell">
    <div class="auth-visual">
        <div class="auth-visual-grid" aria-hidden="true"></div>
        <div class="auth-orb" aria-hidden="true"></div>
        <div style="position: relative; z-index: 1; max-width: 640px;">
            <span class="section-kicker">Student onboarding</span>
            <h1 class="workspace-title mt-4">Build a private <span class="gradient-text">AI study base</span>.</h1>
            <p class="workspace-copy mt-3">
                Create a student account, upload course material, and keep every answer traceable to your own documents.
            </p>
            <div class="auth-metric-row">
                <div class="auth-metric"><strong>Student</strong><span>default role</span></div>
                <div class="auth-metric"><strong>Folders</strong><span>organized sources</span></div>
                <div class="auth-metric"><strong>Cites</strong><span>visible evidence</span></div>
            </div>
        </div>
    </div>

    <MudPaper Class="auth-card glass-card" Elevation="0">
        <MudStack Spacing="3">
            <div>
                <MudText Typo="Typo.h4">Create account</MudText>
                <MudText Typo="Typo.body2" Class="workspace-copy">
                    Start as a student and open the document-first AI workspace.
                </MudText>
            </div>

            <MudForm @ref="_form" Model="_model" @bind-IsValid="_isValid">
                <MudTextField T="string"
                              Label="Email"
                              @bind-Value="_model.Email"
                              Required="true"
                              RequiredError="Email is required"
                              Validation="@(new EmailAddressAttribute() { ErrorMessage = "Invalid email" })"
                              InputType="InputType.Email"
                              Variant="Variant.Outlined"
                              Disabled="_busy" />

                <MudTextField T="string"
                              Label="Username (3-15, a-z 0-9 _)"
                              @bind-Value="_model.Username"
                              Required="true"
                              RequiredError="Username is required"
                              Validation="@(new RegularExpressionAttribute(@"^[a-zA-Z0-9_]{3,15}$") { ErrorMessage = "3-15 chars, alphanumeric or underscore" })"
                              Variant="Variant.Outlined"
                              Class="mt-3"
                              Disabled="_busy" />

                <MudTextField T="string"
                              Label="Full name"
                              @bind-Value="_model.FullName"
                              Required="true"
                              RequiredError="Full name is required"
                              Validation="@(new StringLengthAttribute(100) { MinimumLength = 2, ErrorMessage = "2-100 characters" })"
                              Variant="Variant.Outlined"
                              Class="mt-3"
                              Disabled="_busy" />

                <MudTextField T="string"
                              Label="Password (min 8)"
                              @bind-Value="_model.Password"
                              Required="true"
                              RequiredError="Password is required"
                              Validation="@(new StringLengthAttribute(128) { MinimumLength = 8, ErrorMessage = "Minimum 8 characters" })"
                              InputType="InputType.Password"
                              Variant="Variant.Outlined"
                              Class="mt-3"
                              Disabled="_busy" />
            </MudForm>

            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Filled">@_error</MudAlert>
            }

            <MudButton Variant="Variant.Filled"
                       FullWidth="true"
                       Class="premium-button"
                       OnClick="SubmitAsync"
                       Disabled="_busy">
                @if (_busy)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Creating...</MudText>
                }
                else
                {
                    <MudText>Create account</MudText>
                }
            </MudButton>

            <MudDivider />

            <MudStack Row="true" Justify="Justify.Center" Spacing="1" Style="flex-wrap: wrap;">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Already have an account?</MudText>
                <MudLink Href="/login" Underline="Underline.Always">Sign in</MudLink>
            </MudStack>
        </MudStack>
    </MudPaper>
</section>

@code {
    private MudForm? _form;
    private bool _isValid;
    private bool _busy;
    private string? _error;
    private readonly RegisterRequest _model = new();

    protected override void OnInitialized()
    {
        if (Session.IsAuthenticated)
        {
            Nav.NavigateTo("/profile", replace: true);
        }
    }

    private async Task SubmitAsync()
    {
        _error = null;
        if (_form is null) return;
        await _form.ValidateAsync();
        if (!_isValid) return;

        _busy = true;
        StateHasChanged();
        try
        {
            var resp = await AuthApi.RegisterAsync(_model);
            Session.Set(resp);
            Snackbar.Add($"Account created. Welcome, {resp.User.FullName}!", Severity.Success);
            Nav.NavigateTo("/profile");
        }
        catch (AuthApiException ex)
        {
            _error = ex.Message;
        }
        catch (Exception ex)
        {
            _error = $"Network error: {ex.Message}";
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }
}
