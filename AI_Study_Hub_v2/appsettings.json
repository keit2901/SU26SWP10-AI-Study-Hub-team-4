{
  "ConnectionStrings": {
    "Postgres": ""
  },
  "Supabase": {
    "Url": "",
    "JwtIssuer": "",
    "JwtAudience": "authenticated",
    "AccessTokenSeconds": 900
  },
  "Seed": {
    "DefaultAdmin": {
      "Email": "",
      "Username": "",
      "FullName": ""
    }
  },
  "Groq": {
    "Model": "llama-3.1-8b-instant",
    "Endpoint": "https://api.groq.com/openai/v1",
    "Temperature": 0.2,
    "MaxTokens": 1024
  },
  "Recaptcha": {
    "Enabled": false,
    "AllowDevelopmentFallback": false,
    "SiteKey": "",
    "SecretKey": "",
    "VerifyEndpoint": "https://www.google.com/recaptcha/api/siteverify",
    "Theme": "light",
    "Size": "normal"
  },
  "Rag": {
    "ChunkingStrategy": "semantic",
    "ChunkSizeChars": 700,
    "ChunkOverlapChars": 70,
    "MinChunkChars": 200,
    "MaxSectionChars": 700,
    "DefaultTopK": 5,
    "MaxTopK": 10,
    "EmbeddingDimensions": 384,
    "MaxContextChars": 6000,
    "EmbeddingCacheEnabled": true,
    "EmbeddingCacheMaxEntries": 1000,
    "EmbeddingCacheTtlMinutes": 30,
    "ReRankEnabled": true,
    "ReRankCandidateCount": 20,
    "ReRankTopN": 5,
    "HybridSearchEnabled": true,
    "VectorWeight": 0.7,
    "SearchMode": "hybrid",
    "BenchmarkAutomationEnabled": false,
    "BenchmarkAutomationIntervalHours": 168,
    "BenchmarkAlertDropPercent": 10
  },
"Ollama": {
    "BaseUrl": "http://localhost:11434",
    "Model": "all-minilm:l6-v2",
    "TimeoutSeconds": 30,
    "MaxRetries": 3
},
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
